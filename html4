        const extractFromComments = (comments, type) => {
            if (!comments) return "—";
            if (type === 'version') {
                const match = comments.match(/(?:vers.o da release|vrs|vers.o|version):?\s*([\d\.\w\-]+)/i);
                return match ? match[1] : "—";
            }
            if (type === 'date') {
                const match = comments.match(/(?:data da release|data release|data|date):?\s*(\d{2}\/\d{2}\/\d{4})/i);
                return match ? match[1] : "—";
            }
            return "—";
        };

        const safeDate = v => {
            if (!v) return null;
            if (v instanceof Date) return isNaN(v.getTime()) ? null : v;
            if (typeof v === 'number') return new Date(Math.round((v - 25569) * 86400 * 1000));
            if (typeof v === 'string') {
                let p = v.trim().split(/[\/\s:]/);
                if (p.length >= 3 && p[2].length === 4) { let d = new Date(p[2], p[1] - 1, p[0]); if (!isNaN(d.getTime())) return d; }
                let nD = new Date(v); if (!isNaN(nD.getTime())) return nD;
            }
            return null;
        };

