        function getDaysSilent(r, refDateObj, assignedTo, opDateObj) {
            if (!assignedTo || assignedTo.includes('Não Atribuído') || assignedTo === 'N/A' || assignedTo === '-') return '-';

            let maxDate = opDateObj ? new Date(opDateObj) : new Date(0);
            let regex = /(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?:\s+-\s+|\s+)([^\(]+)\s+\(/g;
            let found = false;

            ['Work notes', 'Work Notes', 'Work notes list', 'Work notes list(s)', 'Additional comments'].forEach(col => {
                if (r[col] && typeof r[col] === 'string') {
                    let m;
                    while ((m = regex.exec(r[col])) !== null) {
                        if (m[2].trim() === assignedTo) {
                            let d = new Date(m[1].replace(/-/g, '/'));
                            if (!isNaN(d) && d.getTime() > maxDate.getTime() && d.getTime() <= refDateObj.getTime()) {
                                maxDate = d;
                                found = true;
                            }
                        }
                    }
                }
            });

            if (maxDate.getTime() === 0 && !found && !opDateObj) return '-';

            let diff = Math.floor((refDateObj - maxDate) / 86400000);
            return diff < 0 ? 0 : diff;
        }

