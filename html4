                (${results.length} encontrados - Página ${page})
            </div>`;

            if (results.length === 0) {
                html += `<div class="report-card text-center py-10"><h3 class="text-slate-500 font-bold text-lg"><i class="fas fa-folder-open text-4xl block mb-4 text-slate-300"></i>Nenhum registro encontrado.</h3></div>`;
                document.getElementById('tab-search').innerHTML = html;
                switchTab('search');
                return;
            }

            let rows = currentResults.map(t => {
                let opS = t.op ? t.op.toLocaleDateString('pt-BR') : '-';
                let clS = t.cl ? t.cl.toLocaleDateString('pt-BR') : 'Aberto';
                let age = (t.op && t.cl) ? Math.floor((t.cl - t.op) / 86400000) : (t.op ? Math.floor((new Date() - t.op) / 86400000) : '-');
                if (age < 0) age = 0;

                let stL = t.st.toLowerCase(), bC = '#f1f5f9', fC = '#475569';
                if (stL.includes('resolv') || stL.includes('complet')) { bC = '#ecfdf5'; fC = '#10b981'; }
                else if (stL.includes('cancel') || stL.includes('incomplet')) { bC = '#fee2e2'; fC = '#ef4444'; }
                else if (stL.includes('pend') || stL.includes('hold')) { bC = '#fef3c7'; fC = '#f59e0b'; }

                return `<tr class="ticket-row hover:bg-slate-50 transition" ${buildDataAttrs(t)}>
                    <td data-label="Ticket Original" class="font-bold text-[var(--primary-dark)] text-center">
                        ${t.tk}
                        <div class="text-[9px] bg-slate-200 px-1.5 py-0.5 rounded inline-block text-slate-500">${t.type}</div>
                        <button onclick="openTicketDetails('${t.tk}')" class="block w-full mt-2 bg-blue-50 hover:bg-blue-100 border border-blue-200/50 p-1.5 rounded text-[9px] uppercase shadow-sm transition"><i class="fas fa-history"></i> Saiba mais</button>
                    </td>
                    <td data-label="Descrição Completa" class="text-left w-[350px] max-w-[350px]">
                        <div class="w-full h-auto max-h-[80px] overflow-y-auto overflow-x-hidden stylized-scrollbar border border-slate-100 bg-slate-50 p-1.5 rounded">
                            <div class="text-xs font-semibold text-slate-800 break-words mb-1">${t.desc}</div>
                            ${(t.longDesc && t.longDesc !== '-') ? `<div class="text-[10px] text-slate-500 italic break-words">${t.longDesc}</div>` : ''}
                            ${(t.info || t.reason) ? `<div class="text-[10px] font-bold text-amber-700 bg-amber-50 border border-amber-100 rounded px-1.5 py-0.5 mt-1 break-words whitespace-normal">⚠️ ${t.info} ${t.reason ? `(${t.reason})` : ''}</div>` : ''}
                        </div>
                    </td>
                    <td data-label="Solicitante" class="text-center">${t.req}</td>
                    <td data-label="Analista / Grupo" class="text-center">${t.asg}<br><span class="text-[9px] text-slate-400 block mt-1">${t.gp}</span></td>
                    <td data-label="Status" data-filter="${t.st}" class="text-center">
                        <span style="background:${bC};color:${fC}; border: 1px solid ${fC}40;" class="px-2 py-0.5 rounded text-[9px] font-bold block mb-1 mx-auto w-max">${t.st}</span>
                        <span class="text-[10px] text-slate-500 block mt-1"><i class="far fa-calendar-alt"></i> ${opS}</span>
                    </td>
                    <td data-label="Datas / Ocioso" class="text-right">
                        <div class="font-bold text-sm ${t.cl ? 'text-[var(--primary-dark)]' : 'text-orange-500'}">${clS}</div>
                        ${age !== '-' ? `<div class="text-[10px] text-slate-400 mt-1">${age}d de vida</div>` : ''}
                        ${t.idle !== '-' ? `<div class="text-[10px] font-bold mt-1 ${t.idle > 3 ? 'text-red-500' : 'text-green-500'}"><i class="fas fa-user-clock"></i> ${t.idle}d ocioso</div>` : ''}
                    </td>
                </tr>`;
            }).join('');

            html += `<div class="report-card">
                <div class="st-dataframe-container border-0">
                    <table class="st-table">
                        <thead>
                            <tr>
                                ${createTh("Ticket Original", "15%")}
                                ${createTh("Descrição Completa", "auto", "left")}
                                ${createTh("Solicitante", "15%")}
                                ${createTh("Analista / Grupo", "15%")}
                                ${createTh("Status", "12%")}
                                ${createTh("Datas / Ocioso", "12%", "right")}
                            </tr>
                        </thead>
                        <tbody>${rows}</tbody>
                    </table>
                </div>
                ${renderPaginationControls('search', results.length, page)}
            </div>`;

            document.getElementById('tab-search').innerHTML = html;
            switchTab('search');
        }

        function filterTables() {
            const input = document.getElementById("globalSearch");
            if (!input) return;
            const term = removeAccents(input.value.toUpperCase());

            document.querySelectorAll('.tab-pane:not(.hidden-st) table tbody').forEach(tbody => {
                Array.from(tbody.getElementsByTagName("tr")).forEach(r => {
                    let rT = removeAccents(r.innerText).toUpperCase();
                    if (!rT.includes("NENHUM") && !rT.includes("TOTAL") && !rT.includes("SEM DADOS")) {
                        r.style.display = rT.includes(term) ? "" : "none";
                    }
                });
            });
        }

        // ==========================================
        // 4. MOTOR CORE DE DADOS 
        // ==========================================
        const C = {
            PRI_D: "#001871", PRI: "#1E3A8A", ACC_D: "#0F172A",
            SUC: "#00C853", DAN: "#D50000", ORG: "#FF8C00",
            GRY_D: "#334155", GRY_L: "#F8FAFC", INFO: "#0284C7"
        };

        function buildDataAttrs(t) {
            return `data-tk="${t.tk}" data-desc="${t.desc}" data-req="${t.req || ''}" data-as="${t.as}" data-gp="${t.gp}" data-st="${t.st}" data-age="${t.age !== undefined ? t.age : (t.d || 0)}" data-op="${t.opStr || t.opS || '-'}" data-info="${t.info || ''}" data-reason="${t.reason || ''}" data-idle="${t.idle !== undefined ? t.idle : '-'}" data-pct="${t.pctSla !== undefined ? t.pctSla : ''}"`;
        }

        function buildTicketObject(r, refDateObj, asg, opOrig, clOrig, stOrig, st, age, typeStr, slaDays) {
            let tk = (typeStr === 'REQ' || typeStr === 'UAM') ? (getCol(r, ['RITM', 'Request Item', 'Item de solicitação', 'Number', 'Ticket']) || '-') : (getCol(r, ['Number', 'number', 'Ticket', 'Problem', 'Task']) || '-');

            let prbRaw = getCol(r, ['Problem', 'PRB', 'Problema', 'problem_id']);
            let prbVal = (prbRaw && String(prbRaw).trim() !== "" && String(prbRaw).trim() !== "undefined") ? String(prbRaw).trim() : 'N/A';

            let stLower = (st || '').toLowerCase();
            let holdReason = getCol(r, ['On hold reason', 'Motivo da espera', 'on_hold_reason']);
            let defaultInfo = String(getCol(r, ['Additional comments', 'Comentários Adicionais', 'Close notes']) || '').replace(/"/g, '&quot;');
            let infoFinal = (stLower.includes('hold') || stLower.includes('espera')) && holdReason
                ? String(holdReason).replace(/"/g, '&quot;')
                : defaultInfo;

            let longDesc = String(getCol(r, ['Description', 'description', 'Descrição Completa', 'Descrição', 'Additional details', 'additional_details']) || '').replace(/"/g, '&quot;');
            let reasonVal = String(getCol(r, ['Reason', 'reason', 'REASON', 'Motivo']) || '').toUpperCase();

            let pctSla = slaDays ? ((age / slaDays) * 100).toFixed(2).replace('.', ',') : '0,00';

            return {
                tk: tk,
                desc: String(getCol(r, ['Short description', 'Descrição Curta', 'Item', 'Problem', 'Problema']) || '-').replace(/"/g, '&quot;'),
                longDesc: longDesc,
                req: getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A',
                as: asg,
                gp: getCol(r, ['Assignment group', 'Grupo']) || '-',
                st: (clOrig ? stOrig : st).toUpperCase(),
                reason: reasonVal,
                age: age,
                opStr: opOrig ? opOrig.toLocaleDateString('pt-BR') : '-',
                idle: (!clOrig || clOrig > refDateObj) ? getDaysSilent(r, refDateObj, asg, opOrig) : '-',
                info: infoFinal,
                prb: prbVal,
                pctSla: pctSla
            };
        }

        function calculateSection(data, slaDays, type, refDateObj) {
            const refDate = new Date(refDateObj);
            refDate.setHours(23, 59, 59, 999);
            const refTime = refDate.getTime();
            let totalMttr = 0, countRes = 0, inSlaMes = 0, resMes = 0, backlog = 0;
            let trendD = {}, trendM = {}, analistas = {}, criticals = [], noPrb = [];
            let agingBuckets = {};

            let allBacklogTks = [];
            let allResolvedTks = [];
            let allCanceledTks = [];

            const isReq = type === "REQ";
            const bucketsDef = isReq
                ? [{ l: "1-3 dias", min: 0, max: 3 }, { l: "3-5 dias", min: 4, max: 5 }, { l: "5-7 dias", min: 6, max: 7 }, { l: "7-10 dias", min: 8, max: 10 }, { l: "10 dias +", min: 11, max: 19 }, { l: "20 dias +", min: 20, max: 29 }, { l: "30 dias +", min: 30, max: 9999 }]
                : [{ l: "1-3 dias", min: 0, max: 3 }, { l: "4-7 dias", min: 4, max: 7 }, { l: "7+ dias", min: 8, max: 9999 }];

            bucketsDef.forEach(b => agingBuckets[b.l] = { count: 0, color: b.min > slaDays ? '#D50000' : '#1E3A8A', tks: [] });

            let rDay = refDate.getDate(); let rMonth = refDate.getMonth(); let rYear = refDate.getFullYear();
            for (let i = 1; i <= rDay; i++) {
                let sD = `${rYear}-${String(rMonth + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
                trendD[sD] = { a: 0, r: 0, c: 0, b: 0, tks_a: [], tks_r: [], tks_c: [] };
            }

            data.forEach(r => {
                let opOrig = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                if (!opOrig || opOrig.getTime() > refTime) return;
                let clOrig = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                let stOrig = String(getCol(r, ['State', 'Status', 'Estado']) || '').toLowerCase();
                let cl = clOrig; let st = stOrig;

                if (clOrig && clOrig.getTime() > refTime) { cl = null; st = 'Open (Retroativo)'; }

                let isRes = cl ? (isReq ? stOrig.includes('complet') : (stOrig.includes('resolv') || stOrig.includes('clos') && !stOrig.includes('cancel'))) : false;
                let isCanc = cl ? (isReq ? stOrig.includes('incomplet') : stOrig.includes('cancel')) : false;
                let age = cl ? Math.floor((cl - opOrig) / 86400000) : Math.floor((refDate - opOrig) / 86400000);
                if (age < 0) age = 0;

                let oY = opOrig.getFullYear(); let oM = String(opOrig.getMonth() + 1).padStart(2, '0');
                let mKey = `${oY}-${oM}`;
                if (!trendM[mKey]) trendM[mKey] = { a: 0, r: 0, c: 0, inSla: 0, tks_a: [], tks_r: [], tks_c: [] };
                trendM[mKey].a++;

                let asg = getCol(r, ['Assigned to', 'Analista', 'Assignee']) || 'Não Atribuído';
                let tObj = buildTicketObject(r, refDate, asg, opOrig, clOrig, stOrig, st, age, type, slaDays);

                trendM[mKey].tks_a.push(tObj);

                let oD = String(opOrig.getDate()).padStart(2, '0');
                let dKey = `${oY}-${oM}-${oD}`;
                if (opOrig.getMonth() === refDate.getMonth() && opOrig.getFullYear() === refDate.getFullYear()) {
                    if (trendD[dKey]) { trendD[dKey].a++; trendD[dKey].tks_a.push(tObj); }
                }

                if (isRes && cl) {
                    let cY = cl.getFullYear(); let cM = String(cl.getMonth() + 1).padStart(2, '0'); let cD = String(cl.getDate()).padStart(2, '0');
                    let mcKey = `${cY}-${cM}`;
                    if (!trendM[mcKey]) trendM[mcKey] = { a: 0, r: 0, c: 0, inSla: 0, tks_a: [], tks_r: [], tks_c: [] };
                    trendM[mcKey].r++;
                    trendM[mcKey].tks_r.push(tObj);
                    if (age <= slaDays) trendM[mcKey].inSla++;

                    let dcKey = `${cY}-${cM}-${cD}`;
                    if (cl.getMonth() === refDate.getMonth() && cl.getFullYear() === refDate.getFullYear()) {
                        allResolvedTks.push(tObj);
                        if (trendD[dcKey]) {
                            trendD[dcKey].r++; trendD[dcKey].tks_r.push(tObj); resMes++; if (age <= slaDays) inSlaMes++;
                        }
                    }
                    totalMttr += age; countRes++;
                } else if (isCanc && cl) {
                    let cY = cl.getFullYear(); let cM = String(cl.getMonth() + 1).padStart(2, '0'); let cD = String(cl.getDate()).padStart(2, '0');
                    let mcKey = `${cY}-${cM}`;
                    if (!trendM[mcKey]) trendM[mcKey] = { a: 0, r: 0, c: 0, inSla: 0, tks_a: [], tks_r: [], tks_c: [] };
                    trendM[mcKey].c++;
                    trendM[mcKey].tks_c.push(tObj);

                    let dcKey = `${cY}-${cM}-${cD}`;
                    if (cl.getMonth() === refDate.getMonth() && cl.getFullYear() === refDate.getFullYear()) {
                        allCanceledTks.push(tObj);
                        if (trendD[dcKey]) { trendD[dcKey].c++; trendD[dcKey].tks_c.push(tObj); }
                    }
                }

                if (!cl) {
                    backlog++;
                    allBacklogTks.push(tObj);

                    if (!analistas[asg]) analistas[asg] = { ab: 0, res: 0, tks_ab: [], tks_res: [] };
                    analistas[asg].ab++;
                    analistas[asg].tks_ab.push(tObj);

                    GlobalOpenTickets.push({ tk: tObj.tk, asg: asg });
                    bucketsDef.forEach(b => { if (age >= b.min && age <= b.max) { agingBuckets[b.l].count++; agingBuckets[b.l].tks.push(tObj); } });

                    let hasPrb = tObj.prb !== "N/A";
                    if (age > slaDays) {
                        criticals.push(tObj);
                        if (!isReq && !hasPrb) noPrb.push(tObj);
                    }
                }

                if (isRes && cl && cl.getMonth() === refDate.getMonth() && cl.getFullYear() === refDate.getFullYear()) {
                    if (!analistas[asg]) analistas[asg] = { ab: 0, res: 0, tks_ab: [], tks_res: [] };
                    analistas[asg].res++;
                    analistas[asg].tks_res.push(tObj);
                }
            });

            let topAnalistas = Object.keys(analistas).map(k => ({
                nome: k, ab: analistas[k].ab, res: analistas[k].res, tot: analistas[k].ab + analistas[k].res,
                tks_ab: analistas[k].tks_ab, tks_res: analistas[k].tks_res
            })).sort((a, b) => b.tot - a.tot).slice(0, 10);

            const calcBacklog = (trendObj) => {
                let keys = Object.keys(trendObj).sort(); let b = 0;
                keys.forEach(k => { let s = trendObj[k].a - (trendObj[k].r + trendObj[k].c); b += s; trendObj[k].b = b; });
            };
            calcBacklog(trendM);

            let dKeys = Object.keys(trendD).sort(); let db = backlog;
            for (let i = dKeys.length - 1; i >= 0; i--) { let k = dKeys[i]; trendD[k].b = db; db -= (trendD[k].a - (trendD[k].r + trendD[k].c)); }

            let inSlaTot = 0, outSlaTot = 0;
            let tksInSlaTot = [], tksOutSlaTot = [];
            bucketsDef.forEach(b => {
                if (b.min > slaDays) { outSlaTot += agingBuckets[b.l].count; tksOutSlaTot = tksOutSlaTot.concat(agingBuckets[b.l].tks); }
                else { inSlaTot += agingBuckets[b.l].count; tksInSlaTot = tksInSlaTot.concat(agingBuckets[b.l].tks); }
            });

            return {
                mttr: countRes ? (totalMttr / countRes).toFixed(2).replace('.', ',') : "0,00",
                pct: resMes ? ((inSlaMes / resMes) * 100).toFixed(2).replace('.', ',') : "0,00",
                resMes: resMes,
                inSla: inSlaMes, outSla: resMes - inSlaMes, backlog,
                inSlaTot, outSlaTot, tksInSlaTot, tksOutSlaTot,
                trendM, trendD, topAnalistas, agingBuckets,
                // Z-A: Chamados mais velhos/críticos no topo
                crits: criticals.sort((a, b) => (b.age || 0) - (a.age || 0)),
                noPrb: noPrb.sort((a, b) => (b.age || 0) - (a.age || 0)),
                allBacklogTks: allBacklogTks.sort((a, b) => (b.age || 0) - (a.age || 0)),
                allResolvedTks: allResolvedTks.sort((a, b) => (b.age || 0) - (a.age || 0)),
                allCanceledTks: allCanceledTks.sort((a, b) => (b.age || 0) - (a.age || 0))
            };
        }

        function calculateClassifications(allData, refDateObj) {
            let res = {
                total: 0, link: 0, noLink: 0, days: 0, max: 0,
                monthTotal: 0, monthLink: 0, monthNoLink: 0, monthDays: 0, monthMax: 0,
                req: {}, gp: {}, asg: {}, m: {}, tks: []
            };

            allData.forEach(r => {
                let tk = getCol(r, ['Number', 'number', 'Ticket', 'RITM', 'Request Item', 'Item de solicitação']) || '-';
                let stOrig = String(getCol(r, ['State', 'Status', 'Estado']) || '').toLowerCase();
                let reason = String(getCol(r, ['Reason', 'reason', 'REASON', 'Motivo']) || '').toUpperCase();
                let isInc = tk.toUpperCase().startsWith('INC');

                if (reason.includes('INCORRECT CLASSIFICATION') && (stOrig.includes('incomplet') || (isInc && stOrig.includes('cancel')))) {
                    let op = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                    let cl = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                    if (!op) return;
                    if (op.getTime() > refDateObj.getTime()) return;

                    let closeNotes = String(getCol(r, ['Close notes', 'Close Notes', 'close_notes', 'Closing notes']) || '');
                    let linkedMatch = closeNotes.match(/(INC|RITM|REQ|TASK)[\s\-]?(\d{6,8})/i);
                    let linkedTicket = linkedMatch ? (linkedMatch[1].toUpperCase() + linkedMatch[2]) : null;

                    // Cálculo preciso para MTTR (sem Math.floor aqui)
                    let rawDays = cl ? ((cl - op) / 86400000) : ((refDateObj - op) / 86400000);
                    if (rawDays < 0) rawDays = 0;

                    let daysInt = Math.floor(rawDays);

                    let asg = getCol(r, ['Assigned to', 'Analista']) || 'N/A';
                    let reqName = getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A';
                    let gpName = getCol(r, ['Assignment group', 'Grupo']) || 'N/A';

                    let idle = (!cl || cl.getTime() > refDateObj.getTime()) ? getDaysSilent(r, refDateObj, asg, op) : '-';

                    res.total++;
                    if (linkedTicket) res.link++; else res.noLink++;
                    res.days += rawDays;
                    if (daysInt > res.max) res.max = daysInt;

                    // Mês Vigente para os cards: Baseado na data de FECHAMENTO (Performance)
                    // Se não tiver data de fechamento, usa a data de abertura como fallback
                    let dateToCompare = cl || op;
                    let isCurrentMonth = (dateToCompare.getMonth() === refDateObj.getMonth() &&
                        dateToCompare.getFullYear() === refDateObj.getFullYear() &&
                        dateToCompare.getTime() <= refDateObj.getTime()); // Trava na data de referência

                    if (isCurrentMonth) {
                        res.monthTotal++;
                        if (linkedTicket) res.monthLink++; else res.monthNoLink++;
                        res.monthDays += rawDays;
                        if (daysInt > res.monthMax) res.monthMax = daysInt;
                    }

                    let mStrKey = op.getFullYear() + '-' + String(op.getMonth() + 1).padStart(2, '0');
                    let mStrLabel = op.toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' }).toUpperCase().replace('.', '');
                    if (!res.m[mStrKey]) res.m[mStrKey] = { count: 0, tks: [], label: mStrLabel };
                    res.m[mStrKey].count++;

                    if (isCurrentMonth) {
                        if (!res.req[reqName]) res.req[reqName] = { count: 0, tks: [] }; res.req[reqName].count++;
                        if (!res.gp[gpName]) res.gp[gpName] = { count: 0, tks: [] }; res.gp[gpName].count++;
                        if (!res.asg[asg]) res.asg[asg] = { count: 0, tks: [] }; res.asg[asg].count++;
                    }

                    let tObj = {
                        tk: tk, req: reqName, as: asg, gp: gpName, l: linkedTicket || '⚠️ Erro / Não Vinculado',
                        rea: reason, st: stOrig.toUpperCase(), d: daysInt, age: daysInt, idle: idle, opStr: op.toLocaleDateString('pt-BR'), opS: op.toLocaleDateString('pt-BR'),
                        desc: String(getCol(r, ['Short description', 'Descrição Curta', 'Descrição']) || '-').replace(/"/g, '&quot;'),
                        info: closeNotes.replace(/"/g, '&quot;') || 'Nenhuma nota de fechamento registrada.',
                        reason: reason,
                        isMonth: isCurrentMonth
                    };
                    res.tks.push(tObj);

                    if (isCurrentMonth) {
                        res.req[reqName].tks.push(tObj); res.gp[gpName].tks.push(tObj); res.asg[asg].tks.push(tObj);
                    }
                    res.m[mStrKey].tks.push(tObj);
                }
            });
            res.avg = res.total ? (res.days / res.total).toFixed(2).replace('.', ',') : "0,00";
            res.avgMonth = res.monthTotal ? (res.monthDays / res.monthTotal).toFixed(2).replace('.', ',') : "0,00";
            res.tks.sort((a, b) => (b.age || 0) - (a.age || 0));
            return res;
        }

        // ==========================================
        // SISTEMA DE DRILLDOWN MODAL
        // ==========================================
        function openDrilldown(title, ticketArrayStrKey, vaultCat) {
            let tks = window.DrilldownVault[vaultCat][ticketArrayStrKey] || [];
            if (!tks || tks.length === 0) return;

            // Z-A: Ordena por Aging decrescente (o mais antigo/crítico no topo)
            tks.sort((a, b) => (b.age || 0) - (a.age || 0));

            window.paginationState.drilldownData = tks;
            window.paginationState.drilldown = 1;
            window.paginationState.drilldownTitle = title;
            window.paginationState.drilldownIsInc = (vaultCat === 'inc' || vaultCat === 'cons' || vaultCat === 'class');

            renderDrilldownPage();

            document.getElementById('drilldown-modal-backdrop').classList.remove('hidden-st');
            setTimeout(() => {
                document.getElementById('drilldown-modal-backdrop').classList.remove('opacity-0');
                document.getElementById('drilldown-modal-content').classList.remove('scale-95');
            }, 10);
        }

        function renderDrilldownPage() {
            const results = window.paginationState.drilldownData;
            const page = window.paginationState.drilldown;
            const title = window.paginationState.drilldownTitle;
            const isInc = window.paginationState.drilldownIsInc;

            const start = (page - 1) * PAGE_SIZE;
            const end = start + PAGE_SIZE;
            const currentResults = results.slice(start, end);

            document.getElementById('drilldown-title').innerText = title;
            document.getElementById('drilldown-subtitle').innerText = `${results.length} registros encontrados (Página ${page})`;

            let rows = currentResults.map(t => {
                let stColor = '#475569', stBg = '#f1f5f9';
                let st = (t.st || '').toLowerCase();
                if (st.includes('resolv') || st.includes('complet')) { stColor = '#10b981'; stBg = '#ecfdf5'; }
                else if (st.includes('cancel') || st.includes('incomplet')) { stColor = '#ef4444'; stBg = '#fee2e2'; }

                return `
                <tr class="ticket-row hover:bg-slate-50 transition" style="border-bottom: 1px solid #f1f5f9;" ${buildDataAttrs(t)}>
                    <td data-label="Ticket" class="font-bold text-[var(--primary-dark)] text-center">
                        ${t.tk}
                        <button onclick="openTicketDetails('${t.tk}')" class="mt-1 w-full text-center bg-blue-50 border border-blue-200/50 hover:bg-blue-100 rounded py-1 text-[9px] uppercase font-bold transition shadow-sm"><i class="fas fa-search mr-1"></i> Detalhes</button>
                    </td>
                    <td data-label="Assunto / Info" class="text-left w-[350px] max-w-[350px]">
                        <div class="w-full h-auto max-h-[80px] overflow-y-auto overflow-x-hidden stylized-scrollbar border border-slate-100 bg-slate-50 p-1.5 rounded">
                            <div class="text-xs font-semibold text-slate-800 break-words mb-1">${t.desc}</div>
                            ${(t.longDesc && t.longDesc !== '-') ? `<div class="text-[10px] text-slate-500 italic break-words">${t.longDesc}</div>` : ''}
                            ${t.info || t.reason ? `<div class="text-[10px] font-bold text-amber-700 bg-amber-50 border border-amber-100 rounded px-1.5 py-0.5 mt-1 break-words whitespace-normal">⚠️ ${t.info} ${t.reason ? `(${t.reason})` : ''}</div>` : ''}
                        </div>
                    </td>
                    <td data-label="Solicitante" class="text-center">${t.req}</td>
                    <td data-label="Analista" class="text-center font-medium">${t.as}</td>
                    <td data-label="Grupo" class="text-center"><span class="text-[11px] bg-slate-100 px-2 py-1 rounded border border-slate-200 block max-w-[120px] mx-auto truncate" title="${t.gp}">${t.gp}</span></td>
                    <td data-label="Status" data-filter="${t.st}" class="text-center">
                        <span style="background:${stBg}; color:${stColor}; border:1px solid ${stColor}40;" class="px-2 py-0.5 rounded text-[9px] font-bold inline-block">${t.st}</span>
                    </td>
                    <td data-label="Abertura" class="text-center text-slate-500 text-[11px]"><i class="far fa-calendar-alt mr-1"></i>${t.opStr || '-'}</td>
                    ${isInc ? `<td data-label="PRB" class="text-center" style="font-weight:${(t.prb && t.prb !== 'N/A') ? 'bold' : 'normal'}; color:${(t.prb && t.prb !== 'N/A') ? 'var(--primary-dark)' : '#94a3b8'}">${t.prb || 'N/A'}</td>` : ''}
                    <td data-label="Aging / Ocioso" class="text-right">
                        <div class="font-bold text-sm ${t.age > (t.slaConfig || 7) ? 'text-red-500' : 'text-slate-700'}">${t.age}d totais</div>
                        ${t.idle !== '-' ? `<div class="text-[10px] font-bold mt-1 ${t.idle > 3 ? 'text-red-500' : 'text-green-500'}"><i class="fas fa-user-clock"></i> ${t.idle}d ocioso</div>` : `<div class="text-[10px] text-slate-400 mt-1"><i class="fas fa-user-clock"></i> N/A</div>`}
                    </td>
                </tr>`;
            }).join('');

            let searchHtml = `
            <div class="mb-4 relative group">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs transition-colors group-focus-within:text-blue-500"></i>
                <input type="text" id="modal-search" placeholder="Filtrar nesta lista..." 
                    class="w-full pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-xs outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium text-slate-700 shadow-sm"
                    onkeyup="filterModalTable(this.value)">
            </div>`;

            document.getElementById('drilldown-table-container').innerHTML = `
                ${searchHtml}
                <div class="st-dataframe-container border-0 max-h-[60vh] stylized-scrollbar" style="overflow-y: auto;">
                    <table class="st-table w-full" id="drilldown-main-table">
                        <thead><tr>
                            ${createTh("Ticket", "10%")}
                            ${createTh("Assunto / Info", "auto", "left")}
                            ${createTh("Solicitante", "12%")}
                            ${createTh("Analista", "12%")}
                            ${createTh("Grupo", "10%")}
                            ${createTh("Status", "8%")}
                            ${createTh("Abertura", "8%")}
                            ${isInc ? createTh("PRB", "8%") : ''}
                            ${createTh("Aging / Ocioso", "10%", "right")}
                        </tr></thead>
                        <tbody>${rows}</tbody>
                    </table>
                ${renderPaginationControls('drilldown', results.length, page)}
            `;
        }

        function changeDrilldownPage(p) {
            window.paginationState.drilldown = p;
            renderDrilldownPage();
            document.getElementById('drilldown-table-container').scrollTop = 0;
        }

        function changeSearchPage(p) {
            window.paginationState.search = p;
            renderSearchPage();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function closeDrilldown() {
            document.getElementById('drilldown-modal-backdrop').classList.add('opacity-0');
            document.getElementById('drilldown-modal-content').classList.add('scale-95');
            setTimeout(() => document.getElementById('drilldown-modal-backdrop').classList.add('hidden-st'), 300);
        }

        window.filterModalTable = function (val) {
            const term = val.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
            const rows = document.querySelectorAll('#drilldown-main-table tbody tr');
            rows.forEach(tr => {
                const text = tr.innerText.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                tr.style.display = text.includes(term) ? '' : 'none';
            });
        };

        // ==========================================
        // 5. HTML GENERATORS
        // ==========================================
        function generateOpenTicketsHTML(incs, reqs, uams, slaI, slaR, refDateObj) {
            let openTks = [];
            function processRow(r, type, slaConfig) {
                let op = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                if (!op || op.getTime() > refDateObj.getTime()) return;
                let cl = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                if (cl && cl.getTime() <= refDateObj.getTime()) return;
                let age = Math.floor((refDateObj - op) / 86400000);
                if (age < 0) age = 0;
                let tk = (type === 'REQ' || type === 'UAM') ? (getCol(r, ['RITM', 'Request Item', 'Item de solicitação', 'Number', 'Ticket']) || '-') : (getCol(r, ['Number', 'Ticket']) || '-');
                let desc = String(getCol(r, ['Short description', 'Descrição Curta', 'Item']) || 'Sem assunto').replace(/"/g, '&quot;');
                let longDesc = String(getCol(r, ['Description', 'description', 'Descrição Completa', 'Descrição', 'Additional details', 'additional_details']) || '').replace(/"/g, '&quot;');
                let reasonVal = String(getCol(r, ['Reason', 'reason', 'REASON', 'Motivo']) || '').toUpperCase();
                let req = getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A';
                let asg = getCol(r, ['Assigned to', 'Analista', 'Assignee']) || 'Não Atribuído';
                let gp = getCol(r, ['Assignment group', 'Grupo']) || 'Sem Grupo';
                let st = getCol(r, ['State', 'Status', 'Estado']) || 'Open';

                let holdReason = getCol(r, ['On hold reason', 'Motivo da espera', 'on_hold_reason']);
                let stLower = st.toLowerCase();
                let infoFinal = (stLower.includes('hold') || stLower.includes('espera')) && holdReason ? String(holdReason).replace(/"/g, '&quot;') : '';

                let prbRaw = getCol(r, ['Problem', 'PRB', 'Problema', 'problem_id']);
                let prbVal = (prbRaw && String(prbRaw).trim() !== "" && String(prbRaw).trim() !== "undefined") ? String(prbRaw).trim() : 'N/A';

                let idle = getDaysSilent(r, refDateObj, asg, op);
                let pctSlaNum = ((age / slaConfig) * 100);
                let pctSla = pctSlaNum.toFixed(2).replace('.', ',');
                let stSla = age > slaConfig ? "Estourado" : "No Prazo";
                openTks.push({ tk, type, desc, longDesc, req, as: asg, gp, st: st.toUpperCase(), reason: reasonVal, opStr: op.toLocaleDateString('pt-BR'), age, pctSla, pctSlaNum, stSla, slaConfig, idle, info: infoFinal, prb: prbVal });
            }
            incs.forEach(r => processRow(r, 'INC', slaI));
            reqs.forEach(r => processRow(r, 'REQ', slaR));
            uams.forEach(r => processRow(r, 'UAM', slaR));

            let groups = {};
            let countTags = { INC: 0, REQ: 0, UAM: 0 };
            openTks.forEach(t => {
                countTags[t.type] = (countTags[t.type] || 0) + 1;
                if (!groups[t.gp]) groups[t.gp] = [];
                groups[t.gp].push(t);
            });

            let html = `<div class="report-section-title" style="background-color: var(--primary-dark);"><i class="fas fa-folder-open mr-2"></i> VISÃO DE TICKETS ABERTOS POR GRUPO RESOLUTOR</div>`;
            // Z-A: Grupos ordenados de forma decrescente
            let sortedGroups = Object.keys(groups).sort((a, b) => b.localeCompare(a));
            if (sortedGroups.length === 0) {
                html += `<div class="report-card text-center py-10 text-slate-400 font-bold"><i class="fas fa-check-circle text-5xl mb-4 block text-emerald-400"></i>Nenhum ticket aberto encontrado na base para a data de referência selecionada. Parabéns!</div>`;
                return html;
            }

            // Discrete totals integrated into the bar
            html += `
            <div class="flex flex-col lg:flex-row justify-between items-center mb-4 bg-white p-3 rounded-lg shadow-sm border border-slate-200 gap-3">
                <div class="flex items-center gap-2 w-full lg:w-auto flex-1 max-w-sm bg-slate-50 border border-slate-200 px-3 py-2 rounded-full focus-within:border-blue-500 focus-within:bg-white transition-all shadow-inner">
                    <i class="fas fa-search text-slate-400 text-sm"></i>
                    <input type="text" placeholder="Filtrar tickets (número, assunto, analista)..." class="w-full bg-transparent outline-none text-[11px] font-inter text-slate-700" onkeyup="filterOpenTickets(this.value)">
                </div>

                <div class="flex flex-wrap items-center gap-2 justify-center py-1">
                    <div class="bg-blue-50 border border-blue-100 px-2.5 py-1 rounded shadow-inner flex items-center">
                        <span class="text-[9px] font-black text-blue-400 uppercase tracking-tighter mr-2">INC</span>
                        <span class="text-xs font-black text-blue-800">${countTags.INC}</span>
                    </div>
                    <div class="bg-purple-50 border border-purple-100 px-2.5 py-1 rounded shadow-inner flex items-center">
                        <span class="text-[9px] font-black text-purple-400 uppercase tracking-tighter mr-2">REQ</span>
                        <span class="text-xs font-black text-purple-800">${countTags.REQ}</span>
                    </div>
                    <div class="bg-amber-50 border border-amber-100 px-2.5 py-1 rounded shadow-inner flex items-center">
                        <span class="text-[9px] font-black text-amber-500 uppercase tracking-tighter mr-2">UAM</span>
                        <span class="text-xs font-black text-amber-800">${countTags.UAM}</span>
                    </div>
                    <div class="bg-[var(--primary-dark)] border border-blue-900 px-3 py-1 rounded shadow-lg flex items-center">
                        <span class="text-[9px] font-black text-blue-300 uppercase tracking-wider mr-2">TOTAL</span>
                        <span class="text-xs font-black text-white">${openTks.length}</span>
                    </div>
                </div>

                <div class="flex items-center gap-3 w-full lg:w-auto justify-end">
                    <div class="text-[10px] font-bold text-slate-500 hidden xl:block uppercase tracking-tight"><i class="fas fa-layer-group mr-1 text-blue-600"></i> ${Object.keys(groups).length} Grupos</div>
                    <button id="btn-toggle-accordions" onclick="toggleAllAccordions()" class="bg-[var(--primary-dark)] text-white px-4 py-2 rounded-full text-[10px] font-black uppercase shadow-md hover:bg-blue-900 transition flex items-center justify-center gap-2"><i class="fas fa-compress-alt"></i> Recolher Todos</button>
                </div>
            </div>
            <div class="text-[10px] text-slate-400 italic mb-2 px-2"><i class="fas fa-info-circle mr-1"></i> Lista agrupada por Grupo Resolutor ordenada por criticidade de SLA.</div>`;

            sortedGroups.forEach(gp => {
                // Z-A: Tickets dentro do grupo ordenados por %SLA (maior primeiro) e depois por Número (descendente)
                let tks = groups[gp].sort((a, b) => (b.pctSlaNum - a.pctSlaNum) || b.tk.localeCompare(a.tk));
                let rows = tks.map(t => {
                    let safePct = isNaN(t.pctSlaNum) ? 0 : Math.min(t.pctSlaNum, 100);
                    let pctText = isNaN(t.pctSlaNum) ? '0%' : t.pctSla + '%';
                    let pctColor = t.pctSlaNum > 100 ? '#ef4444' : (t.pctSlaNum > 75 ? '#f59e0b' : '#10b981');
                    if (isNaN(t.pctSlaNum)) pctColor = '#94a3b8';

                    let stColor = t.pctSlaNum > 100 ? 'text-red-600' : 'text-emerald-600';
                    if (isNaN(t.pctSlaNum)) stColor = 'text-slate-500';

                    return `
                    <tr class="ticket-row hover:bg-slate-50 transition" style="border-bottom: 1px solid #f1f5f9;" ${buildDataAttrs(t)}>
                        <td data-label="Número" class="font-bold text-[var(--primary-dark)] text-center py-2">
                            ${t.tk}
                            <div class="text-[9px] bg-slate-200 px-1 rounded inline-block text-slate-500 ml-1">${t.type}</div>
                            <button onclick="openTicketDetails('${t.tk}')" class="block w-full mt-1.5 bg-blue-50 border border-blue-200/50 p-1 rounded text-[9px] uppercase hover:bg-blue-100 transition shadow-sm"><i class="fas fa-history"></i> Saiba mais</button>
                        </td>
                        <td data-label="Descrição Completa" class="text-left">
                            <div class="text-expandable font-semibold text-slate-800 mb-1" style="-webkit-line-clamp: 2;">${t.desc}</div>
                            ${t.longDesc && t.longDesc !== '-' ? `<div class="text-expandable text-[10px] text-slate-500 mb-1" style="-webkit-line-clamp: 2;">${t.longDesc}</div>` : ''}
                            ${t.info || t.reason ? `<div class="text-[10px] text-amber-700 font-medium leading-tight mt-1 bg-amber-50 p-1 rounded border border-amber-100"><i class="fas fa-exclamation-circle"></i> <b>Atenção:</b> ${t.info} ${t.reason ? `(${t.reason})` : ''}</div>` : ''}
                        </td>
                        <td data-label="Requester" class="text-center">${t.req}</td>
                        <td data-label="Analista" class="text-center font-medium">${t.as}</td>
                        <td data-label="Grupo" class="text-center"><span class="text-[11px] bg-slate-100 px-2 py-1 rounded border border-slate-200 block max-w-[150px] mx-auto truncate" title="${t.gp}">${t.gp}</span></td>
                        <td data-label="State" class="text-center">
                            <span class="px-2 py-1 bg-slate-100 border border-slate-200 rounded text-[9px] uppercase font-bold block mx-auto w-max">${t.st}</span>
                            ${t.reason ? `<span class="block text-[9px] text-slate-500 mt-1 truncate max-w-[100px] mx-auto" title="${t.reason}">${t.reason}</span>` : ''}
                        </td>
                        <td data-label="Abertura" class="text-center"><i class="far fa-calendar-alt text-slate-400 mr-1"></i>${t.opStr}</td>
                        <td data-label="Aging (dias)" class="text-center font-bold text-base ${t.age > t.slaConfig ? 'text-red-600' : 'text-slate-700'}">${t.age}</td>
                        <td data-label="% SLA" class="text-center" style="width: 100px;">
                            <div class="w-full bg-slate-200 rounded-full h-4 relative shadow-inner mx-auto min-w-[70px] overflow-hidden border border-slate-300/50">
                                <div class="h-full absolute left-0 top-0 bottom-0 transition-all" style="width: ${safePct}%; background-color: ${pctColor} !important;"></div>
                                <div class="absolute inset-0 flex items-center justify-center text-[9px] font-bold z-10" style="color: ${t.pctSlaNum > 55 ? '#ffffff' : '#1e293b'}; text-shadow: ${t.pctSlaNum > 55 ? '0 0 2px rgba(0,0,0,0.8)' : 'none'};">${pctText}</div>
                            </div>
                        </td>
                        <td data-label="Status SLA" class="text-center font-black ${stColor} uppercase text-[10px]">${t.stSla}</td>
                    </tr>`;
                }).join('');
                html += `
                <details class="saas-accordion mb-4" open>
                    <summary class="bg-slate-50 border-b border-slate-200 text-slate-800 font-bold text-sm p-4 hover:bg-blue-50 transition">
                        <div class="flex justify-between w-full pr-4 items-center">
                            <span class="flex items-center"><i class="fas fa-users mr-2 text-[var(--primary-dark)] opacity-70"></i> ${gp}</span>
                            <span class="bg-[var(--primary-dark)] text-white px-2.5 py-0.5 rounded-full text-xs shadow-sm">${tks.length} tickets</span>
                        </div>
                    </summary>
                    <div class="acc-content p-0">
                        <div class="st-dataframe-container border-0 rounded-none shadow-none max-h-[400px]">
                            <table class="st-table w-full">
                                <thead><tr>
                                    ${createTh("Número", "10%")}
                                    ${createTh("Descrição Completa / Status", "25%", "left")}
                                    ${createTh("Requester", "12%")}
                                    ${createTh("Analista", "12%")}
                                    ${createTh("Grupo", "12%")}
                                    ${createTh("State", "10%")}
                                    ${createTh("Abertura", "8%")}
                                    ${createTh("Aging", "5%")}
                                    ${createTh("% SLA", "8%")}
                                    ${createTh("Status", "auto")}
                                </tr></thead>
                                <tbody>${rows}</tbody>
                            </table>
                        </div>
                    </div>
                </details>`;
            });
            return html;
        }

        window.filterOpenTickets = function (term) {
            const cleanTerm = term.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
            document.querySelectorAll('#tab-open details.saas-accordion').forEach(acc => {
                let hasVisibleRow = false;
                const rows = acc.querySelectorAll('tbody tr');

                rows.forEach(tr => {
                    const text = tr.innerText.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                    if (text.includes(cleanTerm)) {
                        tr.style.display = '';
                        hasVisibleRow = true;
                    } else {
                        tr.style.display = 'none';
                    }
                });

                if (hasVisibleRow) {
                    acc.style.display = '';
                    if (cleanTerm.length > 0) acc.setAttribute('open', '');
                } else {
                    acc.style.display = 'none';
                }
            });
        };

        function buildThroughputTable(d, lblRes) {
            let rows = "", tA = 0, tR = 0, tC = 0, tS = 0, lastB = 0;
            let keys = Object.keys(d.trendM).sort();
            keys.forEach((k) => {
                let m = d.trendM[k];
                let mesStr = new Date(k.split('-')[0], k.split('-')[1] - 1, 1).toLocaleString('pt-BR', { month: 'short', year: 'numeric' }).toUpperCase().replace('.', '');
                let saldo = m.a - (m.r + m.c);
                let pctStr = m.r > 0 ? ((m.inSla / m.r) * 100).toFixed(2).replace('.', ',') : "0,00";
                let bgPct = pctStr >= 98 ? C.SUC : C.DAN;
                let colorS = saldo > 0 ? C.PRI_D : (saldo < 0 ? C.PRI : C.GRY_D);
                tA += m.a; tR += m.r; tC += m.c; tS += saldo; lastB = m.b;
                rows += `<tr>
                    <td data-label="Mês" style="text-align:center; font-weight:600;">${mesStr}</td>
                    <td data-label="Abertos">${m.a}</td>
                    <td data-label="${lblRes}">${m.r}</td>
                    <td data-label="Cancelados">${m.c}</td>
                    <td data-label="Saldo" style="color:${colorS}; font-weight:bold;">${saldo > 0 ? '+' + saldo : saldo}</td>
                    <td data-label="Backlog" style="font-weight:bold;">${m.b}</td>
                    <td data-label="% no Prazo" style="background-color:${bgPct}; color:#fff; font-weight:bold;">${pctStr}%</td>
                </tr>`;
            });
            return `<div class="st-dataframe-container"><table class="st-table">
                <thead><tr>
                    ${createTh("Mês")} ${createTh("Abertos")} ${createTh(lblRes)} ${createTh("Cancelados")} ${createTh("Saldo")} ${createTh("Backlog")} ${createTh("% no Prazo")}
                </tr></thead>
                <tbody>${rows || `<tr><td colspan="7" style="text-align:center;">Sem histórico.</td></tr>`}</tbody>
                <tfoot><tr>
                    <th data-label="TOTAIS:" style="text-align:right;">TOTAIS:</th>
                    <th data-label="Abertos">${tA}</th> <th data-label="${lblRes}">${tR}</th> <th data-label="Cancelados">${tC}</th>
                    <th data-label="Saldo" style="color:${tS > 0 ? C.PRI_D : C.PRI}; font-weight:bold;">${tS > 0 ? '+' + tS : tS}</th>
                    <th data-label="Backlog">${lastB}</th> <th data-label="% no Prazo">-</th>
                </tr></tfoot>
            </table></div>`;
        }

        function generateSectionHTML(id, title, color, d, typeStr) {
            let cat = id;
            window.DrilldownVault[cat]['all_backlog'] = d.allBacklogTks;
            window.DrilldownVault[cat]['all_res_month'] = d.allResolvedTks;
            window.DrilldownVault[cat]['all_canc_month'] = d.allCanceledTks;

