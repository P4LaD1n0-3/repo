        // Função para adaptar dados de PRB para o formato do dashboard
        function processPRBDataForDisplay(prbRawData) {
            // Adapta os dados de PRB da planilha para o formato esperado por generatePRBTabImproved
            if (!prbRawData || prbRawData.length === 0) return [];

            let processed = [];
            let seenTickets = new Set();

            prbRawData.forEach(row => {
                // Tenta detecitar se é dado agregado (linha de PRB) ou ticket individual
                let isPRBAggregateRow = (row['Menções'] !== undefined && row['Tickets_abertos'] !== undefined && !row['Number']);

                if (isPRBAggregateRow) {
                    // Linha agregada de PRB (da aba "PRB ABERTOS")
                    let prb = String(row['PRB'] || '').trim();
                    let vigentes = parseInt(row['Tickets_Vigentes'] || 0);
                    let release = String(row['Release_Version'] || '—').trim();
                    let mentions = parseInt(row['Menções'] || 0);
                    let top_grupo = String(row['Top grupo'] || '—').trim();

                    if (!prb || seenTickets.has(prb)) return;
                    seenTickets.add(prb);

                    // Cria entrada para PRB com formato que generatePRBTabImproved entende
                    processed.push({
                        number: prb,  // Usa PRB como identificador
                        type: 'PRB',
                        prb: prb,
                        state: vigentes > 0 ? 'OPEN' : 'CLOSED',
                        group: top_grupo,
                        priority: vigentes > 5 ? 'CRITICAL' : (vigentes > 2 ? 'HIGH' : 'MEDIUM'),
                        description: `${mentions} mentões | ${vigentes} tickets vigentes`,
                        release: release,
                        vigentes: vigentes,
                        related_tickets: []
                    });
                } else {
                    // Linha de ticket individual
                    let number = String(row['Number'] || row['Ticket'] || row['RITM'] || '').trim();
                    let prb = String(row['PRB'] || '').trim();
                    let type = String(row['TicketType'] || row['Type'] || 'REQ').toUpperCase();
                    let state = String(row['State'] || row['Status'] || 'Open').toUpperCase();
                    let group = String(row['Assignment group'] || row['Grupo'] || '—').trim();
                    let priority = String(row['Priority'] || 'N/A').trim();
                    let desc = String(row['Short description'] || row['Description'] || row['Descrição'] || '').trim();
                    let release = String(row['Release_Version'] || row['Versão'] || '—').trim();
                    let related_str = String(row['Tickets_Relacionados'] || '').trim();
                    let related_tickets = related_str && related_str !== '—' ? related_str.split(',').map(t => t.trim()) : [];

                    if (!number || !prb || seenTickets.has(number)) return;
                    seenTickets.add(number);

                    let comments = String(row['Additional comments'] || row['Comentários Adicionais'] || row['Comments'] || '').trim();
                    let v_rel_extracted = extractFromComments(comments, 'version');
                    let d_rel_extracted = extractFromComments(comments, 'date');

                    processed.push({
                        number: `${type}:${number} `,
                        type: type,
                        prb: prb,
                        state: state,
                        group: group,
                        priority: priority,
                        description: desc.substring(0, 80) + (desc.length > 80 ? '...' : ''),
                        release: release !== '—' ? release : v_rel_extracted,
                        data_release: d_rel_extracted,
                        related_tickets: related_tickets
                    });
                }
            });

            return processed;
        }

