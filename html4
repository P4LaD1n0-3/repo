        async function exportTodosToPDF() {
            if (todoList.length === 0) return alert("Não existem tarefas ativas para exportar no momento.");

            const { jsPDF } = window.jspdf;
            const doc = jsPDF({ orientation: 'p', unit: 'mm', format: 'a4' });
            const today = new Date().toLocaleDateString('pt-BR');
            const now = new Date().toLocaleString('pt-BR');

            // --- CONFIGURAÇÃO VISUAL --- 
            const primaryColor = [30, 58, 138]; // #1E3A8A
            const accentColor = [0, 24, 113];   // #001871
            const textColor = [30, 41, 59];    // #1E293B

            // --- CABEÇALHO ---
            doc.setFillColor(...primaryColor);
            doc.rect(0, 0, 210, 40, 'F');

            doc.setTextColor(255, 255, 255);
            doc.setFont("helvetica", "bold");
            doc.setFontSize(22);
            doc.text("DAILY REPORT / PLANEJAMENTO TODO", 105, 20, { align: 'center' });

            doc.setFontSize(10);
            doc.setFont("helvetica", "normal");
            doc.text(`Gerado em: ${now}`, 105, 30, { align: 'center' });

            // --- AGRUPAMENTO POR ANALISTA ---
            let groups = {};
            todoList.forEach(t => {
                if (!groups[t.analyst]) groups[t.analyst] = [];
                groups[t.analyst].push(t);
            });

            let startY = 50;

            for (let analyst in groups) {
                // Título do Analista
                doc.setDrawColor(226, 232, 240);
                doc.setFillColor(248, 250, 252);
                doc.rect(14, startY - 5, 182, 10, 'FD');

                doc.setTextColor(...accentColor);
                doc.setFont("helvetica", "bold");
                doc.setFontSize(12);
                doc.text(`ANALISTA: ${analyst.toUpperCase()}`, 20, startY + 1.5);

                const analystTodos = groups[analyst];
                const tableData = [];

                analystTodos.forEach(t => {
                    const ticket = (t.ticket && !t.ticket.includes('undefined')) ? t.ticket : 'Geral';

                    // Busca Contexto do Chamado
                    let context = '-';
                    if (ticket !== 'Geral') {
                        let rec = findTicketRecord(ticket);
                        if (rec) {
                            context = getCol(rec, ['Short description', 'Descrição Curta', 'Descrição', 'Item']) || '-';
                        }
                    }

                    // Cálculo de Status
                    let status = 'Pendente';
                    const total = t.history.length;
                    const done = t.history.filter(h => h.striked).length;
                    if (total > 0) {
                        if (done === total) status = 'Efetuada';
                        else if (done > 0) status = 'Parcialmente Efetuada';
                    }

                    // Formatação do Histórico (espaço para o ícone desenhado)
                    const historyLines = t.history.map(h => `      (${h.date.split(' ')[1]}) ${h.text}`);

                    tableData.push([
                        ticket,
                        context,
                        t.date,
                        status,
                        {
                            content: historyLines.join('\n'),
                            strikedItems: t.history.map(h => h.striked)
                        }
                    ]);
                });

                doc.autoTable({
                    startY: startY + 8,
                    head: [['Ticket', 'Contexto', 'Planejado', 'Status', 'Ações / Histórico']],
                    body: tableData,
                    theme: 'grid',
                    headStyles: {
                        fillColor: primaryColor,
                        textColor: [255, 255, 255],
                        fontSize: 8,
                        fontStyle: 'bold',
                        halign: 'center'
                    },
                    columnStyles: {
                        0: { cellWidth: 22, fontStyle: 'bold', halign: 'center' },
                        1: { cellWidth: 35, fontSize: 7 },
                        2: { cellWidth: 20, halign: 'center', fontSize: 7 },
                        3: { cellWidth: 25, halign: 'center', fontStyle: 'bold', fontSize: 7 },
                        4: { cellWidth: 'auto', fontSize: 7 }
                    },
                    styles: {
                        fontSize: 7,
                        cellPadding: 3,
                        valign: 'middle',
                        overflow: 'linebreak'
                    },
                    margin: { left: 14, right: 14 },
                    willDrawCell: (data) => {
                        // Cores para o Status (Coluna 3) - Estilo Badge
                        if (data.section === 'body' && data.column.index === 3) {
                            const val = data.cell.raw;
                            if (val === 'Efetuada') {
                                data.cell.styles.fillColor = [20, 150, 80]; // Verde
                                data.cell.styles.textColor = [255, 255, 255];
                            } else if (val === 'Parcialmente Efetuada') {
                                data.cell.styles.fillColor = [255, 140, 0]; // Laranja
                                data.cell.styles.textColor = [255, 255, 255];
                            } else if (val === 'Pendente') {
                                data.cell.styles.fillColor = [200, 30, 30]; // Vermelho
                                data.cell.styles.textColor = [255, 255, 255];
                            }
                        }
                    },
                    didDrawCell: (data) => {
                        // Desenhar ícones manuais na coluna de Histórico (Coluna 4)
                        if (data.section === 'body' && data.column.index === 4) {
                            const strikedItems = data.cell.raw.strikedItems;
                            if (!strikedItems) return;

                            const x = data.cell.x + 2;
                            let y = data.cell.y + 4.5;

                            strikedItems.forEach(isDone => {
                                if (isDone) {
                                    // Desenha Checkmark Verde
                                    doc.setDrawColor(34, 197, 94);
                                    doc.setLineWidth(0.4);
                                    doc.line(x, y, x + 1, y + 1);
                                    doc.line(x + 1, y + 1, x + 2.5, y - 1);
                                } else {
                                    // Desenha Círculo Cinza
                                    doc.setDrawColor(200, 200, 200);
                                    doc.setLineWidth(0.3);
                                    doc.circle(x + 1.25, y, 0.8);
                                }
                                y += (data.cell.styles.lineHeight || 3.5); // Ajuste fino do line height
                            });
                        }
                    },
                    didDrawPage: (data) => {
                        startY = data.cursor.y + 15;
                    }
                });

                startY = doc.lastAutoTable.finalY + 15;

                // Verificar se precisa de nova página se o próximo grupo for grande
                if (startY > 250) {
                    doc.addPage();
                    startY = 20;
                }
            }

            // --- RODAPÉ ---
            const pageCount = doc.internal.getNumberOfPages();
            for (let i = 1; i <= pageCount; i++) {
                doc.setPage(i);
                doc.setFontSize(8);
                doc.setTextColor(148, 163, 184);
                doc.text(`Página ${i} de ${pageCount} - Dashboard ITSM Intelligence`, 105, 287, { align: 'center' });
            }

            const fileName = `Planejamento_TODO_${new Date().toISOString().split('T')[0]}.pdf`;
            doc.save(fileName);
        }

