        function processDashboard() {
            if (!RawData.incs.length && !RawData.reqs.length) return alert("Erro: Carregue as planilhas do ServiceNow na aba lateral primeiro.");

            let now = new Date();
            document.getElementById('extraction-time').innerHTML = `<i class="fas fa-clock mr-1"></i> Extração: ${now.toLocaleDateString('pt-BR')} ${now.toLocaleTimeString('pt-BR')}`;
            document.getElementById('init-alert').classList.add('hidden-st');
            document.getElementById('loader').classList.remove('hidden-st');
            document.getElementById('report-content').classList.add('hidden-st');
            document.getElementById('tabs-container').classList.remove('hidden-st');
            if (window.innerWidth < 1024) toggleSidebar();

            if (window.chartInstances.length > 0) {
                window.chartInstances.forEach(c => c.destroy());
                window.chartInstances = [];
            }

            GlobalOpenTickets = [];
            activeTableFilters = {};

            setTimeout(() => {
                const slaI = parseInt(document.getElementById('sla-incs').value) || 7;
                const slaR = parseInt(document.getElementById('sla-reqs').value) || 10;
                const slaP = parseInt(document.getElementById('sla-ptask').value) || 10;
                const slaRCA = parseInt(document.getElementById('sla-rca').value) || 10;
                const refDateInput = document.getElementById('ref-date').value;
                const dateMachine = refDateInput ? new Date(refDateInput + 'T12:00:00') : new Date();

                ['tab-inc', 'tab-req', 'tab-uam', 'tab-cons', 'tab-prb', 'tab-class', 'tab-search', 'tab-open'].forEach(id => {
                    let el = document.getElementById(id);
                    if (el) el.innerHTML = "";
                });

                let dI = null, dRS = null, dRU = null;
                if (RawData.incs.length) {
                    dI = calculateSection(RawData.incs, slaI, "INC", dateMachine);
                    document.getElementById('tab-inc').innerHTML = generateSectionHTML('inc', "SESSÃO INCs (INCIDENTES GERAIS)", C.PRI_D, dI, "INC");
                }

                let rS = [], rU = [];
                if (RawData.reqs.length) {
                    const isUam = r => String(r['Assignment group'] || r['Grupo'] || '').toLowerCase().includes('access');
                    rS = RawData.reqs.filter(r => !isUam(r));
                    rU = RawData.reqs.filter(r => isUam(r));

                    if (rS.length) { dRS = calculateSection(rS, slaR, "REQ", dateMachine); document.getElementById('tab-req').innerHTML = generateSectionHTML('req', "SESSÃO REQs (SUPORTE GERAL)", C.PRI_D, dRS, "REQ"); }
                    if (rU.length) { dRU = calculateSection(rU, slaR, "REQ", dateMachine); document.getElementById('tab-uam').innerHTML = generateSectionHTML('uam', "SESSÃO UAMs (ACESSOS)", C.PRI_D, dRU, "REQ"); }
                }

                document.getElementById('tab-open').innerHTML = generateOpenTicketsHTML(RawData.incs, rS, rU, slaI, slaR, dateMachine);

                if (dI && dRS && dRU) document.getElementById('tab-cons').innerHTML = generateConsolidadoHTML(dI, dRS, dRU);

                // Prioriza PRBs se existirem, caso contrário usa RCA/PTASK
                if (RawData.prb && RawData.prb.length > 0) {
                    let prbProcessed = processPRBDataForDisplay(RawData.prb);
                    document.getElementById('tab-prb').innerHTML = generatePRBTabImproved(prbProcessed);
                } else if (RawData.rca.length || RawData.ptask.length) {
                    document.getElementById('tab-prb').innerHTML = generatePRBTab(RawData.rca, RawData.ptask, slaRCA, slaP, dateMachine);
                } else {
                    document.getElementById('tab-prb').innerHTML = `<div class="report-card text-center py-10"><h3 class="text-slate-600 font-bold">Nenhum dado de Causa Raiz/PTASK/PRB importado.</h3></div>`;
                }

                let allCombinedData = [...RawData.incs, ...RawData.reqs];
                if (allCombinedData.length > 0) {
                    let dClass = calculateClassifications(allCombinedData, dateMachine);
                    document.getElementById('tab-class').innerHTML = generateClassificationsHTML(dClass);

                    requestAnimationFrame(() => {
                        let cnv = document.getElementById('chart-class-trend');
                        if (cnv) {
                            let keysM = Object.keys(dClass.m).sort();
                            window.chartInstances.push(new Chart(cnv, {
                                type: 'line',
                                data: {
                                    labels: keysM.map(k => dClass.m[k].label || k),
                                    datasets: [{
                                        label: 'Erros de Classificação',
                                        data: keysM.map(k => dClass.m[k].count),
                                        borderColor: C.DAN,
                                        fill: false,
                                        borderWidth: 3,
                                        datalabels: { align: 'top', font: { weight: 'bold' }, formatter: v => v > 0 ? v : "" }
                                    }]
                                },
                                options: {
                                    maintainAspectRatio: false,
                                    legend: { display: false },
                                    scales: { yAxes: [{ ticks: { beginAtZero: true } }] },
                                    onClick: function (evt, activeElements) {
                                        if (activeElements.length > 0) {
                                            let idx = activeElements[0]._index;
                                            let mKey = keysM[idx];
                                            window.DrilldownVault['class']['temp'] = dClass.m[mKey].tks;
                                            openDrilldown(`Erros em ${mKey}`, 'temp', 'class');
                                        }
                                    }
                                }
                            }));
                        }
                    });
                }

                document.getElementById('loader').classList.add('hidden-st');
                document.getElementById('report-content').classList.remove('hidden-st');
                document.getElementById('search-container').classList.add('visible');

                let tabs = document.querySelectorAll('.tab-pane');
                tabs.forEach(c => {
                    c.style.display = 'block';
                    c.style.visibility = 'hidden';
                    c.style.position = 'absolute';
                    c.classList.remove('hidden-st');
                });

                requestAnimationFrame(() => {
                    if (dI) drawChartsAll('inc', dI, 'Resolvidos');
                    if (dRS) drawChartsAll('req', dRS, 'Encerrados');
                    if (dRU) drawChartsAll('uam', dRU, 'Encerrados');
                    if (dI && dRS && dRU) drawConsolidadoCharts(dI, dRS, dRU);

                    tabs.forEach(c => {
                        c.style.display = '';
                        c.style.visibility = '';
                        c.style.position = '';
                        c.classList.add('hidden-st');
                    });

                    populateTodoAnalystDropdown();
                    renderTodos();

                    switchTab('tab-open', document.querySelector('.tab-btn[onclick*="tab-open"]'));
                    if (document.getElementById("globalSearch").value.trim() !== "") {
                        performGlobalSearch();
                    } else {
                        filterTables();
                    }

                    document.querySelectorAll('.report-card').forEach(card => {
                        if (!card.querySelector('.btn-snap') && card.style.display !== 'none') {
                            let btn = document.createElement('button');
                            btn.className = 'btn-snap';
                            btn.innerHTML = '<i class="fas fa-camera text-[10px]"></i>';
                            btn.title = "Tirar Foto deste Gráfico/Tabela";
                            btn.onclick = (e) => takeScreenshotItem(btn, e);
                            card.appendChild(btn);
                        }
                    });
                });
            }, 600);
        }

        // --- INICIALIZAÇÃO GERAL (Persistência) ---
        document.addEventListener('DOMContentLoaded', async () => {
            console.log("[INIT] Inicializando Painel com Persistência...");

            // 1. Carrega Configurações (SLA, Email) do localStorage
            loadConfigs();

            // 2. Tenta recuperar Pasta Vinculada do IndexedDB
            try {
                const storedHandle = await loadHandle();
                if (storedHandle) {
                    window.syncContext.dirHandle = storedHandle;
                    document.getElementById('sync-status-indicator').className = 'w-3 h-3 rounded-full bg-amber-500 shadow shadow-amber-200';
                    document.getElementById('sync-status-text').innerText = 'Pasta Lembrada (Aguardando Permissão)';
                    document.getElementById('sync-folder-path').innerText = storedHandle.name;
                    console.log("[INIT] Pasta recuperada do DB:", storedHandle.name);
                }
            } catch (e) {
                console.error("[INIT] Erro ao carregar pasta do DB:", e);
            }

            // 3. Renderiza TODOs se houver (já carregados no escopo global)
            if (todoList.length > 0) {
                renderTodos();
            }
        });

        // ==========================================


        function takeScreenshotItem(btn, e) {
            e.stopPropagation();
            btn.innerHTML = '<i class="fas fa-spinner fa-spin text-[10px]"></i>';
            const card = btn.closest('.report-card');
            if (!card) return;

            let titleText = "Item";
            const titleEl = card.querySelector('.report-card-title');
            if (titleEl) titleText = titleEl.innerText.replace(/[^a-zA-Z0-9]/g, '_').substring(0, 30);

            html2canvas(card, {
                scale: 1.5,
                logging: false,
                useCORS: true,
                backgroundColor: "#ffffff"
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = `ITSM_${titleText}_${new Date().toISOString().slice(0, 10)}.png`;
                link.href = canvas.toDataURL('image/png');
                link.click();
                btn.innerHTML = '<i class="fas fa-camera text-[10px]"></i>';
            }).catch(err => {
                alert("Erro ao tirar print do item.");
                btn.innerHTML = '<i class="fas fa-camera text-[10px]"></i>';
            });
        }
    </script>
</body>

</html>
