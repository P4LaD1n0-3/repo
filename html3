<script>
        // ==========================================
        // 0. DATA & FILES & UTILS
        // ==========================================
        const RawData = { incs: [], reqs: [], rca: [], ptask: [] };
        let todoList = JSON.parse(localStorage.getItem('eliteMasterTodosV69')) || [];
        let GlobalOpenTickets = [];
        let activeTableFilters = {};
        
        // CORREÇÃO DEFINITIVA: Inicialização global do ChartInstances para evitar erro de .push() undefined
        window.chartInstances = [];

        // NOVO: Armazém global para o Drill-down
        window.DrilldownVault = {
            inc: {}, req: {}, uam: {}, cons: {}, class: {}
        };

        document.getElementById('ref-date').valueAsDate = new Date();
        
        function handleFiles(files) {
            Array.from(files).forEach(file => {
                const name = file.name.toLowerCase();
                const reader = new FileReader();
                reader.onload = e => {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array', cellDates: true });
                    const json = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]], { defval: "" });
                    
                    const cleanJson = json.map(r => { 
                         let o = {}; 
                         Object.keys(r).forEach(k => o[k.replace(/\ufffd/g, "").replace(/\s+/g, " ").trim()] = r[k]); 
                         return o; 
                     });
                     
                    if (name.includes('inc')) RawData.incs = cleanJson;
                    else if (name.includes('sc_task') || name.includes('req')) RawData.reqs = cleanJson;
                    else if (name.includes('rca')) RawData.rca = cleanJson;
                    else if (name.includes('ptask')) RawData.ptask = cleanJson;
                    
                    document.getElementById('file-status').innerHTML += `<div class="file-badge"><span class="truncate"><i class="fas fa-file-excel mr-1"></i> ${file.name}</span><i class="fas fa-check"></i></div>`;
                    document.getElementById('btn-clear-files').classList.remove('hidden-st');
                };
                reader.readAsArrayBuffer(file);
            });
        }
        function clearFiles() { location.reload(); }
        
        // CORREÇÃO MÁXIMA PARA COLUNAS: getCol ignorando maiúsculas/minúsculas
        const getCol = (row, keys) => { 
             const rowKeys = Object.keys(row);
             for (let k of keys) {
                 let kLow = String(k).toLowerCase();
                 let match = rowKeys.find(rk => String(rk).toLowerCase() === kLow);
                 if (match && row[match] !== undefined && row[match] !== "") {
                     return row[match];
                 }
             }
             return null; 
         };
         
        const safeDate = v => { 
             if (!v) return null; 
             if (v instanceof Date) return isNaN(v.getTime()) ? null : v;
            if (typeof v === 'number') return new Date(Math.round((v - 25569) * 86400 * 1000));
            if (typeof v === 'string') {
                let p = v.trim().split(/[\/\s:]/);
                if (p.length >= 3 && p[2].length === 4) { let d = new Date(p[2], p[1] - 1, p[0]); if (!isNaN(d.getTime())) return d; }
                let nD = new Date(v); if (!isNaN(nD.getTime())) return nD;
            }
            return null; 
         };
         
        function removeAccents(str) { return str.normalize("NFD").replace(/[\u0300-\u036f]/g, ""); }
        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('collapsed'); setTimeout(() => window.dispatchEvent(new Event('resize')), 350); }
        
        function toggleText(btn) { 
             const t = btn.previousElementSibling; 
             if (t.classList.contains('expanded')) { 
                 t.classList.remove('expanded'); btn.innerHTML = 'Expandir'; 
             } else { 
                 t.classList.add('expanded'); btn.innerHTML = 'Recolher'; 
             } 
         }
         
        function takeScreenshot() {
            const btn = document.querySelector('.fa-camera').parentElement;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin text-sm"></i>';
            html2canvas(document.getElementById('capture-area'), { scrollY: -window.scrollY, scale: 2 }).then(canvas => {
                const link = document.createElement('a'); 
                link.download = `Painel_ITSM_EliteMaster_${new Date().toISOString().slice(0,10)}.png`;
                link.href = canvas.toDataURL('image/png'); 
                link.click(); 
                btn.innerHTML = '<i class="fas fa-camera text-sm"></i>';
            }).catch(err => {
                alert("Erro ao tirar print da tela.");
                btn.innerHTML = '<i class="fas fa-camera text-sm"></i>';
            });
        }
        
        function exportBackupJSON() {
            const link = document.createElement('a');
            link.href = 'data:application/json;charset=utf-8,'+ encodeURIComponent(JSON.stringify(todoList));
            link.download = `EliteMaster_Backup_Tarefas_${new Date().toISOString().slice(0,10)}.json`; 
            link.click();
        }
        function importBackupJSON(e) {
            const file = e.target.files[0]; 
            if(!file) return;
