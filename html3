            });

            ptaskData.forEach(r => {
                let op = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                if (!op || op.getTime() > refTime) return;
                let clOrig = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                let st = String(getCol(r, ['State', 'Status']) || '').toLowerCase();
                if (clOrig && clOrig.getTime() <= refTime) { if (st.includes('clos') || st.includes('resolv') || st.includes('cancel') || st.includes('fech')) return; }
                let age = Math.floor((refDate - op) / 86400000);
                let tk = getCol(r, ['Number', 'Task']) || '-';
                let desc = getCol(r, ['Problem', 'Problema']) || '-';
                let req = getCol(r, ['Requester', 'Caller']) || 'N/A';
                let asg = getCol(r, ['Assigned to', 'Analista']) || '-';
                let idle = (!clOrig || clOrig.getTime() > refDateObj.getTime()) ? getDaysSilent(r, refDateObj, asg, op) : '-';
                
                let dummyT = { tk: tk, desc: desc, req: req, as: asg, gp: getCol(r, ['Assignment group', 'Grupo']) || '-', st: st.toUpperCase(), age: age, idle: idle, opStr: op.toLocaleDateString('pt-BR'), info: 'Task secundária' };
                allPtasks.push(dummyT);
                
                ptaskRows += `<tr ${buildRowAttrs(dummyT)}>
                    <td data-label="Problem (Pai)" class="font-bold text-slate-700">${desc}</td>
                    <td data-label="PTASK" style="color:${C.PRI_D}; font-weight:bold;">
                        ${tk}
                        <button onclick="openTicketDetails('${tk}')" class="mt-2 w-full text-center bg-blue-50/50 hover:bg-blue-100 text-[var(--primary-dark)] border border-blue-200/50 hover:border-blue-300 rounded py-1 px-2 text-[9px] uppercase font-bold transition-colors shadow-sm"><i class="fas fa-history mr-1"></i> Saiba mais</button>
                    </td>
                    <td data-label="Analista" class="font-medium">${dummyT.as}</td>
                    <td data-label="Grupo Resolutor">${dummyT.gp}</td>
                    <td data-label="SLA / Aging / Ocioso" style="text-align:right;">
                        <div style="color:${age > slaPTask ? C.DAN : C.SUC}; font-weight:bold; font-size:13px;">${age > slaPTask ? `Estourado (${age}d)` : `No Prazo (${age}d)`}</div>
                        ${dummyT.idle !== '-' ? `<div style="font-size:10px; font-weight:bold; margin-top:2px; color:${dummyT.idle > 3 ? '#ef4444' : '#10b981'};"><i class="fas fa-user-clock"></i> ${dummyT.idle}d ocioso</div>` : `<div style="font-size:10px; color:#94a3b8; margin-top:2px;"><i class="fas fa-user-clock"></i> N/A</div>`}
                    </td>
                </tr>`;
            });
            
            // Cards interativos para PRB
            window.DrilldownVault['class']['all_prbs'] = allPrbs;
            window.DrilldownVault['class']['all_ptasks'] = allPtasks;

            html += `
            <div class="grid grid-cols-2 gap-6 mb-6">
                <div class="report-card text-center border-l-4 border-orange-600 clickable-card" style="margin-bottom:0;" onclick="openDrilldown('RCAs Abertas (Problems)', 'all_prbs', 'class')">
                    <div class="text-[12px] font-black text-orange-600 mb-2 uppercase">Problemas / RCAs Abertas</div>
                    <div class="text-4xl font-black text-slate-700">${allPrbs.length}</div>
                </div>
                <div class="report-card text-center border-l-4 border-indigo-600 clickable-card" style="margin-bottom:0;" onclick="openDrilldown('Problem Tasks (PTASKs) Abertas', 'all_ptasks', 'class')">
                    <div class="text-[12px] font-black text-indigo-600 mb-2 uppercase">PTASKs Abertas</div>
                    <div class="text-4xl font-black text-slate-700">${allPtasks.length}</div>
                </div>
            </div>
            `;

            html += `<div class="report-card"><div class="report-card-title"><i class="fas fa-search mr-2"></i> 1. PROBLEM RCA - CAUSAS RAIZ EM ABERTO</div>
                <div class="st-dataframe-container"><table class="st-table">
                <thead><tr>
                    ${createTh("Problem", "15%")} ${createTh("Descrição da Causa Raiz", "auto", "left")} ${createTh("Analista Responsável", "20%")} ${createTh("Status RCA", "15%")}
                </tr></thead>
                <tbody>${rcaRows || `<tr><td colspan="4" class="text-center text-slate-500 py-6">Nenhuma RCA aberta no momento.</td></tr>`}</tbody>
                </table></div></div>`;
            
            html += `<div class="report-card"><div class="report-card-title"><i class="fas fa-tasks mr-2"></i> 2. TASKS DE PROBLEMA (PTASK) ABERTAS</div>
                <div class="st-dataframe-container"><table class="st-table">
                <thead><tr>
                    ${createTh("Problem (Pai)", "15%")} ${createTh("PTASK", "15%")} ${createTh("Analista", "20%")} ${createTh("Grupo Resolutor", "25%")} ${createTh("SLA / Ocioso", "15%", "right")}
                </tr></thead>
                <tbody>${ptaskRows || `<tr><td colspan="5" class="text-center text-slate-500 py-6">Nenhuma PTASK aberta no momento.</td></tr>`}</tbody>
                </table></div></div>`;
                
            return html;
        }

        // ==========================================
        // 7. GRÁFICOS CHART.JS COM FIX Y-AXIS & ONCLICK (DRILLDOWN)
        // ==========================================
        function drawChartsAll(id, d, lblRes) {
            Chart.defaults.global.defaultFontFamily = "'Inter', 'Calibri', sans-serif";
            Chart.defaults.global.defaultFontColor = "#475569";
            
            const drawTrend = (canvas, tData, isD) => {
                let keys = Object.keys(tData).sort();
                let labels = keys.map(k => isD ? `${k.split('-')[2]}/${k.split('-')[1]}` : new Date(k.split('-')[0], k.split('-')[1] - 1, 1).toLocaleString('pt-BR', { month: 'short', year: 'numeric' }).toUpperCase().replace('.', ''));
                
                let instance = new Chart(document.getElementById(canvas), {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            { type: 'line', label: 'Backlog Acumulado', data: keys.map(k => tData[k].b), borderColor: C.INFO, fill: false, borderWidth: 3, yAxisID: 'y1', datalabels: { align: 'top', color: '#1e293b', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                            { type: 'bar', label: 'Abertos', data: keys.map(k => tData[k].a), backgroundColor: C.PRI_D, yAxisID: 'y1', datalabels: { color: '#fff', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                            { type: 'bar', label: lblRes, data: keys.map(k => tData[k].r), backgroundColor: C.SUC, yAxisID: 'y1', stack: 'st', datalabels: { color: '#fff', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                            { type: 'bar', label: 'Cancelados', data: keys.map(k => tData[k].c), backgroundColor: C.DAN, yAxisID: 'y1', stack: 'st', datalabels: { display: false } }
                        ]
                    },
                    options: { 
                         maintainAspectRatio: false, 
                         legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } }, 
                         scales: { 
                             xAxes: [{ stacked: true, gridLines: { display: false } }], 
                             yAxes: [{ id: 'y1', stacked: true, position: 'left', gridLines: { color: '#f1f5f9', drawBorder: false }, ticks: { beginAtZero: true } }] 
                         },
                         onClick: function(evt, activeElements) {
                             if(activeElements.length > 0) {
                                 let idx = activeElements[0]._index;
                                 let datasetIdx = activeElements[0]._datasetIndex;
                                 let dKey = keys[idx];
                                 let lblDate = labels[idx];
                                 
                                 let tksToDisplay = [];
                                 let dTitle = "";
                                 
                                 if(datasetIdx === 1) { tksToDisplay = tData[dKey].tks_a; dTitle = `Abertos em ${lblDate}`; }
                                 else if(datasetIdx === 2) { tksToDisplay = tData[dKey].tks_r; dTitle = `Resolvidos em ${lblDate}`; }
                                 else if(datasetIdx === 3) { tksToDisplay = tData[dKey].tks_c; dTitle = `Cancelados em ${lblDate}`; }
                                 else return; 
                                 
                                 window.DrilldownVault[id]['temp'] = tksToDisplay;
                                 openDrilldown(dTitle, 'temp', id);
                             }
                         }
                     }
                });
                window.chartInstances.push(instance);
            };
            drawTrend(`c-d-${id}`, d.trendD, true); 
            drawTrend(`c-m-${id}`, d.trendM, false);
            
            let instA = new Chart(document.getElementById(`c-a-${id}`), {
                type: 'horizontalBar',
                data: { labels: d.topAnalistas.map(a => a.nome), datasets: [{ label: 'Abertos', data: d.topAnalistas.map(a => a.ab), backgroundColor: C.PRI_D }, { label: lblRes, data: d.topAnalistas.map(a => a.res), backgroundColor: C.SUC }] },
                options: { 
                    maintainAspectRatio: false, legend: { position: 'bottom', labels: { usePointStyle: true } }, 
                    scales: { xAxes: [{ stacked: true, gridLines: { color: '#f1f5f9' }, ticks: { beginAtZero: true } }], yAxes: [{ stacked: true, gridLines: { display: false } }] }, 
                    plugins: { datalabels: { color: '#fff', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                    onClick: function(evt, activeElements) {
                        if(activeElements.length > 0) {
                            let idx = activeElements[0]._index;
                            let datasetIdx = activeElements[0]._datasetIndex;
                            let analystName = d.topAnalistas[idx].nome;
                            
                            let tks = datasetIdx === 0 ? d.topAnalistas[idx].tks_ab : d.topAnalistas[idx].tks_res;
                            let dTitle = datasetIdx === 0 ? `Tickets em Backlog de ${analystName}` : `Tickets Resolvidos por ${analystName}`;
                            
                            window.DrilldownVault[id]['temp'] = tks;
                            openDrilldown(dTitle, 'temp', id);
                        }
                    }
                }
            });
            window.chartInstances.push(instA);
            
            let agKeys = Object.keys(d.agingBuckets);
            let instAg = new Chart(document.getElementById(`c-ag-${id}`), {
                type: 'horizontalBar',
                data: { labels: agKeys, datasets: [{ data: agKeys.map(k => d.agingBuckets[k].count), backgroundColor: agKeys.map(k => d.agingBuckets[k].color), barPercentage: 0.7, categoryPercentage: 0.8 }] },
                options: { 
                    maintainAspectRatio: false, legend: { display: false }, 
                    scales: { xAxes: [{ gridLines: { color: '#f1f5f9' }, ticks: { beginAtZero: true } }], yAxes: [{ gridLines: { display: false } }] }, 
                    plugins: { datalabels: { anchor: 'end', align: 'right', color: '#334155', font: { weight: 'bold' }, formatter: v => v > 0 ? v : "" } },
                    onClick: function(evt, activeElements) {
                        if(activeElements.length > 0) {
                            let idx = activeElements[0]._index;
                            let bName = agKeys[idx];
                            window.DrilldownVault[id]['temp'] = d.agingBuckets[bName].tks;
                            openDrilldown(`Tickets no Range: ${bName}`, 'temp', id);
                        }
                    }
                }
            });
            window.chartInstances.push(instAg);
            
            let instP = new Chart(document.getElementById(`c-p-${id}`), {
                type: 'doughnut',
                data: { labels: ['SLA Cumprido (No Prazo)', 'SLA Estourado (Fora)'], datasets: [{ data: [d.inSlaTot, d.outSlaTot], backgroundColor: [C.SUC, C.DAN], borderWidth: 2, borderColor: '#fff' }] },
                options: { 
                    cutoutPercentage: 65, maintainAspectRatio: false, legend: { position: 'right', labels: { usePointStyle: true, padding: 20 } }, 
                    plugins: { datalabels: { color: '#fff', font: { weight: 'bold', size: 14 }, formatter: (val, ctx) => { let sum = 0; ctx.chart.data.datasets[0].data.forEach(x => sum += x); return sum && val > 0 ? Math.round((val / sum) * 100) + '%' : ""; } } },
                    onClick: function(evt, activeElements) {
                        if(activeElements.length > 0) {
                            let idx = activeElements[0]._index;
                            let tks = idx === 0 ? d.tksInSlaTot : d.tksOutSlaTot;
                            let dTitle = idx === 0 ? `Tickets No Prazo SLA` : `Tickets Com SLA Estourado`;
                            window.DrilldownVault[id]['temp'] = tks;
                            openDrilldown(dTitle, 'temp', id);
                        }
                    }
                }
            });
            window.chartInstances.push(instP);
        }

        function drawConsolidadoCharts(i, r, u) {
            let cTrendD = {}; let dKeys = new Set([...Object.keys(i.trendD), ...Object.keys(r.trendD), ...Object.keys(u.trendD)]);
            dKeys.forEach(k => { 
                cTrendD[k] = { 
                    a: (i.trendD[k]?.a || 0) + (r.trendD[k]?.a || 0) + (u.trendD[k]?.a || 0), 
                    r: (i.trendD[k]?.r || 0) + (r.trendD[k]?.r || 0) + (u.trendD[k]?.r || 0), 
                    c: (i.trendD[k]?.c || 0) + (r.trendD[k]?.c || 0) + (u.trendD[k]?.c || 0), 
                    b: (i.trendD[k]?.b || 0) + (r.trendD[k]?.b || 0) + (u.trendD[k]?.b || 0),
                    tks_a: [...(i.trendD[k]?.tks_a||[]), ...(r.trendD[k]?.tks_a||[]), ...(u.trendD[k]?.tks_a||[])],
                    tks_r: [...(i.trendD[k]?.tks_r||[]), ...(r.trendD[k]?.tks_r||[]), ...(u.trendD[k]?.tks_r||[])],
                    tks_c: [...(i.trendD[k]?.tks_c||[]), ...(r.trendD[k]?.tks_c||[]), ...(u.trendD[k]?.tks_c||[])]
                }; 
            });
            
            let cTrendM = {}; let mKeys = new Set([...Object.keys(i.trendM), ...Object.keys(r.trendM), ...Object.keys(u.trendM)]);
            mKeys.forEach(k => { 
                cTrendM[k] = { 
                    a: (i.trendM[k]?.a || 0) + (r.trendM[k]?.a || 0) + (u.trendM[k]?.a || 0), 
                    r: (i.trendM[k]?.r || 0) + (r.trendM[k]?.r || 0) + (u.trendM[k]?.r || 0), 
                    c: (i.trendM[k]?.c || 0) + (r.trendM[k]?.c || 0) + (u.trendM[k]?.c || 0), 
                    b: (i.trendM[k]?.b || 0) + (r.trendM[k]?.b || 0) + (u.trendM[k]?.b || 0),
                    tks_a: [...(i.trendM[k]?.tks_a||[]), ...(r.trendM[k]?.tks_a||[]), ...(u.trendM[k]?.tks_a||[])],
                    tks_r: [...(i.trendM[k]?.tks_r||[]), ...(r.trendM[k]?.tks_r||[]), ...(u.trendM[k]?.tks_r||[])],
                    tks_c: [...(i.trendM[k]?.tks_c||[]), ...(r.trendM[k]?.tks_c||[]), ...(u.trendM[k]?.tks_c||[])]
                }; 
            });
            
            const drawC = (canvas, tData, isD) => {
                let keys = Object.keys(tData).sort();
                let labels = keys.map(k => isD ? `${k.split('-')[2]}/${k.split('-')[1]}` : new Date(k.split('-')[0], k.split('-')[1] - 1, 1).toLocaleString('pt-BR', { month: 'short', year: 'numeric' }).toUpperCase().replace('.', ''));
                
                let instance = new Chart(document.getElementById(canvas), {
                    type: 'bar',
                    data: { labels: labels, datasets: [
                        { type: 'line', label: 'Backlog Global', data: keys.map(k => tData[k].b), borderColor: C.INFO, fill: false, borderWidth: 3, yAxisID: 'y1', datalabels: { align: 'top', color: '#1e293b', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                        { type: 'bar', label: 'Abertos', data: keys.map(k => tData[k].a), backgroundColor: C.PRI_D, yAxisID: 'y1', datalabels: { color: '#fff', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                        { type: 'bar', label: 'Resolvidos/Encerrados', data: keys.map(k => tData[k].r), backgroundColor: C.SUC, yAxisID: 'y1', stack: 'st', datalabels: { color: '#fff', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                        { type: 'bar', label: 'Cancelados', data: keys.map(k => tData[k].c), backgroundColor: C.DAN, yAxisID: 'y1', stack: 'st', datalabels: { display: false } }
                    ]},
                    options: { 
                         maintainAspectRatio: false, 
                         legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } }, 
                         scales: { 
                             xAxes: [{ stacked: true, gridLines: { display: false } }], 
                             yAxes: [{ id: 'y1', stacked: true, position: 'left', gridLines: { color: '#f1f5f9' }, ticks: { beginAtZero: true } }] 
                         },
                         onClick: function(evt, activeElements) {
                             if(activeElements.length > 0) {
                                 let idx = activeElements[0]._index;
                                 let datasetIdx = activeElements[0]._datasetIndex;
                                 let dKey = keys[idx];
                                 let lblDate = labels[idx];
                                 
                                 let tksToDisplay = [];
                                 let dTitle = "";
                                 
                                 if(datasetIdx === 1) { tksToDisplay = tData[dKey].tks_a; dTitle = `Globais Abertos em ${lblDate}`; }
                                 else if(datasetIdx === 2) { tksToDisplay = tData[dKey].tks_r; dTitle = `Globais Resolvidos em ${lblDate}`; }
                                 else if(datasetIdx === 3) { tksToDisplay = tData[dKey].tks_c; dTitle = `Globais Cancelados em ${lblDate}`; }
                                 else return; 
                                 
                                 window.DrilldownVault['cons']['temp'] = tksToDisplay;
                                 openDrilldown(dTitle, 'temp', 'cons');
                             }
                         }
                     }
                });
                window.chartInstances.push(instance);
            };
            drawC('c-d-cons', cTrendD, true); drawC('c-m-cons', cTrendM, false);
        }

        // ==========================================
        // 8. ORQUESTRADOR PRINCIPAL
        // ==========================================
        function processDashboard() {
            if (!RawData.incs.length && !RawData.reqs.length) return alert("Erro: Carregue as planilhas do ServiceNow na aba lateral primeiro.");
            
            let now = new Date(); 
            document.getElementById('extraction-time').innerHTML = `<i class="fas fa-clock mr-1"></i> Extração: ${now.toLocaleDateString('pt-BR')} ${now.toLocaleTimeString('pt-BR')}`;
            document.getElementById('init-alert').classList.add('hidden-st');
            document.getElementById('loader').classList.remove('hidden-st');
            document.getElementById('report-content').classList.add('hidden-st');
            document.getElementById('tabs-container').classList.remove('hidden-st');
            if (window.innerWidth < 1024) toggleSidebar();
            
            // Agora window.chartInstances está garantido que é um Array
            if (window.chartInstances.length > 0) { 
                window.chartInstances.forEach(c => c.destroy()); 
                window.chartInstances = []; 
            }
            
            GlobalOpenTickets = [];
            activeTableFilters = {}; 
            
            setTimeout(() => {
                const slaI = parseInt(document.getElementById('sla-incs').value) || 7;
                const slaR = parseInt(document.getElementById('sla-reqs').value) || 10;
                const slaP = parseInt(document.getElementById('sla-ptask').value) || 10;
                const refDateInput = document.getElementById('ref-date').value;
                const dateMachine = refDateInput ? new Date(refDateInput + 'T12:00:00') : new Date();
                
                ['tab-inc', 'tab-req', 'tab-uam', 'tab-cons', 'tab-prb', 'tab-class', 'tab-search', 'tab-open'].forEach(id => {
                    let el = document.getElementById(id);
                    if (el) el.innerHTML = "";
                });
                
                let dI = null, dRS = null, dRU = null;
                if (RawData.incs.length) {
                    dI = calculateSection(RawData.incs, slaI, "INC", dateMachine);
                    document.getElementById('tab-inc').innerHTML = generateSectionHTML('inc', "SESSÃO INCs (INCIDENTES GERAIS)", C.PRI_D, dI, "INC");
                }
                
                let rS = [], rU = [];
                if (RawData.reqs.length) {
                    const isUam = r => String(r['Assignment group'] || r['Grupo'] || '').toLowerCase().includes('access');
                    rS = RawData.reqs.filter(r => !isUam(r)); 
                    rU = RawData.reqs.filter(r => isUam(r));
                    
                    if (rS.length) { dRS = calculateSection(rS, slaR, "REQ", dateMachine); document.getElementById('tab-req').innerHTML = generateSectionHTML('req', "SESSÃO REQs (SUPORTE GERAL)", C.PRI_D, dRS, "REQ"); }
                    if (rU.length) { dRU = calculateSection(rU, slaR, "REQ", dateMachine); document.getElementById('tab-uam').innerHTML = generateSectionHTML('uam', "SESSÃO UAMs (ACESSOS)", C.PRI_D, dRU, "REQ"); }
                }
                
                document.getElementById('tab-open').innerHTML = generateOpenTicketsHTML(RawData.incs, rS, rU, slaI, slaR, dateMachine);
                
                if (dI && dRS && dRU) document.getElementById('tab-cons').innerHTML = generateConsolidadoHTML(dI, dRS, dRU);
                
                if (RawData.rca.length || RawData.ptask.length) {
                    document.getElementById('tab-prb').innerHTML = generatePRBTab(RawData.rca, RawData.ptask, slaP, dateMachine);
                } else {
                    document.getElementById('tab-prb').innerHTML = `<div class="report-card text-center py-10"><h3 class="text-slate-600 font-bold">Nenhum dado de Causa Raiz/PTASK importado.</h3></div>`;
                }
                
                let allCombinedData = [...RawData.incs, ...RawData.reqs];
                if (allCombinedData.length > 0) {
                    let dClass = calculateClassifications(allCombinedData, dateMachine);
                    document.getElementById('tab-class').innerHTML = generateClassificationsHTML(dClass);
                    
                    requestAnimationFrame(() => {
                        let cnv = document.getElementById('chart-class-trend');
                        if (cnv) {
                            let keysM = Object.keys(dClass.m).sort();
                            window.chartInstances.push(new Chart(cnv, {
                                 type: 'line',
                                 data: {
                                     labels: keysM,
                                     datasets: [{
                                         label: 'Erros de Classificação',
                                         data: keysM.map(k => dClass.m[k].count),
                                         borderColor: C.DAN,
                                         fill: false,
                                         borderWidth: 3,
                                         datalabels: { align: 'top', font: {weight:'bold'}, formatter: v => v > 0 ? v : "" }
                                     }]
                                 },
                                 options: {
                                     maintainAspectRatio: false,
                                     legend: {display:false},
                                     scales: { yAxes: [{ ticks: {beginAtZero:true} }] },
                                     onClick: function(evt, activeElements) {
                                         if(activeElements.length > 0) {
                                             let idx = activeElements[0]._index;
                                             let mKey = keysM[idx];
                                             window.DrilldownVault['class']['temp'] = dClass.m[mKey].tks;
                                             openDrilldown(`Erros em ${mKey}`, 'temp', 'class');
                                         }
                                     }
                                 }
                             }));
                        }
                    });
                }
                
                document.getElementById('loader').classList.add('hidden-st');
                document.getElementById('report-content').classList.remove('hidden-st');
                document.getElementById('search-container').classList.add('visible');
                
                // SOLUÇÃO PARA O CHART.JS EM ABAS OCULTAS
                let tabs = document.querySelectorAll('.tab-pane');
                tabs.forEach(c => {
                    c.style.display = 'block';
                    c.style.visibility = 'hidden';
                    c.style.position = 'absolute';
                    c.classList.remove('hidden-st');
                });
                
                requestAnimationFrame(() => {
                    if (dI) drawChartsAll('inc', dI, 'Resolvidos');
                    if (dRS) drawChartsAll('req', dRS, 'Encerrados');
                    if (dRU) drawChartsAll('uam', dRU, 'Encerrados');
                    if (dI && dRS && dRU) drawConsolidadoCharts(dI, dRS, dRU);
                    
                    // Restaura visibilidade normal das abas
                    tabs.forEach(c => {
                        c.style.display = '';
                        c.style.visibility = '';
                        c.style.position = '';
                        c.classList.add('hidden-st');
                    });
                    
                    populateTodoAnalystDropdown();
                    renderTodos();
                    
                    switchTab('tab-open', document.querySelector('.tab-btn[onclick*="tab-open"]'));
                    if (document.getElementById("globalSearch").value.trim() !== "") {
                        performGlobalSearch();
                    } else {
                        filterTables();
                    }
                });
            }, 600);
        }
    </script>
</body>
</html>
