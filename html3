        let currentModalTk = null;
        function openTicketDetails(tkNumber) {
            currentModalTk = tkNumber; 
            let ticketData = null; 
            let tType = '';
            
            // CORREÇÃO DEFINITIVA MÁXIMA: Busca iterando por TODAS as células da linha (imune a nomes de colunas ou case sensitivity do Excel)
            let cleanTk = String(tkNumber).normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, '').toUpperCase();
            
            [RawData.incs, RawData.reqs, RawData.rca, RawData.ptask].forEach((src, i) => { 
                 if (ticketData) return;
                 let f = src.find(r => {
                     return Object.values(r).some(val => {
                         if (val == null) return false;
                         let cleanVal = String(val).normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, '').toUpperCase();
                         return cleanVal === cleanTk;
                     });
                 }); 
                 if(f) { 
                     ticketData = f; 
                     tType = i===0?'INC':i===1?'REQ':i===2?'RCA':'PTASK'; 
                 } 
             });
             
            if (!ticketData) {
                return alert("Detalhes do ticket não encontrados na base importada. \nTicket: " + tkNumber);
            }
            
            document.getElementById('modal-tk').innerText = tkNumber;
            document.getElementById('modal-title').innerText = getCol(ticketData, ['Short description','Descrição Curta','Descrição', 'Item']) || 'Sem assunto definido.';
            document.getElementById('modal-desc').innerText = getCol(ticketData, ['Description','Descrição Completa']) || 'Sem descrição detalhada fornecida na abertura.';
            
            let req = getCol(ticketData, ['Requester','Caller','Solicitante']) || 'N/A';
            let asg = getCol(ticketData, ['Assigned to','Analista']) || 'Não Atribuído';
            document.getElementById('modal-req').innerText = req;
            document.getElementById('modal-asg').innerText = asg;
            document.getElementById('modal-gp').innerText = getCol(ticketData, ['Assignment group','Grupo']) || 'N/A';
            
            let opD = safeDate(getCol(ticketData, ['Opened','opened_at', 'Data Abertura', 'Created']));
            let clD = safeDate(getCol(ticketData, ['Resolved','Closed', 'Resolved at', 'Data Fechamento']));
            document.getElementById('modal-op').innerText = opD ? opD.toLocaleString('pt-BR') : '-';
            document.getElementById('modal-cl').innerText = clD ? clD.toLocaleString('pt-BR') : 'Aberto';
            
            let st = String(getCol(ticketData, ['State','Status','RCA Status', 'Estado']) || '');
            let stL = st.toLowerCase(), bC = 'bg-blue-500';
            if(stL.includes('resolv') || stL.includes('complet')) bC = 'bg-emerald-500'; 
            else if(stL.includes('cancel') || stL.includes('incomplet')) bC = 'bg-red-500'; 
            else if(stL.includes('pend') || stL.includes('hold')) bC = 'bg-amber-500';
            
            document.getElementById('modal-state').className = `text-[10px] uppercase font-bold text-white px-2 py-0.5 rounded mt-1 inline-block shadow-sm ${bC}`;
            document.getElementById('modal-state').innerText = st;
            
            let refDate = new Date(document.getElementById('ref-date').value + 'T12:00:00');
            let age = Math.floor(((clD ? clD : refDate) - opD) / 86400000);
            if (age < 0) age = 0;
            
            let idle = (!clD || clD > refDate) ? getDaysSilent(ticketData, refDate, asg, opD) : '-';
            document.getElementById('modal-age').innerText = age + ' dias';
            document.getElementById('modal-age').style.color = age > 10 ? '#ef4444' : '#334155';
            
            let idleEl = document.getElementById('modal-idle');
            if (idle !== '-') {
                idleEl.innerHTML = `${idle} dias <i class="fas fa-user-clock text-sm ml-1"></i>`;
                idleEl.style.color = idle > 3 ? '#ef4444' : '#10b981';
            } else {
                idleEl.innerText = 'N/A';
                idleEl.style.color = '#94a3b8';
            }
            
            let slaConfig = tType === 'INC' ? (parseInt(document.getElementById('sla-incs').value) || 7) : (parseInt(document.getElementById('sla-reqs').value) || 10);
            let pctSla = Math.round((age / slaConfig) * 100);
            let slaBar = document.getElementById('modal-sla-bar');
            let slaColor = pctSla > 100 ? '#ef4444' : (pctSla > 75 ? '#f59e0b' : '#10b981');
            slaBar.style.width = Math.min(pctSla, 100) + '%';
            slaBar.style.backgroundColor = slaColor;
            slaBar.innerText = pctSla + '%';
            
            let regex = /^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?:\s+-\s+|\s+)([^\(]+)\s+\(([^)]+)\)/gm;
            let rawC = ""; 
            let cols = new Set();
            
            ['Work notes', 'Work Notes', 'Work notes list', 'Work notes list(s)', 'Additional comments', 'Close notes', 'Closing notes'].forEach(c => { 
                 if (ticketData[c] && !cols.has(c)) { 
                     rawC += ticketData[c] + "\n\n"; 
                     cols.add(c); 
                 } 
             });
             
            let entries = [];
            if(rawC.trim() !== "") {
                let m = [...rawC.matchAll(regex)];
                if(m.length > 0) {
                    for(let i=0; i<m.length; i++) { 
                         let nxtIdx = (i+1 < m.length) ? m[i+1].index : rawC.length;
                        entries.push({ 
                             date: new Date(m[i][1].replace(/-/g,'/')), 
                             dS: m[i][1], 
                             a: m[i][2].trim(), 
                             t: m[i][3].trim(), 
                             txt: rawC.substring(m[i].index + m[i][0].length, nxtIdx).trim() 
                         }); 
                     }
                } else { 
                     entries.push({ date: new Date(0), dS: '-', a: 'Sistema', t: 'Notas Brutas (Log)', txt: rawC.trim() }); 
                 }
            }
            entries.sort((a,b) => b.date - a.date);
            
            document.getElementById('modal-timeline').innerHTML = entries.length ? entries.map(e => {
