        window.filterOpenTickets = function(term) {
            const cleanTerm = term.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
            document.querySelectorAll('#tab-open details.saas-accordion').forEach(acc => {
                let hasVisibleRow = false;
                const rows = acc.querySelectorAll('tbody tr');
                
                rows.forEach(tr => {
                    const text = tr.innerText.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                    if (text.includes(cleanTerm)) {
                        tr.style.display = '';
                        hasVisibleRow = true;
                    } else {
                        tr.style.display = 'none';
                    }
                });
                
                if (hasVisibleRow) {
                    acc.style.display = '';
                    if (cleanTerm.length > 0) acc.setAttribute('open', '');
                } else {
                    acc.style.display = 'none';
                }
            });
        };

