            let html = `<div class="report-section-title" style="background-color: ${C.PRI_D};"><i class="fas fa-bullseye mr-2"></i> SESSÃO PRB TASKs (TODAS AS ABERTAS NO SISTEMA)</div>`;
            
            let rcaRows = "";
            let ptaskRows = "";
            let allPrbs = [];
            let allPtasks = [];

            rcaData.forEach(r => {
                let op = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                if (!op || op.getTime() > refTime) return;
                let clOrig = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                let st = String(getCol(r, ['State', 'Status', 'RCA Status']) || '').toLowerCase();
                if (clOrig && clOrig.getTime() <= refTime) { if (st.includes('clos') || st.includes('resolv') || st.includes('cancel') || st.includes('fech')) return; }
                let asg = getCol(r, ['Assigned to', 'Analista']) || '-';
                let idle = (!clOrig || clOrig.getTime() > refDateObj.getTime()) ? getDaysSilent(r, refDateObj, asg, op) : '-';
                let tk = getCol(r, ['Problem', 'Problema']) || '-';
                let descClean = String(getCol(r, ['Short description', 'Descrição']) || '-').replace(/"/g, '&quot;');
                let req = getCol(r, ['Requester', 'Caller']) || 'N/A';
                
                let dummyT = { tk: tk, desc: descClean, req: req, as: asg, gp: '-', st: getCol(r, ['RCA Status', 'State', 'Status']) || '-', age: Math.floor((refDate - op) / 86400000), idle: idle, opStr: op.toLocaleDateString('pt-BR'), info: 'RCA pendente.' };
                allPrbs.push(dummyT);
                
                rcaRows += `<tr ${buildRowAttrs(dummyT)}>
