    <script>
        // ==========================================
        // 0. INICIALIZAÇÃO, ORDENAÇÃO E UI
        // ==========================================
        document.getElementById('ref-date').valueAsDate = new Date();

        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('collapsed');
            setTimeout(() => window.dispatchEvent(new Event('resize')), 350);
        }

        function toggleText(btn) {
            const textDiv = btn.previousElementSibling;
            if (textDiv.classList.contains('expanded')) {
                textDiv.classList.remove('expanded');
                btn.innerHTML = 'Expandir';
            } else {
                textDiv.classList.add('expanded');
                btn.innerHTML = 'Recolher';
            }
        }

        function removeAccents(str) { return str.normalize("NFD").replace(/[\u0300-\u036f]/g, ""); }

        function filterTables() {
            const input = removeAccents(document.getElementById("globalSearch").value.toUpperCase());
            const activeTables = document.querySelectorAll('.tab-pane:not(.hidden-st) table tbody');
            activeTables.forEach(tbody => {
                const rows = tbody.getElementsByTagName("tr");
                for (let i = 0; i < rows.length; i++) {
                    const rowText = removeAccents((rows[i].innerText || rows[i].textContent).toUpperCase());
                    if (rowText.includes("NENHUM") || rowText.includes("TOTAL")) continue;
                    rows[i].style.display = rowText.indexOf(input) > -1 ? "" : "none";
                }
            });
        }

        function switchTab(tabId, el) {
            document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-pane').forEach(c => { c.classList.add('hidden-st'); c.classList.remove('animate-fade'); });

            el.classList.add('active');

            const searchInput = document.getElementById("globalSearch");
            if (searchInput && searchInput.value.trim() !== "") {
                searchInput.value = "";
            }

            const targetTab = document.getElementById(tabId);
            targetTab.classList.remove('hidden-st');
            void targetTab.offsetWidth;
            targetTab.classList.add('animate-fade');
            window.dispatchEvent(new Event('resize'));
            filterTables();
        }

        // ==========================================
        // FUNÇÃO DE ORDENAÇÃO (SORT TABLE)
        // ==========================================
        function sortTable(th) {
            const table = th.closest('table');
            const tbody = table.querySelector('tbody');
            if (!tbody) return;
            const rows = Array.from(tbody.querySelectorAll('tr'));

            if (rows.length === 1 && rows[0].children[0].colSpan > 1) return;

            let tr = th.closest('tr');
            let colIndex = Array.from(tr.children).indexOf(th);
            let isAsc = th.dataset.dir !== 'asc';
            let dirMultiplier = isAsc ? 1 : -1;

            table.querySelectorAll('th i.fa-sort, th i.fa-sort-up, th i.fa-sort-down').forEach(i => {
                i.className = 'fas fa-sort ml-1 opacity-50';
            });
            th.dataset.dir = isAsc ? 'asc' : 'desc';
            const icon = th.querySelector('i');
            if (icon) icon.className = isAsc ? 'fas fa-sort-up ml-1' : 'fas fa-sort-down ml-1';

            rows.sort((a, b) => {
                let cellA = a.children[colIndex].innerText.trim();
                let cellB = b.children[colIndex].innerText.trim();

                let dateMatchA = cellA.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                let dateMatchB = cellB.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                if (dateMatchA && dateMatchB) {
                    let dA = new Date(dateMatchA[3], dateMatchA[2] - 1, dateMatchA[1]).getTime();
                    let dB = new Date(dateMatchB[3], dateMatchB[2] - 1, dateMatchB[1]).getTime();
                    return (dA - dB) * dirMultiplier;
                }

                let numA = parseFloat(cellA.replace(/[^\d.-]/g, ''));
                let numB = parseFloat(cellB.replace(/[^\d.-]/g, ''));

                let isNumA = cellA.match(/^[\d.,R$+\-%\s]+(d totais|d ocioso|d)?$/i);
                let isNumB = cellB.match(/^[\d.,R$+\-%\s]+(d totais|d ocioso|d)?$/i);

                if (isNumA && isNumB && !isNaN(numA) && !isNaN(numB)) {
                    return (numA - numB) * dirMultiplier;
                }

                return cellA.localeCompare(cellB, undefined, { numeric: true, sensitivity: 'base' }) * dirMultiplier;
            });

            rows.forEach(row => tbody.appendChild(row));
        }

        // ==========================================
        // CONTROLADOR DO MODAL DE THREAD (HISTÓRICO)
        // ==========================================
        function openTicketDetails(tkNumber) {
            let ticketData = null;
            let tType = '';
            const allSources = [
                { name: 'INC', data: RawData.incs },
                { name: 'REQ', data: RawData.reqs },
                { name: 'RCA', data: RawData.rca },
                { name: 'PTASK', data: RawData.ptask }
            ];

            for (let source of allSources) {
                let found = source.data.find(r => {
                    let num = getCol(r, ['Number', 'number', 'Ticket', 'RITM', 'Problem', 'Problema', 'Task']);
                    return num === tkNumber;
                });
                if (found) {
                    ticketData = found;
                    tType = source.name;
                    break;
                }
            }

            if (!ticketData) {
                alert("Detalhes do ticket não encontrados na base importada.");
                return;
            }

            let title = String(getCol(ticketData, ['Short description', 'Descrição Curta', 'Item', 'Descrição']) || 'Sem assunto');
            let desc = String(getCol(ticketData, ['Description', 'Descrição Completa', 'description']) || '');
            let state = String(getCol(ticketData, ['State', 'Status', 'Estado', 'RCA Status']) || '');
            let asg = getCol(ticketData, ['Assigned to', 'Analista', 'Assignee']) || 'Não Atribuído';
            let gp = getCol(ticketData, ['Assignment group', 'Grupo']) || 'N/A';
            let req = getCol(ticketData, ['Requester', 'Caller', 'Solicitante']) || 'N/A';
            let opDate = safeDate(getCol(ticketData, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
            let clDate = safeDate(getCol(ticketData, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));

            let opStr = opDate ? opDate.toLocaleString('pt-BR') : '-';
            let clStr = clDate ? clDate.toLocaleString('pt-BR') : 'Aberto';

            let stLower = state.toLowerCase();
            let badgeColor = 'bg-blue-500';
            if (stLower.includes('resolv') || stLower.includes('complet')) { badgeColor = 'bg-emerald-500'; }
            else if (stLower.includes('cancel') || stLower.includes('incomplet')) { badgeColor = 'bg-red-500'; }
            else if (stLower.includes('pend') || stLower.includes('hold')) { badgeColor = 'bg-amber-500'; }

            let interactionCols = ['Work notes', 'Work Notes', 'Work notes list', 'Work notes lists', 'Work notes list(s)', 'Additional comments', 'Close notes', 'Closing notes'];
            let allEntries = [];
            let regex = /^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?:\s+-\s+|\s+)([^\(]+)\s+\(([^)]+)\)/gm;

            let rawCombined = "";
            let processedCols = new Set();
            interactionCols.forEach(col => {
                if (ticketData[col] && typeof ticketData[col] === 'string' && !processedCols.has(col)) {
                    rawCombined += ticketData[col] + "\n\n";
                    processedCols.add(col);
                }
            });

            if (rawCombined.trim() !== "") {
                let matches = [...rawCombined.matchAll(regex)];
                if (matches.length > 0) {
                    for (let i = 0; i < matches.length; i++) {
                        let match = matches[i];
                        let dateStr = match[1];
                        let author = match[2].trim();
                        let type = match[3].trim();

                        let startIndex = match.index + match[0].length;
                        let endIndex = (i + 1 < matches.length) ? matches[i + 1].index : rawCombined.length;
                        let text = rawCombined.substring(startIndex, endIndex).trim();

                        let d = new Date(dateStr.replace(/-/g, '/'));
                        allEntries.push({ dateObj: d, dateStr, author, type, text });
                    }
                } else {
                    allEntries.push({ dateObj: new Date(0), dateStr: 'Histórico Bruto', author: 'Sistema', type: 'Nota do Sistema', text: rawCombined.trim() });
                }
            }

            allEntries.sort((a, b) => b.dateObj - a.dateObj);

            document.getElementById('modal-tk').innerText = tkNumber + ' (' + tType + ')';
