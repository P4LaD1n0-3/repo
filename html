                            ${t.info.length > 80 ? `<button onclick="toggleText(this)" class="btn-expand">Expandir</button>` : ''}
                        </td>
                        <td data-label="Aging / Ocioso" style="text-align: right;">
                            <div style="color:${C.DAN}; font-weight:bold; font-size:13px;">${t.age}d totais</div>
                            ${t.idle !== '-' ? `<div style="font-size:10px; font-weight:bold; margin-top:2px; color:${t.idle > 3 ? '#ef4444' : '#10b981'};"><i class="fas fa-user-clock"></i> ${t.idle}d ocioso</div>` : `<div style="font-size:10px; color:#94a3b8; margin-top:2px;"><i class="fas fa-user-clock"></i> N/A</div>`}
                        </td>
                    </tr>`).join('')}
                </tbody></table></div>
            </div>` : "";

            return `
            <div class="report-section-title" style="background-color: ${color};"><i class="fas fa-chart-line mr-2"></i> ${title}</div>
            
            <div class="grid-2">
                <div class="report-card" style="text-align:center;">
