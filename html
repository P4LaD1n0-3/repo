            `).join('');

            return `
            <div class="report-section-title" style="background-color: var(--danger);"><i class="fas fa-exchange-alt mr-2"></i> CLASSIFICAÇÕES INCORRETAS (REQ ⇄ INC)</div>
            
            <div class="grid-2" style="grid-template-columns: 1fr 2.5fr;">
                <div class="report-card" style="text-align:center; border-left: 4px solid var(--danger); display:flex; flex-direction:column; justify-content:center;">
                    <div class="report-card-title text-red-700">⛔ TOTAL INCORRETOS</div>
                    <div style="font-size:54px; font-weight:900; color:var(--danger); line-height:1; margin: 10px 0;">${d.total}</div>
                    <div class="text-xs text-slate-500 font-bold uppercase">Registros no Período</div>
                </div>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                    <div class="report-card" style="text-align:center; padding: 15px; border-left: 4px solid var(--success); margin-bottom:0;">
                        <div class="report-card-title text-green-700" style="margin-bottom: 10px; font-size: 11px;">🔗 COM TICKET VINCULADO</div>
                        <div style="font-size:32px; font-weight:900; color:var(--success);">${d.withLink}</div>
                    </div>
                    <div class="report-card" style="text-align:center; padding: 15px; border-left: 4px solid var(--orange); margin-bottom:0;">
                        <div class="report-card-title text-orange-600" style="margin-bottom: 10px; font-size: 11px;">🚫 SEM VÍNCULO (ERRO)</div>
                        <div style="font-size:32px; font-weight:900; color:var(--orange);">${d.withoutLink}</div>
                    </div>
                    <div class="report-card" style="text-align:center; padding: 15px; border-left: 4px solid var(--info); margin-bottom:0;">
                        <div class="report-card-title text-blue-600" style="margin-bottom: 10px; font-size: 11px;">⏱️ DETECÇÃO MÉDIA</div>
                        <div style="font-size:32px; font-weight:900; color:var(--info);">${d.avgDays}d</div>
                    </div>
                    <div class="report-card" style="text-align:center; padding: 15px; border-left: 4px solid var(--gray-dark); margin-bottom:0;">
                        <div class="report-card-title text-slate-600" style="margin-bottom: 10px; font-size: 11px;">⚡ DETECÇÃO MÁXIMA</div>
                        <div style="font-size:32px; font-weight:900; color:var(--gray-dark);">${d.maxDays}d</div>
                    </div>
                </div>
            </div>

            <div class="report-card">
                <div class="report-card-title" style="color:var(--primary-dark)"><i class="fas fa-list mr-2"></i> LISTA DETALHADA DE CLASSIFICAÇÕES INCORRETAS</div>
                <div class="st-dataframe-container">
                    <table class="st-table">
                        <thead><tr>
                            <th style="width:12%;" onclick="sortTable(this)">Ticket Original <i class="fas fa-sort ml-1 opacity-50"></i></th>
                            <th style="width:12%;" onclick="sortTable(this)">Ticket Vinculado <i class="fas fa-sort ml-1 opacity-50"></i></th>
                            <th style="width:25%; text-align:left;" onclick="sortTable(this)">Descrição / Close Notes <i class="fas fa-sort ml-1 opacity-50"></i></th>
                            <th style="width:15%;" onclick="sortTable(this)">Solicitante <i class="fas fa-sort ml-1 opacity-50"></i></th>
                            <th style="width:15%;" onclick="sortTable(this)">Analista / Grupo <i class="fas fa-sort ml-1 opacity-50"></i></th>
                            <th style="width:13%;" onclick="sortTable(this)">Reason / Status <i class="fas fa-sort ml-1 opacity-50"></i></th>
                            <th style="width:8%;" onclick="sortTable(this)">Dias / Ocioso <i class="fas fa-sort ml-1 opacity-50"></i></th>
                        </tr></thead>
                        <tbody>${rows}</tbody>
                    </table>
                </div>
            </div>
            `;
        }

        // ==========================================
        // 3. HTML BUILDERS GERAIS (INCs/REQs)
        // ==========================================
        function buildThroughputTable(d, lblRes) {
            let rows = "", tA = 0, tR = 0, tC = 0, tS = 0, lastB = 0;
            let keys = Object.keys(d.trendM).sort();

            keys.forEach((k) => {
                let m = d.trendM[k];
                let mesStr = new Date(k.split('-')[0], k.split('-')[1] - 1, 1).toLocaleString('pt-BR', { month: 'short', year: 'numeric' }).toUpperCase().replace('.', '');
                let saldo = m.a - (m.r + m.c);
                let pctStr = m.r > 0 ? Math.round((m.inSla / m.r) * 100) : 0;
                let bgPct = pctStr >= 98 ? C.SUC : C.DAN;
                let colorS = saldo > 0 ? C.PRI_D : (saldo < 0 ? C.PRI : C.GRY_D);

                tA += m.a; tR += m.r; tC += m.c; tS += saldo; lastB = m.b;

                rows += `<tr>
                    <td data-label="Mês" style="text-align:center; font-weight:600;">${mesStr}</td>
                    <td data-label="Abertos">${m.a}</td>
                    <td data-label="${lblRes}">${m.r}</td>
                    <td data-label="Cancelados">${m.c}</td>
                    <td data-label="Saldo" style="color:${colorS}; font-weight:bold;">${saldo > 0 ? '+' + saldo : saldo}</td>
                    <td data-label="Backlog" style="font-weight:bold;">${m.b}</td>
                    <td data-label="% no Prazo" style="background-color:${bgPct}; color:#fff; font-weight:bold;">${pctStr}%</td>
                </tr>`;
            });

            return `<div class="st-dataframe-container"><table class="st-table">
                <thead><tr>
                    <th onclick="sortTable(this)">Mês <i class="fas fa-sort ml-1 opacity-50"></i></th>
                    <th onclick="sortTable(this)">Abertos <i class="fas fa-sort ml-1 opacity-50"></i></th>
                    <th onclick="sortTable(this)">${lblRes} <i class="fas fa-sort ml-1 opacity-50"></i></th>
                    <th onclick="sortTable(this)">Cancelados <i class="fas fa-sort ml-1 opacity-50"></i></th>
                    <th onclick="sortTable(this)">Saldo <i class="fas fa-sort ml-1 opacity-50"></i></th>
                    <th onclick="sortTable(this)">Backlog <i class="fas fa-sort ml-1 opacity-50"></i></th>
                    <th onclick="sortTable(this)">% no Prazo <i class="fas fa-sort ml-1 opacity-50"></i></th>
                </tr></thead>
                <tbody>${rows || `<tr><td colspan="7" style="text-align:center;">Sem histórico.</td></tr>`}</tbody>
                <tfoot><tr>
                <th data-label="TOTAIS:" style="text-align:right;">TOTAIS:</th>
                <th data-label="Abertos">${tA}</th>
                <th data-label="${lblRes}">${tR}</th>
                <th data-label="Cancelados">${tC}</th>
                <th data-label="Saldo" style="color:${tS > 0 ? C.PRI_D : C.PRI}; font-weight:bold;">${tS > 0 ? '+' + tS : tS}</th>
                <th data-label="Backlog">${lastB}</th>
                <th data-label="% no Prazo">-</th></tr></tfoot>
            </table></div>`;
        }

        function buildRowAttrs(t) { return `class="ticket-row" data-tk="${t.tk}" data-desc="${t.desc}" data-as="${t.as}" data-gp="${t.gp}" data-st="${t.st}" data-age="${t.age}" data-op="${t.opStr}" data-info="${t.info}" data-idle="${t.idle !== undefined ? t.idle : '-'}"`; }

