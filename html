            const drawTrend = (canvas, tData, isD) => {
                let keys = Object.keys(tData).sort();
                let labels = keys.map(k => isD ? `${k.split('-')[2]}/${k.split('-')[1]}` : new Date(k.split('-')[0], k.split('-')[1] - 1, 1).toLocaleString('pt-BR', { month: 'short', year: 'numeric' }).toUpperCase().replace('.', ''));
                let instance = new Chart(document.getElementById(canvas), {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            { type: 'line', label: 'Backlog Acumulado', data: keys.map(k => tData[k].b), borderColor: C.ORG, fill: false, borderWidth: 3, yAxisID: 'y2', datalabels: { align: 'top', color: '#1e293b', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                            { type: 'bar', label: 'Abertos', data: keys.map(k => tData[k].a), backgroundColor: C.PRI_D, yAxisID: 'y1', datalabels: { color: '#fff', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                            { type: 'bar', label: lblRes, data: keys.map(k => tData[k].r), backgroundColor: C.SUC, yAxisID: 'y1', stack: 'st', datalabels: { color: '#fff', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } },
                            { type: 'bar', label: 'Cancelados', data: keys.map(k => tData[k].c), backgroundColor: C.DAN, yAxisID: 'y1', stack: 'st', datalabels: { display: false } }
                        ]
                    },
                    options: { maintainAspectRatio: false, legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } }, scales: { xAxes: [{ stacked: true, gridLines: { display: false } }], yAxes: [{ id: 'y1', stacked: true, position: 'left', gridLines: { color: '#f1f5f9', drawBorder: false } }, { id: 'y2', position: 'right', gridLines: { display: false } }] } }
                });
                window.chartInstances.push(instance);
            };
            drawTrend(`c-d-${id}`, d.trendD, true); drawTrend(`c-m-${id}`, d.trendM, false);

            let instA = new Chart(document.getElementById(`c-a-${id}`), {
                type: 'horizontalBar',
                data: { labels: d.topAnalistas.map(a => a.nome), datasets: [{ label: 'Abertos', data: d.topAnalistas.map(a => a.ab), backgroundColor: C.PRI_D }, { label: lblRes, data: d.topAnalistas.map(a => a.res), backgroundColor: C.SUC }] },
                options: { maintainAspectRatio: false, legend: { position: 'bottom', labels: { usePointStyle: true } }, scales: { xAxes: [{ stacked: true, gridLines: { color: '#f1f5f9' } }], yAxes: [{ stacked: true, gridLines: { display: false } }] }, plugins: { datalabels: { color: '#fff', font: { weight: 'bold', size: 10 }, formatter: v => v > 0 ? v : "" } } }
            });
            window.chartInstances.push(instA);

            let agKeys = Object.keys(d.agingBuckets);
            let instAg = new Chart(document.getElementById(`c-ag-${id}`), {
                type: 'horizontalBar',
                data: { labels: agKeys, datasets: [{ data: agKeys.map(k => d.agingBuckets[k].count), backgroundColor: agKeys.map(k => d.agingBuckets[k].color), barPercentage: 0.7, categoryPercentage: 0.8 }] },
                options: { maintainAspectRatio: false, legend: { display: false }, scales: { xAxes: [{ gridLines: { color: '#f1f5f9' } }], yAxes: [{ gridLines: { display: false } }] }, plugins: { datalabels: { anchor: 'end', align: 'right', color: '#334155', font: { weight: 'bold' }, formatter: v => v > 0 ? v : "" } } }
            });
            window.chartInstances.push(instAg);

            let instP = new Chart(document.getElementById(`c-p-${id}`), {
                type: 'doughnut',
                data: { labels: ['SLA Cumprido', 'SLA Estourado'], datasets: [{ data: [d.inSlaTot, d.outSlaTot], backgroundColor: [C.SUC, C.DAN], borderWidth: 2, borderColor: '#fff' }] },
                options: { cutoutPercentage: 65, maintainAspectRatio: false, legend: { position: 'right', labels: { usePointStyle: true, padding: 20 } }, plugins: { datalabels: { color: '#fff', font: { weight: 'bold', size: 14 }, formatter: (val, ctx) => { let sum = 0; ctx.chart.data.datasets[0].data.forEach(x => sum += x); return sum && val > 0 ? Math.round((val / sum) * 100) + '%' : ""; } } } }
            });
            window.chartInstances.push(instP);
        }

