        // ==========================================
        // 1. UPLOAD E LEITURA DE ARQUIVOS
        // ==========================================
        const RawData = { incs: [], reqs: [], rca: [], ptask: [] };

        function handleFiles(files) {
            Array.from(files).forEach(file => {
                const name = file.name.toLowerCase();
                if (name.includes('inc')) readFile(file, 'incs');
                else if (name.includes('sc_task') || name.includes('req')) readFile(file, 'reqs');
                else if (name.includes('rca')) readFile(file, 'rca');
                else if (name.includes('ptask')) readFile(file, 'ptask');
            });
        }

        function readFile(file, type) {
            const reader = new FileReader();
            reader.onload = function (e) {
                const data = new Uint8Array(e.target.result);
                const workbook = XLSX.read(data, { type: 'array', cellDates: true });
                const rawJson = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]], { defval: "" });
                RawData[type] = rawJson.map(row => {
                    let newRow = {};
                    Object.keys(row).forEach(k => newRow[k.replace(/\ufffd/g, "").replace(/\s+/g, " ").trim()] = row[k]);
                    return newRow;
                });
                document.getElementById('file-status').innerHTML += `<div class="file-badge"><span class="truncate"><i class="fas fa-file-excel mr-1"></i> ${file.name}</span><i class="fas fa-check"></i></div>`;
                document.getElementById('btn-clear-files').classList.remove('hidden-st');
            };
            reader.readAsArrayBuffer(file);
        }

        function clearFiles() {
            RawData.incs = []; RawData.reqs = []; RawData.rca = []; RawData.ptask = [];
            document.getElementById('file-status').innerHTML = ''; document.getElementById('file-upload').value = '';
            document.getElementById('btn-clear-files').classList.add('hidden-st');

            document.getElementById('report-content').classList.add('hidden-st');
            document.getElementById('search-container').classList.remove('visible');
            document.getElementById('tabs-container').classList.add('hidden-st');
            document.getElementById('init-alert').classList.remove('hidden-st');
            document.getElementById('globalSearch').value = '';

            if (window.chartInstances) { window.chartInstances.forEach(c => c.destroy()); window.chartInstances = []; }
            GlobalOpenTickets = [];
        }

        function safeDate(val) {
            if (!val) return null;
            if (val instanceof Date) return isNaN(val.getTime()) ? null : val;
            if (typeof val === 'number') return new Date(Math.round((val - 25569) * 86400 * 1000));
            if (typeof val === 'string') {
                let p = val.trim().split(/[\/\s:]/);
                if (p.length >= 3 && p[2].length === 4) { let d = new Date(p[2], p[1] - 1, p[0]); if (!isNaN(d.getTime())) return d; }
                let nD = new Date(val); if (!isNaN(nD.getTime())) return nD;
            }
            return null;
        }

        const getCol = (row, keys) => { for (let k of keys) if (row[k] !== undefined && row[k] !== "") return row[k]; return null; };

        // ==========================================
        // 1.5 MOTOR PYTHON: TEMPO DE OCIOSIDADE (DAYS_SILENT)
        // ==========================================
        function getDaysSilent(r, refDateObj, assignedTo, opDateObj) {
            if (!assignedTo || assignedTo === 'Não Atribuído' || assignedTo === 'N/A' || assignedTo === '-') return '-';

            let interactionCols = ['Work notes', 'Work Notes', 'Work notes list', 'Work notes lists', 'Work notes list(s)', 'Additional comments'];
            let maxDate = opDateObj ? new Date(opDateObj) : new Date(refDateObj);
            let foundInteraction = false;

            let regex = /(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?:\s+-\s+|\s+)([^\(]+)\s+\(/g;

            interactionCols.forEach(col => {
                let text = r[col];
                if (text && typeof text === 'string') {
                    let match;
                    while ((match = regex.exec(text)) !== null) {
                        let dateStr = match[1];
                        let author = match[2].trim();

                        if (author === assignedTo) {
                            let d = new Date(dateStr.replace(/-/g, '/'));
                            if (!isNaN(d) && d.getTime() > maxDate.getTime() && d.getTime() <= refDateObj.getTime()) {
                                maxDate = d;
                                foundInteraction = true;
                            }
                        }
                    }
                }
            });

            if (!opDateObj && !foundInteraction) return '-';

            let diff = Math.floor((refDateObj - maxDate) / 86400000);
            return diff > 0 ? diff : 0;
        }


        // ==========================================
        // 2. MOTOR CORE (MÁQUINA DO TEMPO + REGRAS)
        // ==========================================
        let GlobalOpenTickets = [];

        function calculateSection(data, slaDays, type, refDateObj) {
            const refDate = new Date(refDateObj);
            refDate.setHours(23, 59, 59, 999);
            const refTime = refDate.getTime();

            let totalMttr = 0, countRes = 0, inSlaMes = 0, resMes = 0, backlog = 0;
            let trendD = {}, trendM = {}, analistas = {}, criticals = [], noPrb = [];
            let agingBuckets = {};

            const isReq = type === "REQ";
            const bucketsDef = isReq
                ? [{ l: "1-3 dias", min: 0, max: 3 }, { l: "3-5 dias", min: 4, max: 5 }, { l: "5-7 dias", min: 6, max: 7 }, { l: "7-10 dias", min: 8, max: 10 }, { l: "10 dias +", min: 11, max: 19 }, { l: "20 dias +", min: 20, max: 29 }, { l: "30 dias +", min: 30, max: 9999 }]
                : [{ l: "1-3 dias", min: 0, max: 3 }, { l: "4-7 dias", min: 4, max: 7 }, { l: "7+ dias", min: 8, max: 9999 }];
            bucketsDef.forEach(b => agingBuckets[b.l] = { count: 0, color: b.min > slaDays ? '#D50000' : '#1E3A8A' });

            let rDay = refDate.getDate(); let rMonth = refDate.getMonth(); let rYear = refDate.getFullYear();
            for (let i = 1; i <= rDay; i++) {
                let sD = `${rYear}-${String(rMonth + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
                trendD[sD] = { a: 0, r: 0, c: 0, b: 0 };
            }

            data.forEach(r => {
                let opOrig = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                if (!opOrig || opOrig.getTime() > refTime) return;

                let clOrig = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                let stOrig = String(getCol(r, ['State', 'Status', 'Estado']) || '').toLowerCase();

                let cl = clOrig; let st = stOrig;
                if (clOrig && clOrig.getTime() > refTime) { cl = null; st = 'Open (Retroativo)'; }

                let isRes = cl ? (isReq ? stOrig.includes('complet') : (stOrig.includes('resolv') || stOrig.includes('clos') && !stOrig.includes('cancel'))) : false;
                let isCanc = cl ? (isReq ? stOrig.includes('incomplet') : stOrig.includes('cancel')) : false;

                let age = cl ? Math.floor((cl - opOrig) / 86400000) : Math.floor((refDate - opOrig) / 86400000);
                if (age < 0) age = 0;

                let oY = opOrig.getFullYear(); let oM = String(opOrig.getMonth() + 1).padStart(2, '0');
                let mKey = `${oY}-${oM}`;
                if (!trendM[mKey]) trendM[mKey] = { a: 0, r: 0, c: 0, inSla: 0 };
                trendM[mKey].a++;

                let oD = String(opOrig.getDate()).padStart(2, '0');
                let dKey = `${oY}-${oM}-${oD}`;
                if (opOrig.getMonth() === refDate.getMonth() && opOrig.getFullYear() === refDate.getFullYear()) {
                    if (trendD[dKey]) trendD[dKey].a++;
                }

                if (isRes && cl) {
                    let cY = cl.getFullYear(); let cM = String(cl.getMonth() + 1).padStart(2, '0'); let cD = String(cl.getDate()).padStart(2, '0');
                    let mcKey = `${cY}-${cM}`;
                    if (!trendM[mcKey]) trendM[mcKey] = { a: 0, r: 0, c: 0, inSla: 0 };
                    trendM[mcKey].r++;
                    if (age <= slaDays) trendM[mcKey].inSla++;

                    let dcKey = `${cY}-${cM}-${cD}`;
                    if (cl.getMonth() === refDate.getMonth() && cl.getFullYear() === refDate.getFullYear()) {
                        if (trendD[dcKey]) {
                            trendD[dcKey].r++; resMes++; if (age <= slaDays) inSlaMes++;
                        }
                    }
                    totalMttr += age; countRes++;
                } else if (isCanc && cl) {
                    let cY = cl.getFullYear(); let cM = String(cl.getMonth() + 1).padStart(2, '0'); let cD = String(cl.getDate()).padStart(2, '0');
                    let mcKey = `${cY}-${cM}`;
                    if (!trendM[mcKey]) trendM[mcKey] = { a: 0, r: 0, c: 0, inSla: 0 };
                    trendM[mcKey].c++;

                    let dcKey = `${cY}-${cM}-${cD}`;
                    if (cl.getMonth() === refDate.getMonth() && cl.getFullYear() === refDate.getFullYear()) {
                        if (trendD[dcKey]) trendD[dcKey].c++;
                    }
                }

                if (!cl) {
                    backlog++;
                    let asg = getCol(r, ['Assigned to', 'Analista', 'Assignee']) || 'Não Atribuído';
                    let tk = getCol(r, ['Number', 'Ticket']) || '-';

                    let idle = getDaysSilent(r, refDate, asg, opOrig);

                    if (!analistas[asg]) analistas[asg] = { ab: 0, res: 0 };
                    analistas[asg].ab++;

                    GlobalOpenTickets.push({ tk: tk, asg: asg });

                    bucketsDef.forEach(b => { if (age >= b.min && age <= b.max) agingBuckets[b.l].count++; });

                    let prb = getCol(r, ['Problem', 'PRB', 'Problema']);
                    let hasPrb = prb && prb.trim() !== "" && prb.trim() !== "N/A";

                    if (age > slaDays) {
                        let infoRaw = getCol(r, ['Additional comments', 'Comentários Adicionais']) || 'Sem detalhes fornecidos.';
                        let infoClean = String(infoRaw).replace(/"/g, '&quot;').replace(/'/g, '&#39;');
                        let descClean = String(getCol(r, ['Short description', 'Descrição Curta', 'Item']) || 'Sem assunto').replace(/"/g, '&quot;');

                        criticals.push({
                            tk: tk, desc: descClean, as: asg, gp: getCol(r, ['Assignment group', 'Grupo']) || '-',
                            st: (clOrig ? stOrig : st).toUpperCase(), age: age, prb: hasPrb ? prb : 'N/A', info: infoClean,
                            opStr: opOrig.toLocaleDateString('pt-BR'), idle: idle
                        });

                        if (!isReq && !hasPrb) noPrb.push({ tk: tk, as: asg, info: infoClean, desc: descClean, gp: getCol(r, ['Assignment group', 'Grupo']) || '-', st: (clOrig ? stOrig : st).toUpperCase(), age: age, opStr: opOrig.toLocaleDateString('pt-BR'), idle: idle });
                    }
                }

                if (isRes && cl && cl.getMonth() === refDate.getMonth() && cl.getFullYear() === refDate.getFullYear()) {
                    let asg = getCol(r, ['Assigned to', 'Analista']) || 'Não Atribuído';
                    if (!analistas[asg]) analistas[asg] = { ab: 0, res: 0 };
                    analistas[asg].res++;
                }
            });

            let topAnalistas = Object.keys(analistas).map(k => ({ nome: k, ab: analistas[k].ab, res: analistas[k].res, tot: analistas[k].ab + analistas[k].res })).sort((a, b) => b.tot - a.tot).slice(0, 10);

            const calcBacklog = (trendObj) => {
                let keys = Object.keys(trendObj).sort(); let b = 0;
                keys.forEach(k => { let s = trendObj[k].a - (trendObj[k].r + trendObj[k].c); b += s; trendObj[k].b = b; });
            };
            calcBacklog(trendM);

            let dKeys = Object.keys(trendD).sort(); let db = backlog;
            for (let i = dKeys.length - 1; i >= 0; i--) { let k = dKeys[i]; trendD[k].b = db; db -= (trendD[k].a - (trendD[k].r + trendD[k].c)); }

            let inSlaTot = 0, outSlaTot = 0;
            bucketsDef.forEach(b => { if (b.min > slaDays) outSlaTot += agingBuckets[b.l].count; else inSlaTot += agingBuckets[b.l].count; });

            return {
                mttr: countRes ? (totalMttr / countRes).toFixed(2).replace('.', ',') : "0,00",
                pct: resMes ? Math.round((inSlaMes / resMes) * 100) : 0,
                inSla: inSlaMes, outSla: resMes - inSlaMes, backlog,
                inSlaTot, outSlaTot, trendM, trendD, topAnalistas, agingBuckets,
                crits: criticals.sort((a, b) => b.age - a.age), noPrb: noPrb
            };
        }

        const C = { PRI_D: "#001871", PRI: "#1E3A8A", ACC_D: "#0F172A", SUC: "#00C853", DAN: "#D50000", ORG: "#FF8C00", GRY_D: "#334155", GRY_L: "#F8FAFC" };

        // ==========================================
        // ABA ERROS DE CLASSIFICAÇÃO
        // ==========================================
        function calculateClassifications(allData, refDateObj) {
            let incorrectTickets = [];
            let totalDays = 0;
            let maxDays = 0;
            let withLink = 0;
            let withoutLink = 0;

            allData.forEach(r => {
                let stOrig = String(getCol(r, ['State', 'Status', 'Estado']) || '').toLowerCase();
                let reason = String(getCol(r, ['Reason', 'reason', 'REASON', 'Motivo']) || '').toUpperCase();

                if (stOrig.includes('incomplet') && reason.includes('INCORRECT CLASSIFICATION')) {
                    let op = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                    let cl = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                    if (!op) return;

                    if (op.getTime() > refDateObj.getTime()) return;

                    let closeNotes = String(getCol(r, ['Close notes', 'Close Notes', 'close_notes', 'Closing notes']) || '');

                    let linkedMatch = closeNotes.match(/(INC|RITM|REQ|TASK)[\s\-]?(\d{6,8})/i);
                    let linkedTicket = linkedMatch ? (linkedMatch[1].toUpperCase() + linkedMatch[2]) : null;

                    let days = cl ? Math.floor((cl - op) / 86400000) : Math.floor((refDateObj - op) / 86400000);
                    if (days < 0) days = 0;

                    let asg = getCol(r, ['Assigned to', 'Analista']) || 'N/A';
                    let idle = (!clOrig || clOrig.getTime() > refDateObj.getTime()) ? getDaysSilent(r, refDateObj, asg, op) : '-';

                    if (linkedTicket) withLink++; else withoutLink++;
                    totalDays += days;
                    if (days > maxDays) maxDays = days;

                    incorrectTickets.push({
                        tk: getCol(r, ['Number', 'number', 'Ticket', 'RITM']) || '-',
                        req: getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A',
                        as: asg,
                        gp: getCol(r, ['Assignment group', 'Grupo']) || 'N/A',
                        linked: linkedTicket || '⚠️ Não encontrado',
                        reason: reason,
                        st: stOrig.toUpperCase(),
                        age: days,
                        idle: idle,
                        opStr: op.toLocaleDateString('pt-BR'),
                        desc: String(getCol(r, ['Short description', 'Descrição Curta', 'Descrição']) || '-').replace(/"/g, '&quot;'),
                        info: closeNotes.replace(/"/g, '&quot;') || 'Nenhuma nota de fechamento registrada.'
                    });
                }
            });

            return {
                total: incorrectTickets.length,
                withLink,
                withoutLink,
                avgDays: incorrectTickets.length ? (totalDays / incorrectTickets.length).toFixed(1).replace('.', ',') : "0,0",
                maxDays,
                tickets: incorrectTickets.sort((a, b) => b.age - a.age)
            };
        }

