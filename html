                let clOrig = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                let st = String(getCol(r, ['State', 'Status']) || '').toLowerCase();
                if (clOrig && clOrig.getTime() <= refTime) { if (st.includes('clos') || st.includes('resolv') || st.includes('cancel') || st.includes('fech')) return; }

                let age = Math.floor((refDate - op) / 86400000);
                let tk = getCol(r, ['Number', 'Task']) || '-';
                let desc = getCol(r, ['Problem', 'Problema']) || '-';
                let dummyT = { tk: tk, desc: desc, as: getCol(r, ['Assigned to', 'Analista']) || '-', gp: getCol(r, ['Assignment group', 'Grupo']) || '-', st: st.toUpperCase(), age: age, opStr: op.toLocaleDateString('pt-BR'), info: 'Task secundária' };

                ptaskRows += `<tr ${buildRowAttrs(dummyT)}>
                    <td class="font-bold text-slate-700">${desc}</td>
                    <td style="color:${C.PRI_D}; font-weight:bold;">${tk}</td>
                    <td class="font-medium">${dummyT.as}</td>
                    <td>${dummyT.gp}</td>
                    <td style="color:${age > slaPTask ? C.DAN : C.SUC}; font-weight:bold; font-size:13px;">${age > slaPTask ? `Estourado (${age}d)` : `No Prazo (${age}d)`}</td>
                </tr>`;
            });

            html += `<div class="report-card"><div class="report-card-title"><i class="fas fa-tasks mr-2"></i> 2. TASKS DE PROBLEMA (PTASK) ABERTAS</div>
                <div class="st-dataframe-container"><table class="st-table">
                <thead><tr><th class="w-prb" style="background-color:${C.PRI_D};">Problem (Pai)</th><th class="w-tk" style="background-color:${C.PRI_D};">PTASK</th><th class="w-as" style="background-color:${C.PRI_D};">Analista</th><th class="w-gp" style="background-color:${C.PRI_D};">Grupo Resolutor</th><th class="w-age" style="background-color:${C.PRI_D};">SLA / Aging</th></tr></thead>
                <tbody>${ptaskRows || `<tr><td colspan="5" class="text-center text-slate-500 py-6">Nenhuma PTASK aberta no momento.</td></tr>`}</tbody>
                </table></div></div>`;
            return html;
        }

        // ==========================================
        // SISTEMA DE TODO (COM HISTÓRICO)
        // ==========================================
        let todoList = JSON.parse(localStorage.getItem('eliteMasterTodos')) || [];

        function updateTicketsDropdown() {
            const analyst = document.getElementById('todo-analyst').value;
            const selectTk = document.getElementById('todo-tickets');
            selectTk.innerHTML = '<option value="" disabled>Selecione um ou mais chamados...</option>';

            if (!analyst) {
                selectTk.innerHTML = '<option value="" disabled>Selecione um analista primeiro...</option>';
                return;
            }

            let tkSet = new Set();
            GlobalOpenTickets.forEach(t => {
                if (t.asg === analyst) tkSet.add(t.tk);
            });

            tkSet.forEach(tk => {
                selectTk.innerHTML += `<option value="${tk}">${tk}</option>`;
            });
        }

        function addTodo() {
            const analyst = document.getElementById('todo-analyst').value;
            const selectTk = document.getElementById('todo-tickets');
            const desc = document.getElementById('todo-desc').value;

            if (!analyst || !desc.trim()) return alert("Analista e Descrição são obrigatórios.");

            let selectedTks = Array.from(selectTk.selectedOptions).map(opt => opt.value);

            const newTodo = {
                id: Date.now().toString(),
                analyst: analyst,
                tickets: selectedTks,
                desc: desc,
                history: [{
                    date: new Date().toLocaleString('pt-BR'),
                    text: desc
                }],
                date: new Date().toLocaleDateString('pt-BR')
            };

            todoList.push(newTodo);
            saveTodos();
            renderTodos();

            document.getElementById('todo-desc').value = '';
            selectTk.selectedIndex = -1;
        }

        function completeTodo(id) {
            if (confirm("Confirmar a conclusão desta tarefa? O card será removido permanentemente da lista.")) {
                todoList = todoList.filter(t => t.id !== id);
                saveTodos();
                renderTodos();
            }
        }

        function deleteTodo(id) {
            if (confirm("Apagar esta tarefa permanentemente?")) {
                todoList = todoList.filter(t => t.id !== id);
                saveTodos();
                renderTodos();
            }
        }

        function addTodoUpdate(id) {
            const input = document.getElementById(`update-input-${id}`);
            const text = input.value.trim();
            if (!text) return;

            const todo = todoList.find(t => t.id === id);
            if (todo) {
                if (!todo.history) todo.history = [{ date: todo.date, text: todo.desc }];
                todo.history.push({
                    date: new Date().toLocaleString('pt-BR'),
                    text: text
                });
                saveTodos();
                renderTodos();
            }
        }

        function saveTodos() { localStorage.setItem('eliteMasterTodos', JSON.stringify(todoList)); }

        function renderTodos() {
            const container = document.getElementById('todo-list');
            const countEl = document.getElementById('todo-count');

            if (!container) return;

            countEl.innerText = todoList.length;

            if (todoList.length === 0) {
                container.innerHTML = `<div class="text-center py-10 text-slate-400 font-bold"><i class="fas fa-check-circle text-4xl mb-3 text-emerald-400"></i><br>Nenhuma tarefa ativa.</div>`;
                return;
            }

            let html = "";
            todoList.sort((a, b) => b.id - a.id).forEach(t => {
                let tkBadges = t.tickets.map(tk => `<span class="todo-badge"><i class="fas fa-ticket-alt"></i> ${tk}</span>`).join('');

                if (!t.history) {
                    t.history = [{ date: t.date, text: t.desc }];
                }

                let historyHtml = t.history.map(h => `
                    <div class="todo-history-item">
                        <div class="todo-history-date">${h.date}</div>
                        <div class="todo-history-text">${h.text}</div>
                    </div>
                `).join('');

                html += `
                <div class="todo-item">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                        <div style="font-size:13px; font-weight:bold; color:var(--primary-dark);"><i class="fas fa-user text-slate-400 mr-1"></i> ${t.analyst} <span class="text-[10px] text-slate-400 font-normal ml-2">Criado em: ${t.date}</span></div>
                        <div style="display:flex; gap:8px;">
                            <button onclick="completeTodo('${t.id}')" title="Marcar como Concluído (Remover)" style="background:transparent; border:none; cursor:pointer; color:#10b981; font-size:16px; transition:0.2s;"><i class="fas fa-check-circle"></i></button>
                            <button onclick="deleteTodo('${t.id}')" title="Apagar Tarefa" style="background:transparent; border:none; cursor:pointer; color:#f87171; font-size:14px; transition:0.2s;"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                    ${tkBadges ? `<div style="display:flex; gap:5px; flex-wrap:wrap; margin-top:5px; margin-bottom:5px;">${tkBadges}</div>` : ''}
                    
                    <div class="todo-history">
                        ${historyHtml}
                    </div>

                    <div class="todo-update-wrapper">
                        <input type="text" id="update-input-${t.id}" class="form-input" style="padding: 6px 10px; font-size: 12px; margin:0;" placeholder="Adicionar nova atualização...">
                        <button onclick="addTodoUpdate('${t.id}')" class="btn-process" style="width: auto; padding: 6px 12px; font-size: 11px; margin:0; background: var(--accent);"><i class="fas fa-plus"></i> Add</button>
                    </div>
                </div>`;
            });
            container.innerHTML = html;
        }

        function populateTodoAnalystDropdown() {
            const select = document.getElementById('todo-analyst');
            if (!select) return;

            let analystSet = new Set();
            GlobalOpenTickets.forEach(t => { if (t.asg !== 'Não Atribuído' && t.asg !== '-' && t.asg !== 'N/A') analystSet.add(t.asg); });

            let html = '<option value="">Selecione um analista...</option>';
            Array.from(analystSet).sort().forEach(a => { html += `<option value="${a}">${a}</option>`; });
            select.innerHTML = html;

            document.getElementById('todo-tickets').innerHTML = '<option value="" disabled>Selecione um analista primeiro...</option>';
        }

        // ==========================================
        // ORQUESTRADOR PRINCIPAL
        // ==========================================
        function processDashboard() {
            if (!RawData.incs.length && !RawData.reqs.length) return alert("Erro: Carregue as planilhas do ServiceNow na aba lateral primeiro.");

            document.getElementById('init-alert').classList.add('hidden-st');
            document.getElementById('loader').classList.remove('hidden-st');
            document.getElementById('report-content').classList.add('hidden-st');

            if (window.innerWidth < 1024) toggleSidebar();

            if (window.chartInstances) { window.chartInstances.forEach(c => c.destroy()); window.chartInstances = []; }
            GlobalOpenTickets = []; // Reset array de tickets

            setTimeout(() => {
                const slaI = parseInt(document.getElementById('sla-incs').value) || 7;
                const slaR = parseInt(document.getElementById('sla-reqs').value) || 10;
                const slaP = parseInt(document.getElementById('sla-ptask').value) || 10;

                const refDateInput = document.getElementById('ref-date').value;
                const dateMachine = refDateInput ? new Date(refDateInput + 'T12:00:00') : new Date();

                ['tab-inc', 'tab-req', 'tab-uam', 'tab-cons', 'tab-prb'].forEach(id => document.getElementById(id).innerHTML = "");
                let dI = null, dRS = null, dRU = null;

                if (RawData.incs.length) {
                    dI = calculateSection(RawData.incs, slaI, "INC", dateMachine);
                    document.getElementById('tab-inc').innerHTML = generateSectionHTML('inc', "SESSÃO INCs (INCIDENTES GERAIS)", C.PRI_D, dI, "INC");
                }

                if (RawData.reqs.length) {
                    const isUam = r => String(r['Assignment group'] || r['Grupo'] || '').toLowerCase().includes('access');
                    let rS = RawData.reqs.filter(r => !isUam(r)); let rU = RawData.reqs.filter(r => isUam(r));

                    if (rS.length) { dRS = calculateSection(rS, slaR, "REQ", dateMachine); document.getElementById('tab-req').innerHTML = generateSectionHTML('req', "SESSÃO REQs (SUPORTE GERAL)", C.PRI, dRS, "REQ"); }
                    if (rU.length) { dRU = calculateSection(rU, slaR, "REQ", dateMachine); document.getElementById('tab-uam').innerHTML = generateSectionHTML('uam', "SESSÃO UAMs (ACESSOS)", C.ACC_D, dRU, "REQ"); }
                }

                if (dI && dRS && dRU) document.getElementById('tab-cons').innerHTML = generateConsolidadoHTML(dI, dRS, dRU);

                if (RawData.rca.length || RawData.ptask.length) {
                    document.getElementById('tab-prb').innerHTML = generatePRBTab(RawData.rca, RawData.ptask, slaP, dateMachine);
                } else {
                    document.getElementById('tab-prb').innerHTML = `<div class="report-card text-center py-10"><h3 class="text-slate-600 font-bold">Nenhum dado de Causa Raiz/PTASK importado.</h3></div>`;
                }

                document.getElementById('loader').classList.add('hidden-st');
                document.getElementById('report-content').classList.remove('hidden-st');
                document.getElementById('search-container').classList.add('visible');

                requestAnimationFrame(() => {
                    if (dI) drawChartsAll('inc', dI, 'Resolvidos');
                    if (dRS) drawChartsAll('req', dRS, 'Encerrados');
                    if (dRU) drawChartsAll('uam', dRU, 'Encerrados');
                    if (dI && dRS && dRU) drawConsolidadoCharts(dI, dRS, dRU);
                    filterTables();

                    populateTodoAnalystDropdown();
                    renderTodos();
                });
            }, 600);
        }
    </script>
</body>

</html>
