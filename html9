                    const isUam = r => {
                        const accessKw = v => { let s = String(v || '').toLowerCase(); return s.includes('access') || s.includes('acesso') || s.includes('uam'); };
                        return accessKw(r['Assignment group']) || accessKw(r['Grupo']) || accessKw(r['Item']) || accessKw(r['item']) || accessKw(r['Tags']) || accessKw(r['tags']) || accessKw(r['Categoria']) || accessKw(r['Short description']);
                    };
                    rS = RawData.reqs.filter(r => !isUam(r));
