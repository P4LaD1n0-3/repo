                                            borderDash: [6, 3], pointRadius: 3, pointHoverRadius: 5,
                                            pointBackgroundColor: C._REQ,
                                            datalabels: { color: '#1d4ed8', font: { size: 9 }, formatter: v => v > 0 ? v : '' }
                                        },
                                        {
                                            label: 'UAM', data: sd.dDataUam,
                                            borderColor: C._UAM, backgroundColor: C._UAMb,
                                            fill: false, borderWidth: 2, tension: 0.35,
                                            borderDash: [6, 3], pointRadius: 3, pointHoverRadius: 5,
                                            pointBackgroundColor: C._UAM,
                                            datalabels: { color: '#7c3aed', font: { size: 9 }, formatter: v => v > 0 ? v : '' }
                                        }
                                    ]
                                },
                                options: {
                                    maintainAspectRatio: false,
                                    legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, fontSize: 11 } },
                                    elements: { line: { tension: 0.35 } },
                                    scales: {
                                        xAxes: [{ gridLines: { display: false }, ticks: { fontSize: 9, maxRotation: 45, fontColor: '#64748b' } }],
                                        yAxes: [{ ticks: { beginAtZero: true, fontSize: 10, fontColor: '#64748b' }, gridLines: { color: '#f1f5f9', drawBorder: false } }]
                                    },
                                    tooltips: { mode: 'index', intersect: false },
                                    onClick: function (evt) {
                                        const el = this.getElementAtEvent(evt)[0];
                                        if (!el) return;
                                        const idx = el._index;
                                        const datasetIdx = el._datasetIndex;
                                        const dKey = (sd.sortedDays || [])[idx] || '';
                                        let dLabel = (sd.dayLabels || [])[idx] || dKey;
                                        let vaultKey = `day_${dKey}`;

                                        if (datasetIdx === 1) {
                                            vaultKey += '_INC';
                                            dLabel += ' (INC)';
                                        } else if (datasetIdx === 2) {
                                            vaultKey += '_REQ';
                                            dLabel += ' (REQ)';
                                        } else if (datasetIdx === 3) {
                                            vaultKey += '_UAM';
                                            dLabel += ' (UAM)';
                                        }

                                        openDrilldown(`Fora SLA — dia ${dLabel}`, vaultKey, 'sla');
                                    }
                                }
                            }));
                        }
                    });
                }
                // ──────────────────────────────────────────────────────────────────

                // Inject RPA Tab
                document.getElementById('tab-rpa').innerHTML = generateRPATabHTML();

                document.getElementById('loader').classList.add('hidden-st');
                document.getElementById('report-content').classList.remove('hidden-st');
                document.getElementById('search-container').classList.add('visible');

                let tabs = document.querySelectorAll('.tab-pane');
                tabs.forEach(c => {
                    c.style.display = 'block';
                    c.style.visibility = 'hidden';
                    c.style.position = 'absolute';
                    c.classList.remove('hidden-st');
                });

                requestAnimationFrame(() => {
                    if (dI) drawChartsAll('inc', dI, 'Resolvidos');
                    if (dRS) drawChartsAll('req', dRS, 'Encerrados');
                    if (dRU) drawChartsAll('uam', dRU, 'Encerrados');
                    if (dI || dRS || dRU) drawConsolidadoCharts(dI, dRS, dRU);

                    tabs.forEach(c => {
                        c.style.display = '';
                        c.style.visibility = '';
                        c.style.position = '';
                        c.classList.add('hidden-st');
                    });

                    // --- AUTO CLEANUP TODos OF RESOLVED/CLOSED TICKETS ---
                    let toDeleteIds = new Set();
                    todoList.forEach(t => {
                        let row = null;
                        if (t.ticket.startsWith('REQ') || t.ticket.startsWith('RITM')) {
                            row = RawData.reqs.find(x => getCol(x, ['RITM', 'Request Item', 'Item de solicitação', 'Number', 'Ticket']) === t.ticket);
                        } else if (t.ticket.startsWith('PRB')) {
                            row = RawData.prb ? RawData.prb.find(x => getCol(x, ['Number', 'Problem', 'ID']) === t.ticket) : null;
                        } else if (t.ticket.startsWith('INC')) {
                            row = RawData.incs.find(x => getCol(x, ['Number', 'Ticket', 'Task']) === t.ticket);
                        } else {
                            if (t.ticket.startsWith('PTASK')) row = RawData.ptask ? RawData.ptask.find(x => getCol(x, ['Number', 'Task', 'Ticket']) === t.ticket) : null;
                            if (t.ticket.startsWith('RCA')) row = RawData.rca ? RawData.rca.find(x => getCol(x, ['Number', 'Task', 'Ticket']) === t.ticket) : null;
                        }

                        if (row) {
                            let clDate = safeDate(getCol(row, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                            let stOrig = String(getCol(row, ['State', 'Status', 'Estado', 'RCA Status']) || '').toLowerCase();
                            if (clDate || stOrig.includes('cancel') || stOrig.includes('resolv') || stOrig.includes('clos') || stOrig.includes('complet')) {
                                toDeleteIds.add(t.id);
                            }
                        }
                    });

                    if (toDeleteIds.size > 0) {
                        todoList = todoList.filter(t => !toDeleteIds.has(t.id));
                        saveTodos();
                    }

                    populateTodoAnalystDropdown();
                    renderTodos();

                    switchTab('tab-open', document.querySelector('.tab-btn[onclick*="tab-open"]'));
                    if (document.getElementById("globalSearch").value.trim() !== "") {
                        performGlobalSearch();
                    } else {
                        filterTables();
                    }

                    document.querySelectorAll('.report-card').forEach(card => {
                        if (!card.querySelector('.btn-snap') && card.style.display !== 'none') {
                            let btn = document.createElement('button');
                            btn.className = 'btn-snap';
                            btn.innerHTML = '<i class="fas fa-camera text-[10px]"></i>';
                            btn.title = "Tirar Foto deste Gráfico/Tabela";
                            btn.onclick = (e) => takeScreenshotItem(btn, e);
                            card.appendChild(btn);
                        }
                    });
                });
            }, 600);
        }

        // --- INICIALIZAÇÃO GERAL (Persistência) ---
        document.addEventListener('DOMContentLoaded', async () => {
            console.log("[INIT] Inicializando Painel com Persistência...");

            // 1. Carrega Configurações (SLA, Email) do localStorage
            loadConfigs();

            // 2. Tenta recuperar Pasta Vinculada do IndexedDB
            try {
                const storedHandle = await loadHandle();
                if (storedHandle) {
                    window.syncContext.dirHandle = storedHandle;
                    document.getElementById('sync-status-indicator').className = 'w-3 h-3 rounded-full bg-amber-500 shadow shadow-amber-200';
                    document.getElementById('sync-status-text').innerText = 'Pasta Lembrada (Aguardando Permissão)';
                    document.getElementById('sync-folder-path').innerText = storedHandle.name;
                    console.log("[INIT] Pasta recuperada do DB:", storedHandle.name);
                }
            } catch (e) {
                console.error("[INIT] Erro ao carregar pasta do DB:", e);
            }

            // 3. Renderiza TODOs se houver (já carregados no escopo global)
            if (todoList.length > 0) {
                renderTodos();
            }
        });



        function takeScreenshotItem(btn, e) {
            e.stopPropagation();
            btn.innerHTML = '<i class="fas fa-spinner fa-spin text-[10px]"></i>';
            const card = btn.closest('.report-card');
            if (!card) return;

            let titleText = "Item";
            const titleEl = card.querySelector('.report-card-title');
            if (titleEl) titleText = titleEl.innerText.replace(/[^a-zA-Z0-9]/g, '_').substring(0, 30);

            html2canvas(card, {
                scale: 1.5,
                logging: false,
                useCORS: true,
                backgroundColor: "#ffffff"
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = `ITSM_${titleText}_${new Date().toISOString().slice(0, 10)}.png`;
                link.href = canvas.toDataURL('image/png');
                link.click();
                btn.innerHTML = '<i class="fas fa-camera text-[10px]"></i>';
            }).catch(err => {
                alert("Erro ao tirar print do item.");
                btn.innerHTML = '<i class="fas fa-camera text-[10px]"></i>';
            });
        }

        // ==========================================
        // RPA EMAIL VIEWER MODAL LOGIC
        // ==========================================
        async function readRpaEmail(filepath) {
            const modal = document.getElementById('rpaEmailModal');
            const contentDiv = document.getElementById('rpaEmailContent');

            modal.classList.remove('hidden');
            contentDiv.innerHTML = '<div class="p-10 text-center"><i class="fas fa-circle-notch fa-spin text-4xl text-purple-600 mb-4"></i><div class="font-bold text-slate-500">Carregando e-mail...</div></div>';

            try {
                // Fetch the actual email content served by Python bridge
                const response = await fetch('http://localhost:5000/rpa/email?filepath=' + encodeURIComponent(filepath));
                if (!response.ok) throw new Error('API do Robô Indisponível');

                const responseData = await response.json();

                if (responseData.status === 'error') {
                    contentDiv.innerHTML = `<div class="p-10 text-center text-red-500 font-bold"><i class="fas fa-exclamation-triangle block text-3xl mb-2"></i> ${responseData.message}</div>`;
                    return;
                }

                // Render in a sandboxed iframe to prevent CSS bleeding
                contentDiv.innerHTML = `<iframe style="width: 100%; height: 60vh; border: 1px solid #e2e8f0; border-radius: 8px; background: white;" srcdoc="${escapeHTMLDoc(responseData.content)}"></iframe>`;

            } catch (error) {
                contentDiv.innerHTML = `<div class="p-10 text-center text-red-500 font-bold"><i class="fas fa-ban block text-3xl mb-2"></i> Não foi possível conectar ao bridge (localhost:5000)</div>`;
            }
        }

        function closeRpaEmailModal() {
            document.getElementById('rpaEmailModal').classList.add('hidden');
            document.getElementById('rpaEmailContent').innerHTML = '';
        }

        function escapeHTMLDoc(html) {
            if (!html) return '';
            // Para srcdoc, precisamos apenas garantir que as aspas que delimitam o atributo não quebrem
            // e que o conteúdo seja injetado de forma segura mas funcional como HTML.
            return html
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }
    </script>

    <!-- Modal de Visualização de E-mail RPA -->
    <div id="rpaEmailModal"
        class="hidden fixed inset-0 bg-slate-900 bg-opacity-75 z-[10060] flex items-center justify-center p-4">
        <div
            class="bg-white rounded-xl shadow-2xl w-full max-w-5xl flex flex-col max-h-[90vh] overflow-hidden border border-slate-200">
            <div class="bg-purple-600 px-6 py-4 flex justify-between items-center text-white shrink-0">
                <div class="font-bold text-lg flex items-center">
                    <i class="fas fa-envelope-open-text mr-3"></i> Visualizador de E-mail RPA
                </div>
                <button onclick="closeRpaEmailModal()"
                    class="text-white hover:text-purple-200 transition bg-transparent hover:bg-purple-500 rounded p-1 w-8 h-8 flex items-center justify-center">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="p-6 overflow-hidden flex-1 flex flex-col bg-slate-50" id="rpaEmailContent">
                <!-- Iframe injetado pelo js -->
            </div>
            <div class="p-4 bg-white border-t border-slate-100 flex justify-end shrink-0">
                <button onclick="closeRpaEmailModal()"
                    class="bg-slate-100 hover:bg-slate-200 text-slate-700 px-5 py-2 rounded font-bold transition">Fechar</button>
            </div>
        </div>
    </div>
