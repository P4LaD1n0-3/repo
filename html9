                        </td>
                        <td data-label="PRB" class="text-center">
                            ${t.type === 'INC' ? (t.prb !== 'N/A' && t.prb !== '' && t.prb !== 'undefined' ? `<span class="bg-red-50 text-red-700 font-bold px-2 py-0.5 rounded border border-red-200 text-[10px]"><i class="fas fa-bug mr-1"></i>${t.prb}</span>` : '<span class="text-slate-300 text-[10px]">N/A</span>') : '<span class="text-slate-300 text-[10px]">-</span>'}
                        </td>
                        <td data-label="Abertura" class="text-center"><i class="far fa-calendar-alt text-slate-400 mr-1"></i>${t.opStr}</td>
                        <td data-label="Aging (dias)" class="text-center font-bold text-base ${t.age > t.slaConfig ? 'text-red-600' : 'text-slate-700'}">${t.age}</td>
                        <td data-label="% SLA" class="text-center" style="width: 100px;">
                            <div class="w-full bg-slate-200 rounded-full h-4 relative shadow-inner mx-auto min-w-[70px] overflow-hidden border border-slate-300/50">
                                <div class="h-full absolute left-0 top-0 bottom-0 transition-all" style="width: ${safePct}%; background-color: ${pctColor} !important;"></div>
                                <div class="absolute inset-0 flex items-center justify-center text-[9px] font-bold z-10" style="color: ${t.pctSlaNum > 55 ? '#ffffff' : '#1e293b'}; text-shadow: ${t.pctSlaNum > 55 ? '0 0 2px rgba(0,0,0,0.8)' : 'none'};">${pctText}</div>
                            </div>
                        </td>
                        <td data-label="Status SLA" class="text-center font-black ${stColor} uppercase text-[10px]">${t.stSla}</td>
                    </tr>`;
