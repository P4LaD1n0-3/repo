        async function initializeRpaGlobalData() {
            try {
                const response = await fetch('http://localhost:5000/rpa/logs');
                if (!response.ok) return;
                const res = await response.json();
                if (res.status === 'success' && res.data) {
                    window.TicketsWithEmail = new Set(res.data.map(d => d.ticket_number));
                    console.log(`[RPA] Global sync complete: ${window.TicketsWithEmail.size} tickets with emails.`);
                    // Optional: re-render search or tabs if already populated
                }
            } catch (e) {
                console.warn("RPA Bridge offline, global sync skipped.");
            }
        }

        // Chamar na inicialização
        initializeRpaGlobalData();

        async function fetchRPALogs() {
            try {
                const response = await fetch('http://localhost:5000/rpa/logs');
                if (!response.ok) throw new Error('API do Robô Indisponível (email_bridge.py / status: ' + response.status + ')');

                const responseData = await response.json();

                if (responseData.status === 'error') {
                    renderRPAError(responseData.message);
                    return;
                }

                renderRPADashboard(responseData.data || []);
            } catch (error) {
                renderRPAError("Serviço de Comunicação Local Off-line. Certifique-se de que a API (email_bridge.py) está rodando.");
                console.error("RPA Fetch Error:", error);
            }
        }

        function renderRPAError(mensagem) {
            const container = document.getElementById('rpa-dashboard-container');
            if (container) {
                container.innerHTML = `
                <div class="report-card text-center border-l-4 border-red-500 p-8">
                    <i class="fas fa-exclamation-triangle text-4xl text-red-400 mb-4"></i>
                    <h2 class="text-lg font-bold text-slate-700">Erro na Integração Python/RPA</h2>
                    <p class="text-sm text-slate-500 mt-2">${mensagem}</p>
                    <button class="mt-4 px-4 py-2 bg-red-50 text-red-600 rounded font-bold border border-red-200 hover:bg-red-100 transition shadow-sm" onclick="fetchRPALogs()">
                        <i class="fas fa-sync-alt mr-2"></i>Tentar Reconectar
                    </button>
                </div>`;
            }
        }

