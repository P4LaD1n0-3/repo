                <div class="chart-full-width"><canvas id="c-m-cons"></canvas></div>
            </div>
            `;
        }

        function buildProdCard(type, data, color, comp = null) {
            const refDateInput = document.getElementById('ref-date').value;
            const now = new Date();
            const refDate = new Date(refDateInput + (refDateInput.length === 7 ? '-01' : '') + 'T12:00:00');

            // Lógica para divisor de dias (Média Diária)
            let daysDivisor;
            const isCurrentMonth = (now.getFullYear() === refDate.getFullYear() && now.getMonth() === refDate.getMonth());

            if (isCurrentMonth) {
                daysDivisor = now.getDate();
            } else {
                // Pega o último dia do mês selecionado
                daysDivisor = new Date(refDate.getFullYear(), refDate.getMonth() + 1, 0).getDate();
            }

            if (daysDivisor < 1) daysDivisor = 1;

            const resMes = data.resMes || 0;
            const avgDaily = (resMes / daysDivisor).toFixed(1).replace('.', ',');
            const avgWeekly = (resMes / (daysDivisor / 7)).toFixed(1).replace('.', ',');

            const statsHtml = comp ? `
                <div class="flex flex-col gap-2 px-1 bg-blue-50/50 p-2 rounded border border-blue-100/50">
                    <div class="flex justify-between items-center text-[10px]">
                        <span class="font-black text-slate-400 uppercase tracking-tighter">SITUAÇÃO PRESENTE:</span>
                        <span class="font-black text-blue-600">${comp.resMes}</span>
                    </div>
                    <div class="h-px bg-blue-200/30"></div>
                    <div class="flex justify-between items-center text-[10px]">
                        <span class="font-black text-slate-400 uppercase tracking-tighter">CONSOLIDADO MÊS:</span>
                        <span class="font-black text-slate-700">${resMes}</span>
                    </div>
                </div>` : `
                <div class="flex-1 flex flex-col justify-around">
                    <div class="flex justify-between items-baseline px-2">
                        <span class="text-[10px] font-bold text-slate-400 uppercase">Total Mês</span>
                        <span class="text-2xl font-black text-slate-800">${resMes}</span>
                    </div>
                    <div class="my-3 h-px bg-slate-100"></div>
                    <div class="grid grid-cols-2 gap-2">
                        <div class="text-center p-2 bg-slate-50 rounded border border-slate-100">
                            <div class="text-[9px] font-black text-slate-500 uppercase leading-tight">Por Dia</div>
                            <div class="text-xl font-black text-slate-700 mt-1">${avgDaily}</div>
                            <div class="text-[8px] text-slate-400 italic">Média</div>
                        </div>
                        <div class="text-center p-2 bg-slate-50 rounded border border-slate-100">
                            <div class="text-[9px] font-black text-slate-500 uppercase leading-tight">Por Semana</div>
                            <div class="text-xl font-black text-slate-700 mt-1">${avgWeekly}</div>
                            <div class="text-[8px] text-slate-400 italic">Média</div>
                        </div>
                    </div>
                </div>`;

            return `
            <div class="report-card flex flex-col justify-between border-t-4 bg-gradient-to-br from-white to-slate-50" style="border-top-color: ${color}; margin-bottom:0; min-height: 180px;">
                <div class="report-card-title text-center" style="color: ${color}; border-bottom: 1px solid #f1f5f9; padding-bottom: 8px; margin-bottom: 12px;">Produtividade ${type}</div>
                ${statsHtml}
            </div>`;
        }


        function generatePRBTabImproved(prbData, ptaskData, rcaData, refDateObj) {
            let html = `<div class="report-section-title" style="background-color: var(--primary-dark);"><i class="fas fa-shield-alt mr-2"></i> GESTÃO UNIFICADA DE PROBLEMAS E TAREFAS (PRB / PTASK)</div>`;

            if (!prbData || prbData.length === 0) {
                return html + `<div class="report-card" style="text-align: center; padding: 40px;"><p style="color: #94a3b8; font-size: 14px;">Nenhum PRB ativo no momento. Carregue o arquivo <b>problem_rca.xlsx</b> e o <b>index.xlsx</b>.</p></div>`;
            }

            // ---------------------------------------------------------------
            // AGRUPAMENTO: monta estrutura hierárquica diretamente do prbData
            // prbData é produzido por processPRBDataForDisplay com tipos corretos:
            //   type='PRB'   → linha mestre (chave pid = t.tk)
            //   type='INC'   → filho (chave pid = t.prb)
            //   type='PTASK' → filho (chave pid = t.prb)
            // ---------------------------------------------------------------
            let groups = {}; // pid -> { master, incs:[], ptasks:[] }

            prbData.forEach(t => {
                let pid = (t.type === 'PRB') ? t.tk : t.prb;
                if (!pid || pid === '—' || pid === '') pid = '__SEM_PRB__';
                if (!groups[pid]) groups[pid] = { master: null, incs: [], ptasks: [] };

                if (t.type === 'PRB') {
                    // Se já existe um master, mantém o primeiro (mais completo)
                    if (!groups[pid].master) groups[pid].master = t;
                } else if (t.type === 'INC') {
                    groups[pid].incs.push(t);
                } else if (t.type === 'PTASK') {
                    groups[pid].ptasks.push(t);
                }
            });

            // ---------------------------------------------------------------
            // KPI Cards
            // ---------------------------------------------------------------
            let totalPrbs = Object.keys(groups).filter(k => k !== '__SEM_PRB__').length;
            let totalIncs = prbData.filter(t => t.type === 'INC').length;
            let totalPtasks = prbData.filter(t => t.type === 'PTASK').length;
            let affectedGroups = new Set(
                prbData.filter(t => t.type === 'PRB' && t.gp && t.gp !== '—').map(t => t.gp)
            ).size;

            html += `
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                <div class="report-card text-center border-t-4 border-red-500 bg-gradient-to-br from-white to-red-50/30 p-4 shadow-sm">
                    <div class="text-[10px] font-black text-red-600 mb-1 uppercase tracking-widest">Total PRBs</div>
                    <div class="text-4xl font-black text-slate-800">${totalPrbs}</div>
                    <div class="text-[9px] text-slate-400 mt-2 uppercase">Problemas Mapeados</div>
                </div>
                <div class="report-card text-center border-t-4 border-orange-500 bg-gradient-to-br from-white to-orange-50/30 p-4 shadow-sm">
                    <div class="text-[10px] font-black text-orange-600 mb-1 uppercase tracking-widest">INCs Vinculados</div>
                    <div class="text-4xl font-black text-slate-800">${totalIncs}</div>
                    <div class="text-[9px] text-slate-400 mt-2 uppercase">Incidentes por Causa</div>
                </div>
                <div class="report-card text-center border-t-4 border-blue-500 bg-gradient-to-br from-white to-blue-50/30 p-4 shadow-sm">
                    <div class="text-[10px] font-black text-blue-600 mb-1 uppercase tracking-widest">PTASKs</div>
                    <div class="text-4xl font-black text-slate-800">${totalPtasks}</div>
                    <div class="text-[9px] text-slate-400 mt-2 uppercase">Tarefas Vinculadas</div>
                </div>
                <div class="report-card text-center border-t-4 border-emerald-500 bg-gradient-to-br from-white to-emerald-50/30 p-4 shadow-sm">
                    <div class="text-[10px] font-black text-emerald-600 mb-1 uppercase tracking-widest">Grupos Afetados</div>
                    <div class="text-4xl font-black text-slate-800">${affectedGroups}</div>
                    <div class="text-[9px] text-slate-400 mt-2 uppercase">Setores Resolutores</div>
                </div>
            </div>`;

            // ---------------------------------------------------------------
            // Tabelas Analíticas (RCA Status | Grupo) — apenas PRBs mestres
            // ---------------------------------------------------------------
            if (!window.DrilldownVault) window.DrilldownVault = { class: {} };
            if (!window.DrilldownVault['class']) window.DrilldownVault['class'] = {};

            let rcaByStatus = {};
            let sectorStats = {};
            prbData.filter(t => t.type === 'PRB').forEach(t => {
                let st = t.stRca || '—';
                if (!rcaByStatus[st]) rcaByStatus[st] = { count: 0, tks: [] };
                rcaByStatus[st].count++;
                rcaByStatus[st].tks.push(t);

                let gp = t.gp || '—';
                if (!sectorStats[gp]) sectorStats[gp] = { count: 0, tks: [] };
                sectorStats[gp].count++;
                sectorStats[gp].tks.push(t);
            });

            const buildAnalyticalTable = (title, dataObj, labelCol, icon) => {
                let entries = Object.entries(dataObj).sort((a, b) => b[1].count - a[1].count);
                let rows = entries.slice(0, 10).map(([key, value], idx) => {
                    let dKey = `prb_ana_${labelCol}_${idx}`;
                    window.DrilldownVault['class'][dKey] = value.tks;
                    return `
                    <tr class="hover:bg-slate-50 cursor-pointer transition border-b border-slate-50"
                        onclick="openDrilldown('${key.replace(/'/g, "\\'")}', '${dKey}', 'class')">
                        <td class="py-2 text-[11px] font-bold text-slate-700 text-left pl-2">${key}</td>
                        <td class="py-2 text-right">
                            <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded text-[10px] font-black">${value.count}</span>
                        </td>
                        <td class="py-2 text-right w-8"><i class="fas fa-chevron-right text-slate-300 text-[10px]"></i></td>
                    </tr>`;
                }).join('');
                return `
                <div class="report-card" style="margin-bottom:0;">
                    <div class="report-card-title"><i class="${icon} mr-1"></i> ${title}</div>
                    <div class="st-dataframe-container border-0 max-h-[230px] overflow-y-auto">
                        <table class="w-full">
                            <tbody>${rows || '<tr><td colspan="3" class="text-center py-4 text-slate-400 text-xs">Sem dados.</td></tr>'}</tbody>
                        </table>
                    </div>
                </div>`;
            };

            html += `
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                ${buildAnalyticalTable("PRBs por Status RCA", rcaByStatus, "rca_st", "fas fa-info-circle")}
                ${buildAnalyticalTable("Impacto por Grupo Resolutor", sectorStats, "sector", "fas fa-users")}
            </div>`;

            // ---------------------------------------------------------------
            // TABELA PRINCIPAL HIERÁRQUICA
            // ---------------------------------------------------------------
            let sortedPids = Object.keys(groups)
                .filter(k => k !== '__SEM_PRB__')
                .sort((a, b) => {
                    let aIncs = (groups[a].incs || []).length;
                    let bIncs = (groups[b].incs || []).length;
                    if (bIncs !== aIncs) return bIncs - aIncs;
                    let aTotal = aIncs + (groups[a].ptasks || []).length;
                    let bTotal = bIncs + (groups[b].ptasks || []).length;
                    return bTotal - aTotal || b.localeCompare(a);
                });

            if (groups['__SEM_PRB__'] &&
                (groups['__SEM_PRB__'].incs.length > 0 || groups['__SEM_PRB__'].ptasks.length > 0)) {
                sortedPids.push('__SEM_PRB__');
            }

            // ── Helpers visuais ──────────────────────────────────────────
            const stBadge = (stVal) => {
                let v = String(stVal || '').toUpperCase();
                if (['RESOLVED', 'CLOSED', 'PUBLISHED', 'COMPLETED'].some(s => v.includes(s)))
                    return `<span style="background:#ecfdf5;color:#065f46;border:1px solid #a7f3d0;padding:2px 7px;border-radius:4px;font-size:8.5px;font-weight:800;text-transform:uppercase;">${stVal}</span>`;
                if (v.includes('OPEN') || v.includes('IN PROGRESS') || v.includes('NEW'))
                    return `<span style="background:#fee2e2;color:#b91c1c;border:1px solid #fecaca;padding:2px 7px;border-radius:4px;font-size:8.5px;font-weight:800;text-transform:uppercase;">${stVal}</span>`;
                if (v.includes('HOLD') || v.includes('PENDING') || v.includes('AGUARD'))
                    return `<span style="background:#fef9c3;color:#854d0e;border:1px solid #fde68a;padding:2px 7px;border-radius:4px;font-size:8.5px;font-weight:800;text-transform:uppercase;">${stVal}</span>`;
                return `<span style="background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;padding:2px 7px;border-radius:4px;font-size:8.5px;font-weight:800;text-transform:uppercase;">${stVal || '—'}</span>`;
            };

            const prioBadge = (p) => {
                let v = String(p || '').toUpperCase();
                if (v.includes('1') || v.includes('CRITICAL'))
                    return `<span class="text-[9px] font-black text-red-600">🔴 ${p}</span>`;
                if (v.includes('2') || v.includes('HIGH'))
                    return `<span class="text-[9px] font-black text-orange-500">🟠 ${p}</span>`;
                if (v.includes('3') || v.includes('MEDIUM') || v.includes('MOD'))
                    return `<span class="text-[9px] font-black text-yellow-600">🟡 ${p}</span>`;
                if (p && p !== 'N/A' && p !== '—')
                    return `<span class="text-[9px] text-slate-500 font-bold">${p}</span>`;
                return `<span class="text-[9px] text-slate-300">N/A</span>`;
            };

            const agingBadge = (age) => {
                let a = parseInt(age) || 0;
                let color = a > 30 ? '#ef4444' : a > 14 ? '#f97316' : '#64748b';
                return `<span style="color:${color};font-weight:800;font-size:10px;">${a}d</span>`;
            };

            // ── Construção das linhas ────────────────────────────────────
            let tableRows = '';

            const _maxIncForBadge = sortedPids.length > 0
                ? Math.max(...sortedPids.map(p => (groups[p].incs || []).length))
                : 0;
            let _topBadgeCount = 0;

            sortedPids.forEach(pid => {
                let g = groups[pid];
                let displayPid = pid === '__SEM_PRB__' ? 'SEM PRB' : pid;
                let master = g.master;
                let incs = g.incs;
                let ptasks = g.ptasks;
                let totalChildren = incs.length + ptasks.length;
                let incCount = incs.length;
                let isTopImpact = incCount > 0 && incCount === _maxIncForBadge && _topBadgeCount < 3;
                if (isTopImpact) _topBadgeCount++;

                // ── Linha mestre (PRB) ───────────────────────────────────
                if (master) {
                    let rcaStBadge = master.stRca && master.stRca !== '—'
                        ? `<span style="background:#e0f2fe;color:#0369a1;border:1px solid #bae6fd;padding:2px 6px;border-radius:4px;font-size:8px;font-weight:800;text-transform:uppercase;">${master.stRca}</span>`
                        : '<span style="color:#94a3b8;font-size:9px;">—</span>';
                    let impactBorder = isTopImpact ? 'border-left:4px solid #dc2626;' : 'border-left:4px solid #1d4ed8;';
                    let impactBg = isTopImpact ? 'background:#fff1f2;border-bottom:2px solid #fecaca;' : 'background:#f0f9ff;border-bottom:2px solid #bfdbfe;';
                    let impactBadgeHtml = isTopImpact
                        ? `<span style="margin-left:6px;padding:1px 6px;background:#dc2626;color:#fff;font-size:8px;font-weight:900;border-radius:99px;">🔥 MAIS IMPACTO</span>`
                        : '';

                    tableRows += `
                    <tr style="${impactBg}" data-prb-group="${pid}" data-prb-type="master">
                        <td class="p-3" style="${impactBorder}">
                            <div class="flex flex-col gap-0.5">
                                <div class="flex items-center flex-wrap gap-1">
                                    <span onclick="openTicketDetails('${pid}')" class="ticket-id-clickable font-black text-blue-800 text-sm">${displayPid}</span>${impactBadgeHtml}
                                </div>
                                <span class="text-[8px] text-slate-400 font-bold uppercase"><i class="fas fa-bug mr-1"></i>PROBLEM</span>
                            </div>
                        </td>
                        <td class="p-2 text-center">${stBadge(master.st)}</td>
                        <td class="p-2 text-center">${prioBadge(master.priority)}</td>
                        <td class="p-2 text-left text-[10px] font-semibold text-slate-700 max-w-[200px]">
                            <div class="truncate" title="${master.desc}">${master.desc}</div>
                        </td>
                        <td class="p-2 text-center text-[10px] font-bold text-slate-700">${master.as || '—'}</td>
                        <td class="p-2 text-center text-[10px] font-semibold text-slate-600">
                            <div class="truncate max-w-[150px] mx-auto" title="${master.gp}">${master.gp || '—'}</div>
                        </td>
                        <td class="p-2 text-center">${rcaStBadge}</td>
                        <td class="p-2 text-center text-[10px] text-slate-500">${master.opStr || '—'}</td>
                        <td class="p-2 text-center">${agingBadge(master.age)}</td>
                        <td class="p-2 text-center">
                            <span class="bg-slate-700 text-white text-[9px] font-black px-2 py-0.5 rounded-full">${totalChildren}</span>
                        </td>
                    </tr>`;
                } else {
                    // PRB sem registro mestre
                    tableRows += `
                    <tr style="background:#f8fafc;border-bottom:1px dashed #cbd5e1;" data-prb-group="${pid}" data-prb-type="master">
                        <td class="p-3" style="border-left:4px solid #94a3b8;" colspan="10">
                            <div class="flex items-center gap-3">
                                <span class="font-black text-slate-500 text-sm italic">${displayPid}</span>
                                <span class="text-[9px] text-slate-400 bg-slate-100 px-2 py-0.5 rounded border border-slate-200">
                                    <i class="fas fa-exclamation-circle mr-1"></i>Sem registro mestre no problem_rca.xlsx — ${totalChildren} ticket(s) vinculado(s)
                                </span>
                            </div>
                        </td>
                    </tr>`;
                }

                // ── Linhas filhas: INCs ──────────────────────────────────
                incs.forEach(inc => {
                    let caller = inc.req && inc.req !== 'N/A' ? inc.req : '—';
                    tableRows += `
                    <tr class="hover:bg-red-50/40 transition-colors" style="background:#fff8f8;border-bottom:1px solid #fee2e2;" data-prb-group="${pid}" data-prb-type="child">
                        <td class="p-2 pl-8" style="border-left:4px solid #fca5a5;">
                            <div class="flex flex-col gap-0.5">
                                <span onclick="openTicketDetails('${inc.tk}')" class="ticket-id-clickable font-black text-red-700 text-xs">${inc.tk}</span>
                                <span class="text-[8px] text-red-400 font-bold uppercase">
                                    <i class="fas fa-fire mr-1"></i>INC &nbsp;·&nbsp; <i class="fas fa-user mr-1"></i>${caller}
                                </span>
                            </div>
                        </td>
                        <td class="p-2 text-center">${stBadge(inc.st)}</td>
                        <td class="p-2 text-center">${prioBadge(inc.priority)}</td>
                        <td class="p-2 text-left text-[10px] text-slate-600 max-w-[200px]">
                            <div class="truncate" title="${inc.desc}">${inc.desc}</div>
                        </td>
                        <td class="p-2 text-center text-[10px] text-slate-600">${inc.as || '—'}</td>
                        <td class="p-2 text-center text-[10px] text-slate-500">
                            <div class="truncate max-w-[150px] mx-auto" title="${inc.gp}">${inc.gp || '—'}</div>
                        </td>
                        <td class="p-2 text-center text-[9px] text-slate-300">—</td>
                        <td class="p-2 text-center text-[10px] text-slate-500">${inc.opStr || '—'}</td>
                        <td class="p-2 text-center">${agingBadge(inc.age)}</td>
                        <td class="p-2 text-center text-[9px] text-slate-300">—</td>
                    </tr>`;
                });

                // ── Linhas filhas: PTASKs ────────────────────────────────
                ptasks.forEach(pt => {
                    tableRows += `
