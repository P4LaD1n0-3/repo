        // Função para adaptar dados de PRB para o formato do dashboard
        // Cruza: index.xlsx (RawData.incs – campo Problem) + problem_rca.xlsx (RawData.rca – campos Problem/Number)
        function processPRBDataForDisplay(prbRawData, ptaskRawData, rcaRawData) {

            // ---------------------------------------------------------------
            // ETAPA 1: Mapa de mestres PRB  ←  problem_rca.xlsx  (RawData.rca)
            // O campo identificador do PRB neste arquivo pode ser "Problem" ou "Number"
            // Ambos têm formato PRBxxxxxxx.
            // ---------------------------------------------------------------
            let prbMasterMap = {}; // prbId (ex: "PRB0012345") -> linha bruta do problem_rca.xlsx

            // Primeiro carrega de prbRawData (RawData.prb) — RawData.rca tem prioridade e vai sobrescrever se houver
            // Apenas aceita como master PRB linhas cujo próprio Number começa com 'PRB' (exclui INCs que referenciam PRBs)
            if (prbRawData && prbRawData.length > 0) {
                prbRawData.forEach(row => {
                    let idA = String(getCol(row, ['Number', 'Ticket', 'Número', 'number']) || '').trim().toUpperCase();
                    if (!idA.startsWith('PRB')) return; // Ignora linhas INC/REQ/TASK que referenciam PRBs
                    if (!prbMasterMap[idA]) prbMasterMap[idA] = row;
                });
            }

            if (rcaRawData && rcaRawData.length > 0) {
                rcaRawData.forEach(row => {
                    // Tenta "Problem" primeiro (coluna específica de vínculo), depois "Number"
                    let idA = String(getCol(row, ['Problem', 'Problema', 'problem_id']) || '').trim().toUpperCase();
                    let idB = String(getCol(row, ['Number', 'Ticket', 'Número', 'number']) || '').trim().toUpperCase();
                    let prbId = idA.startsWith('PRB') ? idA : (idB.startsWith('PRB') ? idB : '');
                    if (!prbId) return;
                    prbMasterMap[prbId] = row; // RCA sempre tem prioridade sobre prb.xlsx
                });
            }

            // ---------------------------------------------------------------
            // ETAPA 2: Mapa PRB -> [linhas INC]  ←  index.xlsx  (RawData.incs)
            // Critérios de vínculo (em ordem de prioridade):
            //   a) Campo "Problem" do INC contém PRBxxxxxxx
            //   b) Campo "Related Incidents" do problem_rca contém o número do INC
            //   c) Menção textual PRBxxxxxxx em "Additional comments" do INC
            // ---------------------------------------------------------------
            let prbToIncsMap = {}; // prbId -> Set de linhas brutas de INC (sem duplicata por Number)

            const incSource = (RawData && RawData.incs) ? RawData.incs : [];

            // (a) + (c): percorre todos os INCs
            incSource.forEach(inc => {
                let incNum = String(getCol(inc, ['Number', 'Ticket', 'Número', 'number']) || '').trim().toUpperCase();
                if (!incNum.startsWith('INC')) return;

                // (a) campo direto Problem
                let prbDirect = String(getCol(inc, ['Problem', 'Problema', 'problem_id']) || '').trim().toUpperCase();
                if (prbDirect.startsWith('PRB')) {
                    if (!prbToIncsMap[prbDirect]) prbToIncsMap[prbDirect] = new Map();
                    if (!prbToIncsMap[prbDirect].has(incNum)) prbToIncsMap[prbDirect].set(incNum, inc);
                }

                // (c) varredura textual em Additional comments
                let addComments = String(getCol(inc, ['Additional comments', 'Comentários', 'Work notes', 'Description', 'description']) || '').toUpperCase();
                let extraMatches = addComments.match(/PRB[0-9]+/g) || [];
                extraMatches.forEach(p => {
                    if (!prbToIncsMap[p]) prbToIncsMap[p] = new Map();
                    if (!prbToIncsMap[p].has(incNum)) prbToIncsMap[p].set(incNum, inc);
                });
            });

            // (b) campo "Related Incidents" do problem_rca.xlsx → busca INC em incSource
            Object.entries(prbMasterMap).forEach(([prbId, row]) => {
                let relRaw = String(getCol(row, ['Related Incidents', 'Incidentes Relacionados', 'Tickets Relacionados', 'Related tickets']) || '');
                let relNums = relRaw.split(/[,\s;|]+/).map(s => s.trim().toUpperCase()).filter(s => s.startsWith('INC'));
                relNums.forEach(incNum => {
                    let incRow = incSource.find(x => String(getCol(x, ['Number', 'Ticket', 'Número', 'number']) || '').trim().toUpperCase() === incNum);
                    if (!incRow) return;
                    if (!prbToIncsMap[prbId]) prbToIncsMap[prbId] = new Map();
                    if (!prbToIncsMap[prbId].has(incNum)) prbToIncsMap[prbId].set(incNum, incRow);
                });
            });

            // Converte Maps para arrays
            let prbToIncsArray = {}; // prbId -> [linhas brutas de INC]
            Object.entries(prbToIncsMap).forEach(([pid, m]) => {
                prbToIncsArray[pid] = Array.from(m.values());
            });

            // ---------------------------------------------------------------
            // ETAPA 3: Monta array processado
            // ---------------------------------------------------------------
            let processed = [];
            let seenTickets = new Set();

            // Todos os PRB IDs únicos (mestres + via INCs)
            let allPrbIds = new Set([...Object.keys(prbMasterMap), ...Object.keys(prbToIncsArray)]);

            allPrbIds.forEach(prbId => {
                if (!prbId || !prbId.startsWith('PRB')) return;

                let masterRow = prbMasterMap[prbId] || null;
                let linkedIncs = prbToIncsArray[prbId] || [];

                // ── Linha MESTRE (tipo PRB) ──────────────────────────────
                if (!seenTickets.has(prbId)) {
                    seenTickets.add(prbId);

                    // Datas do problem_rca.xlsx
                    let opD = masterRow ? safeDate(getCol(masterRow, ['Opened', 'Data Abertura', 'Created', 'opened_at'])) : null;
                    let clD = masterRow ? safeDate(getCol(masterRow, ['Closed', 'Data Fechamento', 'Resolved', 'Resolved at'])) : null;
                    let aging = (opD && clD) ? Math.floor((clD - opD) / 86400000)
                        : (opD ? Math.floor((new Date() - opD) / 86400000) : 0);
                    if (aging < 0) aging = 0;

                    // Priority: problem_rca NÃO tem essa coluna → deriva do INC com maior criticidade
                    let prioVal = 'N/A';
                    let masterPrio = masterRow ? getCol(masterRow, ['Priority', 'Prioridade', 'priority']) : null;
                    if (masterRow && masterPrio) {
                        prioVal = String(masterPrio).trim();
                    } else if (linkedIncs.length > 0) {
                        // Pega a maior prioridade (menor número) entre os INCs filhos
                        let prioNums = linkedIncs
                            .map(inc => parseInt(String(getCol(inc, ['Priority', 'Prioridade', 'priority']) || '99').replace(/[^0-9]/g, '')) || 99)
                            .filter(n => n < 99);
                        if (prioNums.length > 0) {
                            let minPrio = Math.min(...prioNums);
                            // Reconstroi o label a partir do primeiro INC que bate
                            let refInc = linkedIncs.find(inc => {
                                let p = String(getCol(inc, ['Priority', 'Prioridade', 'priority']) || '');
                                return p.includes(String(minPrio));
                            });
                            prioVal = refInc ? String(getCol(refInc, ['Priority', 'Prioridade', 'priority'])).trim() : String(minPrio);
                        }
                    }

                    processed.push({
                        tk: prbId,
                        prb: prbId,
                        type: 'PRB',
                        st: masterRow ? String(getCol(masterRow, ['State', 'Status', 'Estado', 'status']) || 'Open').toUpperCase() : 'OPEN',
                        stRca: masterRow ? String(getCol(masterRow, ['RCA Status', 'rca_status']) || '—').trim() : '—',
                        gp: masterRow ? String(getCol(masterRow, ['Assignment group', 'Grupo', 'Group', 'assignment_group']) || '—').trim() : '—',
                        as: masterRow ? String(getCol(masterRow, ['Assigned to', 'Analista', 'Assignee', 'assigned_to']) || '—').trim() : '—',
                        priority: prioVal,
                        desc: masterRow ? String(getCol(masterRow, ['Short description', 'Descrição', 'Assunto']) || '—').trim() : '—',
                        ci: masterRow ? String(getCol(masterRow, ['Configuration item', 'CI', 'Item de configuracao']) || '—').trim() : '—',
                        related_incidents_raw: masterRow ? String(getCol(masterRow, ['Related Incidents', 'Incidentes Relacionados']) || '—').trim() : '—',
                        rca_due: masterRow ? String(getCol(masterRow, ['RCA Due Date', 'Prazo RCA']) || '—').trim() : '—',
                        rca_pub: masterRow ? String(getCol(masterRow, ['RCA Published Date', 'Data RCA']) || '—').trim() : '—',
                        age: aging,
                        opStr: opD ? opD.toLocaleDateString('pt-BR') : '—',
                        clStr: clD ? clD.toLocaleDateString('pt-BR') : '—',
                        req: masterRow ? String(getCol(masterRow, ['Caller', 'Requester', 'Solicitante']) || 'N/A').trim() : 'N/A',
                        inc_count: linkedIncs.length   // usado internamente; exibido na coluna Filhos via groups
                    });
                }

                // ── Linhas FILHAS (tipo INC) ─────────────────────────────
                linkedIncs.forEach(inc => {
                    let incNum = String(getCol(inc, ['Number', 'Ticket', 'Número', 'number']) || '').trim().toUpperCase();
                    if (!incNum || seenTickets.has(incNum)) return;
                    seenTickets.add(incNum);

                    let opD = safeDate(getCol(inc, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                    // index.xlsx usa "Resolved" para INCs fechados
                    let clD = safeDate(getCol(inc, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']) || '');
                    let aging = (opD && clD) ? Math.floor((clD - opD) / 86400000)
                        : (opD ? Math.floor((new Date() - opD) / 86400000) : 0);
                    if (aging < 0) aging = 0;

                    // Grupo: prioriza o do INC (Assignment group do index.xlsx)
                    let gpInc = String(getCol(inc, ['Assignment group', 'Grupo', 'Group', 'assignment_group']) || '—').trim();

                    // Caller / Solicitante: campo exato "Caller" do index.xlsx
                    let caller = String(getCol(inc, ['Caller', 'Requester', 'Solicitante']) || 'N/A').trim();

                    // Priority: campo exato "Priority" do index.xlsx
                    let priority = String(getCol(inc, ['Priority', 'Prioridade', 'priority']) || 'N/A').trim();

                    processed.push({
                        tk: incNum,
                        prb: prbId,   // vínculo correto com o pai
                        type: 'INC',
                        st: String(getCol(inc, ['State', 'Status', 'Estado', 'status']) || 'Open').toUpperCase(),
                        stRca: '—',
                        gp: gpInc,
                        as: String(getCol(inc, ['Assigned to', 'Analista', 'Assignee', 'assigned_to']) || '—').trim(),
                        req: caller,  // para o modal e a sub-linha
                        priority: priority,
                        desc: String(getCol(inc, ['Short description', 'Descrição', 'Assunto']) || '—').trim(),
                        ci: String(getCol(inc, ['Configuration item', 'CI', 'Item de configuracao']) || '—').trim(),
                        related_incidents_raw: '—',
                        rca_due: '—',
                        rca_pub: '—',
                        age: aging,
                        opStr: opD ? opD.toLocaleDateString('pt-BR') : '—',
                        clStr: clD ? clD.toLocaleDateString('pt-BR') : '—'
                    });
                });
            });

            // ── PTASKs ──────────────────────────────────────────────────
            let _ptasksAdded = 0;
            if (ptaskRawData && ptaskRawData.length > 0) {
                ptaskRawData.forEach((row, _ptIdx) => {
                    let number = String(getCol(row, ['Number', 'Ticket', 'Número', 'number', 'Task Number', 'PTASK', 'task_number']) || '').trim().toUpperCase();
                    let prb = String(getCol(row, ['Problem', 'Problema', 'problem_id', 'PRB', 'Parent']) || '').trim().toUpperCase();
                    if (!number && prb.startsWith('PRB')) number = 'PTASK_' + prb + '_' + (_ptIdx + 1);
                    if (!number || seenTickets.has(number)) return;
                    seenTickets.add(number);
                    _ptasksAdded++;

                    let opD = safeDate(getCol(row, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                    let clD = safeDate(getCol(row, ['Closed', 'Data Fechamento', 'Resolved', 'Resolved at']) || '');
                    let aging = (opD && clD) ? Math.floor((clD - opD) / 86400000)
                        : (opD ? Math.floor((new Date() - opD) / 86400000) : 0);
                    if (aging < 0) aging = 0;

                    processed.push({
                        tk: number,
                        prb: prb || '—',
                        type: 'PTASK',
                        st: String(getCol(row, ['State', 'Status', 'Estado', 'status']) || 'Open').toUpperCase(),
                        stRca: '—',
                        gp: String(getCol(row, ['Assignment group', 'Grupo', 'Group', 'assignment_group']) || '—').trim(),
                        as: String(getCol(row, ['Assigned to', 'Analista', 'Assignee', 'assigned_to']) || '—').trim(),
                        req: String(getCol(row, ['Caller', 'Requester', 'Solicitante']) || 'N/A').trim(),
                        priority: String(getCol(row, ['Priority', 'Prioridade', 'priority']) || 'N/A').trim(),
                        desc: String(getCol(row, ['Short description', 'Descrição', 'Assunto']) || '—').trim(),
                        ci: String(getCol(row, ['Configuration item', 'CI', 'Item de configuracao']) || '—').trim(),
                        related_incidents_raw: '—',
                        rca_due: '—',
                        rca_pub: '—',
                        age: aging,
                        opStr: opD ? opD.toLocaleDateString('pt-BR') : '—',
                        clStr: clD ? clD.toLocaleDateString('pt-BR') : '—'
                    });
                });
            }

            // ── Fallback: extrai PTASKs embutidos nas linhas de rcaRawData quando não há arquivo ptask separado ──
            // Cada linha de problem_rca.xlsx que contém colunas de tarefa (State, Opened, Configuration item)
            // é tratada como 1 PTASK vinculada ao seu PRB pai.
            // Também dispara quando ptaskRawData existia mas nenhuma PTASK foi efetivamente adicionada.
            if ((_ptasksAdded === 0) && rcaRawData && rcaRawData.length > 0) {
                rcaRawData.forEach(row => {
                    let prbId = String(getCol(row, ['Problem', 'Problema', 'problem_id']) || '').trim().toUpperCase();
                    if (!prbId.startsWith('PRB')) return;
                    let taskState = getCol(row, ['State', 'Status', 'Estado', 'status']);
                    if (!taskState) return;
                    let synthNum = 'PTASK' + prbId.replace('PRB', '');
                    if (seenTickets.has(synthNum)) return;
                    seenTickets.add(synthNum);
                    let opD = safeDate(getCol(row, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                    let clD = safeDate(getCol(row, ['Closed', 'Data Fechamento', 'Resolved', 'Resolved at']));
                    let aging = (opD && clD) ? Math.floor((clD - opD) / 86400000)
                        : (opD ? Math.floor((new Date() - opD) / 86400000) : 0);
                    if (aging < 0) aging = 0;
                    processed.push({
                        tk: synthNum,
                        prb: prbId,
                        type: 'PTASK',
                        st: String(taskState).toUpperCase(),
                        stRca: '—',
                        gp: String(getCol(row, ['Assignment group.1', 'Assignment group', 'Grupo', 'assignment_group']) || '—').trim(),
                        as: String(getCol(row, ['Assigned to.1', 'Assigned to', 'Analista']) || '—').trim(),
                        req: 'N/A',
                        priority: String(getCol(row, ['Priority', 'Prioridade', 'priority']) || 'N/A').trim(),
                        desc: String(getCol(row, ['Short description', 'Descrição', 'Assunto']) || '—').trim(),
                        ci: String(getCol(row, ['Configuration item', 'CI', 'Item de configuracao']) || '—').trim(),
                        related_incidents_raw: '—',
                        rca_due: '—',
                        rca_pub: '—',
                        age: aging,
                        opStr: opD ? opD.toLocaleDateString('pt-BR') : '—',
                        clStr: clD ? clD.toLocaleDateString('pt-BR') : '—'
                    });
                });
            }

            return processed;
        }

        function generatePRBTab(rcaData, ptaskData, slaRCA, slaPTask, refDateObj) {
            const refDate = new Date(refDateObj); refDate.setHours(23, 59, 59, 999); const refTime = refDate.getTime();

            // --- NOVO: Rastreamento Robusto de PRB -> INCs (Herança / Reuso) ---
            // Analisa todas as INCs em busca de PRBs mencionados em qualquer campo de texto
            let globalPrbToIncsMap = {};
            if (RawData && RawData.incs) {
                RawData.incs.forEach(inc => {
                    let incNum = (getCol(inc, ['Number', 'Ticket', 'Número']) || '').trim().toUpperCase();
                    if (!incNum) return;

                    let incPrbRaw = String(getCol(inc, ['Problem', 'Problema', 'Problem ID', 'problem_id']) || '').toUpperCase();
                    let incShortDesc = String(getCol(inc, ['Short description', 'Descrição', 'Assunto']) || '').toUpperCase();
                    let incNotes = String(getCol(inc, ['Work notes', 'Additional comments', 'Comentários', 'Description']) || '').toUpperCase();

                    let combinedIncText = `${incPrbRaw} ${incShortDesc} ${incNotes}`;
                    // Tenta capturar múltiplos PRBs mencionados (resolve casos como "RITM9889436/PRB0113800")
                    let prbMatches = combinedIncText.match(/PRB[0-9]+/g) || [];

                    let uniquePrbs = [...new Set(prbMatches)];
                    uniquePrbs.forEach(pNum => {
                        if (!globalPrbToIncsMap[pNum]) globalPrbToIncsMap[pNum] = [];
                        globalPrbToIncsMap[pNum].push(inc);
                    });
                });
            }
            // ------------------------------------------------------------------

            let allPrbs = [];
            let allPtasks = [];
            let rcaOpenBySector = {}; // For filtering RCA != Published

            rcaData.forEach(r => {
                let tk = getCol(r, ['Problem', 'Number', 'PRB', 'ID', 'Ticket']) || '-';
                let op = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                if (!op || op.getTime() > refTime) return;

                let clOrig = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                let stOrig = String(getCol(r, ['RCA Status', 'State', 'Status', 'Estado']) || '').toUpperCase();
                let st = stOrig.toLowerCase();

                // Filtro: manter abertos ou não publicados
                if (clOrig && clOrig.getTime() <= refTime) {
                    if (st.includes('clos') || st.includes('resolv') || st.includes('cancel') || st.includes('fech')) return;
                }

                let age = Math.floor((refDate - op) / 86400000);
                if (age < 0) age = 0;
                let asg = getCol(r, ['Assigned to', 'Analista', 'Assignee']) || '-';
                let gp = getCol(r, ['Assignment group', 'Grupo', 'Group']) || '-';
                let idle = (!clOrig || clOrig.getTime() > refDateObj.getTime()) ? getDaysSilent(r, refDateObj, asg, op) : '-';
                let descClean = String(getCol(r, ['Short description', 'Descrição']) || '-').replace(/"/g, '&quot;');

                // Metadata extraction
                let workNotes = String(getCol(r, ['Work notes', 'Work Notes', 'Work notes list', 'Additional comments']) || '');
                let shortDesc = String(getCol(r, ['Short description', 'Descrição']) || '');
                let combinedText = shortDesc + " " + workNotes;

                let vRel = extractFromComments(combinedText, 'release');
                let dRel = extractFromComments(combinedText, 'deploy');

                // RCA Indicators logic
                let isRcaOpen = stOrig !== "PUBLISHED" && stOrig !== "PUBLISHED/COMPLETED";
                if (isRcaOpen) {
                    if (!rcaOpenBySector[gp]) rcaOpenBySector[gp] = { count: 0, tks: [] };
                    rcaOpenBySector[gp].count++;
                }

                // Contagem de Tickets Associados em Incs
                let associatedIncs = [];
                const slaIncs = parseInt(document.getElementById('sla-incs')?.value) || 7;
                const tkNormalized = tk.trim().toUpperCase();

                // 1. Extração direta da coluna 'Related Incidents' da extração de PRB
                let relCols = ['Related Incidents', 'Incidentes Relacionados', 'Tickets Relacionados', 'Related tickets'];
                let relRaw = getCol(r, relCols);
                let relList = relRaw ? relRaw.split(/[,\s;]+/).map(s => s.trim().toUpperCase()).filter(s => s.startsWith('INC')) : [];

                if (RawData && RawData.incs) {
                    // Busca tickets explicitamente mencionados na coluna do PRB
                    let explicitIncs = RawData.incs.filter(inc => {
                        let incNum = (getCol(inc, ['Number', 'Ticket', 'Número']) || '').trim().toUpperCase();
                        return relList.includes(incNum);
                    });

                    // Busca tickets do mapeamento global via Regex (Herança / Reuso)
                    let mappedIncs = globalPrbToIncsMap[tkNormalized] || [];

                    // Busca tickets que o próprio PRB menciona inversamente no seu texto
                    let prbIncMatches = combinedText.toUpperCase().match(/INC[0-9]+/g) || [];
                    let prbMentionedIncs = [];
                    if (prbIncMatches.length > 0) {
                        prbMentionedIncs = RawData.incs.filter(inc => {
                            let incNum = (getCol(inc, ['Number', 'Ticket', 'Número']) || '').trim().toUpperCase();
                            return prbIncMatches.includes(incNum);
                        });
                    }

                    // Unifica e remove duplicatas
                    const seen = new Set();
                    associatedIncs = [...explicitIncs, ...mappedIncs, ...prbMentionedIncs].filter(inc => {
                        let num = (getCol(inc, ['Number', 'Ticket', 'Número']) || '-').trim().toUpperCase();
                        if (seen.has(num)) return false;
                        seen.add(num);
                        return true;
                    }).map(inc => {
                        let iOp = safeDate(getCol(inc, ['Opened', 'Data Abertura', 'Created']));
                        let iAge = iOp ? Math.floor((refDate - iOp) / 86400000) : 0;
