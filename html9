                        let pctNum = (iAge / slaIncs) * 100;
                        let stSla = iAge > slaIncs ? 'FORA DO PRAZO' : 'DENTRO DO PRAZO';

                        return {
                            tk: getCol(inc, ['Number', 'Ticket', 'Número']) || '-',
                            desc: String(getCol(inc, ['Short description', 'Descrição']) || '-'),
                            req: getCol(inc, ['Requester', 'Caller', 'Solicitante']) || 'N/A',
