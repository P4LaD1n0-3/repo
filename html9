        function addTodo() {
            const analyst = document.getElementById('todo-analyst').value;
            const selectTk = document.getElementById('todo-tickets');
            const desc = document.getElementById('todo-desc').value;

            if (!analyst || !desc.trim()) return alert("Selecione um analista e preencha a descrição da tarefa.");

            let selectedTks = Array.from(selectTk.selectedOptions).map(opt => opt.value);
            if (selectedTks.length === 0) selectedTks = [null];

            selectedTks.forEach(tk => {
                let existing = tk ? todoList.find(t => t.ticket === tk && t.analyst === analyst) : null;
                if (existing) {
                    existing.history.push({ text: desc, date: new Date().toLocaleString('pt-BR'), striked: false });
                } else {
                    todoList.push({
                        id: Date.now().toString() + Math.random().toString(36).substr(2, 9),
                        analyst: analyst,
                        ticket: tk,
                        date: new Date().toLocaleDateString('pt-BR'),
                        history: [{ text: desc, date: new Date().toLocaleString('pt-BR'), striked: false }]
                    });
                }
            });

            saveTodos();
            document.getElementById('todo-desc').value = '';
            selectTk.selectedIndex = -1;
        }

