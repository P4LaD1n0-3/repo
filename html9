                        const cI = window.ComparisonData.inc || { backlog: 0, resMes: 0, inSla: 0, outSla: 0, pct: "0,00", mttr: "0,00" };
                        const cR = window.ComparisonData.req || { backlog: 0, resMes: 0, inSla: 0, outSla: 0, pct: "0,00", mttr: "0,00" };
