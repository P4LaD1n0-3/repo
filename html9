                        btn.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
                        btn.classList.remove('bg-white', 'border-slate-300', 'text-slate-600');
                    }
                    const fromEl = document.getElementById('cons-trend-from');
                    const toEl = document.getElementById('cons-trend-to');
                    if (fromEl) fromEl.value = '';
                    if (toEl) toEl.value = '';
                    const fd = window._consTrendFullData;
                    const keys = n === 0 ? fd.sortedTrendM.slice() : fd.sortedTrendM.slice(-n);
                    _applyTrendFilter(keys);
                };

                window.filterConsTrendRange = function () {
                    const fromEl = document.getElementById('cons-trend-from');
                    const toEl = document.getElementById('cons-trend-to');
                    const fromVal = (fromEl?.value || '').trim();
                    const toVal = (toEl?.value || '').trim();
                    if (!fromVal && !toVal) return;
                    document.querySelectorAll('.cons-trend-btn').forEach(b => {
                        b.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
                        b.classList.add('bg-white', 'border-slate-300', 'text-slate-600');
                    });
                    const fd = window._consTrendFullData;
                    let keys = fd.sortedTrendM.slice();
                    if (fromVal) keys = keys.filter(k => k >= fromVal);
                    if (toVal) keys = keys.filter(k => k <= toVal);
                    if (keys.length) _applyTrendFilter(keys);
                };

                window.refreshConsTrend = function() {
                    const fd = window._consTrendFullData;
                    if (fd && fd._activeKeys) {
                        _applyTrendFilter(fd._activeKeys);
                    }
                };

                window.clearConsTrendRange = function () {
                    const fromEl = document.getElementById('cons-trend-from');
                    const toEl = document.getElementById('cons-trend-to');
                    if (fromEl) fromEl.value = '';
                    if (toEl) toEl.value = '';
                    const allBtn = document.querySelector('.cons-trend-btn[onclick*="filterConsTrend(0"]');
                    window.filterConsTrend(0, allBtn);
                };

