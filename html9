                        <span class="text-[11px] font-extrabold text-blue-600">${valHoje}${label}</span>
                    </div>
                </div>`;
            };

            let noPrbHtml = typeStr === 'INC' && d.noPrb.length > 0 ? `
            <div class="report-card" style="margin-top:20px; border-color: ${C.PRI_D};">
                <div class="report-card-title" style="color:${C.PRI_D}"><i class="fas fa-exclamation-triangle mr-2"></i> INCIDENTES CRÍTICOS SEM PRB (${d.noPrb.length})</div>
                <div class="st-dataframe-container"><table class="st-table">
                <thead><tr>
                    ${createTh("Ticket", "12%")} ${createTh("Assunto / Info", "auto", "left")} ${createTh("Analista", "18%")} ${createTh("AGING", "15%", "right")}
                </tr></thead>
                <tbody>${d.noPrb.map(t => `
                    <tr class="ticket-row" ${buildDataAttrs(t)}>
                        <td data-label="Ticket" style="color:${C.PRI_D}; font-weight:bold;">
                            ${t.tk}
                            <button onclick="openTicketDetails('${t.tk}')" class="mt-2 w-full text-center bg-blue-50/50 hover:bg-blue-100 text-[var(--primary-dark)] border border-blue-200/50 hover:border-blue-300 rounded py-1 px-2 text-[9px] uppercase font-bold transition-colors shadow-sm"><i class="fas fa-history mr-1"></i> Saiba mais</button>
                        </td>
                        <td data-label="Assunto / Info" style="text-align:left;">
                            <div class="text-expandable text-xs font-semibold text-slate-800 mb-1" style="-webkit-line-clamp: 1;">${t.desc}</div>
                            ${t.longDesc && t.longDesc !== '-' ? `<div class="text-expandable text-[10px] text-slate-600 mb-1" style="-webkit-line-clamp: 1;">${t.longDesc}</div>` : ''}
                            <div class="text-expandable text-[10px] text-slate-500"><strong class="text-slate-600">Info:</strong> ${t.info} ${t.reason ? `(${t.reason})` : ''}</div>
                        </td>
                        <td data-label="Analista">${t.as}</td>
                        <td data-label="AGING" style="text-align: right;">
                            <div style="color:${C.DAN}; font-weight:bold; font-size:13px;">${t.age}d totais</div>
                            ${(t.idle !== '-' && !isNaN(Number(t.idle))) ? `<div style="font-size:10px; font-weight:bold; margin-top:2px; color:${Number(t.idle) > 3 ? '#ef4444' : '#10b981'};"><i class="fas fa-user-clock"></i> ${t.idle}d ocioso</div>` : `<div style="font-size:10px; color:#94a3b8; margin-top:2px;"><i class="fas fa-user-clock"></i> N/A</div>`}
                        </td>
                    </tr>`).join('')}
                </tbody></table></div>
            </div>` : "";

            return `
            <div class="report-section-title" style="background-color: ${color};"><i class="fas fa-chart-line mr-2"></i> ${title}</div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                <div class="report-card clickable-card" style="text-align:center;" onclick="openDrilldown('Backlog Vigente (${typeStr})', 'all_backlog', '${cat}')" title="Clique para ver o backlog">
                    <div class="report-card-title"><i class="fas fa-layer-group"></i> VOLUME EM BACKLOG</div>
                    <div style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                        <div style="font-size:13px; font-weight:bold; color:${C.GRY_D}; text-transform:uppercase; margin-bottom:5px;">CONSOLIDADO DO MÊS</div>
                        <div style="font-size:32px; font-weight:800; color:${C.PRI_D}; line-height:1;">${d.backlog}</div>
                        ${comp ? `
                        <div class="mt-3 pt-2 border-t border-blue-100 bg-blue-50/30 rounded">
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">SITUAÇÃO PRESENTE (HOJE):</span>
                            <span class="text-lg font-black text-blue-600 ml-1">${comp.backlog}</span>
                        </div>` : ""}
                    </div>
