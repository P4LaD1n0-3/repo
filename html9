                            ${t.longDesc && t.longDesc !== '-' ? `<div class="text-expandable text-[10px] text-slate-500 mb-1" style="-webkit-line-clamp: 2;">${t.longDesc}</div>` : ''}
                            ${t.info || t.reason ? `<div class="text-[10px] text-amber-700 font-medium leading-tight mt-1 bg-amber-50 p-1 rounded border border-amber-100"><i class="fas fa-exclamation-circle"></i> <b>Atenção:</b> ${t.info} ${t.reason ? `(${t.reason})` : ''}</div>` : ''}
                        </td>
                        <td data-label="Requester" class="text-center">${t.req}</td>
                        <td data-label="Analista" class="text-center font-medium">${t.as}</td>
                        <td data-label="Grupo" class="text-center"><span class="text-[11px] bg-slate-100 px-2 py-1 rounded border border-slate-200 block max-w-[150px] mx-auto truncate" title="${t.gp}">${t.gp}</span></td>
