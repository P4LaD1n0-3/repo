            return html;
        }

        window.filterOpenTickets = function (term) {
            const input = document.querySelector('#tab-open input[onkeyup*="filterOpenTickets"]');
            if (input && input.value !== term) {
                input.value = term;
            }
            const cleanTerm = term.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
            document.querySelectorAll('#tab-open details.saas-accordion').forEach(acc => {
                let hasVisibleRow = false;
                const rows = acc.querySelectorAll('tbody tr');

                rows.forEach(tr => {
                    const text = tr.innerText.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                    if (text.includes(cleanTerm)) {
                        tr.style.display = '';
                        hasVisibleRow = true;
                    } else {
                        tr.style.display = 'none';
                    }
                });

                if (hasVisibleRow) {
                    acc.style.display = '';
                    if (cleanTerm.length > 0) acc.setAttribute('open', '');
                } else {
                    acc.style.display = 'none';
                }
            });
        };

        function buildThroughputTable(d, lblRes) {
            let rows = "", tA = 0, tR = 0, tC = 0, tS = 0, lastB = 0;
            let keys = Object.keys(d.trendM).sort();
            keys.forEach((k) => {
                let m = d.trendM[k];
                let mesStr = new Date(k.split('-')[0], k.split('-')[1] - 1, 1).toLocaleString('pt-BR', { month: 'short', year: 'numeric' }).toUpperCase().replace('.', '');
                let saldo = m.a - (m.r + m.c);
                let pctVal = m.r > 0 ? (m.inSla / m.r) * 100 : 0;
                let pctStr = pctVal.toFixed(2).replace('.', ',');
                let bgPct = pctVal >= 98 ? C.SUC : C.DAN;
                let colorS = saldo > 0 ? C.PRI_D : (saldo < 0 ? C.PRI : C.GRY_D);
                tA += m.a; tR += m.r; tC += m.c; tS += saldo; lastB = m.b;
                rows += `<tr>
                    <td data-label="Mês" style="text-align:center; font-weight:600;">${mesStr}</td>
                    <td data-label="Abertos">${m.a}</td>
                    <td data-label="${lblRes}">${m.r}</td>
                    <td data-label="Cancelados">${m.c}</td>
                    <td data-label="Saldo" style="color:${colorS}; font-weight:bold;">${saldo > 0 ? '+' + saldo : saldo}</td>
                    <td data-label="Backlog" style="font-weight:bold;">${m.b}</td>
                    <td data-label="% no Prazo" style="background-color:${bgPct}; color:#fff; font-weight:bold;">${pctStr}%</td>
                </tr>`;
            });
            return `<div class="st-dataframe-container"><table class="st-table">
                <thead><tr>
                    ${createTh("Mês")} ${createTh("Abertos")} ${createTh(lblRes)} ${createTh("Cancelados")} ${createTh("Saldo")} ${createTh("Backlog")} ${createTh("% no Prazo")}
                </tr></thead>
                <tbody>${rows || `<tr><td colspan="7" style="text-align:center;">Sem histórico.</td></tr>`}</tbody>
                <tfoot><tr>
                    <th data-label="TOTAIS:" style="text-align:right;">TOTAIS:</th>
                    <th data-label="Abertos">${tA}</th> <th data-label="${lblRes}">${tR}</th> <th data-label="Cancelados">${tC}</th>
                    <th data-label="Saldo" style="color:${tS > 0 ? C.PRI_D : C.PRI}; font-weight:bold;">${tS > 0 ? '+' + tS : tS}</th>
                    <th data-label="Backlog">${lastB}</th> <th data-label="% no Prazo">-</th>
                </tr></tfoot>
            </table></div>`;
        }

        function generateSectionHTML(id, title, color, d, typeStr) {
            let cat = id;
            window.DrilldownVault[cat]['all_backlog'] = d.allBacklogTks;
            window.DrilldownVault[cat]['all_res_month'] = d.allResolvedTks;
            window.DrilldownVault[cat]['all_canc_month'] = d.allCanceledTks;

            let lblRes = typeStr === 'INC' ? 'Resolvidos' : 'Encerrados';
            let pctColor = parseFloat(String(d.pct).replace(',', '.')) >= 98 ? C.SUC : C.DAN;

            // Lógica de Comparação
            let comp = window.isComparisonActive ? window.ComparisonData[cat] : null;

            const renderComparison = (valHoje, label = "") => {
