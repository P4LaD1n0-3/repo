        async function exportTodosToPDF() {
            if (todoList.length === 0) return alert("Não existem tarefas ativas para exportar no momento.");

            const { jsPDF } = window.jspdf;
            const doc = jsPDF({ orientation: 'l', unit: 'mm', format: 'a4' });
            const today = new Date().toLocaleDateString('pt-BR');
            const now = new Date().toLocaleString('pt-BR');

            // --- CONFIGURAÇÃO VISUAL --- 
            const primaryColor = [30, 58, 138]; // #1E3A8A
            const accentColor = [0, 24, 113];   // #001871
            const textColor = [30, 41, 59];    // #1E293B

            // --- CABEÇALHO ---
            doc.setFillColor(...primaryColor);
            doc.rect(0, 0, 210, 40, 'F');

            doc.setTextColor(255, 255, 255);
            doc.setFont("helvetica", "bold");
            doc.setFontSize(22);
            doc.text("DAILY REPORT / PLANEJAMENTO TODO", 105, 20, { align: 'center' });

            doc.setFontSize(10);
            doc.setFont("helvetica", "normal");
            doc.text(`Gerado em: ${now}`, 105, 30, { align: 'center' });

            // --- AGRUPAMENTO POR ANALISTA ---
            let groups = {};
            todoList.forEach(t => {
                if (!groups[t.analyst]) groups[t.analyst] = [];
                groups[t.analyst].push(t);
            });

            let startY = 50;

            for (let analyst in groups) {
                // Título do Analista
                doc.setDrawColor(226, 232, 240);
                doc.setFillColor(248, 250, 252);
                doc.rect(14, startY - 5, 182, 10, 'FD');

                doc.setTextColor(...accentColor);
                doc.setFont("helvetica", "bold");
                doc.setFontSize(12);
                doc.text(`ANALISTA: ${analyst.toUpperCase()}`, 20, startY + 1.5);

                const analystTodos = groups[analyst];
                const tableData = [];

                let activeHeaders = ['Ticket'];
                if (dynamicExportConfig.Contexto) activeHeaders.push('Contexto');
                if (dynamicExportConfig.Aging) activeHeaders.push('Aging');
                if (dynamicExportConfig['SLA%']) activeHeaders.push('SLA%');
                if (dynamicExportConfig.Status) activeHeaders.push('Status');
                dynamicExportConfig.CustomFields.forEach(f => activeHeaders.push(f));
                activeHeaders.push('Ações / Histórico');

                let colIdxSLA = activeHeaders.indexOf('SLA%');
                let colIdxStatus = activeHeaders.indexOf('Status');
                let colIdxAcoes = activeHeaders.indexOf('Ações / Histórico');

                let colStylesObj = {
                    0: { cellWidth: 22, fontStyle: 'bold', halign: 'center' }
                };
                if (dynamicExportConfig.Contexto) colStylesObj[activeHeaders.indexOf('Contexto')] = { cellWidth: 50, fontSize: 6.5 };
                if (dynamicExportConfig.Aging) colStylesObj[activeHeaders.indexOf('Aging')] = { cellWidth: 12, halign: 'center', fontSize: 6.5 };
                if (dynamicExportConfig['SLA%']) colStylesObj[activeHeaders.indexOf('SLA%')] = { cellWidth: 15, halign: 'center', fontSize: 6.5 };
                if (dynamicExportConfig.Status) colStylesObj[activeHeaders.indexOf('Status')] = { cellWidth: 18, halign: 'center', fontStyle: 'bold', fontSize: 6.5 };
                dynamicExportConfig.CustomFields.forEach(f => {
                    colStylesObj[activeHeaders.indexOf(f)] = { cellWidth: 'auto', fontSize: 6.5 };
                });
                colStylesObj[colIdxAcoes] = { cellWidth: 'auto', fontSize: 6.5 };

                analystTodos.forEach(t => {
                    const ticketToUse = (t.ticket && !t.ticket.includes('undefined')) ? t.ticket : 'Geral';
                    let context = '-';
                    let slaConfig = 10; // Default
                    let age = 0;
                    let rec = null;

                    let opD = null;
                    let clD = null;

                    if (ticketToUse !== 'Geral') {
                        rec = findTicketRecord(ticketToUse);
                        if (rec) {
                            context = getCol(rec, ['Short description', 'Descrição Curta', 'Descrição', 'Item']) || '-';
                            opD = safeDate(getCol(rec, ['Opened', 'opened_at', 'Data Abertura', 'Created']));
                            clD = safeDate(getCol(rec, ['Resolved', 'Closed', 'Resolved at', 'Data Fechamento']));
                            let isInc = (ticketToUse.toUpperCase().startsWith('INC'));
                            slaConfig = isInc ? (parseInt(document.getElementById('sla-incs').value) || 7) : (parseInt(document.getElementById('sla-reqs').value) || 10);
                        }
                    }

                    if (!opD && t.date) {
                        let parts = t.date.split('/');
                        if (parts.length === 3) opD = new Date(parts[2], parts[1] - 1, parts[0], 12, 0, 0);
                    }

                    if (opD) {
                        age = clD ? Math.floor((clD - opD) / 86400000) : Math.floor((new Date() - opD) / 86400000);
                        if (isNaN(age) || age < 0) age = 0;
                    }

                    // Cálculo de Status
                    let status = 'Pendente';
                    const total = t.history.length;
                    const done = t.history.filter(h => h.striked).length;
                    if (total > 0) {
                        if (done === total) status = 'Efetuada';
                        else if (done > 0) status = 'Parcialmente Efetuada';
                    }

                    // Porcentagem SLA
                    let pctSla = (isNaN(age) || isNaN(slaConfig) || slaConfig === 0) ? 0 : Math.min(Math.round((age / slaConfig) * 100), 150);
                    if (isNaN(pctSla)) pctSla = 0;

                    // Formatação do Histórico
                    const historyLines = t.history.map(h => h.text);

                    let rowData = [ticketToUse];
                    if (dynamicExportConfig.Contexto) rowData.push(context);
                    if (dynamicExportConfig.Aging) rowData.push(`${age} dias`);
                    if (dynamicExportConfig['SLA%']) rowData.push({ content: `${pctSla}%`, val: pctSla });
                    if (dynamicExportConfig.Status) rowData.push(status);

                    dynamicExportConfig.CustomFields.forEach(f => {
                        let searchKeys = ITIL_STANDARD_HEADERS[f] || [f];
                        if (rec) rowData.push(String(getCol(rec, searchKeys) || '-').slice(0, 80));
                        else rowData.push('-');
                    });

                    rowData.push({
                        content: historyLines.join('\n'),
                        strikedItems: t.history.map(h => h.striked),
                        datesInfo: t.history.map(h => {
                            const splits = h.date ? h.date.split(' ') : [];
                            return (splits[0] && splits[1]) ? `${splits[0].substring(0, 5)} ${splits[1].substring(0, 5)}` : '';
                        })
                    });

                    tableData.push(rowData);
                });

                doc.autoTable({
                    startY: startY + 8,
                    head: [activeHeaders],
                    body: tableData,
                    theme: 'grid',
                    headStyles: {
                        fillColor: primaryColor,
                        textColor: [255, 255, 255],
                        fontSize: 7,
                        fontStyle: 'bold',
                        halign: 'center'
                    },
                    columnStyles: colStylesObj,
                    styles: {
                        fontSize: 7,
                        cellPadding: 3,
                        valign: 'middle',
                        overflow: 'linebreak'
                    },
                    margin: { left: 14, right: 14 },
                    didParseCell: (data) => {
                        if (data.section === 'body' && data.column.index === colIdxAcoes) {
                            data.cell.styles.cellPadding = { top: 3, right: 3, bottom: 3, left: 18 };
                        }
                    },
                    willDrawCell: (data) => {
                        if (colIdxStatus !== -1 && data.section === 'body' && data.column.index === colIdxStatus) {
                            const val = data.cell.raw;
                            if (val === 'Efetuada') {
                                data.cell.styles.fillColor = [20, 150, 80]; // Verde
                                data.cell.styles.textColor = [255, 255, 255];
                            } else if (val === 'Parcialmente Efetuada') {
                                data.cell.styles.fillColor = [255, 140, 0]; // Laranja
                                data.cell.styles.textColor = [255, 255, 255];
                            } else if (val === 'Pendente') {
                                data.cell.styles.fillColor = [200, 30, 30]; // Vermelho
                                data.cell.styles.textColor = [255, 255, 255];
                            }
                        }
                    },
                    didDrawCell: (data) => {
                        if (colIdxSLA !== -1 && data.section === 'body' && data.column.index === colIdxSLA) {
                            const pct = data.cell.raw.val;
                            const barWidth = 14;
                            const barHeight = 2.0;
                            const x = data.cell.x + (data.cell.width - barWidth) / 2;
                            const y = data.cell.y + (data.cell.height / 2) + 1.8;

                            doc.setFillColor(230, 230, 230);
                            doc.rect(x, y, barWidth, barHeight, 'F');

                            let color = [16, 185, 129];
                            if (pct > 100) color = [239, 68, 68];
                            else if (pct > 75) color = [245, 158, 11];

                            doc.setFillColor(...color);
                            doc.rect(x, y, Math.min(pct, 100) * (barWidth / 100), barHeight, 'F');
                        }

                        if (colIdxAcoes !== -1 && data.section === 'body' && data.column.index === colIdxAcoes) {
                            const strikedItems = data.cell.raw.strikedItems;
                            const datesInfo = data.cell.raw.datesInfo;
                            if (!strikedItems) return;

                            const x = data.cell.x + 2;
                            let y = data.cell.y + 4.5;
                            const pillX = x + 3.5;

                            strikedItems.forEach((isDone, idx) => {
                                doc.setLineWidth(0.2);
                                if (isDone) {
                                    doc.setDrawColor(34, 197, 94);
                                    doc.setFillColor(240, 253, 244);
                                    doc.rect(x, y - 1.2, 2.4, 2.4, 'FD');
                                    doc.setDrawColor(20, 150, 80);
                                    doc.line(x + 0.5, y, x + 1, y + 0.5);
                                    doc.line(x + 1, y + 0.5, x + 2, y - 0.5);
                                } else {
                                    doc.setDrawColor(148, 163, 184);
                                    doc.rect(x, y - 1.2, 2.4, 2.4, 'D');
                                }

                                if (datesInfo && datesInfo[idx]) {
                                    doc.setDrawColor(226, 232, 240);
                                    doc.setFillColor(248, 250, 252);
                                    doc.roundedRect(pillX, y - 1.6, 12, 3.2, 0.5, 0.5, 'FD');
                                    doc.setTextColor(100, 116, 139);

                                    let oldFSize = doc.internal.getFontSize();
                                    doc.setFontSize(5);
                                    doc.text(datesInfo[idx], pillX + 1, y + 0.6);
                                    doc.setFontSize(oldFSize);
                                }

                                y += (data.cell.styles.lineHeight || 3.8);
                            });
                        }
                    },
                    didDrawPage: (data) => {
                        startY = data.cursor.y + 15;
                    }
                });

                startY = doc.lastAutoTable.finalY + 15;

                // Verificar se precisa de nova página se o próximo grupo for grande
                if (startY > 250) {
                    doc.addPage();
                    startY = 20;
                }
            }

            // --- RODAPÉ ---
            const pageCount = doc.internal.getNumberOfPages();
            for (let i = 1; i <= pageCount; i++) {
                doc.setPage(i);
                doc.setFontSize(8);
                doc.setTextColor(148, 163, 184);
                doc.text(`Página ${i} de ${pageCount} - Dashboard ITSM Intelligence`, 148.5, 200, { align: 'center' }); // Landscape base
            }

            const fileName = `Planejamento_TODO_${new Date().toISOString().split('T')[0]}.pdf`;
            doc.save(fileName);
        }

