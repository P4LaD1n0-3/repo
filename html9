            <div class="report-card h-[400px]">
                <div class="report-card-title">1. ACOMPANHAMENTO GLOBAL DIÁRIO (MÊS VIGENTE)</div>
                <div class="chart-full-width"><canvas id="c-d-cons"></canvas></div>
            </div>

            <div class="report-card h-[400px]">
