    <script>
        // ==========================================
        // 0. DATA & FILES & UTILS
        // ==========================================
        const RawData = { incs: [], reqs: [], rca: [], ptask: [], prb: [] };
        window.openTodoAnalysts = new Set();
        window.openModalTodoAnalysts = new Set();
        window.TicketsWithEmail = new Set(); // Global set for tickets with RPA emails

        function getEmailIndicator(tk) {
            if (!tk) return '';
            const cleanTk = tk.includes(':') ? tk.split(':')[1].trim() : tk.trim();
            if (window.TicketsWithEmail.has(cleanTk)) {
                return `<i class="fas fa-envelope text-purple-500 ml-1.5 cursor-help" title="E-mail vinculado detectado via RPA"></i>`;
            }
            return '';
        }

        const PAGE_SIZE = 60;
        window.paginationState = {
            search: 1,
            drilldown: 1,
            searchData: [],
            drilldownData: [],
            drilldownTitle: '',
            drilldownVaultCat: '',
            drilldownKey: ''
        };

        function changeSearchPage(page) {
            window.paginationState.search = page;
            renderSearchPage();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function changeDrilldownPage(page) {
            window.paginationState.drilldown = page;
            renderDrilldownPage();
            document.getElementById('drilldown-table-container').scrollTop = 0;
        }
        window.openModalTodoAnalysts = new Set();

        // ==========================================
        // AUTO-SYNC (CLOUD FOLDER) LOGIC
        // ==========================================
        // Segurança: Limpa qualquer intervalo residual de carregamentos anteriores
        if (window.syncContext && window.syncContext.interval) clearInterval(window.syncContext.interval);

        window.syncContext = {
            dirHandle: null,
            interval: null,
            cacheStamps: {},
            isSyncing: false
        };

        function openConfigModal() { document.getElementById('config-modal').classList.remove('hidden-st'); }
        function closeConfigModal() { document.getElementById('config-modal').classList.add('hidden-st'); }
        function dismissUpdateModal() { document.getElementById('update-alert-modal').classList.add('translate-x-[120%]'); }

        // --- PERSISTÊNCIA (localStorage) ---
        function saveConfigs() {
            const config = {
                slaIncs: document.getElementById('sla-incs').value,
                slaReqs: document.getElementById('sla-reqs').value,
                slaPtask: document.getElementById('sla-ptask').value,
                slaRca: document.getElementById('sla-rca').value,
                emailTo: document.getElementById('email-to').value,
                emailCc: document.getElementById('email-cc').value
            };
            localStorage.setItem('eliteMasterConfigV1', JSON.stringify(config));
            console.log("[CONFIG] Configurações salvas no localStorage.");
        }

        window.isComparisonActive = false;
        window.ComparisonData = { inc: null, req: null, uam: null, cons: null };

        function changeMonth(offset) {
            const input = document.getElementById('ref-date');
            if (!input.value) return;

            const [year, month] = input.value.split('-').map(Number);
            const date = new Date(year, month - 1 + offset, 1);

            const newYear = date.getFullYear();
            const newMonth = String(date.getMonth() + 1).padStart(2, '0');
            input.value = `${newYear}-${newMonth}`;

            if (RawData.incs.length || RawData.reqs.length) {
                processDashboard();
            }
            saveConfigs();
        }

        function setToToday() {
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            document.getElementById('ref-date').value = `${year}-${month}`;
            if (RawData.incs.length || RawData.reqs.length) {
                processDashboard();
            }
            saveConfigs();
        }

        function toggleComparisonMode() {
            window.isComparisonActive = !window.isComparisonActive;
            const btn = document.getElementById('btn-compare');
            const badge = document.getElementById('comparison-badge');

            if (window.isComparisonActive) {
                btn.classList.remove('bg-slate-100', 'text-slate-700');
                btn.classList.add('bg-amber-500', 'text-white', 'border-amber-600', 'shadow-md');
                badge.classList.remove('hidden-st');
            } else {
                btn.classList.add('bg-slate-100', 'text-slate-700');
                btn.classList.remove('bg-amber-500', 'text-white', 'border-amber-600', 'shadow-md');
                badge.classList.add('hidden-st');
            }

            // Re-processa se já houver dados
            if (RawData.incs.length || RawData.reqs.length) {
                processDashboard();
            }
        }

        function loadConfigs() {
            const saved = localStorage.getItem('eliteMasterConfigV1');
            if (saved) {
                const config = JSON.parse(saved);
                if (config.slaIncs) document.getElementById('sla-incs').value = config.slaIncs;
                if (config.slaReqs) document.getElementById('sla-reqs').value = config.slaReqs;
                if (config.slaPtask) document.getElementById('sla-ptask').value = config.slaPtask;
                if (config.slaRca) document.getElementById('sla-rca').value = config.slaRca;
                if (config.emailTo) document.getElementById('email-to').value = config.emailTo;
                if (config.emailCc) document.getElementById('email-cc').value = config.emailCc;
                console.log("[CONFIG] Configurações recuperadas.");
            }
        }

        let alertModalCallback = null;
        function showAlertModal(title, message, callback = null) {
            document.getElementById('alert-modal-title').innerText = title;
            document.getElementById('alert-modal-message').innerText = message;
            document.getElementById('alert-modal').classList.remove('hidden-st');
            alertModalCallback = callback;
        }
        function closeAlertModal() {
            document.getElementById('alert-modal').classList.add('hidden-st');
            if (typeof alertModalCallback === 'function') {
                alertModalCallback();
                alertModalCallback = null;
            }
        }

        // --- PERSISTÊNCIA (IndexedDB para o DirectoryHandle) ---
        // Browser security: Handles cannot be saved in localStorage.
        const dbName = "EliteMasterDB";
        const storeName = "ConfigStore";

        async function getDB() {
            return new Promise((resolve, reject) => {
                const request = indexedDB.open(dbName, 1);
                request.onupgradeneeded = () => request.result.createObjectStore(storeName);
                request.onsuccess = () => resolve(request.result);
                request.onerror = () => reject(request.error);
            });
        }

        async function saveHandle(handle) {
            const db = await getDB();
            const tx = db.transaction(storeName, "readwrite");
            tx.objectStore(storeName).put(handle, "dirHandle");
            return tx.complete;
        }

        async function loadHandle() {
            const db = await getDB();
            const tx = db.transaction(storeName, "readonly");
            return new Promise((resolve) => {
                const req = tx.objectStore(storeName).get("dirHandle");
                req.onsuccess = () => resolve(req.result);
                req.onerror = () => resolve(null);
            });
        }

        async function bindCloudFolder() {
            try {
                const handle = await window.showDirectoryPicker({ mode: 'read' });
                window.syncContext.dirHandle = handle;
                window.syncContext.cacheStamps = {};

                // Salva no IndexedDB
                await saveHandle(handle);

                document.getElementById('sync-status-indicator').className = 'w-3 h-3 rounded-full bg-emerald-500 shadow shadow-emerald-200';
                document.getElementById('sync-status-text').innerText = 'Pasta vinculada';
                document.getElementById('sync-folder-path').innerText = handle.name;

                console.log("[SYNC] Pasta vinculada e salva no DB:", handle.name);
                showAlertModal("Pasta Vinculada", "A pasta '" + handle.name + "' foi associada e será lembrada. Clique em Atualizar (🔄) no topo.");
                setTimeout(() => closeConfigModal(), 500);
            } catch (e) {
                console.warn("Folder picker cancelado ou erro:", e);
            }
        }

        async function manualSyncCheck() {
            if (window.syncContext.isSyncing) return;

            if (!window.syncContext.dirHandle) {
                showAlertModal("Pasta não Vinculada", "Para sincronizar, você precisa primeiro associar uma pasta do seu computador ou nuvem (onde os arquivos .xlsx estão salvos).", openConfigModal);
                return;
            }

            const btn = document.getElementById('btn-manual-sync');
            const icon = document.getElementById('icon-sync');

            window.syncContext.isSyncing = true;
            btn.classList.add('opacity-50', 'cursor-not-allowed');
            icon.classList.add('fa-spin');

            const msg = document.getElementById('extraction-time');
            msg.className = "text-[10px] font-bold text-white bg-amber-500 px-2 py-0.5 rounded shadow-sm inline-block mt-1";
            msg.innerHTML = '<i class="fas fa-sync fa-spin mr-1"></i> Lendo arquivos da pasta...';

            console.log("[SYNC] Início da sincronização manual...");

            try {
                // Recupera permissão (Browser security: exige interação após refresh)
                const permission = await window.syncContext.dirHandle.queryPermission({ mode: 'read' });
                if (permission !== 'granted') {
                    // Se não tiver permissão, o navegador exige uma interação. 
                    // O clique no botão 'Atualizar' conta como interação.
                    const req = await window.syncContext.dirHandle.requestPermission({ mode: 'read' });
                    if (req !== 'granted') {
                        showAlertModal("Permissão Necessária", "O navegador bloqueou o acesso à pasta. Por favor, clique novamente em Atualizar e autorize o acesso.");
                        throw new Error("Permissão negada");
                    }
                }

                // Lê TODOS os arquivos xlsx da pasta
                let filesToProcess = [];
                let totalFound = 0;

                for await (const entry of window.syncContext.dirHandle.values()) {
                    if (entry.kind !== 'file' || !entry.name.endsWith('.xlsx')) continue;

                    let nameLower = entry.name.toLowerCase();
                    if (nameLower.includes('inc') || nameLower.includes('sc_task') || nameLower.includes('req') || nameLower.includes('rca') || nameLower.includes('ptask') || nameLower.includes('prb')) {
                        const file = await entry.getFile();
                        totalFound++;

                        // Verifica se o arquivo é mais recente que o último processado
                        const cachedStamp = window.syncContext.cacheStamps[nameLower];
                        if (!cachedStamp || file.lastModified > cachedStamp) {
                            console.log(`[SYNC] Arquivo atualizado encontrado: ${entry.name} (modified: ${new Date(file.lastModified).toLocaleString('pt-BR')})`);
                            filesToProcess.push({ file: file, name: nameLower, originalName: entry.name });
                            window.syncContext.cacheStamps[nameLower] = file.lastModified;
                        } else {
                            console.log(`[SYNC] Arquivo sem alteração: ${entry.name}`);
                        }
                    }
                }

                if (totalFound === 0) {
                    showAlertModal("Nenhum Arquivo", "Não encontramos arquivos .xlsx válidos (INC, REQ, RCA, PTASK) na pasta vinculada.");
                    msg.className = "text-[10px] font-bold text-white bg-red-500 px-2 py-0.5 rounded shadow-sm inline-block mt-1";
                    msg.innerHTML = '<i class="fas fa-exclamation-triangle mr-1"></i> Nenhum arquivo encontrado';
                    return;
                }

                if (filesToProcess.length > 0) {
                    msg.innerHTML = `<i class="fas fa-cog fa-spin mr-1"></i> Processando ${filesToProcess.length} arquivo(s)...`;

                    // Processa todos os arquivos atualizados
                    await processArrayOfFiles(filesToProcess);

                    // Gera o relatório automaticamente
                    if (typeof processDashboard === 'function') {
                        processDashboard();
                    }

                    const now = new Date();
                    msg.className = "text-[10px] font-bold text-white bg-blue-600 px-2 py-0.5 rounded shadow-sm inline-block mt-1 animate-pulse";
                    msg.innerHTML = `<i class="fas fa-check-circle mr-1"></i> Atualizado: ${now.toLocaleTimeString('pt-BR')} (${filesToProcess.length} arquivo(s))`;
                    console.log(`[SYNC] Concluído: ${filesToProcess.length} arquivo(s) processado(s).`);
                } else {
                    msg.className = "text-[10px] font-bold text-white bg-slate-500 px-2 py-0.5 rounded shadow-sm inline-block mt-1";
                    msg.innerHTML = '<i class="fas fa-info-circle mr-1"></i> Tudo atualizado — nenhuma novidade';
                    console.log("[SYNC] Nenhum arquivo mais recente encontrado.");
                    setTimeout(() => {
                        msg.className = "text-[10px] font-bold text-white bg-emerald-600 px-2 py-0.5 rounded shadow-sm inline-block mt-1";
                        msg.innerHTML = '<i class="fas fa-clock mr-1"></i> Dados em dia';
                    }, 3000);
                }

            } catch (e) {
                console.warn("[SYNC] Falha na sincronização ou permissão negada:", e);
                showAlertModal("Erro de Acesso", "Não conseguimos acessar os arquivos. Clique na engrenagem e selecione a pasta novamente para reativar o acesso.");
                msg.className = "text-[10px] font-bold text-white bg-red-500 px-2 py-0.5 rounded shadow-sm inline-block mt-1";
                msg.innerHTML = '<i class="fas fa-times-circle mr-1"></i> Erro ao sincronizar';
            } finally {
                setTimeout(() => {
                    window.syncContext.isSyncing = false;
                    btn.classList.remove('opacity-50', 'cursor-not-allowed');
                    icon.classList.remove('fa-spin');
                    console.log("[SYNC] Lock liberado.");
                }, 1000);
            }
        }

        async function processArrayOfFiles(fileObjs) {
            return new Promise((resolve) => {
                let processed = 0;
                if (fileObjs.length === 0) return resolve();

                fileObjs.forEach(obj => {
                    const reader = new FileReader();
                    reader.onload = e => {
                        parseExcelBlob(e.target.result, obj.name, obj.originalName || obj.file.name);
                        processed++;
                        if (processed === fileObjs.length) resolve();
                    };
                    reader.readAsArrayBuffer(obj.file);
                });
            });
        }

        function triggerAutoSync() {
            dismissUpdateModal();
            let msg = document.getElementById('extraction-time');
            msg.className = "text-[10px] font-bold text-white bg-amber-500 px-2 py-0.5 rounded shadow-sm inline-block mt-1";
            msg.innerHTML = '<i class="fas fa-sync fa-spin mr-1"></i> Carregando Atualizações...';

            setTimeout(async () => {
                if (window.pendingFilesToProcess) {
                    await processArrayOfFiles(window.pendingFilesToProcess);
                    window.pendingFilesToProcess = null;
                }

                // Executa a macro normal do refresh
                if (typeof processDashboard === 'function') {
                    processDashboard();
                }

                msg.className = "text-[10px] font-bold text-white bg-blue-600 px-2 py-0.5 rounded shadow-sm inline-block mt-1 animate-pulse";
                msg.innerHTML = '<i class="fas fa-check-circle mr-1"></i> Atualizado via Nuvem';
            }, 300);
        }

        function parseExcelBlob(arrayBuffer, nameLower, originalName) {
            const data = new Uint8Array(arrayBuffer);
            const workbook = XLSX.read(data, { type: 'array', cellDates: true });
            const json = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]], { defval: "" });

            const cleanJson = json.map(r => {
                let o = {};
                Object.keys(r).forEach(k => o[k.replace(/\ufffd/g, "").replace(/\s+/g, " ").trim()] = r[k]);
                return o;
            });

            // Detecção por nome de arquivo — ordem importa: mais específico primeiro
            let assigned = false;
            if (cleanJson.length > 0) {
                if (nameLower.includes('ptask')) { RawData.ptask = cleanJson; assigned = true; }
                else if (nameLower.includes('rca')) { RawData.rca = cleanJson; assigned = true; }
                else if (nameLower.includes('sc_task') || nameLower.includes('sctask')) { RawData.reqs = cleanJson; assigned = true; }
                else if (nameLower.includes('inc')) { RawData.incs = cleanJson; assigned = true; }
                else if (nameLower.includes('prb') || (nameLower.includes('problem') && !nameLower.includes('ptask') && !nameLower.includes('rca'))) { RawData.prb = cleanJson; assigned = true; }
                else if (nameLower.includes('req')) { RawData.reqs = cleanJson; assigned = true; }
            }

            // Fallback: detecção automática pelos cabeçalhos das colunas
            if (!assigned && cleanJson.length > 0) {
                const cols = Object.keys(cleanJson[0]).map(k => k.toLowerCase());
                const hasCol = (...names) => names.some(n => cols.some(c => c.includes(n)));
                if (hasCol('caller', 'priority') && hasCol('incident', 'inc')) { RawData.incs = cleanJson; assigned = true; }
                else if (hasCol('caller', 'priority') && !RawData.incs.length) { RawData.incs = cleanJson; assigned = true; }
                else if (hasCol('request item', 'ritm', 'sc_task', 'requester') && !RawData.reqs.length) { RawData.reqs = cleanJson; assigned = true; }
                else if (hasCol('rca status', 'rca due') && !RawData.rca.length) { RawData.rca = cleanJson; assigned = true; }
                else if (hasCol('ptask', 'problem task') && !RawData.ptask.length) { RawData.ptask = cleanJson; assigned = true; }
                else if (hasCol('problem', 'prb') && !RawData.prb.length) { RawData.prb = cleanJson; assigned = true; }
                else if (!RawData.incs.length) { RawData.incs = cleanJson; assigned = true; }
                else if (!RawData.reqs.length) { RawData.reqs = cleanJson; assigned = true; }
            }

            if (!assigned) {
                console.warn(`[DATA] Arquivo '${originalName}' ignorado ou sem dados válidos. Mantendo dados existentes.`);
                return;
            }

            let badgeHtml = `<div class="file-badge"><span class="truncate"><i class="fas fa-file-excel mr-1"></i> ${originalName}</span><i class="fas fa-check"></i></div>`;
            if (!document.getElementById('file-status').innerHTML.includes(originalName)) {
                document.getElementById('file-status').innerHTML += badgeHtml;
                document.getElementById('btn-clear-files').classList.remove('hidden-st');
            }
        }

        let todoList = JSON.parse(localStorage.getItem('eliteMasterTodosV69')) || [];
        let dynamicExportConfig = JSON.parse(localStorage.getItem('todoExportConfig')) || {
            Contexto: true, Aging: true, 'SLA%': true, Status: true, CustomFields: []
        };
        let GlobalOpenTickets = [];
        let activeTableFilters = {};

        window.chartInstances = [];

        window.DrilldownVault = {
            inc: {}, req: {}, uam: {}, cons: {}, class: {}, sla: {}
        };

        // Inicializa com o mês atual
        const nowInit = new Date();
        document.getElementById('ref-date').value = nowInit.toISOString().slice(0, 7);

        function handleFiles(files) {
            Array.from(files).forEach(file => {
                const name = file.name.toLowerCase();
                const reader = new FileReader();
                reader.onload = e => {
                    parseExcelBlob(e.target.result, name, file.name);
                };
                reader.readAsArrayBuffer(file);
            });
        }
        function clearFiles() { location.reload(); }

        function renderPaginationControls(type, totalItems, currentPage) {
            const totalPages = Math.ceil(totalItems / PAGE_SIZE);
            if (totalPages <= 1) return '';

            const changeFn = type === 'search' ? 'changeSearchPage' : 'changeDrilldownPage';

            return `
            <div class="pagination-container">
                <button class="pagination-btn" onclick="${changeFn}(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>
                    <i class="fas fa-chevron-left"></i> Anterior
                </button>
                <div class="pagination-info">
                    Página <span class="text-[var(--primary-dark)]">${currentPage}</span> de <span class="text-[var(--primary-dark)]">${totalPages}</span>
                </div>
                <button class="pagination-btn" onclick="${changeFn}(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>
                    Próximo <i class="fas fa-chevron-right"></i>
                </button>
            </div>
            `;
        }

        const getCol = (row, keys) => {
            if (!row) return '';
            for (let k of keys) {
                if (row[k] !== undefined && row[k] !== null && row[k] !== '') {
                    let v = String(row[k]).trim();
                    if (v.toLowerCase() !== 'undefined') return v;
                }
            }
            return '';
        };

        const findTicketRecord = (tkNumber) => {
            if (!tkNumber || tkNumber === 'undefined') return null;
            let cleanTk = String(tkNumber).normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, '').toUpperCase();
            let found = null;
            [RawData.incs, RawData.reqs, RawData.rca, RawData.ptask, RawData.uam].forEach(src => {
                if (found || !src) return;
                let f = src.find(r => {
                    return Object.values(r).some(val => {
                        if (val == null) return false;
                        let cleanVal = String(val).normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, '').toUpperCase();
                        return cleanVal === cleanTk;
                    });
                });
                if (f) found = f;
            });
            // Fallback para PTASKs sint\u00e9ticas: PTASK2000001 \u2192 busca PRB2000001 no RCA
            if (!found && cleanTk.startsWith('PTASK')) {
                let prbEquiv = 'PRB' + cleanTk.slice(5);
                [RawData.rca, RawData.prb].forEach(src => {
                    if (found || !src) return;
                    let f = src.find(r => {
                        let v = String(getCol(r, ['Problem', 'Number', 'Problema', 'problem_id']) || '').trim().toUpperCase();
                        return v === prbEquiv;
                    });
                    if (f) found = f;
                });
            }
            return found;
        };

        const extractFromComments = (comments, type) => {
            if (!comments) return "—";
            if (type === 'version' || type === 'release') {
                const match = comments.match(/(?:vers.o da release|vrs|vers.o|version|release):?\s*([\d\.\w\-]+)/i);
                return match ? match[1] : "—";
            }
            if (type === 'date' || type === 'deploy') {
                const match = comments.match(/(?:data da release|data release|data deploy|data de deploy|data|date|deploy):?\s*(\d{2}\/\d{2}\/\d{4})/i);
                return match ? match[1] : "—";
            }
            return "—";
        };

        const safeDate = v => {
            if (!v) return null;
            if (v instanceof Date) return isNaN(v.getTime()) ? null : v;
            if (typeof v === 'number') return new Date(Math.round((v - 25569) * 86400 * 1000));
            if (typeof v === 'string') {
                let cleanDt = v.trim().replace(/-/g, '/');
                let p = cleanDt.split(/[\/\s:T]/);
                if (p.length >= 3) {
                    if (p[0].length === 4) {
                        let d = new Date(p[0], p[1] - 1, p[2], p[3] || 0, p[4] || 0, p[5] || 0);
                        if (!isNaN(d.getTime())) return d;
                    } else if (p[2].length === 4) {
                        let d = new Date(p[2], p[1] - 1, p[0], p[3] || 0, p[4] || 0, p[5] || 0);
                        if (!isNaN(d.getTime())) return d;
                    }
                }
                let nD = new Date(cleanDt);
                if (!isNaN(nD.getTime())) return nD;
            }
            return null;
        };

