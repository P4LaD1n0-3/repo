                <div class="report-card clickable-card" style="text-align:center;" onclick="openDrilldown('${lblRes} no Mês (${typeStr})', 'all_res_month', '${cat}')" title="Clique para ver os resolvidos no mês">
                    <div class="report-card-title">📊 ${lblRes.toUpperCase()} NO MÊS</div>
                    <div style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                        <div style="font-size:14px; font-weight:bold; color:${C.GRY_D}; margin-bottom:8px; display:flex; justify-content:center; gap:15px;">
                            <span style="color:${C.SUC}; background:#ecfdf5; padding:4px 12px; border-radius:20px; border:1px solid #a7f3d0;">✅ ${d.inSla} no Prazo</span>
                        </div>
                        <div style="color:${pctColor}; font-size:22px; font-weight:800; line-height:1;">${d.pct}% Dentro</div>
                        ${comp ? `
                        <div class="mt-3 pt-2 border-t border-blue-100 bg-blue-50/30 rounded">
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">SITUAÇÃO PRESENTE (HOJE):</span>
                            <span class="text-lg font-black text-blue-600 ml-1">${comp.pct}%</span>
                        </div>` : ""}
                    </div>
                </div>
                <div class="report-card" style="text-align:center;">
                    <div class="report-card-title"><i class="fas fa-stopwatch inline-block mb-1"></i> MTTR MENSAL (${typeStr})</div>
                    <div style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                        <div style="font-size:32px; font-weight:800; color:#0f172a; line-height:1; display:flex; align-items:flex-end; justify-content:center;">
                            ${d.mttr} <span style="font-size:14px; font-weight:bold; color:#64748b; margin-left:4px; margin-bottom:5px;">Dias</span>
                        </div>
                        ${comp ? `
                        <div class="mt-3 pt-2 border-t border-blue-100 bg-blue-50/30 rounded">
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">SITUAÇÃO PRESENTE (HOJE):</span>
                            <span class="text-lg font-black text-blue-600 ml-1">${comp.mttr} d</span>
                        </div>` : `
                        <div style="font-size:13px; font-weight:bold; color:#64748b; text-transform:uppercase; margin-top:5px;">CONSOLIDADO DO MÊS</div>`}
