                // Calculate SLA % for the hover tooltip (assuming 10 days for PRBs as default)
                const slaP = parseInt(document.getElementById('sla-rca')?.value) || 10;
                prbObj.pctSla = ((age / slaP) * 100).toFixed(2).replace('.', ',');

                allPrbs.push(prbObj);
