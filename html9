                let a = getCol(r, ['Assigned to', 'Analista']);
                if (a && a !== '-' && a !== 'N/A' && !a.includes('Não Atribuído')) set.add(a);
            }));

            select.innerHTML = '<option value="">Selecione um analista...</option>' + Array.from(set).sort().map(a => `<option value="${a}">${a}</option>`).join('');
            document.getElementById('todo-tickets').innerHTML = '<option value="" disabled>Selecione um analista primeiro...</option>';
        }

        // ==========================================
        // 3. MOTOR DE OCIOSIDADE E PESQUISA GLOBAL
        // ==========================================
        function getDaysSilent(r, refDateObj, assignedTo, opDateObj) {
            if (!assignedTo || assignedTo === 'undefined' || assignedTo.includes('Não Atribuído') || assignedTo === 'N/A' || assignedTo === '-') return '-';

            let maxDate = opDateObj ? new Date(opDateObj) : new Date(0);
            let regex = /(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?:\s+-\s+|\s+)([^\(]+)\s+\(/g;
            let found = false;

            ['Work notes', 'Work Notes', 'Work notes list', 'Work notes list(s)', 'Additional comments'].forEach(col => {
                if (r[col] && typeof r[col] === 'string') {
                    let m;
                    while ((m = regex.exec(r[col])) !== null) {
                        if (m[2].trim() === assignedTo) {
                            let d = new Date(m[1].replace(/-/g, '/'));
                            if (!isNaN(d) && d.getTime() > maxDate.getTime() && d.getTime() <= refDateObj.getTime()) {
                                maxDate = d;
                                found = true;
                            }
                        }
                    }
                }
            });

            if (maxDate.getTime() === 0 && !found && !opDateObj) return '-';

            let diff = Math.floor((refDateObj - maxDate) / 86400000);
            return diff < 0 ? 0 : diff;
        }

        let searchTimeout = null;
        function performGlobalSearch(e) {
            if (e && e.key === "Enter") {
                clearTimeout(searchTimeout);
                executeGlobalSearch();
                return;
            }
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(executeGlobalSearch, 400);
        }

        function executeGlobalSearch() {
            const input = document.getElementById("globalSearch");
            if (!input) return;
            const inputVal = input.value.trim();
            const term = removeAccents(inputVal.toUpperCase());

            if (term.length === 0) {
                // Se a pesquisa estiver vazia, volta para a última aba ativa ou Tickets Abertos
                const searchTab = document.getElementById('tab-search');
                if (searchTab && !searchTab.classList.contains('hidden-st')) {
                    let act = document.querySelector('.tab-btn.active');
                    if (act) switchTab(act.getAttribute('onclick').match(/'([^']+)'/)[1], act);
                    else switchTab('tab-open', document.querySelector('.tab-btn'));
                }
                return;
            }

            document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-pane').forEach(c => { c.classList.add('hidden-st'); c.classList.remove('animate-fade'); });

            const searchTab = document.getElementById('tab-search');
            searchTab.classList.remove('hidden-st');
            searchTab.classList.add('animate-fade');

            let results = [];
            const refDateInput = document.getElementById('ref-date').value;
            const refDateObj = new Date(refDateInput + (refDateInput.length === 7 ? '-01' : '') + 'T12:00:00');

            [{ n: 'INC', d: RawData.incs }, { n: 'REQ', d: RawData.reqs }, { n: 'RCA', d: RawData.rca }, { n: 'PTASK', d: RawData.ptask }, { n: 'PRB', d: RawData.prb }].forEach(src => {
                src.d.forEach(r => {
                    let rowString = removeAccents(Object.values(r).join(" ").toUpperCase());
                    if (rowString.includes(term)) {
                        let asg = getCol(r, ['Assigned to', 'Analista']) || 'Não Atribuído';
                        let op = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                        let cl = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));

                        let tk = src.n === 'REQ' || src.n === 'UAM' ? (getCol(r, ['RITM', 'Request Item', 'Item de solicitação', 'Number', 'Ticket']) || '-') : (getCol(r, ['Number', 'Ticket', 'Problem', 'Task']) || '-');
                        let stOrig = String(getCol(r, ['State', 'Status', 'RCA Status']) || '').toUpperCase();
                        let reasonOrig = String(getCol(r, ['Reason', 'reason', 'Motivo']) || '').toUpperCase();
                        let holdReason = String(getCol(r, ['On hold reason', 'Motivo da espera']) || '');

                        results.push({
                            type: src.n,
                            tk: tk,
                            desc: String(getCol(r, ['Short description', 'Descrição Curta', 'Descrição', 'Item']) || '-').replace(/"/g, '&quot;'),
                            longDesc: String(getCol(r, ['Description', 'Descrição Completa']) || '-').replace(/"/g, '&quot;'),
                            req: getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A',
                            asg: asg,
                            gp: getCol(r, ['Assignment group', 'Grupo']) || '-',
                            st: stOrig,
                            reason: reasonOrig,
                            info: holdReason,
                            op: op,
                            cl: cl,
                            idle: (!cl || cl > refDateObj) ? getDaysSilent(r, refDateObj, asg, op) : '-'
                        });
                    }
                });
            });

            results.sort((a, b) => {
                if (!a.op) return 1;
                if (!b.op) return -1;
                return b.op - a.op;
            });

            window.paginationState.searchData = results;
            window.paginationState.search = 1;
            renderSearchPage();
        }

        function renderSearchPage() {
            const results = window.paginationState.searchData;
            const page = window.paginationState.search;
            const start = (page - 1) * PAGE_SIZE;
            const end = start + PAGE_SIZE;
            const currentResults = results.slice(start, end);
            const inputVal = document.getElementById('globalSearch').value;

            let html = `<div class="report-section-title" style="background-color: var(--primary-dark);">
                <i class="fas fa-search mr-2"></i> RESULTADOS DA PESQUISA GLOBAL: "${inputVal}" 
                (${results.length} encontrados - Página ${page})
            </div>`;

            if (results.length === 0) {
                html += `<div class="report-card text-center py-10"><h3 class="text-slate-500 font-bold text-lg"><i class="fas fa-folder-open text-4xl block mb-4 text-slate-300"></i>Nenhum registro encontrado.</h3></div>`;
                document.getElementById('tab-search').innerHTML = html;
                switchTab('tab-search');
