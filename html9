                let holdReason = getCol(r, ['On hold reason', 'Motivo da espera', 'on_hold_reason']);
                let stLower = st.toLowerCase();
                let infoFinal = (stLower.includes('hold') || stLower.includes('espera')) && holdReason ? String(holdReason).replace(/"/g, '&quot;') : '';

                let prbRaw = getCol(r, ['Problem', 'PRB', 'Problema', 'problem_id', 'Problem ID', 'Número do Problema', 'problem_number']);
                let prbVal = (prbRaw && String(prbRaw).trim() !== "" && String(prbRaw).trim() !== "undefined") ? String(prbRaw).trim() : 'N/A';

                let idle = getDaysSilent(r, refDateObj, asg, op);
                let pctSlaNum = ((age / slaConfig) * 100);
                let pctSla = pctSlaNum.toFixed(2).replace('.', ',');
                let stSla = age > slaConfig ? "Estourado" : "No Prazo";
                openTks.push({ tk, type, desc, longDesc, req, as: asg, gp, st: st.toUpperCase(), reason: reasonVal, opStr: op.toLocaleDateString('pt-BR'), age, pctSla, pctSlaNum, stSla, slaConfig, idle, info: infoFinal, prb: prbVal });
            }
            incs.forEach(r => processRow(r, 'INC', slaI));
            reqs.forEach(r => processRow(r, 'REQ', slaR));
            uams.forEach(r => processRow(r, 'UAM', slaR));

            let groups = {};
            let countTags = { INC: 0, REQ: 0, UAM: 0 };
            openTks.forEach(t => {
                countTags[t.type] = (countTags[t.type] || 0) + 1;
                if (!groups[t.gp]) groups[t.gp] = [];
                groups[t.gp].push(t);
            });

            let html = `<div class="report-section-title" style="background-color: var(--primary-dark);"><i class="fas fa-folder-open mr-2"></i> VISÃO DE TICKETS ABERTOS POR GRUPO RESOLUTOR</div>`;
            // Z-A: Grupos ordenados de forma decrescente
            let sortedGroups = Object.keys(groups).sort((a, b) => b.localeCompare(a));
            if (sortedGroups.length === 0) {
                html += `<div class="report-card text-center py-10 text-slate-400 font-bold"><i class="fas fa-check-circle text-5xl mb-4 block text-emerald-400"></i>Nenhum ticket aberto encontrado na base para a data de referência selecionada. Parabéns!</div>`;
                return html;
            }

            // Discrete totals integrated into the bar
            html += `
            <div class="flex flex-col lg:flex-row justify-between items-center mb-4 bg-white p-3 rounded-lg shadow-sm border border-slate-200 gap-3">
                <div class="flex items-center gap-2 w-full lg:w-auto flex-1 max-w-sm bg-slate-50 border border-slate-200 px-3 py-2 rounded-full focus-within:border-blue-500 focus-within:bg-white transition-all shadow-inner">
                    <i class="fas fa-search text-slate-400 text-sm"></i>
                    <input type="text" placeholder="Filtrar tickets (número, assunto, analista)..." class="w-full bg-transparent outline-none text-[11px] font-inter text-slate-700" onkeyup="filterOpenTickets(this.value)">
                </div>

                <div class="flex flex-wrap items-center gap-2 justify-center py-1">
                    <div class="bg-blue-50 border border-blue-100 px-2.5 py-1 rounded shadow-inner flex items-center cursor-pointer hover:bg-blue-100 transition" onclick="filterOpenTickets('INC')">
                        <span class="text-[9px] font-black text-blue-400 uppercase tracking-tighter mr-2">INC</span>
                        <span class="text-xs font-black text-blue-800">${countTags.INC}</span>
                    </div>
                    <div class="bg-purple-50 border border-purple-100 px-2.5 py-1 rounded shadow-inner flex items-center cursor-pointer hover:bg-purple-100 transition" onclick="filterOpenTickets('REQ')">
                        <span class="text-[9px] font-black text-purple-400 uppercase tracking-tighter mr-2">REQ</span>
                        <span class="text-xs font-black text-purple-800">${countTags.REQ}</span>
                    </div>
                    <div class="bg-amber-50 border border-amber-100 px-2.5 py-1 rounded shadow-inner flex items-center cursor-pointer hover:bg-amber-100 transition" onclick="filterOpenTickets('UAM')">
                        <span class="text-[9px] font-black text-amber-500 uppercase tracking-tighter mr-2">UAM</span>
                        <span class="text-xs font-black text-amber-800">${countTags.UAM}</span>
                    </div>
                    <div class="bg-[var(--primary-dark)] border border-blue-900 px-3 py-1 rounded shadow-lg flex items-center cursor-pointer hover:brightness-110 transition" onclick="filterOpenTickets('')">
                        <span class="text-[9px] font-black text-blue-300 uppercase tracking-wider mr-2">TOTAL</span>
                        <span class="text-xs font-black text-white">${openTks.length}</span>
                    </div>
                </div>

                <div class="flex items-center gap-3 w-full lg:w-auto justify-end">
                    <div class="text-[10px] font-bold text-slate-500 hidden xl:block uppercase tracking-tight"><i class="fas fa-layer-group mr-1 text-blue-600"></i> ${Object.keys(groups).length} Grupos</div>
                    <button id="btn-toggle-accordions" onclick="toggleAllAccordions()" class="bg-[var(--primary-dark)] text-white px-4 py-2 rounded-full text-[10px] font-black uppercase shadow-md hover:bg-blue-900 transition flex items-center justify-center gap-2"><i class="fas fa-compress-alt"></i> Recolher Todos</button>
                </div>
            </div>
            <div class="text-[10px] text-slate-400 italic mb-2 px-2"><i class="fas fa-info-circle mr-1"></i> Lista agrupada por Grupo Resolutor ordenada por criticidade de SLA.</div>`;

            sortedGroups.forEach(gp => {
                // Z-A: Tickets dentro do grupo ordenados por %SLA (maior primeiro) e depois por Número (descendente)
                let tks = groups[gp].sort((a, b) => (b.pctSlaNum - a.pctSlaNum) || b.tk.localeCompare(a.tk));
                let rows = tks.map(t => {
                    let safePct = isNaN(t.pctSlaNum) ? 0 : Math.min(t.pctSlaNum, 100);
                    let pctText = isNaN(t.pctSlaNum) ? '0%' : t.pctSla + '%';
                    let pctColor = t.pctSlaNum > 100 ? '#ef4444' : (t.pctSlaNum > 75 ? '#f59e0b' : '#10b981');
                    if (isNaN(t.pctSlaNum)) pctColor = '#94a3b8';

                    let stColor = t.pctSlaNum > 100 ? 'text-red-600' : 'text-emerald-600';
                    if (isNaN(t.pctSlaNum)) stColor = 'text-slate-500';

                    return `
                    <tr class="ticket-row hover:bg-slate-50 transition" style="border-bottom: 1px solid #f1f5f9;" ${buildDataAttrs(t)}>
                        <td data-label="Número" class="font-bold text-[var(--primary-dark)] text-center py-2">
                            ${t.tk}
                            <div class="text-[9px] bg-slate-200 px-1 rounded inline-block text-slate-500 ml-1">${t.type}</div>
                            <button onclick="openTicketDetails('${t.tk}')" class="block w-full mt-1.5 bg-blue-50 border border-blue-200/50 p-1 rounded text-[9px] uppercase hover:bg-blue-100 transition shadow-sm"><i class="fas fa-history"></i> Saiba mais</button>
