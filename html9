        function sortTable(th) {
            const table = th.closest('table');
            const tbody = table.querySelector('tbody');
            if (!tbody) return;

            const rows = Array.from(tbody.querySelectorAll('tr'));
            if (rows.length < 2 && !(rows.length === 1 && rows[0].children.length > 1)) return;

            const colIdx = Array.from(th.parentNode.children).indexOf(th);
            const isAsc = th.dataset.dir !== 'asc';
            th.dataset.dir = isAsc ? 'asc' : 'desc';

            const compareVals = (vA, vB) => {
                let dateA = vA.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                let dateB = vB.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                if (dateA && dateB) return (new Date(dateA[3], dateA[2] - 1, dateA[1]) - new Date(dateB[3], dateB[2] - 1, dateB[1])) * (isAsc ? 1 : -1);
                let numA = parseFloat(vA.replace(/[^\d.-]/g, ''));
                let numB = parseFloat(vB.replace(/[^\d.-]/g, ''));
                if (vA.match(/^[\d.,R$+\-%\s]+(d totais|d ocioso|d|%)?$/i) && vB.match(/^[\d.,R$+\-%\s]+(d totais|d ocioso|d|%)?$/i) && !isNaN(numA) && !isNaN(numB)) {
                    return (numA - numB) * (isAsc ? 1 : -1);
                }
                return vA.localeCompare(vB, undefined, { numeric: true }) * (isAsc ? 1 : -1);
            };

            // Tabela PRB hierárquica: ordena grupos inteiros (master + filhos juntos)
            const hasPrbGroups = rows.some(r => r.dataset.prbGroup);
            if (hasPrbGroups) {
                let groupMap = new Map();
                let groupOrder = [];
                rows.forEach(r => {
                    let gid = r.dataset.prbGroup || '__ungrouped__';
                    if (!groupMap.has(gid)) { groupMap.set(gid, []); groupOrder.push(gid); }
                    groupMap.get(gid).push(r);
                });
                groupOrder.sort((a, b) => {
                    let masterA = groupMap.get(a).find(r => r.dataset.prbType === 'master');
                    let masterB = groupMap.get(b).find(r => r.dataset.prbType === 'master');
                    if (!masterA || !masterB) return 0;
                    let cellA = masterA.children[colIdx];
                    let cellB = masterB.children[colIdx];
                    if (!cellA || !cellB) return 0;
                    return compareVals(cellA.innerText.trim(), cellB.innerText.trim());
                });
                groupOrder.forEach(gid => groupMap.get(gid).forEach(r => tbody.appendChild(r)));
            } else {
                rows.sort((a, b) => {
                    let cellA = a.children[colIdx];
                    let cellB = b.children[colIdx];
                    if (!cellA || !cellB) return 0;
                    return compareVals(cellA.innerText.trim(), cellB.innerText.trim());
                });
                rows.forEach(r => tbody.appendChild(r));
            }

            th.parentNode.querySelectorAll('i.fa-sort, i.fa-sort-up, i.fa-sort-down').forEach(i => i.className = "fas fa-sort opacity-30 text-[10px]");
            let sortIcon = th.querySelector('i:not(.fa-filter)');
            if (sortIcon) sortIcon.className = isAsc ? "fas fa-sort-up ml-1 text-white text-[10px]" : "fas fa-sort-down ml-1 text-white text-[10px]";
        }

        function openFilter(e, iconEl) {
            e.stopPropagation();
            const th = iconEl.closest('th');
            const table = th.closest('table');
            if (!table.id) table.id = 'tbl_' + Math.random().toString(36).substr(2, 9);

            const tbody = table.querySelector('tbody');
            const colIdx = Array.from(th.parentNode.children).indexOf(th);

            document.querySelectorAll('.custom-filter-dropdown').forEach(el => el.remove());

            let uniqueVals = new Set();
            Array.from(tbody.querySelectorAll('tr')).forEach(tr => {
                if (tr.children.length > 1) {
                    let cell = tr.children[colIdx];
                    if (!cell) return;
                    let cv = cell.getAttribute('data-filter');
                    if (!cv) {
                        let textNodes = Array.from(cell.childNodes).filter(n => n.nodeType === 3).map(n => n.textContent.trim()).filter(t => t.length > 0);
                        cv = textNodes.length > 0 ? textNodes[0] : cell.innerText;
                    }
                    uniqueVals.add(cv.trim().replace(/\n/g, ' '));
                }
            });
            let valsArr = Array.from(uniqueVals).sort((a, b) => {
                let da = a.match(/^(\d{2})\/(\d{2})\/(\d{4}|\d{2})$/);
                let db = b.match(/^(\d{2})\/(\d{2})\/(\d{4}|\d{2})$/);
                if (da && db) {
                    let ya = da[3].length === 2 ? '20' + da[3] : da[3];
                    let yb = db[3].length === 2 ? '20' + db[3] : db[3];
                    // Z-A: Datas mais recentes primeiro (descendente)
                    return new Date(`${yb}-${db[2]}-${db[1]}`) - new Date(`${ya}-${da[2]}-${da[1]}`);
                }
                // Z-A: Alfabeto invertido
                return b.localeCompare(a, undefined, { numeric: true });
            });

            let drop = document.createElement('div');
            drop.className = 'custom-filter-dropdown fixed bg-white shadow-2xl border border-slate-200 rounded p-3 z-[10500] flex flex-col gap-1 w-64 animate-fade';

            let rect = iconEl.getBoundingClientRect();
            let dTop = rect.bottom + 5;
            let dLeft = rect.left - 100;
            if (dLeft < 10) dLeft = 10;

            drop.style.top = dTop + 'px';
            drop.style.left = dLeft + 'px';

            let selectAll = document.createElement('label');
            selectAll.className = 'font-bold cursor-pointer hover:bg-slate-100 p-1 flex items-center gap-2 border-b border-slate-200 pb-2 mb-2 text-xs text-slate-800';
            selectAll.innerHTML = `<input type="checkbox" class="filter-all w-4 h-4" checked> (Selecionar Tudo)`;
            drop.appendChild(selectAll);

            let itemsDiv = document.createElement('div');
            itemsDiv.className = 'max-h-48 overflow-y-auto flex flex-col gap-1 pr-1';

            valsArr.forEach(val => {
                let lbl = document.createElement('label');
                lbl.className = 'cursor-pointer hover:bg-slate-50 p-1 flex items-start gap-2 text-xs text-slate-600';
                let isCh = (!activeTableFilters[table.id] || !activeTableFilters[table.id][colIdx] || activeTableFilters[table.id][colIdx].includes(val));
                lbl.innerHTML = `<input type="checkbox" value="${val.replace(/"/g, '&quot;')}" class="w-4 h-4 mt-0.5" ${isCh ? 'checked' : ''}> <span class="break-words">${val}</span>`;
                itemsDiv.appendChild(lbl);
            });
            drop.appendChild(itemsDiv);

            let btn = document.createElement('button');
            btn.className = 'mt-3 bg-blue-600 text-white p-2 rounded font-bold uppercase text-xs hover:bg-blue-700 shadow-sm transition';
            btn.innerText = 'Aplicar Filtro';
            drop.appendChild(btn);

            document.body.appendChild(drop);

            selectAll.querySelector('input').onchange = ev => drop.querySelectorAll('input[type="checkbox"]:not(.filter-all)').forEach(cb => cb.checked = ev.target.checked);

            btn.onclick = () => {
                let checked = Array.from(drop.querySelectorAll('input[type="checkbox"]:not(.filter-all):checked')).map(cb => cb.value);
                if (!activeTableFilters[table.id]) activeTableFilters[table.id] = {};

                activeTableFilters[table.id][colIdx] = checked;

                const allTrs = Array.from(tbody.querySelectorAll('tr'));
                const hasPrbGroups = allTrs.some(r => r.dataset.prbGroup);

                if (hasPrbGroups) {
                    // Filtra grupos inteiros: avalia filtro apenas na linha mestre, propaga para filhos
                    let groupVisibility = {};
                    allTrs.forEach(tr => {
                        if (tr.dataset.prbType !== 'master') return;
                        let gid = tr.dataset.prbGroup;
                        let show = true;
                        for (let c in activeTableFilters[table.id]) {
                            let cell = tr.children[c];
                            if (!cell) continue;
                            let cVal = cell.getAttribute('data-filter');
                            if (!cVal) {
                                let textNodes = Array.from(cell.childNodes).filter(n => n.nodeType === 3).map(n => n.textContent.trim()).filter(t => t.length > 0);
                                cVal = textNodes.length > 0 ? textNodes[0] : cell.innerText;
                            }
                            if (!activeTableFilters[table.id][c].includes(cVal.trim().replace(/\n/g, ' '))) {
                                show = false; break;
                            }
                        }
                        groupVisibility[gid] = show;
                    });
                    allTrs.forEach(tr => {
                        let gid = tr.dataset.prbGroup;
                        if (gid) tr.style.display = groupVisibility[gid] ? '' : 'none';
                    });
                } else {
                    allTrs.forEach(tr => {
                        if (tr.children.length === 1) return;
                        let show = true;
                        for (let c in activeTableFilters[table.id]) {
                            let cell = tr.children[c];
                            let cVal = cell.getAttribute('data-filter');
                            if (!cVal) {
                                let textNodes = Array.from(cell.childNodes).filter(n => n.nodeType === 3).map(n => n.textContent.trim()).filter(t => t.length > 0);
                                cVal = textNodes.length > 0 ? textNodes[0] : cell.innerText;
                            }
                            if (!activeTableFilters[table.id][c].includes(cVal.trim().replace(/\n/g, ' '))) {
                                show = false; break;
                            }
                        }
                        tr.style.display = show ? '' : 'none';
                    });
                }

                iconEl.style.color = checked.length < valsArr.length ? '#f59e0b' : '';
                drop.remove();
            };

            setTimeout(() => {
                const closeFn = evClick => {
                    if (!drop.contains(evClick.target) && evClick.target !== iconEl) {
                        drop.remove(); document.removeEventListener('click', closeFn);
                    }
                };
                document.addEventListener('click', closeFn);
            }, 100);
        }

