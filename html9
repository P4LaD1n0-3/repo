        async function fetchAttachedEmails(searchQuery) {
            const container = document.getElementById('modal-rpa-emails');
            const accordion = document.getElementById('modal-rpa-accordion');

            // Limpa e valida os termos de busca (suporta múltiplos separados por vírgula)
            const cleanQuery = searchQuery.split(',').map(s => {
                let term = s.includes(':') ? s.split(':')[1].trim() : s.trim();
                return term;
            }).filter(s => s && s !== 'N/A' && s !== '-' && s.length > 3).join(',');

            if (!cleanQuery) {
                container.innerHTML = '<div class="text-center py-6 text-slate-400 text-[10px] font-bold">Nenhum identificador válido para busca de e-mails.</div>';
                return;
            }

            container.innerHTML = '<div class="text-center py-4 text-purple-600"><i class="fas fa-circle-notch fa-spin mr-2"></i>Buscando vínculos no Outlook...</div>';
            accordion.classList.remove('hidden-st');

            try {
                const response = await fetch(`http://localhost:5000/rpa/logs?ticket=${encodeURIComponent(cleanQuery)}`);
                if (!response.ok) throw new Error('Serviço Offline');

                const res = await response.json();

                if (res.status === 'success' && res.data && res.data.length > 0) {
                    container.innerHTML = res.data.map(email => `
                        <div class="bg-purple-50 border border-purple-100 p-3 rounded-lg flex items-center justify-between hover:bg-purple-100 transition-all group">
                            <div class="flex items-center gap-3 overflow-hidden">
                                <div class="w-8 h-8 rounded bg-purple-600 text-white flex items-center justify-center shrink-0 shadow-sm">
                                    <i class="fas fa-envelope"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <div class="text-[11px] font-black text-slate-700 truncate" title="${email.assunto}">${email.assunto}</div>
                                    <div class="text-[9px] text-slate-500 font-bold flex items-center gap-2">
                                        <span><i class="fas fa-user mr-1 opacity-50"></i> ${email.remetente.split('<')[0]}</span>
                                        <span class="opacity-30">|</span>
                                        <span><i class="far fa-calendar-alt mr-1 opacity-50"></i> ${email.data_recebimento}</span>
                                    </div>
                                </div>
                            </div>
                            <button onclick="readRpaEmail('${email.arquivo_caminho.replace(/\\/g, '\\\\')}')" 
                                    class="bg-white text-purple-600 border border-purple-200 px-3 py-1.5 rounded-md text-[9px] font-black uppercase hover:bg-purple-600 hover:text-white transition-all shadow-sm shrink-0">
                                Ver Conteúdo
                            </button>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = '<div class="text-center py-6 bg-slate-50 border border-dashed rounded-lg text-slate-400 text-[10px] font-bold"><i class="fas fa-search-minus text-2xl mb-2 block opacity-20"></i>Nenhuma comunicação vinculada detectada para este ticket.</div>';
                }
            } catch (e) {
                console.error("RPA Fetch Error Modal:", e);
                container.innerHTML = `
                <div class="text-center py-4 bg-red-50 border border-red-100 rounded-lg">
                    <div class="text-red-500 text-[10px] font-bold mb-1"><i class="fas fa-exclamation-triangle mr-1"></i> Erro de Conexão (RPA Bridge)</div>
                    <div class="text-[9px] text-red-400 px-4 leading-tight">Certifique-se que o serviço local (Python/Flask) está rodando na porta 5000 e com CORS habilitado.</div>
                </div>`;
            }
        }

        function addTodoFromModal() {
            const txt = document.getElementById('modal-new-todo').value;
            if (!txt.trim()) return;

            const tk = currentModalTk;
            const asg = document.getElementById('modal-asg').innerText;

            let ext = todoList.find(t => t.ticket === tk && t.analyst === asg);
            if (ext) {
                ext.history.push({ text: txt, date: new Date().toLocaleString('pt-BR'), striked: false });
            } else {
                todoList.push({
                    id: Date.now().toString() + Math.random().toString(36).substr(2, 5),
                    analyst: asg,
                    ticket: tk,
                    date: new Date().toLocaleDateString('pt-BR'),
                    history: [{ text: txt, date: new Date().toLocaleString('pt-BR'), striked: false }]
                });
            }

            document.getElementById('modal-new-todo').value = '';
            saveTodos();
            renderModalTodos(tk);
        }

