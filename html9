        let currentModalTk = null;
        function openTicketDetails(tkNumber) {
            currentModalTk = tkNumber;
            let ticketData = null;
            let tType = '';

            let cleanTk = String(tkNumber).normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, '').toUpperCase();

            // Busca rigorosa pelo campo Number (ou equivalente) de cada fonte,
            // na ordem correta para evitar falso-positivo (ex: número de INC aparecendo
            // em campo de texto de um registro RCA).
            const sourceDefs = [
                { src: RawData.incs, type: 'INC', fields: ['Number', 'Ticket', 'Número', 'number'] },
                { src: RawData.reqs, type: 'REQ', fields: ['Number', 'RITM', 'Request Item', 'Ticket', 'Número'] },
                { src: RawData.ptask, type: 'PTASK', fields: ['Number', 'Ticket', 'Número', 'number'] },
                { src: RawData.rca, type: 'RCA', fields: ['Problem', 'Number', 'Problema', 'problem_id', 'Ticket'] },
                { src: RawData.prb, type: 'PRB', fields: ['Number', 'Problem', 'Problema', 'problem_id', 'Ticket'] }
            ];

            for (let def of sourceDefs) {
                if (ticketData || !def.src || !def.src.length) continue;
                let f = def.src.find(r => {
                    let v = getCol(r, def.fields);
                    if (v == null || v === '') return false;
                    let cleanVal = String(v).normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, '').toUpperCase();
                    return cleanVal === cleanTk;
                });
                if (f) {
                    ticketData = f;
                    tType = def.type;
                }
            }

            // Se não encontrou no RawData, procura no cache de PRB dinâmico
            if (!ticketData && window.PrbGroupsCache) {
                if (window.PrbGroupsCache[cleanTk]) {
                    let pGroup = window.PrbGroupsCache[cleanTk];
                    ticketData = {
                        'Problem': pGroup.prb,
                        'Short description': 'PRB Extraído Dinamicamente',
                        'State': pGroup.state || (pGroup.active_count > 0 ? 'OPEN' : 'PUBLISHED'),
                        'Description': `Problema detectado via incidentes.\n\nMenções: ${pGroup.mentions}\nTickets Abertos: ${pGroup.active_count}\nIncidentes Relacionados: ${pGroup.related_count_total}\nVersão (RCA): ${pGroup.release}\n\nPTASKs e INCs contidos nesta árvore de problemas podem ser vistos na aba PRB.`,
                        'Additional comments': 'Este PRB foi gerado pelas referências nos incidentes.'
                    };
                    tType = 'RCA';
                }
            }

            // Fallback para PTASKs sintéticas: PTASK2000042 → busca PRB2000042 no RCA/PRB
