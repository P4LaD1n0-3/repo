        window.exportDrilldownPdf = function () {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF({ orientation: 'l', unit: 'mm', format: 'a4' });

            const title = window.paginationState.drilldownTitle || "Exportação";
            const _allData = window.paginationState.drilldownData || [];
            const _pdfFirstTk = String(((_allData[0] || {}).tk) || '').toUpperCase();
            const isPrbDrill = title.includes("RCA") || title.includes("Problem") || title.includes("PRB") || title.includes("PTASK") ||
                _pdfFirstTk.startsWith('PRB') || _pdfFirstTk.startsWith('PTASK');
            const isInc = window.paginationState.drilldownIsInc;

            const searchInput = document.getElementById('modal-search');
            const term = searchInput ? searchInput.value.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase() : "";

            let allData = window.paginationState.drilldownData || [];

            const filteredData = allData.filter(t => {
                if (!term) return true;
                const rowText = `${t.tk} ${t.desc} ${t.longDesc} ${t.req} ${t.as} ${t.gp} ${t.st} ${t.opStr} ${t.prb} ${t.info} ${t.reason}`.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                return rowText.includes(term);
            });

            if (filteredData.length === 0) return alert("Nenhum registro para exportar com este filtro.");

            doc.setFillColor(30, 58, 138);
            doc.rect(0, 0, 297, 30, 'F');
            doc.setTextColor(255, 255, 255);
            doc.setFont("helvetica", "bold");
            doc.setFontSize(16);
            doc.text(title.toUpperCase(), 148, 15, { align: 'center' });
            doc.setFontSize(10);
            doc.setFont("helvetica", "normal");
            doc.text(`Total filtrado e exportado: ${filteredData.length} chamados | Data: ${new Date().toLocaleString('pt-BR')}`, 148, 22, { align: 'center' });

            let head = [];
            if (!isPrbDrill && isInc) head = [["Ticket", "Assunto", "Solicitante", "Analista", "Grupo", "Status", "Abertura", "PRB", "AGING"]];
            else if (!isPrbDrill && !isInc) head = [["Ticket", "Assunto", "Solicitante", "Analista", "Grupo", "Status", "Abertura", "AGING"]];
            else head = [["Ticket", "Assunto", "Analista", "Grupo", "Status", "Abertura", "AGING"]];

            let body = filteredData.map(t => {
                let infoClean = t.info ? t.info.replace(/&quot;/g, '"') : "";
                let rReas = t.reason ? `(${t.reason})` : "";
                let descFull = `${t.desc}\n${infoClean} ${rReas}`.trim();

                let row = [];
                row.push(t.tk || "-");
                row.push(descFull || "-");
                if (!isPrbDrill) row.push(t.req || "N/A");
                row.push(t.as || "-");
                row.push(t.gp || "-");
                row.push(t.st || "-");
                row.push(t.opStr || "-");
                if (isInc) row.push(t.prb || "N/A");
                row.push(`${t.age}d`);
                return row;
            });

            doc.autoTable({
                startY: 35,
                head: head,
                body: body,
                styles: { fontSize: 7, cellPadding: 2, overflow: 'linebreak' },
                headStyles: { fillColor: [0, 24, 113], textColor: 255, fontStyle: 'bold' },
                alternateRowStyles: { fillColor: [241, 245, 249] },
                columnStyles: { 1: { cellWidth: 80 } },
                margin: { top: 35, bottom: 15, right: 10, left: 10 },
            });

            doc.save(`Export_Detalhado_${new Date().getTime()}.pdf`);
        };

