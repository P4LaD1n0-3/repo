                else if (stL.includes('cancel') || stL.includes('incomplet')) { bC = '#fee2e2'; fC = '#ef4444'; }
                else if (stL.includes('pend') || stL.includes('hold')) { bC = '#fef3c7'; fC = '#f59e0b'; }

                return `<tr class="ticket-row hover:bg-slate-50 transition" ${buildDataAttrs(t)}>
                    <td data-label="Ticket Original" class="font-bold text-[var(--primary-dark)] text-center">
                        ${t.tk} ${getEmailIndicator(t.tk)}
                        <div class="text-[9px] bg-slate-200 px-1.5 py-0.5 rounded inline-block text-slate-500">${t.type}</div>
                        <button onclick="openTicketDetails('${t.tk}')" class="block w-full mt-2 bg-blue-50 hover:bg-blue-100 border border-blue-200/50 p-1.5 rounded text-[9px] uppercase shadow-sm transition"><i class="fas fa-history"></i> Saiba mais</button>
                    </td>
                    <td data-label="Descrição Completa" class="text-left w-[350px] max-w-[350px]">
                        <div class="w-full h-auto max-h-[80px] overflow-y-auto overflow-x-hidden stylized-scrollbar border border-slate-100 bg-slate-50 p-1.5 rounded">
                            <div class="text-xs font-semibold text-slate-800 break-words mb-1">${t.desc}</div>
                            ${(t.longDesc && t.longDesc !== '-') ? `<div class="text-[10px] text-slate-500 italic break-words">${t.longDesc}</div>` : ''}
                            ${(t.info || t.reason) ? `<div class="text-[10px] font-bold text-amber-700 bg-amber-50 border border-amber-100 rounded px-1.5 py-0.5 mt-1 break-words whitespace-normal">⚠️ ${t.info} ${t.reason ? `(${t.reason})` : ''}</div>` : ''}
                        </div>
                    </td>
                    <td data-label="Solicitante" class="text-center">${t.req}</td>
                    <td data-label="Analista / Grupo" class="text-center">${t.asg}<br><span class="text-[9px] text-slate-400 block mt-1">${t.gp}</span></td>
                    <td data-label="Status" data-filter="${t.st}" class="text-center">
                        <span style="background:${bC};color:${fC}; border: 1px solid ${fC}40;" class="px-2 py-0.5 rounded text-[9px] font-bold block mb-1 mx-auto w-max">${t.st}</span>
                        <span class="text-[10px] text-slate-500 block mt-1"><i class="far fa-calendar-alt"></i> ${opS}</span>
                    </td>
                    <td data-label="AGING" class="text-right">
                        <div class="font-bold text-sm ${t.cl ? 'text-[var(--primary-dark)]' : 'text-orange-500'}">${clS}</div>
                        ${age !== '-' ? `<div class="text-[10px] text-slate-400 mt-1">${age}d de vida</div>` : ''}
                        ${(t.idle !== '-' && !isNaN(Number(t.idle))) ? `<div class="text-[10px] font-bold mt-1 ${Number(t.idle) > 3 ? 'text-red-500' : 'text-green-500'}"><i class="fas fa-user-clock"></i> ${t.idle}d ocioso</div>` : ''}
                    </td>
                </tr>`;
            }).join('');

            html += `<div class="report-card">
                <div class="st-dataframe-container border-0">
                    <table class="st-table">
                        <thead>
                            <tr>
                                ${createTh("Ticket Original", "15%")}
                                ${createTh("Descrição Completa", "auto", "left")}
                                ${createTh("Solicitante", "15%")}
                                ${createTh("Analista / Grupo", "15%")}
                                ${createTh("Status", "12%")}
                                ${createTh("AGING", "12%", "right")}
                            </tr>
                        </thead>
                        <tbody>${rows}</tbody>
                    </table>
                </div>
                ${renderPaginationControls('search', results.length, page)}
            </div>`;

            document.getElementById('tab-search').innerHTML = html;
            switchTab('tab-search');
        }

        function filterTables() {
            const input = document.getElementById("globalSearch");
            if (!input) return;
            const term = removeAccents(input.value.toUpperCase());

            document.querySelectorAll('.tab-pane:not(.hidden-st) table tbody').forEach(tbody => {
                Array.from(tbody.getElementsByTagName("tr")).forEach(r => {
                    let rT = removeAccents(r.innerText).toUpperCase();
                    if (!rT.includes("NENHUM") && !rT.includes("TOTAL") && !rT.includes("SEM DADOS")) {
                        r.style.display = rT.includes(term) ? "" : "none";
                    }
                });
            });
        }

        // ==========================================
        // 4. MOTOR CORE DE DADOS 
        // ==========================================
        const C = {
            PRI_D: "#001871", PRI: "#1E3A8A", ACC_D: "#0F172A",
            SUC: "#00C853", DAN: "#D50000", ORG: "#FF8C00",
            GRY_D: "#334155", GRY_L: "#F8FAFC", INFO: "#0284C7",
            // ── rgba chart palette ─────────────────────────────────────────────
            _A: 'rgba(30,58,138,0.82)', _Ab: 'rgba(30,58,138,0.11)',
            _R: 'rgba(5,150,105,0.82)', _Rb: 'rgba(5,150,105,0.10)',
            _Cc: 'rgba(220,38,38,0.72)', _Cb: 'rgba(220,38,38,0.08)',
            _B: 'rgba(2,132,199,1)', _Bb: 'rgba(2,132,199,0.08)',
            _INC: 'rgba(30,58,138,0.82)', _INCb: 'rgba(30,58,138,0.11)',
            _REQ: 'rgba(37,99,235,0.82)', _REQb: 'rgba(37,99,235,0.10)',
            _UAM: 'rgba(124,58,237,0.82)', _UAMb: 'rgba(124,58,237,0.09)',
            _SLA: 'rgba(127,29,29,0.92)', _SLAb: 'rgba(127,29,29,0.08)'
        };
        // ── Chart.js global defaults ──────────────────────────────────────────
        if (typeof Chart !== 'undefined') {
            Chart.defaults.global.defaultFontFamily = "'Inter','system-ui','sans-serif'";
            Chart.defaults.global.defaultFontSize = 11;
            Chart.defaults.global.defaultFontColor = '#475569';
            Chart.defaults.global.animation.duration = 500;
            Chart.defaults.global.animation.easing = 'easeInOutQuart';
        }

        function buildDataAttrs(t) {
            let hasInc = (t.related_incidents_raw && t.related_incidents_raw !== '—' && t.related_incidents_raw !== '') ? 'true' : 'false';
            return `data-tk="${t.tk}" data-desc="${t.desc}" data-req="${t.req || ''}" data-as="${t.as}" data-gp="${t.gp}" data-st="${t.st}" data-rca="${t.stRca || ''}" data-has-inc="${hasInc}" data-age="${t.age !== undefined ? t.age : (t.d || 0)}" data-op="${t.opStr || t.opS || '-'}" data-info="${t.info || ''}" data-reason="${t.reason || ''}" data-idle="${t.idle !== undefined ? t.idle : '-'}" data-pct="${t.pctSla !== undefined ? t.pctSla : ''}"`;
        }

        function buildTicketObject(r, refDateObj, asg, opOrig, clOrig, stOrig, st, age, typeStr, slaDays) {
            let tk = (typeStr === 'REQ' || typeStr === 'UAM') ? (getCol(r, ['RITM', 'Request Item', 'Item de solicitação', 'Number', 'Ticket']) || '-') : (getCol(r, ['Number', 'number', 'Ticket', 'Problem', 'Task']) || '-');

            let prbRaw = getCol(r, ['Problem', 'PRB', 'Problema', 'problem_id']);
            let prbVal = (prbRaw && String(prbRaw).trim() !== "" && String(prbRaw).trim() !== "undefined") ? String(prbRaw).trim() : 'N/A';

            let stLower = (st || '').toLowerCase();
            let holdReason = getCol(r, ['On hold reason', 'Motivo da espera', 'on_hold_reason']);
            let defaultInfo = String(getCol(r, ['Additional comments', 'Comentários Adicionais', 'Close notes']) || '').replace(/"/g, '&quot;');
            let infoFinal = (stLower.includes('hold') || stLower.includes('espera')) && holdReason
                ? String(holdReason).replace(/"/g, '&quot;')
                : defaultInfo;

            let longDesc = String(getCol(r, ['Description', 'description', 'Descrição Completa', 'Descrição', 'Additional details', 'additional_details']) || '').replace(/"/g, '&quot;');
            let reasonVal = String(getCol(r, ['Reason', 'reason', 'REASON', 'Motivo']) || '').toUpperCase();

            let pctSla = slaDays ? ((age / slaDays) * 100).toFixed(2).replace('.', ',') : '0,00';

            return {
                tk: tk,
                desc: String(getCol(r, ['Short description', 'Descrição Curta', 'Item', 'Problem', 'Problema']) || '-').replace(/"/g, '&quot;'),
                longDesc: longDesc,
                req: getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A',
                as: asg,
                gp: getCol(r, ['Assignment group', 'Grupo']) || '-',
                st: (clOrig ? stOrig : st).toUpperCase(),
                reason: reasonVal,
                age: age,
                opStr: opOrig ? opOrig.toLocaleDateString('pt-BR') : '-',
                idle: (!clOrig || clOrig > refDateObj) ? getDaysSilent(r, refDateObj, asg, opOrig) : '-',
                info: infoFinal,
                prb: prbVal,
                pctSla: pctSla
            };
        }

        function calculateSection(data, slaDays, type, refDateObj, isFullMonth = true) {
            const limitDate = new Date(refDateObj);
            const limitTime = limitDate.getTime();

            // Para trend e inicialização
            const refMonth = limitDate.getMonth();
            const refYear = limitDate.getFullYear();

            let totalMttr = 0, countRes = 0, inSlaMes = 0, resMes = 0, backlog = 0;
            let trendD = {}, trendM = {}, analistas = {}, criticals = [], noPrb = [];
            let agingBuckets = {};

            let allBacklogTks = [];
            let allResolvedTks = [];
            let allCanceledTks = [];

            const isReq = type === "REQ" || type === "UAM";
            const bucketsDef = isReq
                ? [{ l: "1-3 dias", min: 0, max: 3 }, { l: "3-5 dias", min: 4, max: 5 }, { l: "5-7 dias", min: 6, max: 7 }, { l: "7-10 dias", min: 8, max: 10 }, { l: "10 dias +", min: 11, max: 19 }, { l: "20 dias +", min: 20, max: 29 }, { l: "30 dias +", min: 30, max: 9999 }]
                : [{ l: "1-3 dias", min: 0, max: 3 }, { l: "4-7 dias", min: 4, max: 7 }, { l: "7+ dias", min: 8, max: 9999 }];

            bucketsDef.forEach(b => agingBuckets[b.l] = { count: 0, color: b.min > slaDays ? '#D50000' : '#1E3A8A', tks: [] });

            // Inicializa trendD
            let maxDay = isFullMonth ? limitDate.getDate() : 1;
            // Para o modo 'Dia', só queremos o dia específico de refDateObj
            if (!isFullMonth) {
                let sD = `${refYear}-${String(refMonth + 1).padStart(2, '0')}-${String(limitDate.getDate()).padStart(2, '0')}`;
                trendD[sD] = { a: 0, r: 0, c: 0, b: 0, tks_a: [], tks_r: [], tks_c: [] };
            } else {
                for (let i = 1; i <= limitDate.getDate(); i++) {
                    let sD = `${refYear}-${String(refMonth + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
                    trendD[sD] = { a: 0, r: 0, c: 0, b: 0, tks_a: [], tks_r: [], tks_c: [] };
                }
            }

            data.forEach(r => {
                let opOrig = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                if (!opOrig || opOrig.getTime() > limitTime) return;

                let clOrig = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                let stOrig = String(getCol(r, ['State', 'Status', 'Estado']) || '').toLowerCase();
                let cl = clOrig; let st = stOrig;

                if (clOrig && clOrig.getTime() > limitTime) { cl = null; st = 'Open (Retroativo)'; }

                let stL = stOrig.toLowerCase();
                let isRes = false;
                let isCanc = false;
                if (cl) {
                    if (stL.includes('cancel') || stL.includes('incomplet') || stL.includes('rejeit') || stL.includes('reject')) {
                        isCanc = true;
                    } else if (stL.includes('resolv') || stL.includes('clos') || stL.includes('fechad') || stL.includes('encerrad') || stL.includes('conclu') || stL.includes('complet')) {
                        isRes = true;
                    } else {
                        // Fallback crítico: se tem data de fechamento mas o status é desconhecido, marca como resolvido.
                        // Impede que tickets fiquem fantasmagoricamente ativos na projeção do backlog histórico.
                        isRes = true;
                    }
                }
                let age = cl ? Math.floor((cl - opOrig) / 86400000) : Math.floor((limitDate - opOrig) / 86400000);
                if (age < 0) age = 0;

                // Para indicadores 'Mensais' ou 'Diários' dependendo do modo
                let passMonth = isFullMonth ? (opOrig.getMonth() === refMonth && opOrig.getFullYear() === refYear) :
                    (opOrig.getDate() === limitDate.getDate() && opOrig.getMonth() === refMonth && opOrig.getFullYear() === refYear);

                let oY = opOrig.getFullYear(); let oM = String(opOrig.getMonth() + 1).padStart(2, '0');
                let mKey = `${oY}-${oM}`;
                if (!trendM[mKey]) trendM[mKey] = { a: 0, r: 0, c: 0, inSla: 0, tks_a: [], tks_r: [], tks_c: [] };

                let asg = getCol(r, ['Assigned to', 'Analista', 'Assignee']) || 'Não Atribuído';
                let tObj = buildTicketObject(r, limitDate, asg, opOrig, clOrig, stOrig, st, age, type, slaDays);

                trendM[mKey].a++;
                trendM[mKey].tks_a.push(tObj);

                let oD = String(opOrig.getDate()).padStart(2, '0');
                let dKey = `${oY}-${oM}-${oD}`;
                if (passMonth && trendD[dKey]) {
                    trendD[dKey].a++; trendD[dKey].tks_a.push(tObj);
                }

                if (isRes && cl) {
                    let cPass = isFullMonth ? (cl.getMonth() === refMonth && cl.getFullYear() === refYear) :
                        (cl.getDate() === limitDate.getDate() && cl.getMonth() === refMonth && cl.getFullYear() === refYear);

                    let cY = cl.getFullYear(); let cM = String(cl.getMonth() + 1).padStart(2, '0'); let cD = String(cl.getDate()).padStart(2, '0');

                    let mcKey = `${cY}-${cM}`;
                    if (!trendM[mcKey]) trendM[mcKey] = { a: 0, r: 0, c: 0, inSla: 0, tks_a: [], tks_r: [], tks_c: [] };
                    trendM[mcKey].r++;
                    trendM[mcKey].tks_r.push(tObj);
                    if (age <= slaDays) trendM[mcKey].inSla++;

                    if (cPass) {
                        resMes++;
                        if (age <= slaDays) inSlaMes++;
                        allResolvedTks.push(tObj);

                        let dcKey = `${cY}-${cM}-${cD}`;
                        if (trendD[dcKey]) {
                            trendD[dcKey].r++; trendD[dcKey].tks_r.push(tObj);
                        }
                        totalMttr += age; countRes++;
                    }
                } else if (isCanc && cl) {
                    let cPass = isFullMonth ? (cl.getMonth() === refMonth && cl.getFullYear() === refYear) :
                        (cl.getDate() === limitDate.getDate() && cl.getMonth() === refMonth && cl.getFullYear() === refYear);

                    let cY = cl.getFullYear(); let cM = String(cl.getMonth() + 1).padStart(2, '0'); let cD = String(cl.getDate()).padStart(2, '0');

                    let mcKey = `${cY}-${cM}`;
                    if (!trendM[mcKey]) trendM[mcKey] = { a: 0, r: 0, c: 0, inSla: 0, tks_a: [], tks_r: [], tks_c: [] };
                    trendM[mcKey].c++;
                    trendM[mcKey].tks_c.push(tObj);

                    if (cPass) {
                        allCanceledTks.push(tObj);
                        let dcKey = `${cY}-${cM}-${cD}`;
                        if (trendD[dcKey]) { trendD[dcKey].c++; trendD[dcKey].tks_c.push(tObj); }
                    }
                }

                if (!cl) {
                    backlog++;
                    allBacklogTks.push(tObj);

                    if (!analistas[asg]) analistas[asg] = { ab: 0, res: 0, tks_ab: [], tks_res: [] };
                    analistas[asg].ab++;
                    analistas[asg].tks_ab.push(tObj);

                    GlobalOpenTickets.push({ tk: tObj.tk, asg: asg });
                    bucketsDef.forEach(b => { if (age >= b.min && age <= b.max) { agingBuckets[b.l].count++; agingBuckets[b.l].tks.push(tObj); } });

                    let hasPrb = tObj.prb !== "N/A";
                    if (age > slaDays) {
                        criticals.push(tObj);
                        if (!isReq && !hasPrb) noPrb.push(tObj);
                    }
                }

                if (isRes && cl) {
                    let cPass = isFullMonth ? (cl.getMonth() === refMonth && cl.getFullYear() === refYear) :
                        (cl.getDate() === limitDate.getDate() && cl.getMonth() === refMonth && cl.getFullYear() === refYear);
                    if (cPass) {
                        if (!analistas[asg]) analistas[asg] = { ab: 0, res: 0, tks_ab: [], tks_res: [] };
                        analistas[asg].res++;
                        analistas[asg].tks_res.push(tObj);
                    }
                }
            });

            let topAnalistas = Object.keys(analistas).map(k => ({
                nome: k, ab: analistas[k].ab, res: analistas[k].res, tot: analistas[k].ab + analistas[k].res,
                tks_ab: analistas[k].tks_ab, tks_res: analistas[k].tks_res
            })).sort((a, b) => b.tot - a.tot).slice(0, 10);

            let mKeys = Object.keys(trendM).sort();
            let mb = backlog;
            for (let i = mKeys.length - 1; i >= 0; i--) {
                let k = mKeys[i];
                trendM[k].b = mb;
                mb -= (trendM[k].a - (trendM[k].r + trendM[k].c));
            }

            let dKeys = Object.keys(trendD).sort(); let db = backlog;
            for (let i = dKeys.length - 1; i >= 0; i--) {
                let k = dKeys[i];
                trendD[k].b = db;
                db -= (trendD[k].a - (trendD[k].r + trendD[k].c));
            }

            let inSlaTot = 0, outSlaTot = 0;
            let tksInSlaTot = [], tksOutSlaTot = [];
            bucketsDef.forEach(b => {
                if (b.min > slaDays) { outSlaTot += agingBuckets[b.l].count; tksOutSlaTot = tksOutSlaTot.concat(agingBuckets[b.l].tks); }
                else { inSlaTot += agingBuckets[b.l].count; tksInSlaTot = tksInSlaTot.concat(agingBuckets[b.l].tks); }
            });

            return {
                mttr: countRes ? (totalMttr / countRes).toFixed(2).replace('.', ',') : "0,00",
                pct: resMes ? ((inSlaMes / resMes) * 100).toFixed(2).replace('.', ',') : "0,00",
                resMes: resMes,
                inSla: inSlaMes, outSla: resMes - inSlaMes, backlog,
                inSlaTot, outSlaTot, tksInSlaTot, tksOutSlaTot,
                trendM, trendD, topAnalistas, agingBuckets,
                // Z-A: Chamados mais velhos/críticos no topo
                crits: criticals.sort((a, b) => (b.age || 0) - (a.age || 0)),
                noPrb: noPrb.sort((a, b) => (b.age || 0) - (a.age || 0)),
                allBacklogTks: allBacklogTks.sort((a, b) => (b.age || 0) - (a.age || 0)),
                allResolvedTks: allResolvedTks.sort((a, b) => (b.age || 0) - (a.age || 0)),
                allCanceledTks: allCanceledTks.sort((a, b) => (b.age || 0) - (a.age || 0))
            };
        }

        function calculateClassifications(allData, refDateObj) {
            let res = {
                total: 0, link: 0, noLink: 0, days: 0, max: 0,
                monthTotal: 0, monthLink: 0, monthNoLink: 0, monthDays: 0, monthMax: 0,
                req: {}, gp: {}, asg: {}, m: {}, tks: [],
                // Totais de TODOS os cancelados (para reconciliação com abas INC/REQ)
                allCancelados: { inc: { count: 0, tks: [] }, req: { count: 0, tks: [] } }
            };

            allData.forEach(r => {
                let tk = getCol(r, ['Number', 'number', 'Ticket', 'RITM', 'Request Item', 'Item de solicitação']) || '-';
                let stOrig = String(getCol(r, ['State', 'Status', 'Estado']) || '').toLowerCase();
                let reason = String(getCol(r, ['Reason', 'reason', 'REASON', 'Motivo']) || '').toUpperCase();
                let isInc = tk.toUpperCase().startsWith('INC');

                // ── Rastreia TODOS os cancelados para reconciliação (qualquer motivo) ─────
                let isAnyCanc = stOrig.includes('cancel') || stOrig.includes('incomplet') || stOrig.includes('rejeit') || stOrig.includes('reject');
                if (isAnyCanc) {
                    let opAll = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                    let clAll = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                    if (opAll && clAll && opAll.getTime() <= refDateObj.getTime() && clAll.getTime() <= refDateObj.getTime()) {
                        let isCurrMonth = clAll.getMonth() === refDateObj.getMonth() && clAll.getFullYear() === refDateObj.getFullYear();
                        if (isCurrMonth) {
                            let tinyAge = Math.max(0, Math.floor((clAll - opAll) / 86400000));
                            let tinyObj = {
                                tk, st: stOrig.toUpperCase(), reason,
                                desc: String(getCol(r, ['Short description', 'Descrição Curta', 'Descrição']) || '-').replace(/"/g, '&quot;'),
                                as: getCol(r, ['Assigned to', 'Analista', 'Assignee']) || 'N/A',
                                gp: getCol(r, ['Assignment group', 'Grupo']) || 'N/A',
                                req: getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A',
                                info: String(getCol(r, ['Close notes', 'Close Notes', 'On hold reason', 'Additional comments', 'Comentários']) || '-').replace(/"/g, '&quot;'),
                                age: tinyAge, d: tinyAge, idle: '-',
                                opStr: opAll.toLocaleDateString('pt-BR')
                            };
                            if (isInc) { res.allCancelados.inc.count++; res.allCancelados.inc.tks.push(tinyObj); }
                            else { res.allCancelados.req.count++; res.allCancelados.req.tks.push(tinyObj); }
                        }
                    }
                }
                // ─────────────────────────────────────────────────────────────────────────

                // Captura Classificações Incorretas: qualquer tipo (INC ou REQ) com status de encerramento anormal
                if (reason.includes('INCORRECT CLASSIFICATION') && (stOrig.includes('incomplet') || stOrig.includes('cancel') || stOrig.includes('rejeit') || stOrig.includes('reject'))) {
                    let op = safeDate(getCol(r, ['Opened', 'Data Abertura', 'Created', 'opened_at']));
                    let cl = safeDate(getCol(r, ['Resolved', 'Closed', 'Data Fechamento', 'Resolved at']));
                    if (!op) return;
                    if (op.getTime() > refDateObj.getTime()) return;

                    let closeNotes = String(getCol(r, ['Close notes', 'Close Notes', 'close_notes', 'Closing notes']) || '');
                    let linkedMatch = closeNotes.match(/(INC|RITM|REQ|TASK)[\s\-]?(\d{6,8})/i);
                    let linkedTicket = linkedMatch ? (linkedMatch[1].toUpperCase() + linkedMatch[2]) : null;

                    // Cálculo preciso para MTTR (sem Math.floor aqui)
                    let rawDays = cl ? ((cl - op) / 86400000) : ((refDateObj - op) / 86400000);
                    if (rawDays < 0) rawDays = 0;

                    let daysInt = Math.floor(rawDays);

                    let asg = getCol(r, ['Assigned to', 'Analista']) || 'N/A';
                    let reqName = getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A';
                    let gpName = getCol(r, ['Assignment group', 'Grupo']) || 'N/A';

                    let idle = (!cl || cl.getTime() > refDateObj.getTime()) ? getDaysSilent(r, refDateObj, asg, op) : '-';

                    res.total++;
                    if (linkedTicket) res.link++; else res.noLink++;
                    res.days += rawDays;
                    if (daysInt > res.max) res.max = daysInt;

                    // Mês Vigente para os cards: Baseado na data de FECHAMENTO (Performance)
                    // Se não tiver data de fechamento, usa a data de abertura como fallback
                    let dateToCompare = cl || op;
                    let isCurrentMonth = (dateToCompare.getMonth() === refDateObj.getMonth() &&
                        dateToCompare.getFullYear() === refDateObj.getFullYear() &&
                        dateToCompare.getTime() <= refDateObj.getTime()); // Trava na data de referência

                    if (isCurrentMonth) {
                        res.monthTotal++;
                        if (linkedTicket) res.monthLink++; else res.monthNoLink++;
                        res.monthDays += rawDays;
                        if (daysInt > res.monthMax) res.monthMax = daysInt;
                    }

                    let mStrKey = dateToCompare.getFullYear() + '-' + String(dateToCompare.getMonth() + 1).padStart(2, '0');
                    let mStrLabel = dateToCompare.toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' }).toUpperCase().replace('.', '');
                    if (!res.m[mStrKey]) res.m[mStrKey] = { count: 0, tks: [], label: mStrLabel };
                    res.m[mStrKey].count++;

                    if (isCurrentMonth) {
                        if (!res.req[reqName]) res.req[reqName] = { count: 0, tks: [] }; res.req[reqName].count++;
                        if (!res.gp[gpName]) res.gp[gpName] = { count: 0, tks: [] }; res.gp[gpName].count++;
                        if (!res.asg[asg]) res.asg[asg] = { count: 0, tks: [] }; res.asg[asg].count++;
                    }

                    let tObj = {
                        tk: tk, req: reqName, as: asg, gp: gpName, l: linkedTicket || '⚠️ Erro / Não Vinculado',
                        rea: reason, st: stOrig.toUpperCase(), d: daysInt, age: daysInt, idle: idle, opStr: op.toLocaleDateString('pt-BR'), opS: op.toLocaleDateString('pt-BR'),
                        desc: String(getCol(r, ['Short description', 'Descrição Curta', 'Descrição']) || '-').replace(/"/g, '&quot;'),
                        info: closeNotes.replace(/"/g, '&quot;') || 'Nenhuma nota de fechamento registrada.',
                        reason: reason,
                        isMonth: isCurrentMonth,
                        direction: isInc ? 'INC→REQ' : 'REQ→INC'
                    };
                    res.tks.push(tObj);

                    if (isCurrentMonth) {
                        res.req[reqName].tks.push(tObj); res.gp[gpName].tks.push(tObj); res.asg[asg].tks.push(tObj);
                    }
                    res.m[mStrKey].tks.push(tObj);
                }
            });
            res.avg = res.total ? (res.days / res.total).toFixed(2).replace('.', ',') : "0,00";
            res.avgMonth = res.monthTotal ? (res.monthDays / res.monthTotal).toFixed(2).replace('.', ',') : "0,00";
            res.tks.sort((a, b) => (b.age || 0) - (a.age || 0));
            return res;
        }

