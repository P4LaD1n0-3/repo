        function generateSLABreachTab(dI, dRS, dRU, slaI, slaR, refDateObj) {
            if (!window.DrilldownVault['sla']) window.DrilldownVault['sla'] = {};

            const _I = dI || { outSla: 0, resMes: 0, outSlaTot: 0, tksOutSlaTot: [], allResolvedTks: [], trendM: {}, trendD: {} };
            const _RS = dRS || { outSla: 0, resMes: 0, outSlaTot: 0, tksOutSlaTot: [], allResolvedTks: [], trendM: {}, trendD: {} };
            const _RU = dRU || { outSla: 0, resMes: 0, outSlaTot: 0, tksOutSlaTot: [], allResolvedTks: [], trendM: {}, trendD: {} };

            // ── KPI ─────────────────────────────────────────────────────────────
            const outMesInc = _I.outSla || 0;
            const outMesReq = _RS.outSla || 0;
            const outMesUam = _RU.outSla || 0;
            const totalOutMes = outMesInc + outMesReq + outMesUam;
            const resMesTotal = (_I.resMes || 0) + (_RS.resMes || 0) + (_RU.resMes || 0);
            const pctOut = resMesTotal > 0 ? ((totalOutMes / resMesTotal) * 100).toFixed(1).replace('.', ',') : '0,0';

            const blOutInc = _I.outSlaTot || 0;
            const blOutReq = _RS.outSlaTot || 0;
            const blOutUam = _RU.outSlaTot || 0;
            const totalBlOut = blOutInc + blOutReq + blOutUam;

            const pctInc = _I.resMes > 0 ? ((outMesInc / _I.resMes) * 100).toFixed(1).replace('.', ',') : '0,0';
            const pctReq = _RS.resMes > 0 ? ((outMesReq / _RS.resMes) * 100).toFixed(1).replace('.', ',') : '0,0';
            const pctUam = _RU.resMes > 0 ? ((outMesUam / _RU.resMes) * 100).toFixed(1).replace('.', ',') : '0,0';

            // ── LISTAS DE TICKETS ────────────────────────────────────────────────
            const mk = t => t;
