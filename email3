#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
ABA: ANALISTAS — Dashboard de Performance Individual (REQs x INCs)

MELHORIAS IMPLEMENTADAS (SEM CORTES / SEM OMISSÕES):
- Limite de analistas exibidos: TOP N (padrão 20) para garantir legibilidade e evitar gráficos quebrados
- Inclusão de INCs (incidentes) com métricas próprias:
    - Quantidade atendida (encerrados)
    - Tempo de atendimento (MTTR, mediana, p90)
    - Backlog aberto (abertos)
    - SLA Compliance (fechados dentro do SLA) com SLA menor por padrão (INCs: 7 dias; REQs: 10 dias)
- Painel comparativo "REQs x INCs" por analista (lado a lado na mesma tabela)
- Tabelas mais objetivas (ranking + colunas essenciais + indicadores de risco)
- Área de dados para gráficos isolada (evita sobreposição com tabelas)
- Gráficos refeitos para usar TOP N e ranges estáveis
- Mantém padrão visual compatível com analise_temporal.py (ModernColors + utilitários)
"""

import pandas as pd
import numpy as np
from datetime import datetime

from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from openpyxl.utils import get_column_letter


# =============================================================================
# PALETA DE CORES MODERNA (mesmo padrão do analise_temporal.py)
# =============================================================================
class ModernColors:
    """Paleta de cores profissional e moderna"""
    # Primárias
    PRIMARY_DARK  = "2C3E50"
    PRIMARY       = "3498DB"
    PRIMARY_LIGHT = "EBF5FB"

    # Status
    SUCCESS       = "27AE60"
    SUCCESS_LIGHT = "D5F4E6"
    WARNING       = "F39C12"
    WARNING_LIGHT = "FCF3CF"
    DANGER        = "E74C3C"
    DANGER_LIGHT  = "FADBD8"

    # Extras
    ORANGE        = "E67E22"
    ORANGE_LIGHT  = "FDEBD0"

    # Neutros
    GRAY_DARK     = "34495E"
    GRAY          = "7F8C8D"
    GRAY_LIGHT    = "ECF0F1"
    WHITE         = "FFFFFF"

    # Especiais
    ACCENT        = "9B59B6"
    ACCENT_LIGHT  = "EBDEF0"
    INFO          = "17A2B8"
    INFO_LIGHT    = "D1ECF1"

    # Dashboard
    BACKGROUND    = "F5F6FA"


# =============================================================================
# Utilitários base (no mesmo padrão do analise_temporal.py)
# =============================================================================
def _pick_col(df, candidates):
    for c in candidates:
        if c in df.columns:
            return c
    return None


def _norm_state(x):
    if pd.isna(x):
        return "Open"
    v = str(x).strip().lower()
    if any(k in v for k in ["closed", "fechado", "final", "encerr", "resolv", "done", "completed", "resolved"]):
        return "Closed"
    return "Open"


def _modern_border(style="thin", color=None):
    color = color or ModernColors.GRAY
    return Border(
        left=Side(style=style, color=color),
        right=Side(style=style, color=color),
        top=Side(style=style, color=color),
        bottom=Side(style=style, color=color),
    )


def _apply_border_to_range(ws, start_row, start_col, end_row, end_col,
                           border_style="medium", border_color=None):
    border_color = border_color or ModernColors.PRIMARY_DARK
    for row in range(start_row, end_row + 1):
        for col in range(start_col, end_col + 1):
            cell = ws.cell(row=row, column=col)

            left_style   = "medium" if col == start_col else "thin"
            right_style  = "medium" if col == end_col else "thin"
            top_style    = "medium" if row == start_row else "thin"
            bottom_style = "medium" if row == end_row else "thin"

            cell.border = Border(
                left=Side(style=left_style, color=border_color),
                right=Side(style=right_style, color=border_color),
                top=Side(style=top_style, color=border_color),
                bottom=Side(style=bottom_style, color=border_color),
            )


def _fill_background_cells(ws, start_row, start_col, end_row, end_col, bg_color):
    for row in range(start_row, end_row + 1):
        for col in range(start_col, end_col + 1):
            cell = ws.cell(row=row, column=col)
            if (not cell.fill
                    or getattr(cell.fill, "start_color", None) is None
                    or getattr(cell.fill.start_color, "rgb", None) in (None, "00000000")):
                cell.fill = PatternFill(
                    start_color=bg_color,
                    end_color=bg_color,
                    fill_type="solid"
                )


def _merge_and_style(ws, start_row, start_col, end_row, end_col, value,
                     font_size=12, font_color="FFFFFF", bg_color=None,
                     bold=True, align="center", border_color=None):
    start_cell = f"{get_column_letter(start_col)}{start_row}"
    end_cell   = f"{get_column_letter(end_col)}{end_row}"
    ws.merge_cells(f"{start_cell}:{end_cell}")

    cell = ws[start_cell]
    cell.value = value
    cell.font = Font(size=font_size, bold=bold, color=font_color, name="Calibri")

    if bg_color:
        cell.fill = PatternFill(start_color=bg_color, end_color=bg_color, fill_type="solid")

    cell.alignment = Alignment(horizontal=align, vertical="center", wrap_text=True)

    _apply_border_to_range(
        ws, start_row, start_col, end_row, end_col,
        border_style="medium",
        border_color=border_color or ModernColors.PRIMARY_DARK
    )

    if bg_color:
        _fill_background_cells(ws, start_row, start_col, end_row, end_col, bg_color)

    return cell


def _create_kpi_card(ws, row, col, label, value, delta="", icon="📊",
                     bg_color=None, value_color=None, size="normal"):
    """
    Card KPI com altura padronizada (sempre 3 linhas).
    """
    bg_color = bg_color or ModernColors.PRIMARY_LIGHT
    value_color = value_color or ModernColors.PRIMARY_DARK

    ws.row_dimensions[row].height = 18

    _merge_and_style(
        ws, row, col, row, col + 1, f"{icon} {label}",
        font_size=9, font_color=ModernColors.GRAY_DARK,
        bg_color=ModernColors.GRAY_LIGHT, bold=True, align="left",
        border_color=ModernColors.PRIMARY_DARK
    )

    _merge_and_style(
        ws, row + 1, col, row + 1, col + 1, value,
        font_size=22 if size == "normal" else 18,
        font_color=value_color,
        bg_color=bg_color, bold=True, align="center",
        border_color=ModernColors.PRIMARY_DARK
    )
    ws.row_dimensions[row + 1].height = 40 if size == "normal" else 30

    delta_text = delta if (delta is not None and str(delta).strip() != "") else " "
    _merge_and_style(
        ws, row + 2, col, row + 2, col + 1, delta_text,
        font_size=8, font_color=ModernColors.GRAY,
        bg_color=bg_color, bold=False, align="center",
        border_color=ModernColors.PRIMARY_DARK
    )
    ws.row_dimensions[row + 2].height = 18


def _create_section_header(ws, row, start_col, end_col, title, icon="", bg_color=None):
    bg_color = bg_color or ModernColors.PRIMARY_DARK
    _merge_and_style(
        ws, row, start_col, row, end_col, f"{icon} {title}",
        font_size=13, font_color="FFFFFF",
        bg_color=bg_color, bold=True, align="left",
        border_color=bg_color
    )
    ws.row_dimensions[row].height = 30


def _create_table_compact(ws, start_row, start_col, headers, data,
                          col_widths=None, zebra=True, highlight_cols=None,
                          header_color=None):
    header_color = header_color or ModernColors.PRIMARY

    # Header
    for idx, header in enumerate(headers):
        cell = ws.cell(row=start_row, column=start_col + idx)
        cell.value = header
        cell.font = Font(size=10, bold=True, color="FFFFFF", name="Calibri")
        cell.fill = PatternFill(start_color=header_color,
                                end_color=header_color,
                                fill_type="solid")
        cell.alignment = Alignment(horizontal="center", vertical="center")
        cell.border = _modern_border("thin", ModernColors.PRIMARY_DARK)

        if col_widths and idx < len(col_widths):
            ws.column_dimensions[get_column_letter(start_col + idx)].width = col_widths[idx]

    ws.row_dimensions[start_row].height = 25

    # Data
    for row_idx, row_data in enumerate(data):
        current_row = start_row + 1 + row_idx

        if zebra and row_idx % 2 == 0:
            bg_fill = PatternFill(start_color=ModernColors.GRAY_LIGHT,
                                  end_color=ModernColors.GRAY_LIGHT,
                                  fill_type="solid")
        else:
            bg_fill = PatternFill(start_color=ModernColors.WHITE,
                                  end_color=ModernColors.WHITE,
                                  fill_type="solid")

        for col_idx, val in enumerate(row_data):
            cell = ws.cell(row=current_row, column=start_col + col_idx)
            cell.value = val
            cell.font = Font(size=10, name="Calibri", bold=(col_idx == 0))

            applied_highlight = False
            if highlight_cols and col_idx in highlight_cols:
                check_func, hl_bg, hl_text = highlight_cols[col_idx]
                if check_func(val, row_data):
                    cell.fill = PatternFill(start_color=hl_bg, end_color=hl_bg, fill_type="solid")
                    cell.font = Font(size=10, name="Calibri", bold=True, color=hl_text)
                    applied_highlight = True

            if not applied_highlight:
                cell.fill = bg_fill

            cell.alignment = Alignment(horizontal="center" if col_idx > 0 else "left",
                                       vertical="center")
            cell.border = _modern_border("thin", ModernColors.GRAY)

        ws.row_dimensions[current_row].height = 22

    return start_row + len(data) + 2


def _get_status_colors(value, threshold_good, threshold_warning, reverse=False):
    if pd.isna(value):
        return (ModernColors.GRAY_LIGHT, ModernColors.GRAY_DARK)

    if reverse:
        if value <= threshold_good:
            return (ModernColors.SUCCESS_LIGHT, ModernColors.SUCCESS)
        elif value <= threshold_warning:
            return (ModernColors.WARNING_LIGHT, ModernColors.WARNING)
        else:
            return (ModernColors.DANGER_LIGHT, ModernColors.DANGER)
    else:
        if value >= threshold_good:
            return (ModernColors.SUCCESS_LIGHT, ModernColors.SUCCESS)
        elif value >= threshold_warning:
            return (ModernColors.WARNING_LIGHT, ModernColors.WARNING)
        else:
            return (ModernColors.DANGER_LIGHT, ModernColors.DANGER)


def _create_info_box(ws, row, col, width_cols, title, text, icon="💡",
                     bg_title=None, bg_text=None, border_color=None):
    end_col = col + width_cols - 1
    bg_title = bg_title or ModernColors.PRIMARY_LIGHT
    bg_text = bg_text or ModernColors.WHITE
    border_color = border_color or ModernColors.PRIMARY

    _merge_and_style(
        ws, row, col, row, end_col, f"{icon} {title}",
        font_size=10, font_color=ModernColors.PRIMARY,
        bg_color=bg_title, bold=True, align="left",
        border_color=border_color
    )
    _merge_and_style(
        ws, row + 1, col, row + 1, end_col, text,
        font_size=9, font_color=ModernColors.GRAY_DARK,
        bg_color=bg_text, bold=False, align="left",
        border_color=border_color
    )

    ws.row_dimensions[row + 1].height = 34
    return row + 3


def _fill_spacer_column(ws, col, start_row, end_row):
    for rr in range(start_row, end_row + 1):
        cell = ws.cell(row=rr, column=col)
        cell.fill = PatternFill(start_color=ModernColors.BACKGROUND,
                                end_color=ModernColors.BACKGROUND,
                                fill_type="solid")


def _safe_int(x, default=0):
    try:
        if pd.isna(x):
            return default
        return int(float(x))
    except Exception:
        return default


def _safe_float(x, default=0.0):
    try:
        if pd.isna(x):
            return default
        return float(x)
    except Exception:
        return default


def _weighted_mean(values, weights):
    try:
        v = np.array(values, dtype=float)
        w = np.array(weights, dtype=float)
        if np.sum(w) <= 0:
            return 0.0
        return float(np.sum(v * w) / np.sum(w))
    except Exception:
        return 0.0


# =============================================================================
# Cálculo da Análise por Analista (genérico para REQ/INC)
# =============================================================================
def calculate_analyst_analysis(df,
                              meses_extracao_override=None,
                              ticket_label="REQ",
                              sla_max_days=None,
                              months_limit=None):
    """
    Retorna métricas por analista para um dataset (REQ ou INC).

    meses_extracao_override:
      - None: calcula pela janela mensal (fechamento)
      - int: força valor exibido como "X meses analisados"

    sla_max_days:
      - None: não calcula compliance SLA
      - int: calcula SLA compliance em fechados (% aging <= SLA)

    months_limit:
      - None: usa todos os meses contínuos disponíveis
      - int: limita a exibição/pivot aos últimos N meses (melhora legibilidade)
    """
    print("\n" + "=" * 100)
    print(f"📊 ANÁLISE POR ANALISTA — Cálculo de Métricas ({ticket_label})")
    print("=" * 100)

    if df is None or len(df) == 0:
        analysis_meta = {
            "meses_calculado": 0,
            "meses_exibido": int(meses_extracao_override) if meses_extracao_override is not None else 0,
            "override_aplicado": meses_extracao_override is not None,
            "janela": "N/A",
            "periodo_inicio": "N/A",
            "periodo_fim": "N/A",
            "ticket_label": str(ticket_label),
            "sla_max_days": int(sla_max_days) if sla_max_days is not None else None,
        }
        empty = pd.DataFrame()
        return {
            "analysis": analysis_meta,
            "summary": empty,
            "monthly_pivot": empty,
            "months_list": [],
            "analysts_sorted": [],
            "kpis": {
                "total_team_closed": 0,
                "total_team_open": 0,
                "team_mttr_mean": 0.0,
                "team_mttr_p90": 0.0,
                "team_sla_compliance_closed_pct": 0.0,
                "ticket_label": str(ticket_label),
            },
            "base_counts": {
                "total_rows": 0,
                "open_rows": 0,
                "closed_rows": 0
            }
        }

    dfc = df.copy()

    # GARANTIA DE SEGURANÇA: Remove colunas duplicadas e reseta o index
    if dfc.columns.duplicated().any():
        dfc = dfc.loc[:, ~dfc.columns.duplicated()]
    dfc = dfc.reset_index(drop=True)

    analyst_col = _pick_col(dfc, ["Assigned to", "Assigned_to", "Analista", "AssignedTo", "Assignee"])
    opened_col  = _pick_col(dfc, ["Opened", "Open", "OpenedAt", "Data Abertura", "Created"])
    closed_col  = _pick_col(dfc, ["Closed", "Close", "ClosedAt", "Data Fechamento"])
    state_col   = _pick_col(dfc, ["Status_Bin", "Status Bin", "State", "Status", "Estado"])
    aging_col   = _pick_col(dfc, ["Aging", "AGING"])
    reopen_col  = _pick_col(dfc, ["Reopen_Count", "Reopen count", "ReopenCount", "Reaberto", "Reabertos"])
    month_col   = _pick_col(dfc, ["Month"])

    if not analyst_col:
        raise ValueError("Coluna de analista não encontrada (Assigned to / Analista).")

    dfc["_analyst"] = (dfc[analyst_col].fillna("Sem Analista").astype(str).str.strip())
    dfc["_analyst"] = dfc["_analyst"].replace({"": "Sem Analista"})

    if state_col:
        dfc["_state"] = dfc[state_col].apply(_norm_state)
    else:
        if closed_col:
            dfc["_state"] = np.where(pd.to_datetime(dfc[closed_col], errors="coerce").notna(),
                                     "Closed", "Open")
        else:
            dfc["_state"] = "Open"

    # Datas (para pivô mensal)
    if opened_col:
        dfc["_opened_dt"] = pd.to_datetime(dfc[opened_col], errors="coerce")
    else:
        dfc["_opened_dt"] = pd.NaT

    if closed_col:
        dfc["_closed_dt"] = pd.to_datetime(dfc[closed_col], errors="coerce")
    else:
        dfc["_closed_dt"] = pd.NaT

    if month_col:
        dfc["_month_open_raw"] = dfc[month_col].astype(str).str.strip()
    else:
        dfc["_month_open_raw"] = ""

    # Aging/tempo de atendimento
    if aging_col:
        dfc["_aging"] = pd.to_numeric(dfc[aging_col], errors="coerce").fillna(0).astype(float)
    else:
        # fallback: se não houver aging, calcula por Opened/Closed
        now = pd.Timestamp(datetime.now())
        opened_dt = dfc["_opened_dt"]
        closed_dt = dfc["_closed_dt"].fillna(now)
        dfc["_aging"] = (closed_dt - opened_dt).dt.days
        dfc["_aging"] = pd.to_numeric(dfc["_aging"], errors="coerce").fillna(0).astype(float)

    if reopen_col:
        dfc["_reopen"] = pd.to_numeric(dfc[reopen_col], errors="coerce").fillna(0).astype(float)
    else:
        dfc["_reopen"] = 0.0

    # Month de fechamento
    dfc["_close_month"] = (
        dfc["_closed_dt"]
        .dt.to_period("M")
        .dt.to_timestamp()
        .where(dfc["_closed_dt"].notna(), other=pd.NaT)
    )

    closed_df = dfc[dfc["_state"] == "Closed"].copy()
    open_df   = dfc[dfc["_state"] != "Closed"].copy()

    all_analysts = sorted(dfc["_analyst"].unique().tolist())

    # Métricas base
    total_assigned = dfc.groupby("_analyst").size()
    total_closed   = closed_df.groupby("_analyst").size()
    total_open     = open_df.groupby("_analyst").size()

    mttr_mean = (closed_df.groupby("_analyst")["_aging"].mean()
                 if len(closed_df) else pd.Series(dtype=float))
    mttr_median = (closed_df.groupby("_analyst")["_aging"].median()
                   if len(closed_df) else pd.Series(dtype=float))
    mttr_p90 = (closed_df.groupby("_analyst")["_aging"].quantile(0.90)
                if len(closed_df) else pd.Series(dtype=float))
    mttr_std = (closed_df.groupby("_analyst")["_aging"].std()
                if len(closed_df) else pd.Series(dtype=float))

    reopen_sum = (closed_df.groupby("_analyst")["_reopen"].sum()
                  if len(closed_df) else pd.Series(dtype=float))

    # Aging Index: % chamados abertos com aging > 5
    open_inactive = open_df[open_df["_aging"] > 5].groupby("_analyst").size()

    summary = pd.DataFrame(index=all_analysts)
    summary["Total_Atribuidos"] = total_assigned.reindex(all_analysts, fill_value=0)
    summary["Total_Abertos"]    = total_open.reindex(all_analysts, fill_value=0)
    summary["Total_Fechados"]   = total_closed.reindex(all_analysts, fill_value=0)

    # Net Flow: atribuídos - fechados (mantém semântica do seu texto original)
    summary["Net_Flow"] = summary["Total_Atribuidos"] - summary["Total_Fechados"]

    summary["MTTR_Mean"]   = mttr_mean.reindex(all_analysts, fill_value=0).round(1)
    summary["MTTR_Median"] = mttr_median.reindex(all_analysts, fill_value=0).round(1)
    summary["MTTR_P90"]    = mttr_p90.reindex(all_analysts, fill_value=0).round(1)
    summary["MTTR_Std"]    = mttr_std.reindex(all_analysts, fill_value=0).fillna(0).round(1)

    summary["Reopen_Total"] = reopen_sum.reindex(all_analysts, fill_value=0).round(0).astype(int)

    summary["Taxa_Resolucao_%"] = (
        (summary["Total_Fechados"] / summary["Total_Atribuidos"] * 100)
        .where(summary["Total_Atribuidos"] > 0, 0)
        .round(1)
    )

    summary["Effective_Res_%"] = (
        ((summary["Total_Fechados"] - summary["Reopen_Total"]) / summary["Total_Fechados"] * 100)
        .where(summary["Total_Fechados"] > 0, 0)
        .round(1)
        .clip(lower=0)
    )

    summary["Aging_Index_%"] = (
        (open_inactive / summary["Total_Abertos"] * 100)
        .replace([np.inf, -np.inf], 0)
        .reindex(all_analysts, fill_value=0)
        .round(1)
    )

    # SLA compliance em fechados (opcional)
    if sla_max_days is not None and len(closed_df) > 0:
        sla_max_days = int(sla_max_days)
        closed_df["_sla_ok"] = closed_df["_aging"] <= sla_max_days
        sla_ok = closed_df.groupby("_analyst")["_sla_ok"].sum()
        sla_total = closed_df.groupby("_analyst")["_sla_ok"].count()
        sla_pct = (sla_ok / sla_total * 100).replace([np.inf, -np.inf], 0).fillna(0).round(1)
        summary["SLA_Compliance_Closed_%"] = sla_pct.reindex(all_analysts, fill_value=0)
        summary["SLA_Breaches_Closed"] = (sla_total - sla_ok).reindex(all_analysts, fill_value=0).astype(int)
    else:
        summary["SLA_Compliance_Closed_%"] = 0.0
        summary["SLA_Breaches_Closed"] = 0

    # Janela mensal contínua baseada nos fechamentos
    close_months = dfc["_close_month"].dropna()
    if len(close_months) > 0:
        month_start = close_months.min()
        month_end   = close_months.max()
        all_months  = pd.date_range(month_start, month_end, freq="MS")

        if months_limit is not None:
            months_limit = int(months_limit)
            if months_limit > 0 and len(all_months) > months_limit:
                all_months = all_months[-months_limit:]

        meses_calculado = int(len(all_months))
        meses_exibido = int(meses_extracao_override) if meses_extracao_override is not None else meses_calculado
        periodo_ini = pd.Timestamp(all_months[0]).strftime("%Y-%m")
        periodo_fim = pd.Timestamp(all_months[-1]).strftime("%Y-%m")
        janela = f"{periodo_ini} → {periodo_fim}"
        months_list_str = [pd.Timestamp(m).strftime("%Y-%m") for m in all_months]
    else:
        all_months = pd.DatetimeIndex([])
        meses_calculado = 0
        meses_exibido = int(meses_extracao_override) if meses_extracao_override is not None else 0
        janela = "N/A"
        months_list_str = []

    # Pivot de encerramentos por mês
    if len(closed_df) > 0 and len(months_list_str) > 0:
        closed_df["_close_month_str"] = closed_df["_close_month"].dt.strftime("%Y-%m")
        monthly_pivot = (
            closed_df.groupby(["_analyst", "_close_month_str"]).size().unstack(fill_value=0)
        )
        monthly_pivot = monthly_pivot.reindex(columns=months_list_str, fill_value=0)
    else:
        monthly_pivot = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0).astype(int)

    

    # Métricas mensais detalhadas (para comparação por mês / últimos 3 meses)
    # Retorna pivôs por analista x mês para: Closed_Count, MTTR_Mean, MTTR_P90, SLA_Compliance_%
    if len(closed_df) > 0 and len(months_list_str) > 0:
        closed_df["_close_month_str"] = closed_df["_close_month"].dt.strftime("%Y-%m")

        m_count = (closed_df.groupby(["_analyst", "_close_month_str"]).size().unstack(fill_value=0)
                   .reindex(columns=months_list_str, fill_value=0))

        m_mttr_mean = (closed_df.groupby(["_analyst", "_close_month_str"])["_aging"].mean().unstack()
                       if len(closed_df) else pd.DataFrame())
        if isinstance(m_mttr_mean, pd.DataFrame) and len(m_mttr_mean) > 0:
            m_mttr_mean = m_mttr_mean.reindex(columns=months_list_str).fillna(0).round(2)
        else:
            m_mttr_mean = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0)

        m_mttr_p90 = (closed_df.groupby(["_analyst", "_close_month_str"])["_aging"].quantile(0.90).unstack()
                      if len(closed_df) else pd.DataFrame())
        if isinstance(m_mttr_p90, pd.DataFrame) and len(m_mttr_p90) > 0:
            m_mttr_p90 = m_mttr_p90.reindex(columns=months_list_str).fillna(0).round(2)
        else:
            m_mttr_p90 = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0)

        if sla_max_days is not None:
            sla_days = int(sla_max_days)
            closed_df["_sla_ok"] = closed_df["_aging"] <= sla_days
            m_sla = (closed_df.groupby(["_analyst", "_close_month_str"])["_sla_ok"].mean().unstack()
                     if len(closed_df) else pd.DataFrame())
            if isinstance(m_sla, pd.DataFrame) and len(m_sla) > 0:
                m_sla = (m_sla.reindex(columns=months_list_str).fillna(0) * 100.0).round(2)
            else:
                m_sla = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0)
        else:
            m_sla = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0)

        # Garante mesma ordem/índice
        m_count = m_count.reindex(index=all_analysts, fill_value=0)
        m_mttr_mean = m_mttr_mean.reindex(index=all_analysts).fillna(0)
        m_mttr_p90 = m_mttr_p90.reindex(index=all_analysts).fillna(0)
        m_sla = m_sla.reindex(index=all_analysts).fillna(0)

    else:
        m_count = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0).astype(int)
        m_mttr_mean = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0)
        m_mttr_p90 = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0)
        m_sla = pd.DataFrame(index=all_analysts, columns=months_list_str).fillna(0)

    monthly_metrics = {
        "Closed_Count": m_count,
        "MTTR_Mean": m_mttr_mean,
        "MTTR_P90": m_mttr_p90,
        "SLA_Compliance_%": m_sla,
    }

# Ordenação por fechados (principal)
    summary = summary.sort_values(["Total_Fechados", "Total_Atribuidos", "MTTR_Mean"],
                                  ascending=[False, False, True])
    analysts_sorted = summary.index.tolist()

    # KPIs da equipe
    n_analysts = len(analysts_sorted)
    total_team_closed = int(summary["Total_Fechados"].sum())
    total_team_open = int(summary["Total_Abertos"].sum())

    if len(closed_df) > 0:
        team_mttr_mean = float(closed_df["_aging"].mean())
        team_mttr_p90  = float(closed_df["_aging"].quantile(0.90))
        if sla_max_days is not None:
            team_sla_compliance = float((closed_df["_aging"] <= int(sla_max_days)).mean() * 100.0)
        else:
            team_sla_compliance = 0.0
    else:
        team_mttr_mean = 0.0
        team_mttr_p90  = 0.0
        team_sla_compliance = 0.0

    analysis_meta = {
        "meses_calculado": meses_calculado,
        "meses_exibido": meses_exibido,
        "override_aplicado": meses_extracao_override is not None,
        "janela": janela,
        "periodo_inicio": months_list_str[0] if months_list_str else "N/A",
        "periodo_fim": months_list_str[-1] if months_list_str else "N/A",
        "ticket_label": str(ticket_label),
        "sla_max_days": int(sla_max_days) if sla_max_days is not None else None,
        "months_limit": int(months_limit) if months_limit is not None else None,
    }

    print(f"✓ [{ticket_label}] Analistas: {n_analysts} | Janela: {janela} | Fechados: {total_team_closed} | Abertos: {total_team_open}")
    print("✅ Análise por analista calculada!")
    print("=" * 100)

    return {
        "analysis": analysis_meta,
        "summary": summary,
        "monthly_pivot": monthly_pivot,
        "monthly_metrics": monthly_metrics,
        "months_list": months_list_str,
        "analysts_sorted": analysts_sorted,
        "kpis": {
