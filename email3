def load_prepare_ptasks(source_file, now=None, q=None):
    log_q(q, f"\n📂 [PTASKs] Carregando dados de: {source_file}")
    if not os.path.exists(source_file):
        log_q(q, "⚠️ Arquivo de PTASK não encontrado. A sessão será ignorada.")
        return pd.DataFrame()

    df = pd.read_excel(source_file)
    if df.columns.duplicated().any():
        df = df.loc[:, ~df.columns.duplicated()]
    log_q(q, f"   ✓ {len(df)} registros carregados")
    
    df = _normalize_columns(df)
    
    prob_col = _pick_col(df, ["Problem", "Problema"])
    num_col = _pick_col(df, ["Number", "Número", "Task"])
    state_col = _pick_col(df, ["State", "Estado"])
    prob_state_col = _pick_col(df, ["Problem State", "Problem.State", "Estado do Problema"])
    asg_col = _pick_col(df, ["Assigned to", "Analista"])
    rca_status_col = _pick_col(df, ["RCA Status", "Status do RCA"])
    due_date_col = _pick_col(df, ["Due date", "Data de vencimento"])
    rca_due_date_col = _pick_col(df, ["RCA Due Date", "Data de vencimento do RCA", "RCA Due", "Due date (RCA)"])

    d = pd.DataFrame()
    d["Problem"] = df[prob_col].astype(str).fillna("N/A") if prob_col else "N/A"
    d["PTASK"] = df[num_col].astype(str).fillna("N/A") if num_col else "N/A"
    d["PTASK State"] = df[state_col].astype(str).fillna("N/A") if state_col else "N/A"
    d["Problem State"] = df[prob_state_col].astype(str).fillna("N/A") if prob_state_col else "N/A"
    d["Assigned to"] = df[asg_col].astype(str).fillna("N/A").replace("nan", "N/A").replace("", "N/A") if asg_col else "N/A"
    d["RCA Status"] = df[rca_status_col].astype(str).fillna("N/A").replace("nan", "N/A") if rca_status_col else "N/A"
    
    now_dt = now or datetime.now()
    now_ts = pd.Timestamp(now_dt)
    
    if due_date_col:
        d["PTASK Due Date"] = pd.to_datetime(df[due_date_col], errors='coerce', dayfirst=True)
        d["SLA PTASK (Dias)"] = (d["PTASK Due Date"] - now_ts).dt.days
    else:
        d["SLA PTASK (Dias)"] = np.nan
        
    if rca_due_date_col:
        d["RCA Due Date"] = pd.to_datetime(df[rca_due_date_col], errors='coerce', dayfirst=True)
        d["SLA RCA (Dias)"] = (d["RCA Due Date"] - now_ts).dt.days
    else:
        d["SLA RCA (Dias)"] = np.nan
        
    return d

