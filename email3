                else:
                    df_critical = pd.DataFrame(columns=[
                                               "Ticket", "Info (Saiba Mais)", "Analista", "Solicitante", "Grupo", "Status", "Abertura", "Aging"])

            return df_m, df_d, df_a, df_ag, df_critical, mttr_val, in_sla, out_sla, in_sla_closed, out_sla_closed, in_sla_pct, df_missing_prb


