def compute_daily_table_html(df, start_date=None, end_date=None, ticket_type="REQ", real_backlog=0, sla_days=0):
    if df is None or df.empty:
        return pd.DataFrame(columns=["Data", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"])

    d = df.copy().reset_index(drop=True)
    d["State_Lower"] = d["State"].astype(
        str).str.lower().str.strip() if "State" in d.columns else ""
    opened_dates = pd.to_datetime(
        d["Opened"], errors="coerce", dayfirst=True).dropna().dt.floor("D")

    d_closed = d[d["Closed"].notna()].copy()
    d_closed["Closed_Date"] = pd.to_datetime(
        d_closed["Closed"], errors="coerce", dayfirst=True).dt.floor("D")
    d_closed["Opened_Date"] = pd.to_datetime(
        d_closed["Opened"], errors="coerce", dayfirst=True).dt.floor("D")
    d_closed["Aging_Resolved"] = (
        d_closed["Closed_Date"] - d_closed["Opened_Date"]).dt.days.fillna(0).astype(int).abs()

    if ticket_type == "INC":
        mask_canceled = d_closed["State_Lower"].isin(
            ["canceled", "cancelled"]) | d_closed["State_Lower"].str.contains(r"\bcancel", regex=True)
        mask_resolved = d_closed["State_Lower"].isin(
            ["resolved", "closed"]) | d_closed["State_Lower"].str.contains("resolv|clos", regex=True)
        mask_resolved = mask_resolved & ~mask_canceled
    else:
        mask_canceled = d_closed["State_Lower"].isin(
            ["closed incomplete"]) | d_closed["State_Lower"].str.contains("closed incomplet", regex=False)
        mask_resolved = d_closed["State_Lower"].isin(
            ["closed complete"]) | d_closed["State_Lower"].str.contains("closed complet", regex=False)

    resolved_dates = d_closed[mask_resolved]["Closed_Date"]
    canceled_dates = d_closed[mask_canceled]["Closed_Date"]

    valid_dts = [dt for dt in [opened_dates.min(), resolved_dates.min(),
                               canceled_dates.min()] if pd.notna(dt)]
    if not valid_dts and not start_date:
        return pd.DataFrame(columns=["Data", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"])

    min_dt = min(valid_dts) if valid_dts else start_date
    max_dt = end_date if end_date else datetime.now()

    all_days_global = pd.date_range(min_dt, max_dt, freq="D")
    op = opened_dates.value_counts().reindex(all_days_global, fill_value=0)
    res = resolved_dates.value_counts().reindex(all_days_global, fill_value=0)
    canc = canceled_dates.value_counts().reindex(all_days_global, fill_value=0)

    net = op - (res + canc)

    historico_net = net.values
    backlog_retro = np.zeros(len(historico_net))
    current_bklg = real_backlog
    for i in range(len(historico_net) - 1, -1, -1):
        backlog_retro[i] = current_bklg
        current_bklg = current_bklg - historico_net[i]

    df_out = pd.DataFrame({
        "Data": all_days_global,
        "Abertos": op.values.astype(int),
        "Encerrados": res.values.astype(int),
        "Cancelados": canc.values.astype(int),
        "Saldo": net.values.astype(int),
        "Backlog Acumulado": backlog_retro.astype(int)
    })

    if start_date and end_date:
        full_month_range = pd.date_range(start_date, end_date, freq="D")
        df_month = pd.DataFrame({"Data": full_month_range})
        df_month = pd.merge(df_month, df_out, on="Data", how="left")
        df_month["Abertos"] = df_month["Abertos"].fillna(0)
        df_month["Encerrados"] = df_month["Encerrados"].fillna(0)
        df_month["Cancelados"] = df_month["Cancelados"].fillna(0)
        df_month["Saldo"] = df_month["Saldo"].fillna(0)
        b_series = df_month["Backlog Acumulado"].ffill().bfill()
        df_month["Backlog Acumulado"] = b_series.fillna(0)
        df_out = df_month.copy()

    df_out["Data"] = df_out["Data"].dt.strftime("%d/%m/%Y")
    for c in ["Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"]:
        df_out[c] = df_out[c].astype(int)

    return df_out


def compute_monthly_throughput_table_html(df, months_limit=None, ticket_type="REQ", real_backlog=0, sla_days=0):
    if df is None or df.empty:
        return pd.DataFrame(columns=["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado", "% no Prazo"])

    d = df.copy()
    d["Opened"] = pd.to_datetime(d["Opened"], errors="coerce", dayfirst=True)
    d["Closed"] = pd.to_datetime(d["Closed"], errors="coerce", dayfirst=True)
    d["State_Lower"] = d["State"].astype(
        str).str.lower().str.strip() if "State" in d.columns else ""

    opened_months = d["Opened"].dropna().dt.to_period('M').value_counts()

    d_closed = d[d["Closed"].notna()].copy()
    d_closed["Closed_Month"] = d_closed["Closed"].dt.to_period('M')
    d_closed["Opened_Date"] = d_closed["Opened"].dt.floor("D")
    d_closed["Closed_Date"] = d_closed["Closed"].dt.floor("D")
    d_closed["Aging_Resolved"] = (
        d_closed["Closed_Date"] - d_closed["Opened_Date"]).dt.days.fillna(0).astype(int).abs()

    if ticket_type == "INC":
        mask_canceled = d_closed["State_Lower"].isin(
            ["canceled", "cancelled"]) | d_closed["State_Lower"].str.contains(r"\bcancel", regex=True)
        mask_resolved = d_closed["State_Lower"].isin(
            ["resolved", "closed"]) | d_closed["State_Lower"].str.contains("resolv|clos", regex=True)
        mask_resolved = mask_resolved & ~mask_canceled
    else:
        mask_canceled = d_closed["State_Lower"].isin(
            ["closed incomplete"]) | d_closed["State_Lower"].str.contains("closed incomplet", regex=False)
        mask_resolved = d_closed["State_Lower"].isin(
            ["closed complete"]) | d_closed["State_Lower"].str.contains("closed complet", regex=False)

    resolved_months = d_closed[mask_resolved]["Closed_Month"].value_counts()
    canceled_months = d_closed[mask_canceled]["Closed_Month"].value_counts()

    # Lógica de SLA NO PRAZO Mensal
    mask_sla_ok = mask_resolved & (d_closed["Aging_Resolved"] <= sla_days)
    sla_ok_months = d_closed[mask_sla_ok]["Closed_Month"].value_counts()

    all_months_index = opened_months.index.union(
        resolved_months.index).union(canceled_months.index).sort_values()

    if len(all_months_index) == 0:
        return pd.DataFrame(columns=["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado", "% no Prazo"])

    if months_limit and len(all_months_index) > months_limit:
        all_months_index = all_months_index[-months_limit:]

    df_out = pd.DataFrame(index=all_months_index)
    df_out["Abertos"] = opened_months.reindex(
        all_months_index, fill_value=0).values.astype(int)
    df_out["Encerrados"] = resolved_months.reindex(
        all_months_index, fill_value=0).values.astype(int)
    df_out["Cancelados"] = canceled_months.reindex(
        all_months_index, fill_value=0).values.astype(int)
    df_out["SLA no Prazo"] = sla_ok_months.reindex(
        all_months_index, fill_value=0).values.astype(int)

    pct_no_prazo = (df_out["SLA no Prazo"] /
                    df_out["Encerrados"].replace(0, np.nan)) * 100
    df_out["% no Prazo"] = pct_no_prazo.fillna(0).round(2).apply(lambda x: f"{x:.2f}".replace('.', ',')) + "%"

    df_out["Saldo"] = df_out["Abertos"] - \
        (df_out["Encerrados"] + df_out["Cancelados"])

    historico_net = df_out["Saldo"].values
    backlog_retro = np.zeros(len(historico_net))

    current_bklg = real_backlog
    for i in range(len(historico_net) - 1, -1, -1):
        backlog_retro[i] = current_bklg
        current_bklg = current_bklg - historico_net[i]

    df_out["Backlog Acumulado"] = backlog_retro.astype(int)
    df_out.reset_index(inplace=True)
    df_out.rename(columns={"index": "Mês"}, inplace=True)
    df_out["Mês"] = df_out["Mês"].dt.strftime("%b/%Y").str.upper()

    return df_out[["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado", "% no Prazo"]]


