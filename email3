def sanitize_label(text, limit=20):
    if pd.isna(text):
        return "Nao Assinado"
    clean = re.sub(r'[^a-zA-Z0-9À-ÿ \-]', '', str(text)).strip()
    if clean.lower() == "nan" or clean == "":
        return "Nao Assinado"
    return clean[:limit] + "..." if len(clean) > limit else clean


