        # 3. Segregação: INC, REQ (Suporte) e UAM (Acessos)
        req["IS_ACCESS"] = req["Assignment group"].apply(
            _is_access_ticket_html)
        req_support = req[~req["IS_ACCESS"]].copy()
        req_uam = req[req["IS_ACCESS"]].copy()

        inc_open_strict = _get_only_open_incs(inc)
        req_sup_open_strict = _get_only_open_reqs(req_support)
        uam_open_strict = _get_only_open_reqs(req_uam)

        inc_count = len(inc_open_strict)
        req_support_count = len(req_sup_open_strict)
        uam_count = len(uam_open_strict)
        
        # Filtro de PTASKs (GLOBAL - Todas as abertas)
        if not df_ptasks_raw.empty:
            closed_states = ['closed complete', 'closed incomplete', 'closed skipped', 'fechado', 'cancelado', 'encerrado', 'resolved', 'resolvido']
            df_ptasks_open = df_ptasks_raw[~df_ptasks_raw['PTASK State'].str.lower().str.strip().isin(closed_states)].copy()
        else:
            df_ptasks_open = pd.DataFrame()

        all_months, meta = build_month_window_html(
            [req, inc], MONTHS_LIMIT_HTML)
        start_date = meta.get("start_date")
        end_date = meta.get("end_date")
        now_floor = pd.Timestamp(datetime.now()).floor('D')
        if end_date and end_date > now_floor:
            end_date = now_floor

        # ========================================================================
        # FUNÇÃO INTERNA PARA PROCESSAR UMA SESSÃO
        # ========================================================================
        def process_section(df_full, df_open, ticket_type, sla_days, real_backlog, is_inc=False):
            df_m = compute_monthly_throughput_table_html(
                df_full, MONTHS_LIMIT_THROUGHPUT, ticket_type=ticket_type, real_backlog=real_backlog, sla_days=sla_days)

            df_d_full = compute_daily_table_html(
                df_full, start_date=start_date, end_date=end_date, ticket_type=ticket_type, real_backlog=real_backlog, sla_days=sla_days)
            df_d = get_current_month_daily(df_d_full)

            mttr_dict = compute_closed_metrics_html(
                df_full, ticket_type=ticket_type)
            mttr_val = mttr_dict["mttr_mean"]

            _, df_ag, _, open_df = compute_open_backlog_metrics_html(
                df_full, sla_days, ticket_type=ticket_type)

            # Lógica de Fechados no Mês Vigente vs Abertos por Analista
            current_month_period = pd.Timestamp(datetime.now()).to_period('M')
            closed_this_month = df_full[(df_full["Closed"].notna()) & (
                pd.to_datetime(df_full["Closed"]).dt.to_period('M') == current_month_period)].copy()

            abertos_counts = df_open["Assigned to"].replace(
                "nan", "Nao Assinado").replace("", "N/A").value_counts()
            fechados_counts = closed_this_month["Assigned to"].replace(
                "nan", "Nao Assinado").replace("", "N/A").value_counts()

            df_a = pd.DataFrame({"Abertos (Atuais)": abertos_counts,
                                "Fechados (Mês)": fechados_counts}).fillna(0).astype(int)
            df_a["Total"] = df_a["Abertos (Atuais)"] + df_a["Fechados (Mês)"]
            df_a = df_a.sort_values(by="Total", ascending=False).head(10)

            df_a.index.name = "Analista"
            df_a = df_a.reset_index()
            if df_a.empty:
                df_a = pd.DataFrame(
                    columns=["Analista", "Abertos (Atuais)", "Fechados (Mês)", "Total"])

            # Lógica de SLA Card dos Fechados (Calculado estritamente Resolvido - Aberto)
            if not closed_this_month.empty:
                closed_this_month["Opened_Date"] = pd.to_datetime(
                    closed_this_month["Opened"], errors="coerce").dt.floor("D")
                closed_this_month["Closed_Date"] = pd.to_datetime(
                    closed_this_month["Closed"], errors="coerce").dt.floor("D")
                closed_this_month["Aging_Resolved_Days"] = (
                    closed_this_month["Closed_Date"] - closed_this_month["Opened_Date"]).dt.days

                in_sla_closed = (
                    closed_this_month["Aging_Resolved_Days"] <= sla_days).sum()
                out_sla_closed = (
                    closed_this_month["Aging_Resolved_Days"] > sla_days).sum()
                total_closed_month = in_sla_closed + out_sla_closed

                # CÁLCULO POSITIVO DA PORCENTAGEM (DENTRO DO SLA)
                in_sla_pct = int(
                    (in_sla_closed / total_closed_month * 100)) if total_closed_month > 0 else 0
            else:
                in_sla_closed, out_sla_closed, in_sla_pct = 0, 0, 0

            # Status de SLA para a Pizza (Focado apenas nos Abertos Atuais)
            if "SLA_BREACH_OPEN" in open_df.columns:
                sla_counts = open_df["SLA_BREACH_OPEN"].value_counts()
                in_sla = int(sla_counts.get(False, 0))
                out_sla = int(sla_counts.get(True, 0))
            else:
                in_sla, out_sla = 0, 0

            # Tabela Crítica + Tabela Auxiliar de Sem PRB (apenas INCs)
            df_missing_prb = pd.DataFrame()
            if "SLA_BREACH_OPEN" in open_df.columns:
                df_critical = open_df[open_df["SLA_BREACH_OPEN"]
                                      == True].copy()
            else:
                df_critical = pd.DataFrame()

            if not df_critical.empty:
                df_critical = df_critical.sort_values(
                    by="AGING_OPEN", ascending=False).head(50)
                df_critical["Opened_Str"] = df_critical["Opened"].dt.strftime(
                    '%d/%m/%Y').fillna("-")

                if is_inc:
                    for col in ["Number", "Assignment group", "Assigned to", "Requester", "State", "On hold reason", "PRB", "Additional_Comments"]:
                        if col not in df_critical.columns:
                            df_critical[col] = "N/A"
                    
                    # Cria tabela auxiliar de INCs sem PRB ANTES de limpar as colunas
                    mask_missing_prb = df_critical["PRB"] == "N/A"
                    if mask_missing_prb.any():
                        df_missing_prb = df_critical[mask_missing_prb][["Number", "Assigned to", "Additional_Comments"]].copy()
                        # Truncar comentário em 150 caracteres
                        df_missing_prb["Additional_Comments"] = df_missing_prb["Additional_Comments"].apply(lambda x: (str(x)[:150] + '...') if len(str(x)) > 150 else str(x))
                        df_missing_prb.columns = ["Ticket", "Analista", "Último Comentário Registrado"]
                    
                    df_critical = df_critical[[
                        "Number", "Assigned to", "Requester", "Assignment group", "State", "On hold reason", "Opened_Str", "AGING_OPEN", "PRB"]]
                    df_critical.columns = [
                        "Ticket", "Analista", "Solicitante", "Grupo", "Status", "Motivo Espera", "Abertura", "Aging", "PRB"]
                else:
                    for col in ["Number", "Assignment group", "Assigned to", "Requester", "State"]:
                        if col not in df_critical.columns:
                            df_critical[col] = "N/A"
                    df_critical = df_critical[[
                        "Number", "Assigned to", "Requester", "Assignment group", "State", "Opened_Str", "AGING_OPEN"]]
                    df_critical.columns = [
                        "Ticket", "Analista", "Solicitante", "Grupo", "Status", "Abertura", "Aging"]
            else:
                if is_inc:
                    df_critical = pd.DataFrame(columns=[
                                               "Ticket", "Analista", "Solicitante", "Grupo", "Status", "Motivo Espera", "Abertura", "Aging", "PRB"])
                else:
                    df_critical = pd.DataFrame(columns=[
                                               "Ticket", "Analista", "Solicitante", "Grupo", "Status", "Abertura", "Aging"])

            return df_m, df_d, df_a, df_ag, df_critical, mttr_val, in_sla, out_sla, in_sla_closed, out_sla_closed, in_sla_pct, df_missing_prb


        # ========================================================================
        # FUNÇÃO INTERNA DE MONTAGEM HTML DA SESSÃO
        # ========================================================================

