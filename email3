def _get_only_open_reqs(df):
    if df.empty:
        return df
    state_col = _pick_col(df, ["State", "Status", "Estado"])
    if state_col:
        s = df[state_col].astype(str).str.strip().str.lower()
        mask = ~(s.isin(["closed complete", "closed incomplete"]) | s.str.contains(
            "closed complet|closed incomplet", na=False))
        return df[mask].copy()
    return df


