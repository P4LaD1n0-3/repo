def load_prepare_rca(source_file, now=None, q=None):
    log_q(q, f"\n📂 [RCA] Carregando dados de: {source_file}")
    if not os.path.exists(source_file):
        log_q(q, "⚠️ Arquivo de RCA não encontrado. A tabela será ignorada.")
        return pd.DataFrame()

    df = pd.read_excel(source_file)
    if df.columns.duplicated().any():
        df = df.loc[:, ~df.columns.duplicated()]
    log_q(q, f"   ✓ {len(df)} registros carregados")
    
    df = _normalize_columns(df)
    
    prob_col = _pick_col(df, ["Problem", "Problema"])
    asg_col = _pick_col(df, ["Assigned to", "Analista", "assigned_to"])
    rca_status_col = _pick_col(df, ["RCA Status", "Status do RCA", "Status RCA", "RCA", "RCA_Status", "u_rca_status", "rca_status", "State", "Status", "Estado"])
    rca_due_date_col = _pick_col(df, ["RCA Due Date", "Data de vencimento do RCA", "RCA Due", "Due date (RCA)", "RCA_Due_Date", "u_rca_due_date", "Target date", "RCA Target Date", "Due Date", "due_date"])
    pub_date_col = _pick_col(df, ["RCA Published Date", "Published Date", "Published", "Data de Publicação do RCA", "Data de Publicação"])
    state_col = _pick_col(df, ["State", "Estado", "Status"])
    opened_col = _pick_col(df, ["Opened", "Open", "Data Abertura", "Created", "Criado em", "opened_at", "sys_created_on"])

    d = pd.DataFrame()
    d["Problem"] = df[prob_col].astype(str).fillna("N/A") if prob_col else "N/A"
    d["Assigned to"] = df[asg_col].astype(str).replace(["nan", "None", "<NA>", ""], "N/A").fillna("N/A") if asg_col else "N/A"
    d["RCA Status"] = df[rca_status_col].astype(str).replace(["nan", "None", "<NA>", ""], "N/A").fillna("N/A") if rca_status_col else "N/A"
    d["State_Original"] = df[state_col].astype(str) if state_col else d["RCA Status"]
    
    now_dt = now or datetime.now()
    now_ts = pd.Timestamp(now_dt).floor('D')
    
    if opened_col:
        d["Opened"] = pd.to_datetime(df[opened_col], errors='coerce', dayfirst=True)
        d["RCA Aging"] = (now_ts - d["Opened"]).dt.days
    else:
        d["RCA Aging"] = np.nan
    
    if rca_due_date_col:
        d["RCA Due Date"] = pd.to_datetime(df[rca_due_date_col], errors='coerce', dayfirst=True)
        d["RCA Due Date Str"] = d["RCA Due Date"].dt.strftime('%d/%m/%Y').fillna("N/A")
        d["Days Overdue"] = (now_ts - d["RCA Due Date"]).dt.days
    else:
        d["RCA Due Date Str"] = "N/A"
        d["Days Overdue"] = np.nan
        
    if pub_date_col:
        d["RCA Published Date"] = pd.to_datetime(df[pub_date_col], errors='coerce', dayfirst=True)
    else:
        d["RCA Published Date"] = pd.NaT

    # Filtro rigoroso: Remover closed complete, closed incomplete, closed skipped, Resolved
    closed_states = ['closed complete', 'closed incomplete', 'closed skipped', 'resolved', 'fechado', 'cancelado', 'encerrado', 'resolvido']
    
    # Filtra por estado e se a Data de Publicação está vazia
    mask_state = ~d['State_Original'].str.lower().str.strip().isin(closed_states)
    mask_published = d["RCA Published Date"].isna()
    
    d = d[mask_state & mask_published].copy()

    return d


