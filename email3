# ENVIO DE EMAIL INTERATIVO VIA OUTLOOK
# ============================================================================

def enviar_email_relatorio(html_content, caminhos_anexos=None, q=None):
    if caminhos_anexos is None:
        caminhos_anexos = []
        
    log_q(q, "\n--- Preparando envio de E-mail via Outlook ---")

    safe_destinatario = str(destinatario) if destinatario else ""
    safe_copia = str(copia) if copia else ""
    safe_titulo = str(
        titulo) if titulo else "Relatório Novo Layout de tickets - Data: "

    try:
        safe_importance = int(importance) if importance else 2
    except (ValueError, TypeError):
        safe_importance = 2

    try:
        outlook = win32com.client.Dispatch("outlook.application")
        mail = outlook.CreateItem(0)

        if safe_destinatario:
            mail.To = safe_destinatario
        else:
            log_q(q, "⚠️ Aviso: Variável 'destinatario' está vazia. O envio pode falhar.")

        mail.Importance = safe_importance
        mail.Subject = safe_titulo + f"{datetime.now().strftime('%d/%m/%Y')}"
        mail.HTMLBody = html_content

        if safe_copia:
            mail.CC = safe_copia

        anexos_adicionados = 0
        for caminho_anexo in caminhos_anexos:
            if caminho_anexo and os.path.exists(caminho_anexo):
                absolute_path = os.path.abspath(caminho_anexo)
                mail.Attachments.Add(absolute_path)
                anexos_adicionados += 1
                
        global IMAGE_ATTACHMENTS
        for img_path, cid in IMAGE_ATTACHMENTS:
            if os.path.exists(img_path):
                try:
                    attachment = mail.Attachments.Add(os.path.abspath(img_path))
                    attachment.PropertyAccessor.SetProperty("http://schemas.microsoft.com/mapi/proptag/0x3712001F", cid)
                except Exception as att_err:
                    log_q(q, f"⚠️ Falha ao anexar imagem {cid}: {att_err}")

        mail.Send()

        if anexos_adicionados > 0:
            log_q(
                q, f"✅ E-mail enviado com sucesso (com {anexos_adicionados} anexo(s) e gráficos embutidos)!")
        else:
            log_q(q, "✅ E-mail enviado com sucesso (sem anexo, com gráficos embutidos)!")

    except Exception as e:
        log_q(q, f"❌ Erro crítico ao enviar e-mail. Erro: {e}")
