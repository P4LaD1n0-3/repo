def get_chart_cid(cfg, width, height, q=None):
    global IMAGE_ATTACHMENTS
    url = "https://quickchart.io/chart"
    payload = {"chart": cfg, "width": width, "height": height, "format": "png"}
    try:
        data = json.dumps(payload).encode('utf-8')
        req = urllib.request.Request(url, data=data, headers={
                                     'Content-Type': 'application/json'})
        with urllib.request.urlopen(req) as response:
            img_data = response.read()

            cid = f"chart_{uuid.uuid4().hex}.png"
            temp_path = os.path.join(os.path.dirname(OUTPUT_FILE) or ".", cid)
            _ensure_dir(temp_path)

            with open(temp_path, "wb") as f:
                f.write(img_data)

            IMAGE_ATTACHMENTS.append((temp_path, cid))
            return f"cid:{cid}"
    except Exception as e:
        log_q(q, f"⚠️ Aviso: Falha ao gerar/baixar gráfico. Erro: {e}")
        return f"https://quickchart.io/chart?w={width}&h={height}&c={urllib.parse.quote(json.dumps(cfg))}"


