        m_p90   = monthly_metrics.get("MTTR_P90", pd.DataFrame())
        m_sla   = monthly_metrics.get("SLA_Compliance_%", pd.DataFrame())

        def _get(df, a, mo, default=0.0):
            try:
                if df is None or len(df) == 0:
                    return default
                if a not in df.index or mo not in df.columns:
                    return default
                v = df.loc[a, mo]
