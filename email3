def build_ptask_table_html(df):
    if df.empty:
        return f"<div style='padding: 15px; background-color: {ModernColors.GRAY_LIGHT}; color: {ModernColors.GRAY_DARK}; text-align: center; font-weight: bold; border: 1px solid #ddd; border-radius: 4px; font-family: Calibri, sans-serif;'>✅ Nenhuma Problem Task (PTASK) aberta localizada.</div>"
    
    html = f"<table width='100%' cellpadding='0' cellspacing='0' border='0' style='border-collapse: collapse; font-size: 11px; font-family: Calibri, Arial, sans-serif; white-space: nowrap; margin: 0 auto;'>"
    html += f"<thead><tr style='background-color: {ModernColors.PRIMARY_DARK}; color: #fff;'>"
    cols = ["Problem", "PTASK", "Abertura", "Problem State", "PTASK State", "Analista", "RCA Status", "SLA RCA", "SLA PTASK"]
    for c in cols:
        html += f"<th style='padding: 4px 6px; border: 1px solid #ddd; text-align: center;'>{c}</th>"
    html += "</tr></thead><tbody>"
    
    for i, row in df.iterrows():
        bg = ModernColors.GRAY_LIGHT if i % 2 == 0 else ModernColors.WHITE
        html += f"<tr style='background-color: {bg};'>"
        
        sla_rca_val = row["SLA RCA (Dias)"]
        if pd.isna(sla_rca_val):
            txt_rca = "N/A"
            col_rca = ModernColors.GRAY_DARK
        elif sla_rca_val < 0:
            txt_rca = f"Estourado ({abs(int(sla_rca_val))} dias)"
            col_rca = ModernColors.DANGER
        else:
            txt_rca = f"No Prazo ({int(sla_rca_val)} dias)"
            col_rca = ModernColors.SUCCESS
            
        sla_ptask_val = row["SLA PTASK (Dias)"]
        if pd.isna(sla_ptask_val):
            txt_ptask = "N/A"
            col_ptask = ModernColors.GRAY_DARK
        elif sla_ptask_val < 0:
            txt_ptask = f"Estourado ({abs(int(sla_ptask_val))} dias)"
            col_ptask = ModernColors.DANGER
        else:
            txt_ptask = f"No Prazo ({int(sla_ptask_val)} dias)"
            col_ptask = ModernColors.SUCCESS
        
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {ModernColors.PRIMARY_DARK}; font-weight: bold;'>{row['Problem']}</td>"
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {ModernColors.PRIMARY_DARK}; font-weight: bold;'>{row['PTASK']}</td>"
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {ModernColors.PRIMARY_DARK}; font-weight: bold;'>{row.get('Opened_Str', 'N/A')}</td>"
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {ModernColors.PRIMARY_DARK};'>{row['Problem State']}</td>"
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {ModernColors.PRIMARY_DARK};'>{row['PTASK State']}</td>"
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {ModernColors.PRIMARY_DARK};'>{row['Assigned to']}</td>"
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {ModernColors.PRIMARY_DARK};'>{row['RCA Status']}</td>"
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {col_rca}; font-weight: bold;'>{txt_rca}</td>"
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: center; color: {col_ptask}; font-weight: bold;'>{txt_ptask}</td>"
        
        html += "</tr>"
    
    html += "</tbody></table>"
    return html


