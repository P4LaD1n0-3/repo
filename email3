    def _period_weighted_metrics(monthly_metrics, analysts, months):
        """Retorna (closed_sum, mttr_weighted, p90_weighted, sla_weighted) no período."""
        if monthly_metrics is None or not isinstance(monthly_metrics, dict) or len(months) == 0:
            return (0, 0.0, 0.0, 0.0)

        m_count = monthly_metrics.get("Closed_Count", pd.DataFrame())
