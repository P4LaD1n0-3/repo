    tot_a = df["Abertos"].sum()
    tot_f = df["Encerrados"].sum()
    tot_c = df["Cancelados"].sum()
    tot_s = df["Saldo"].sum()
    last_b = df["Backlog Acumulado"].iloc[-1] if not df.empty else 0
