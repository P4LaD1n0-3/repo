def merge_daily_data(inc_d, req_d, uam_d):
    cols_i = {"Abertos": "INC Abertos", "Encerrados": "INC Resolvidos", "Cancelados": "INC Cancelados", "Saldo": "INC Saldo", "Backlog Acumulado": "INC Backlog"}
    cols_r = {"Abertos": "REQ Abertos", "Encerrados": "REQ Encerrados", "Cancelados": "REQ Cancelados", "Saldo": "REQ Saldo", "Backlog Acumulado": "REQ Backlog"}
    cols_u = {"Abertos": "UAM Abertos", "Encerrados": "UAM Encerrados", "Cancelados": "UAM Cancelados", "Saldo": "UAM Saldo", "Backlog Acumulado": "UAM Backlog"}

    df_i = inc_d[["Data", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"]].rename(columns=cols_i)
    df_r = req_d[["Data", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"]].rename(columns=cols_r)
    df_u = uam_d[["Data", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"]].rename(columns=cols_u)

    df_merged = pd.merge(df_i, df_r, on="Data", how="outer")
    df_merged = pd.merge(df_merged, df_u, on="Data", how="outer")

    df_merged["_dt"] = pd.to_datetime(df_merged["Data"], format="%d/%m/%Y", errors="coerce")
    df_merged = df_merged.sort_values("_dt").drop(columns=["_dt"])

    # Forward e Backward fill para manter o backlog contínuo se faltarem dias em algum DataFrame
    for c in ["INC Backlog", "REQ Backlog", "UAM Backlog"]:
        if c in df_merged.columns:
            df_merged[c] = df_merged[c].ffill().bfill()

    df_merged = df_merged.fillna(0)

    for c in df_merged.columns:
        if c != "Data":
            df_merged[c] = df_merged[c].astype(int)

    df_merged["Total Abertos"] = df_merged["INC Abertos"] + df_merged["REQ Abertos"] + df_merged["UAM Abertos"]
    df_merged["Total Encerrados"] = df_merged["INC Resolvidos"] + df_merged["REQ Encerrados"] + df_merged["UAM Encerrados"]
    df_merged["Total Cancelados"] = df_merged["INC Cancelados"] + df_merged["REQ Cancelados"] + df_merged["UAM Cancelados"]
    df_merged["Saldo Global"] = df_merged["Total Abertos"] - (df_merged["Total Encerrados"] + df_merged["Total Cancelados"])
    df_merged["Backlog Global"] = df_merged["INC Backlog"] + df_merged["REQ Backlog"] + df_merged["UAM Backlog"]

    return df_merged

def merge_monthly_data(inc_m, req_m, uam_m):
    cols_i = {"Abertos": "INC Abertos", "Encerrados": "INC Resolvidos", "Cancelados": "INC Cancelados", "Saldo": "INC Saldo", "Backlog Acumulado": "INC Backlog"}
    cols_r = {"Abertos": "REQ Abertos", "Encerrados": "REQ Encerrados", "Cancelados": "REQ Cancelados", "Saldo": "REQ Saldo", "Backlog Acumulado": "REQ Backlog"}
    cols_u = {"Abertos": "UAM Abertos", "Encerrados": "UAM Encerrados", "Cancelados": "UAM Cancelados", "Saldo": "UAM Saldo", "Backlog Acumulado": "UAM Backlog"}

    df_i = inc_m[["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"]].rename(columns=cols_i)
    df_r = req_m[["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"]].rename(columns=cols_r)
    df_u = uam_m[["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"]].rename(columns=cols_u)

    df_merged = pd.merge(df_i, df_r, on="Mês", how="outer")
    df_merged = pd.merge(df_merged, df_u, on="Mês", how="outer")

    meses_map = {"JAN": 1, "FEV": 2, "MAR": 3, "ABR": 4, "MAI": 5, "JUN": 6, "JUL": 7, "AGO": 8, "SET": 9, "OUT": 10, "NOV": 11, "DEZ": 12}
    def sort_key(m_str):
        try:
            m, y = m_str.split('/')
            return int(y) * 100 + meses_map.get(m.upper(), 1)
        except:
            return 0
    
    df_merged["SortKey"] = df_merged["Mês"].apply(sort_key)
    df_merged = df_merged.sort_values("SortKey").drop(columns=["SortKey"])

    # Forward e Backward fill para manter o backlog contínuo se faltarem meses em algum DataFrame
    for c in ["INC Backlog", "REQ Backlog", "UAM Backlog"]:
        if c in df_merged.columns:
            df_merged[c] = df_merged[c].ffill().bfill()
            
    df_merged = df_merged.fillna(0)
    
    for c in df_merged.columns:
        if c != "Mês":
            df_merged[c] = df_merged[c].astype(int)
            
    df_merged["Total Abertos"] = df_merged["INC Abertos"] + df_merged["REQ Abertos"] + df_merged["UAM Abertos"]
    df_merged["Total Encerrados"] = df_merged["INC Resolvidos"] + df_merged["REQ Encerrados"] + df_merged["UAM Encerrados"]
    df_merged["Total Cancelados"] = df_merged["INC Cancelados"] + df_merged["REQ Cancelados"] + df_merged["UAM Cancelados"]
    df_merged["Saldo Global"] = df_merged["Total Abertos"] - (df_merged["Total Encerrados"] + df_merged["Total Cancelados"])
    df_merged["Backlog Global"] = df_merged["INC Backlog"] + df_merged["REQ Backlog"] + df_merged["UAM Backlog"]
    
    return df_merged

def build_combined_table_html(df):
    if df.empty:
        return f"<div style='padding: 15px; color: {ModernColors.PRIMARY_DARK}; text-align: center; font-weight: bold;'>✅ Sem dados aplicáveis para o período consolidado.</div>"

    html = f"<table width='100%' cellpadding='0' cellspacing='0' border='0' style='border-collapse: collapse; font-size: 11px; font-family: Calibri, Arial, sans-serif; white-space: nowrap; margin: 0 auto;'>"
    html += f"<thead><tr style='background-color: {ModernColors.GRAY_DARK}; color: #fff;'>"
    cols = ["Mês", "INC Ab.", "INC Res.", "REQ Ab.", "REQ Enc.", "UAM Ab.", "UAM Enc.", "Tot. Ab.", "Tot. Enc.", "Tot. Canc.", "Saldo Global", "Backlog Global"]
    
    for c in cols:
        html += f"<th style='padding: 4px 6px; border: 1px solid #ddd; text-align: center;'>{c}</th>"
    html += "</tr></thead><tbody>"

    for i, row in df.iterrows():
        bg = ModernColors.GRAY_LIGHT if i % 2 == 0 else ModernColors.WHITE
        html += f"<tr style='background-color: {bg};'>"
        
        vals = [
            row["Mês"],
            row["INC Abertos"], row["INC Resolvidos"],
            row["REQ Abertos"], row["REQ Encerrados"],
            row["UAM Abertos"], row["UAM Encerrados"],
            row["Total Abertos"], row["Total Encerrados"], row["Total Cancelados"],
            row["Saldo Global"], row["Backlog Global"]
        ]
        
        for j, val in enumerate(vals):
            align = "left" if j == 0 else "center"
            weight = "bold" if j == 0 or j >= 7 else "normal"
            
            color = ModernColors.PRIMARY_DARK
            if j == 10: # Saldo Global
                color = ModernColors.PRIMARY_DARK if int(val) > 0 else (ModernColors.PRIMARY if int(val) < 0 else ModernColors.GRAY_DARK)
                if int(val) > 0: val = f"+{val}"
            
            html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: {align}; color: {color}; font-weight: {weight};'>{val}</td>"
        html += "</tr>"
    html += "</tbody>"

    html += f"<tfoot style='background-color: {ModernColors.GRAY_LIGHT}; font-weight: bold; color: {ModernColors.PRIMARY_DARK}; border-top: 2px solid {ModernColors.PRIMARY_DARK};'><tr>"
    
    sums = [
        "TOTAIS",
        df["INC Abertos"].sum(), df["INC Resolvidos"].sum(),
        df["REQ Abertos"].sum(), df["REQ Encerrados"].sum(),
        df["UAM Abertos"].sum(), df["UAM Encerrados"].sum(),
        df["Total Abertos"].sum(), df["Total Encerrados"].sum(), df["Total Cancelados"].sum(),
        df["Saldo Global"].sum(),
        df["Backlog Global"].iloc[-1] if not df.empty else 0
    ]
    
    for j, val in enumerate(sums):
        align = "left" if j == 0 else "center"
        color = ModernColors.PRIMARY_DARK
        if j == 10: # Saldo Total
            color = ModernColors.PRIMARY_DARK if int(val) > 0 else (ModernColors.PRIMARY if int(val) < 0 else ModernColors.GRAY_DARK)
            if int(val) > 0: val = f"+{val}"
            
        html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: {align}; color: {color};'>{val}</td>"
        
    html += "</tr></tfoot></table>"

    return html

def build_stacked_chart_cfg(df, col_labels, title):
    # Lógica para as labels (se for diário exibe os primeiros caracteres dd/mm, senão o mês inteiro)
    labels_raw = df[col_labels].tolist()
    tot_abertos = df["Total Abertos"].tolist()
    # Para o "Out" da barra consideramos Resolvidos + Cancelados 
    tot_saidas = (df["Total Encerrados"] + df["Total Cancelados"]).tolist()

    labels = []
    for i, raw in enumerate(labels_raw):
        lbl = str(raw)[:5] if col_labels == "Data" else str(raw)
        # Array multi-linha na legenda do eixo X para exibir as somas embaixo da barra
        labels.append([lbl, f"In: {tot_abertos[i]} | Out: {tot_saidas[i]}"])
        
    datasets = [
        {"label": "INC Abertos", "data": hide_zeros(df["INC Abertos"].tolist()), "backgroundColor": ModernColors.GRAY_DARK, "stack": "Abertos"},
        {"label": "REQ Abertos", "data": hide_zeros(df["REQ Abertos"].tolist()), "backgroundColor": ModernColors.PRIMARY_DARK, "stack": "Abertos"},
        {"label": "UAM Abertos", "data": hide_zeros(df["UAM Abertos"].tolist()), "backgroundColor": ModernColors.ACCENT_DARK, "stack": "Abertos"},
        
        {"label": "INC Encerrados", "data": hide_zeros(df["INC Resolvidos"].tolist()), "backgroundColor": ModernColors.GRAY, "stack": "Encerrados"},
        {"label": "REQ Encerrados", "data": hide_zeros(df["REQ Encerrados"].tolist()), "backgroundColor": ModernColors.PRIMARY, "stack": "Encerrados"},
        {"label": "UAM Encerrados", "data": hide_zeros(df["UAM Encerrados"].tolist()), "backgroundColor": ModernColors.INFO, "stack": "Encerrados"}
    ]
    
    cfg = {
        "type": "bar",
        "data": {
            "labels": labels,
            "datasets": datasets
        },
        "options": {
            "plugins": {
                "datalabels": {
                    "display": True,
                    "color": "#fff",
                    "font": {"weight": "bold", "size": 9}
                }
            },
            "legend": {"display": True, "position": "bottom"},
            "scales": {
                "xAxes": [{"stacked": True}],
                "yAxes": [{"stacked": True, "ticks": {"beginAtZero": True}}]
            }
        }
    }
    return add_title_to_cfg(cfg, title)

