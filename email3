            "open_rows": int(len(open_df)),
            "closed_rows": int(len(closed_df)),
        }
    }


# =============================================================================
# Combina REQs e INCs por analista (para tabela comparativa)
# =============================================================================
def calculate_analyst_reqs_incs(df_reqs,
                               df_incs,
                               meses_extracao_override=None,
                               top_n_analysts=20,
                               sla_days_reqs=10,
                               sla_days_incs=7,
                               months_limit=12):
    """
    Calcula métricas para REQs e INCs e prepara um resumo combinado TOP N.
    """
    m_reqs = calculate_analyst_analysis(
        df_reqs,
        meses_extracao_override=meses_extracao_override,
        ticket_label="REQ",
        sla_max_days=int(sla_days_reqs),
        months_limit=months_limit
    )

    m_incs = calculate_analyst_analysis(
        df_incs,
        meses_extracao_override=meses_extracao_override,
        ticket_label="INC",
        sla_max_days=int(sla_days_incs),
        months_limit=months_limit
    )

    s_req = m_reqs["summary"].copy()
    s_inc = m_incs["summary"].copy()

    # Garante colunas esperadas
    for col in ["Total_Fechados", "Total_Atribuidos", "Total_Abertos", "Net_Flow",
                "MTTR_Mean", "MTTR_P90", "Effective_Res_%", "Aging_Index_%",
                "SLA_Compliance_Closed_%", "SLA_Breaches_Closed"]:
        if col not in s_req.columns:
            s_req[col] = 0
        if col not in s_inc.columns:
            s_inc[col] = 0

    # Renomeia com prefixos
    s_req = s_req.rename(columns={
        "Total_Fechados": "REQ_Fechados",
        "Total_Atribuidos": "REQ_Atribuidos",
        "Total_Abertos": "REQ_Abertos",
        "Net_Flow": "REQ_NetFlow",
        "MTTR_Mean": "REQ_MTTR",
        "MTTR_P90": "REQ_P90",
        "Effective_Res_%": "REQ_EffRes",
        "Aging_Index_%": "REQ_AgingIdx",
        "SLA_Compliance_Closed_%": "REQ_SLA%",
        "SLA_Breaches_Closed": "REQ_SLA_Breaches",
    })

    s_inc = s_inc.rename(columns={
        "Total_Fechados": "INC_Fechados",
        "Total_Atribuidos": "INC_Atribuidos",
        "Total_Abertos": "INC_Abertos",
        "Net_Flow": "INC_NetFlow",
        "MTTR_Mean": "INC_MTTR",
        "MTTR_P90": "INC_P90",
        "Effective_Res_%": "INC_EffRes",
        "Aging_Index_%": "INC_AgingIdx",
        "SLA_Compliance_Closed_%": "INC_SLA%",
        "SLA_Breaches_Closed": "INC_SLA_Breaches",
    })

    # Merge por analista (outer)
    combo = s_req[[
        "REQ_Fechados", "REQ_Atribuidos", "REQ_Abertos", "REQ_NetFlow",
        "REQ_MTTR", "REQ_P90", "REQ_EffRes", "REQ_AgingIdx",
        "REQ_SLA%", "REQ_SLA_Breaches"
    ]].merge(
        s_inc[[
            "INC_Fechados", "INC_Atribuidos", "INC_Abertos", "INC_NetFlow",
            "INC_MTTR", "INC_P90", "INC_EffRes", "INC_AgingIdx",
            "INC_SLA%", "INC_SLA_Breaches"
        ]],
        left_index=True, right_index=True, how="outer"
    ).fillna(0)

    combo["TOTAL_Fechados"] = combo["REQ_Fechados"] + combo["INC_Fechados"]
    combo["TOTAL_Atribuidos"] = combo["REQ_Atribuidos"] + combo["INC_Atribuidos"]
    combo["TOTAL_Abertos"] = combo["REQ_Abertos"] + combo["INC_Abertos"]

    # MTTR total ponderado pelo volume fechado (mais correto do que média simples)
    combo["TOTAL_MTTR"] = [
        _weighted_mean(
            [combo.loc[a, "REQ_MTTR"], combo.loc[a, "INC_MTTR"]],
            [combo.loc[a, "REQ_Fechados"], combo.loc[a, "INC_Fechados"]],
        )
        for a in combo.index
    ]
    combo["TOTAL_P90"] = [
        _weighted_mean(
            [combo.loc[a, "REQ_P90"], combo.loc[a, "INC_P90"]],
            [combo.loc[a, "REQ_Fechados"], combo.loc[a, "INC_Fechados"]],
        )
        for a in combo.index
    ]

    # Ranking objetivo (prioridade: TOTAL_Fechados, depois INC_Fechados, depois MTTR)
    combo = combo.sort_values(
        by=["TOTAL_Fechados", "INC_Fechados", "TOTAL_MTTR"],
        ascending=[False, False, True]
    )

    # TOP N exibido
    top_n_analysts = int(top_n_analysts) if top_n_analysts is not None else 20
    if top_n_analysts <= 0:
        top_n_analysts = 20
    combo_top = combo.head(top_n_analysts).copy()

    # Coluna de risco/observação (bem objetiva)
    def _risk_note(r):
        notes = []
        if r["INC_Fechados"] > 0:
            if float(r["INC_SLA%"]) < 80:
                notes.append("INC SLA baixo")
            if float(r["INC_MTTR"]) >= 5:
                notes.append("INC MTTR alto")
        if r["REQ_Fechados"] > 0:
            if float(r["REQ_MTTR"]) >= 15:
                notes.append("REQ MTTR alto")
        if int(r["TOTAL_Abertos"]) > 20:
            notes.append("Backlog alto")
        return " | ".join(notes) if notes else "OK"

    combo_top["Observação"] = combo_top.apply(_risk_note, axis=1)

    return {
        "reqs": m_reqs,
        "incs": m_incs,
        "combo_all": combo,
        "combo_top": combo_top,
        "config": {
            "top_n_analysts": top_n_analysts,
            "sla_days_reqs": int(sla_days_reqs),
            "sla_days_incs": int(sla_days_incs),
            "months_limit": int(months_limit) if months_limit is not None else None,
        }
    }


