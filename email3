def normalize_ticket_df_html(df, ticket_type_label="REQ"):
    df = df.copy()
    df = _normalize_columns(df)
    state_col = _pick_col(
        df, ["State", "StatusBin", "Status_Bin", "Status", "Status Bin", "Estado"])
    opened_col = _pick_col(df, ["Opened", "Open", "OpenedAt",
                           "Data Abertura", "Created", "Criado em", "Creation date"])
    closed_col = _pick_col(
        df, ["Resolved", "Resolved at", "Closed", "Close", "ClosedAt", "Data Fechamento"])
    ag_col = _pick_col(df, ["Assignment group", "Assignment Group",
                       "Grupo", "Grupo de Atribuição", "Grupo de atribuicao"])
    asg_col = _pick_col(
        df, ["Assigned to", "AssignedTo", "Analista", "Assignee"])
    number_col = _pick_col(df, ["Number", "Número", "Ticket", "ID", "Task"])

    prb_col = _pick_col(df, ["PRB", "Problem", "Problem ID", "Problema"])
    short_desc_col = _pick_col(
        df, ["Short description", "Descrição Curta", "Description", "Descrição"])
    on_hold_col = _pick_col(df, ["On hold reason", "Motivo de espera", "On Hold Reason"])
    
    # NOVA COLUNA: Comentários adicionais para a tabela auxiliar
    add_comments_col = _pick_col(df, ["Additional comments", "Comentários Adicionais", "Comments", "Comentários"])

    def extract_prb(row):
        # 1. Verifica coluna "Problem"
        prb_val = str(row.get(prb_col, "")).strip() if prb_col and pd.notna(row.get(prb_col)) else ""
        if prb_val and prb_val.upper() not in ["NAN", "N/A", "NONE", ""]:
            match_prb = re.search(r'(PRB\d+)', prb_val, re.IGNORECASE)
            if match_prb:
                return match_prb.group(1).upper()
            return prb_val

        # 2. Verifica coluna "Short description"
        sd_val = str(row.get(short_desc_col, "")) if short_desc_col and pd.notna(row.get(short_desc_col)) else ""
        match_sd = re.search(r'(PRB\d+)', sd_val, re.IGNORECASE)
        if match_sd:
            return match_sd.group(1).upper()

        # 3. Verifica coluna "Additional comments"
        ac_val = str(row.get(add_comments_col, "")) if add_comments_col and pd.notna(row.get(add_comments_col)) else ""
        match_ac = re.search(r'(PRB\d+)', ac_val, re.IGNORECASE)
        if match_ac:
            return match_ac.group(1).upper()

        return "N/A"

    df["Opened"] = pd.to_datetime(
        df[opened_col], errors="coerce", dayfirst=True) if opened_col else pd.NaT
    df["Closed"] = pd.to_datetime(
        df[closed_col], errors="coerce", dayfirst=True) if closed_col else pd.NaT
    df["Assignment group"] = df[ag_col].astype(
        str).fillna("").replace("", "—") if ag_col else "—"
    df["Assigned to"] = df[asg_col].astype(str).fillna(
        "").replace("", "—") if asg_col else "—"
    df["Number"] = df[number_col].astype(str).fillna("") if number_col else ""
    df["State"] = df[state_col].astype(
        str).fillna("N/A") if state_col else "N/A"
    
    # Aplica o super filtro de PRB
    df["PRB"] = df.apply(extract_prb, axis=1)
    
    df["On hold reason"] = df[on_hold_col].astype(str).fillna("").replace("nan", "") if on_hold_col else ""
    df["Additional_Comments"] = df[add_comments_col].astype(str).fillna("").replace("nan", "") if add_comments_col else "Sem comentários"

    return df


def build_month_window_html(dfs, months_limit=None):
    opened_months, closed_months = [], []
    for df in dfs:
        if df is None or df.empty:
            continue
        mo = pd.to_datetime(df["Opened"], errors="coerce", dayfirst=True).dropna()
        mc = pd.to_datetime(df["Closed"], errors="coerce", dayfirst=True).dropna()
        if not mo.empty:
            opened_months.extend([mo.min(), mo.max()])
        if not mc.empty:
            closed_months.extend([mc.min(), mc.max()])

    valid_dates = [d for d in (opened_months + closed_months) if pd.notna(d)]
    if not valid_dates:
        now_dt = datetime.now()
        start = pd.Timestamp(year=now_dt.year, month=now_dt.month, day=1)
        return pd.DatetimeIndex([]), {"periodo_inicio": "N/A", "periodo_fim": "N/A", "janela": "N/A", "meses_calculado": 0, "start_date": start, "end_date": pd.Timestamp(now_dt)}

    month_start = min(valid_dates).replace(
        day=1, hour=0, minute=0, second=0, microsecond=0)
    month_end = max(valid_dates).replace(
        day=1, hour=0, minute=0, second=0, microsecond=0)

    all_months = pd.date_range(month_start, month_end, freq="MS")

    if months_limit is not None:
        try:
            months_limit = int(months_limit)
            if months_limit > 0 and len(all_months) > months_limit:
                all_months = all_months[-months_limit:]
        except:
            pass

    if len(all_months) == 0:
        now_dt = datetime.now()
        start = pd.Timestamp(year=now_dt.year, month=now_dt.month, day=1)
        return pd.DatetimeIndex([]), {"periodo_inicio": "N/A", "periodo_fim": "N/A", "janela": "N/A", "meses_calculado": 0, "start_date": start, "end_date": pd.Timestamp(now_dt)}

    final_start = pd.Timestamp(
        year=all_months[0].year, month=all_months[0].month, day=1)
    final_end = pd.Timestamp(year=all_months[-1].year, month=all_months[-1].month,
                             day=calendar.monthrange(all_months[-1].year, all_months[-1].month)[1])

    meta = {
        "periodo_inicio": all_months[0].strftime("%Y-%m"),
        "periodo_fim": all_months[-1].strftime("%Y-%m"),
        "janela": f"{all_months[0].strftime('%m/%Y')} → {all_months[-1].strftime('%m/%Y')}" if len(all_months) > 1 else all_months[0].strftime('%m/%Y'),
        "meses_calculado": int(len(all_months)),
        "start_date": final_start,
        "end_date": final_end
    }
    return all_months, meta


def compute_open_backlog_metrics_html(df, sla_days, ticket_type="REQ"):
    now = pd.Timestamp(datetime.now())

    if ticket_type == "REQ":
        open_df = _get_only_open_reqs(df)
    else:
        open_df = _get_only_open_incs(df)

    open_df["Opened_dt"] = pd.to_datetime(open_df["Opened"], errors="coerce", dayfirst=True)
    open_df = open_df[open_df["Opened_dt"].notna()].copy()
    open_df["AGING_OPEN"] = (now - open_df["Opened_dt"]).dt.days
    open_df["AGING_OPEN"] = pd.to_numeric(
        open_df["AGING_OPEN"], errors="coerce").fillna(0).astype(int).clip(lower=0).abs()
    open_df["SLA_BREACH_OPEN"] = open_df["AGING_OPEN"] > int(sla_days)

    total_open = int(len(open_df))
    breach_open = int(open_df["SLA_BREACH_OPEN"].sum()) if total_open else 0

    if ticket_type == "REQ":
        bins = [-1, 3, 5, 7, 10, 20, 30, np.inf]
        labels = ["1-3 dias", "3-5 dias", "5-7 dias",
                  "7-10 dias", "10 dias +", "20 dias +", "30 dias +"]
    else:
        bins = [-1, 3, 7, np.inf]
        labels = ["1-3 dias", "4-7 dias", "7+ dias"]

    if total_open > 0:
        open_df["AgingBin"] = pd.cut(
            open_df["AGING_OPEN"], bins=bins, labels=labels, include_lowest=False, right=True)
        bucket_counts = open_df.groupby(
            "AgingBin").size().reindex(labels, fill_value=0)
    else:
        bucket_counts = pd.Series(
            index=labels, data=np.zeros(len(labels), dtype=int))

    bucket_total = int(bucket_counts.sum())
    bucket_pct = ((bucket_counts / bucket_total * 100)
                  if bucket_total > 0 else 0).round(1)
    buckets_df = pd.DataFrame(
        {"Faixa": labels, "Qtd": bucket_counts.values.astype(int), "%": bucket_pct.values})

    kpis = {
        "open_total": total_open,
        "open_breach": breach_open,
        "mttr_mean": round(float(open_df["AGING_OPEN"].mean()) if total_open else 0.0, 1),
    }
    return kpis, buckets_df, None, open_df


def compute_closed_metrics_html(df, ticket_type="REQ"):
    d = df.copy()
    if ticket_type == "REQ":
        state_col = _pick_col(d, ["State", "Status", "Estado"])
        if state_col:
            s = d[state_col].astype(str).str.strip().str.lower()
            closed_df = d[(s.isin(["closed complete", "closed incomplete"]) | s.str.contains(
                "closed complet|closed incomplet", na=False)) & (d["Opened"].notna())].copy()
        else:
            closed_df = d[(d["Closed"].notna()) & (d["Opened"].notna())].copy()
    else:
        state_col = _pick_col(d, ["State", "Status", "Estado"])
        if state_col:
            s = d[state_col].astype(str).str.strip().str.lower()
            closed_df = d[(s.isin(["resolved", "canceled", "cancelled", "closed"]) | s.str.contains(
                "resolv|cancel|clos", na=False)) & (d["Opened"].notna())].copy()
        else:
            closed_df = d[(d["Closed"].notna()) & (d["Opened"].notna())].copy()

    if len(closed_df) == 0:
        return {"closed_total": 0, "mttr_mean": 0.0}

    closed_dt_safe = pd.to_datetime(closed_df["Closed"], errors="coerce", dayfirst=True).fillna(
        pd.Timestamp(datetime.now()))
    closed_df["AGING_CLOSED"] = (
        closed_dt_safe - pd.to_datetime(closed_df["Opened"], errors="coerce", dayfirst=True)).dt.days
    closed_df["AGING_CLOSED"] = pd.to_numeric(
        closed_df["AGING_CLOSED"], errors="coerce").fillna(0).astype(int).clip(lower=0).abs()

    return {
        "closed_total": len(closed_df),
        "mttr_mean": round(float(closed_df["AGING_CLOSED"].mean()), 1),
    }


def get_current_month_daily(df_daily):
    if df_daily.empty:
        return df_daily
    d = df_daily.copy()
    d["_dt"] = pd.to_datetime(d["Data"], format="%d/%m/%Y")
    max_month = d["_dt"].dt.to_period("M").max()
    filtered = d[d["_dt"].dt.to_period("M") == max_month].drop(
        columns=["_dt"]).copy()
    return filtered


def compute_daily_table_html(df, start_date=None, end_date=None, ticket_type="REQ", real_backlog=0, sla_days=0):
    if df is None or df.empty:
        return pd.DataFrame(columns=["Data", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"])

    d = df.copy().reset_index(drop=True)
    d["State_Lower"] = d["State"].astype(
        str).str.lower().str.strip() if "State" in d.columns else ""
    opened_dates = pd.to_datetime(
        d["Opened"], errors="coerce", dayfirst=True).dropna().dt.floor("D")

    d_closed = d[d["Closed"].notna()].copy()
    d_closed["Closed_Date"] = pd.to_datetime(
        d_closed["Closed"], errors="coerce", dayfirst=True).dt.floor("D")
    d_closed["Opened_Date"] = pd.to_datetime(
        d_closed["Opened"], errors="coerce", dayfirst=True).dt.floor("D")
    d_closed["Aging_Resolved"] = (
        d_closed["Closed_Date"] - d_closed["Opened_Date"]).dt.days.fillna(0).astype(int).abs()

    if ticket_type == "INC":
        mask_canceled = d_closed["State_Lower"].isin(
            ["canceled", "cancelled"]) | d_closed["State_Lower"].str.contains(r"\bcancel", regex=True)
        mask_resolved = d_closed["State_Lower"].isin(
            ["resolved", "closed"]) | d_closed["State_Lower"].str.contains("resolv|clos", regex=True)
        mask_resolved = mask_resolved & ~mask_canceled
    else:
        mask_canceled = d_closed["State_Lower"].isin(
            ["closed incomplete"]) | d_closed["State_Lower"].str.contains("closed incomplet", regex=False)
        mask_resolved = d_closed["State_Lower"].isin(
            ["closed complete"]) | d_closed["State_Lower"].str.contains("closed complet", regex=False)

    resolved_dates = d_closed[mask_resolved]["Closed_Date"]
    canceled_dates = d_closed[mask_canceled]["Closed_Date"]

    valid_dts = [dt for dt in [opened_dates.min(), resolved_dates.min(),
                               canceled_dates.min()] if pd.notna(dt)]
    if not valid_dts and not start_date:
        return pd.DataFrame(columns=["Data", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"])

    min_dt = min(valid_dts) if valid_dts else start_date
    max_dt = end_date if end_date else datetime.now()

    all_days_global = pd.date_range(min_dt, max_dt, freq="D")
    op = opened_dates.value_counts().reindex(all_days_global, fill_value=0)
    res = resolved_dates.value_counts().reindex(all_days_global, fill_value=0)
    canc = canceled_dates.value_counts().reindex(all_days_global, fill_value=0)

    net = op - (res + canc)

    historico_net = net.values
    backlog_retro = np.zeros(len(historico_net))
    current_bklg = real_backlog
    for i in range(len(historico_net) - 1, -1, -1):
        backlog_retro[i] = current_bklg
        current_bklg = current_bklg - historico_net[i]

    df_out = pd.DataFrame({
        "Data": all_days_global,
        "Abertos": op.values.astype(int),
        "Encerrados": res.values.astype(int),
        "Cancelados": canc.values.astype(int),
        "Saldo": net.values.astype(int),
        "Backlog Acumulado": backlog_retro.astype(int)
    })

    if start_date and end_date:
        full_month_range = pd.date_range(start_date, end_date, freq="D")
        df_month = pd.DataFrame({"Data": full_month_range})
        df_month = pd.merge(df_month, df_out, on="Data", how="left")
        df_month["Abertos"] = df_month["Abertos"].fillna(0)
        df_month["Encerrados"] = df_month["Encerrados"].fillna(0)
        df_month["Cancelados"] = df_month["Cancelados"].fillna(0)
        df_month["Saldo"] = df_month["Saldo"].fillna(0)
        b_series = df_month["Backlog Acumulado"].ffill().bfill()
        df_month["Backlog Acumulado"] = b_series.fillna(0)
        df_out = df_month.copy()

    df_out["Data"] = df_out["Data"].dt.strftime("%d/%m/%Y")
    for c in ["Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado"]:
        df_out[c] = df_out[c].astype(int)

    return df_out


def compute_monthly_throughput_table_html(df, months_limit=None, ticket_type="REQ", real_backlog=0, sla_days=0):
    if df is None or df.empty:
        return pd.DataFrame(columns=["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado", "SLA no Prazo", "% no Prazo"])

    d = df.copy()
    d["Opened"] = pd.to_datetime(d["Opened"], errors="coerce", dayfirst=True)
    d["Closed"] = pd.to_datetime(d["Closed"], errors="coerce", dayfirst=True)
    d["State_Lower"] = d["State"].astype(
        str).str.lower().str.strip() if "State" in d.columns else ""

    opened_months = d["Opened"].dropna().dt.to_period('M').value_counts()

    d_closed = d[d["Closed"].notna()].copy()
    d_closed["Closed_Month"] = d_closed["Closed"].dt.to_period('M')
    d_closed["Opened_Date"] = d_closed["Opened"].dt.floor("D")
    d_closed["Closed_Date"] = d_closed["Closed"].dt.floor("D")
    d_closed["Aging_Resolved"] = (
        d_closed["Closed_Date"] - d_closed["Opened_Date"]).dt.days.fillna(0).astype(int).abs()

    if ticket_type == "INC":
        mask_canceled = d_closed["State_Lower"].isin(
            ["canceled", "cancelled"]) | d_closed["State_Lower"].str.contains(r"\bcancel", regex=True)
        mask_resolved = d_closed["State_Lower"].isin(
            ["resolved", "closed"]) | d_closed["State_Lower"].str.contains("resolv|clos", regex=True)
        mask_resolved = mask_resolved & ~mask_canceled
    else:
        mask_canceled = d_closed["State_Lower"].isin(
            ["closed incomplete"]) | d_closed["State_Lower"].str.contains("closed incomplet", regex=False)
        mask_resolved = d_closed["State_Lower"].isin(
            ["closed complete"]) | d_closed["State_Lower"].str.contains("closed complet", regex=False)

    resolved_months = d_closed[mask_resolved]["Closed_Month"].value_counts()
    canceled_months = d_closed[mask_canceled]["Closed_Month"].value_counts()

    # Lógica de SLA NO PRAZO Mensal
    mask_sla_ok = mask_resolved & (d_closed["Aging_Resolved"] <= sla_days)
    sla_ok_months = d_closed[mask_sla_ok]["Closed_Month"].value_counts()

    all_months_index = opened_months.index.union(
        resolved_months.index).union(canceled_months.index).sort_values()

    if len(all_months_index) == 0:
        return pd.DataFrame(columns=["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado", "SLA no Prazo", "% no Prazo"])

    if months_limit and len(all_months_index) > months_limit:
        all_months_index = all_months_index[-months_limit:]

    df_out = pd.DataFrame(index=all_months_index)
    df_out["Abertos"] = opened_months.reindex(
        all_months_index, fill_value=0).values.astype(int)
    df_out["Encerrados"] = resolved_months.reindex(
        all_months_index, fill_value=0).values.astype(int)
    df_out["Cancelados"] = canceled_months.reindex(
        all_months_index, fill_value=0).values.astype(int)
    df_out["SLA no Prazo"] = sla_ok_months.reindex(
        all_months_index, fill_value=0).values.astype(int)

    # Divisão segura para evitar o erro IntCastingNaNError
    pct_no_prazo = (df_out["SLA no Prazo"] /
                    df_out["Encerrados"].replace(0, np.nan)) * 100
    df_out["% no Prazo"] = pct_no_prazo.fillna(0).astype(int).astype(str) + "%"

    df_out["Saldo"] = df_out["Abertos"] - \
        (df_out["Encerrados"] + df_out["Cancelados"])

    historico_net = df_out["Saldo"].values
    backlog_retro = np.zeros(len(historico_net))

    current_bklg = real_backlog
    for i in range(len(historico_net) - 1, -1, -1):
        backlog_retro[i] = current_bklg
        current_bklg = current_bklg - historico_net[i]

    df_out["Backlog Acumulado"] = backlog_retro.astype(int)
    df_out.reset_index(inplace=True)
    df_out.rename(columns={"index": "Mês"}, inplace=True)
    df_out["Mês"] = df_out["Mês"].dt.strftime("%b/%Y").str.upper()

    return df_out[["Mês", "Abertos", "Encerrados", "Cancelados", "Saldo", "Backlog Acumulado", "% no Prazo"]]


