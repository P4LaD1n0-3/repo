def build_html_table_html(df, header_bg=ModernColors.PRIMARY, zebra=True, show_totals=True, lbl_resolved="Encerrados", sla_days=10):
    if df is None or df.empty:
        return f"<div style='padding: 15px; color: {ModernColors.PRIMARY_DARK}; background-color: {ModernColors.PRIMARY_LIGHT}; text-align: center; font-weight: bold; border: 1px solid {ModernColors.PRIMARY_DARK}; border-radius: 4px; font-family: Calibri, sans-serif;'>✅ Sem dados aplicáveis para o período.</div>"

    html = f"<table width='100%' cellpadding='0' cellspacing='0' border='0' style='border-collapse: collapse; font-size: 11px; font-family: Calibri, Arial, sans-serif; white-space: nowrap; margin: 0 auto;'>"
    html += "<thead><tr>"
    for col in df.columns:
        display_col = lbl_resolved if col == "Encerrados" else col
        html += f"<th style='background-color: {header_bg}; color: #fff; padding: 4px 6px; border: 1px solid #ddd; text-align: center;'>{display_col}</th>"
    html += "</tr></thead><tbody>"

    for i, row in df.iterrows():
        bg = ModernColors.GRAY_LIGHT if zebra and i % 2 == 0 else ModernColors.WHITE
        html += f"<tr style='background-color: {bg};'>"
        for j, val in enumerate(row):
            v_str = str(val)
            color = ModernColors.PRIMARY_DARK
            font_weight = "bold" if j == 0 else "normal"

            if "Aging" in df.columns and j == list(df.columns).index("Aging"):
                try:
                    # Lógica ajustada: Aging > SLA fica Vermelho (DANGER)
                    if int(val) > sla_days:
                        color = "#ffffff"
                        bg_cell = ModernColors.DANGER
                        font_weight = "bold"
                    else:
                        bg_cell = "transparent"
                except:
                    bg_cell = "transparent"
            elif "PRB" in df.columns and j == list(df.columns).index("PRB"):
                color = ModernColors.PRIMARY_DARK if str(
                    val).strip() != "N/A" else ModernColors.GRAY
                font_weight = "bold" if str(val).strip() != "N/A" else "normal"
                bg_cell = "transparent"
            else:
                bg_cell = "transparent"

            align = "left" if j == 0 else "center"
            html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: {align}; color: {color}; font-weight: {font_weight}; background-color: {bg_cell};'>{v_str}</td>"
        html += "</tr>"
    html += "</tbody>"

    if show_totals:
        html += f"<tfoot style='background-color: {ModernColors.GRAY_LIGHT}; font-weight: bold; color: {ModernColors.PRIMARY_DARK}; border-top: 2px solid {ModernColors.PRIMARY_DARK};'><tr>"
        for j, col_name in enumerate(df.columns):
            col_lower = str(col_name).strip().lower()
            if j == 0:
                val = "TOTAL"
                align = "left"
            elif "backlog acumulado" in col_lower:
                last_val = df.iloc[-1][col_name]
                val = int(last_val) if pd.notna(last_val) else 0
                align = "center"
            elif pd.api.types.is_numeric_dtype(df[col_name]):
                if "%" in col_lower or col_name == "%":
                    val = "100.0"
                else:
                    val = int(df[col_name].sum()) if sum(df[col_name]) == int(
                        sum(df[col_name])) else round(df[col_name].sum(), 1)
                align = "center"
            else:
                val = "—"
                align = "center"
            html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: {align};'>{val}</td>"
        html += "</tr></tfoot>"

    html += "</table>"
    return html


