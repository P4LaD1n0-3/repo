                    # Injeta o TITLE na célula <td> E na tag <acronym> (tag altamente respeitada pelo Outlook Word Engine)
                    td_title = f" title=\"{safe_text}\""
                    v_str = f"<acronym title=\"{safe_text}\" style='display: inline-block; background-color: {ModernColors.INFO}; color: #ffffff; padding: 4px 10px; border-radius: 4px; font-size: 11px; font-weight: bold; text-decoration: none; cursor: help; border-bottom: 1px dotted #ffffff;'>SAIBA MAIS 📄</acronym>"
                
                bg_cell = "transparent"
                font_weight = "normal"
            else:
                bg_cell = "transparent"

            align = "left" if j == 0 else "center"
            
            # Aqui é onde o td_title é aplicado no HTML
            html += f"<td{td_title} style='padding: 4px 6px; border: 1px solid #ddd; text-align: {align}; color: {color}; font-weight: {font_weight}; background-color: {bg_cell};'>{v_str}</td>"
            
        html += "</tr>"
    html += "</tbody>"

    if show_totals:
        html += f"<tfoot style='background-color: {ModernColors.GRAY_LIGHT}; font-weight: bold; color: {ModernColors.PRIMARY_DARK}; border-top: 2px solid {ModernColors.PRIMARY_DARK};'><tr>"
        for j, col_name in enumerate(df.columns):
            col_lower = str(col_name).strip().lower()
            if j == 0:
                val = "TOTAL"
                align = "left"
            elif "backlog acumulado" in col_lower:
                last_val = df.iloc[-1][col_name]
                val = int(last_val) if pd.notna(last_val) else 0
                align = "center"
            elif col_name == "Info (Saiba Mais)":
                val = "—"
                align = "center"
            elif pd.api.types.is_numeric_dtype(df[col_name]):
                if "%" in col_lower or col_name == "%":
                    val = "100,00%"
                else:
                    val_sum = df[col_name].sum()
                    if val_sum == int(val_sum):
                        val = int(val_sum)
                    else:
                        val = f"{val_sum:.2f}".replace('.', ',')
                align = "center"
            else:
                val = "—"
                align = "center"
            html += f"<td style='padding: 4px 6px; border: 1px solid #ddd; text-align: {align};'>{val}</td>"
        html += "</tr></tfoot>"

    html += "</table>"
    return html


