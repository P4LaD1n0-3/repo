    <script>
        // ==========================================
        // 1. CORE E DATA
        // ==========================================
        const RawData = { incs: [], reqs: [], rca: [], ptask: [] };
        let todoList = JSON.parse(localStorage.getItem('eliteMasterTodosV65')) || [];
        let GlobalOpenTickets = [];

        function handleFiles(files) {
            Array.from(files).forEach(file => {
                const name = file.name.toLowerCase();
                const reader = new FileReader();
                reader.onload = e => {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array', cellDates: true });
                    const sheet = workbook.Sheets[workbook.SheetNames[0]];
                    const json = XLSX.utils.sheet_to_json(sheet, { defval: "" });
                    const cleanJson = json.map(r => {
                        let obj = {};
                        Object.keys(r).forEach(k => obj[k.trim()] = r[k]);
                        return obj;
                    });
                    if (name.includes('inc')) RawData.incs = cleanJson;
                    else if (name.includes('sc_task') || name.includes('req')) RawData.reqs = cleanJson;
                    else if (name.includes('rca')) RawData.rca = cleanJson;
                    else if (name.includes('ptask')) RawData.ptask = cleanJson;
                    document.getElementById('file-status').innerHTML += `<div class="text-green-600 font-bold">✓ ${file.name}</div>`;
                    document.getElementById('btn-clear-files').classList.remove('hidden-st');
                };
                reader.readAsArrayBuffer(file);
            });
        }

        function clearFiles() {
            location.reload();
        }

        const getCol = (row, keys) => { for (let k of keys) if (row[k] !== undefined && row[k] !== "") return row[k]; return null; };
        const safeDate = v => {
            if (!v) return null;
            let d = new Date(v);
            return isNaN(d.getTime()) ? null : d;
        };

        // ==========================================
        // 2. MOTOR DE ESTAGNAÇÃO (PYTHON PORT)
        // ==========================================
        function getDaysSilent(r, refDate, assignedTo, opDate) {
            if (!assignedTo || assignedTo.includes('Não Atribuído') || assignedTo === 'N/A') return '-';
            let maxDate = opDate ? new Date(opDate) : new Date(0);
            let regex = /(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?:\s+-\s+|\s+)([^\(]+)\s+\(/g;
            ['Work notes', 'Additional comments'].forEach(col => {
                let txt = r[col];
                if (txt && typeof txt === 'string') {
                    let m;
                    while ((m = regex.exec(txt)) !== null) {
                        if (m[2].trim() === assignedTo) {
                            let d = new Date(m[1].replace(/-/g, '/'));
                            if (d > maxDate && d <= refDate) maxDate = d;
                        }
                    }
                }
            });
            if (maxDate.getTime() === 0) return '-';
            let diff = Math.floor((refDate - maxDate) / 86400000);
            return diff < 0 ? 0 : diff;
        }

        // ==========================================
        // 3. TODO SYSTEM (REGRAS DE RISCO E MODAL)
        // ==========================================
        function showConfirm(title, msg, onConfirm) {
            const modal = document.getElementById('custom-confirm-modal');
            document.getElementById('confirm-title').innerText = title;
            document.getElementById('confirm-msg').innerText = msg;
            modal.classList.remove('hidden-st');
            
            const confirmBtn = document.getElementById('btn-modal-confirm');
            const cancelBtn = document.getElementById('btn-modal-cancel');
            
            const cleanup = () => {
                modal.classList.add('hidden-st');
                confirmBtn.removeEventListener('click', handleConfirm);
                cancelBtn.removeEventListener('click', cleanup);
            };

            const handleConfirm = () => {
                onConfirm();
                cleanup();
            };

            confirmBtn.addEventListener('click', handleConfirm);
            cancelBtn.addEventListener('click', cleanup);
        }

        function saveTodos() {
            localStorage.setItem('eliteMasterTodosV65', JSON.stringify(todoList));
            renderTodos();
        }

        function addTodo() {
            const analyst = document.getElementById('todo-analyst').value;
            const desc = document.getElementById('todo-desc').value;
            if (!analyst || !desc.trim()) return alert("Selecione um analista e preencha a descrição.");
            
            todoList.push({
                id: Date.now().toString(),
                analyst,
                ticket: null,
                date: new Date().toLocaleDateString('pt-BR'),
                history: [{ text: desc, date: new Date().toLocaleString('pt-BR'), striked: false }]
            });
            document.getElementById('todo-desc').value = '';
            saveTodos();
        }

        function toggleStrike(todoId, index) {
            let todo = todoList.find(t => t.id === todoId);
            if (todo) {
                todo.history[index].striked = !todo.history[index].striked;
                saveTodos();
                // Se estiver no modal, atualiza a view do modal também
                let modalTk = document.getElementById('modal-tk').innerText.split(' ')[0];
                if (todo.ticket === modalTk) renderModalTodos(modalTk);
            }
        }

        function deleteTodo(id) {
            showConfirm("Apagar Tarefa?", "O histórico desta tarefa será removido permanentemente.", () => {
                todoList = todoList.filter(t => t.id !== id);
                saveTodos();
            });
        }

        function completeTodo(id) {
            showConfirm("Concluir Tarefa?", "A tarefa será marcada como concluída e arquivada.", () => {
                todoList = todoList.filter(t => t.id !== id);
                saveTodos();
            });
        }

        function renderTodos() {
            const container = document.getElementById('todo-list');
            if (!container) return;
            document.getElementById('todo-count').innerText = todoList.length;
            if (todoList.length === 0) {
                container.innerHTML = '<div class="text-center py-10 text-slate-300 font-bold">Nenhuma tarefa pendente.</div>';
                return;
            }
            container.innerHTML = todoList.map(t => `
                <div class="todo-item border-l-4 border-blue-600">
                    <div class="flex justify-between items-start mb-2">
                        <div class="font-black text-[var(--primary-dark)] text-sm"><i class="fas fa-user mr-1 text-slate-400"></i> ${t.analyst} ${t.ticket ? `<span class="todo-badge ml-2">${t.ticket}</span>` : ''}</div>
                        <div class="flex gap-2">
                            <button onclick="completeTodo('${t.id}')" class="text-emerald-500"><i class="fas fa-check-circle"></i></button>
                            <button onclick="deleteTodo('${t.id}')" class="text-red-400"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                    <div class="space-y-2 mt-3">
                        ${t.history.map((h, idx) => `
                            <div class="history-entry" onclick="toggleStrike('${t.id}', ${idx})">
                                <div class="text-[9px] font-bold text-slate-400">${h.date}</div>
                                <div class="history-text text-xs text-slate-600 ${h.striked ? 'striked' : ''}">${h.text}</div>
                            </div>
                        `).join('')}
                    </div>
                </div>
            `).join('');
        }

        // ==========================================
        // 4. CROSSOVER: TICKET MODAL + TODO
        // ==========================================
        let currentModalTk = null;

        function openTicketDetails(tkNumber) {
            currentModalTk = tkNumber;
            let ticketData = null;
            let type = '';
            [RawData.incs, RawData.reqs, RawData.ptask].forEach((src, idx) => {
                let found = src.find(r => getCol(r, ['Number','number','Ticket','Problem','Task']) === tkNumber);
                if (found) { ticketData = found; type = idx === 0 ? 'INC' : idx === 1 ? 'REQ' : 'TASK'; }
            });

            if (!ticketData) return;

            document.getElementById('modal-tk').innerText = tkNumber;
            document.getElementById('modal-title').innerText = getCol(ticketData, ['Short description','Descrição Curta','Descrição']) || 'Sem assunto';
            document.getElementById('modal-desc').innerText = getCol(ticketData, ['Description','Descrição Completa']) || 'Sem descrição detalhada.';
            document.getElementById('modal-state').innerText = getCol(ticketData, ['State','Status']) || 'N/A';
            document.getElementById('modal-req').innerText = getCol(ticketData, ['Requester','Caller','Solicitante']) || 'N/A';
            document.getElementById('modal-asg').innerText = getCol(ticketData, ['Assigned to','Analista']) || 'Não Atribuído';
            document.getElementById('modal-gp').innerText = getCol(ticketData, ['Assignment group','Grupo']) || 'N/A';
            document.getElementById('modal-op').innerText = safeDate(getCol(ticketData, ['Opened','opened_at']))?.toLocaleString('pt-BR') || '-';
            document.getElementById('modal-cl').innerText = safeDate(getCol(ticketData, ['Resolved','Closed']))?.toLocaleString('pt-BR') || 'Aberto';

            // TIMELINE NOTES
            let regex = /^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?:\s+-\s+|\s+)([^\(]+)\s+\(([^)]+)\)/gm;
            let rawCombined = (ticketData['Work notes'] || '') + "\n" + (ticketData['Additional comments'] || '');
            let matches = [...rawCombined.matchAll(regex)];
            let entries = matches.map((m, i) => {
                let text = rawCombined.substring(m.index + m[0].length, (i + 1 < matches.length) ? matches[i+1].index : rawCombined.length).trim();
                return { date: m[1], author: m[2].trim(), type: m[3].trim(), text };
            }).sort((a,b) => new Date(b.date) - new Date(a.date));

            document.getElementById('modal-timeline').innerHTML = entries.map(e => `
                <div class="mb-4 pl-4 border-l-2 ${e.type.includes('Work') ? 'border-orange-400 bg-orange-50/20' : 'border-blue-400 bg-blue-50/20'} p-3 rounded">
                    <div class="flex justify-between text-[10px] font-bold mb-1">
                        <span class="text-slate-800">${e.author}</span>
                        <span class="text-slate-400">${e.date}</span>
                    </div>
                    <div class="text-[9px] uppercase font-black mb-1 opacity-60">${e.type}</div>
                    <div class="text-xs text-slate-600 whitespace-pre-wrap">${e.text}</div>
                </div>
            `).join('') || '<div class="text-slate-400 text-xs italic">Sem notas registradas.</div>';

            renderModalTodos(tkNumber);

            document.getElementById('ticket-modal-backdrop').classList.remove('hidden-st');
            setTimeout(() => document.getElementById('ticket-modal-content').classList.remove('scale-95'), 10);
        }

        function renderModalTodos(tkNumber) {
            const container = document.getElementById('modal-todo-container');
            let tkTodos = todoList.filter(t => t.ticket === tkNumber);
            if (tkTodos.length === 0) {
                container.innerHTML = '<div class="text-[10px] text-slate-400 italic">Nenhuma ação de TODO vinculada a este ticket.</div>';
                return;
            }
            container.innerHTML = tkTodos.map(t => `
                <div class="bg-white border p-2 rounded shadow-sm">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-[10px] font-bold text-blue-600">${t.analyst}</span>
                        <button onclick="completeTodo('${t.id}')" class="text-emerald-500 text-[10px]"><i class="fas fa-check"></i></button>
                    </div>
                    ${t.history.map((h, idx) => `
                        <div class="text-[10px] ${h.striked ? 'striked opacity-40' : ''} cursor-pointer hover:bg-slate-50" onclick="toggleStrike('${t.id}', ${idx})">
                            • ${h.text}
                        </div>
                    `).join('')}
                </div>
            `).join('');
        }

        function addTodoFromModal() {
            const text = document.getElementById('modal-new-todo').value;
            if (!text.trim()) return;
            const tk = document.getElementById('modal-tk').innerText;
            const analyst = document.getElementById('modal-asg').innerText;
            
            // Procura se já existe um TODO para este ticket
            let existing = todoList.find(t => t.ticket === tk);
            if (existing) {
                existing.history.push({ text: text, date: new Date().toLocaleString('pt-BR'), striked: false });
            } else {
                todoList.push({
                    id: Date.now().toString(),
                    analyst: analyst,
                    ticket: tk,
                    date: new Date().toLocaleDateString('pt-BR'),
                    history: [{ text: text, date: new Date().toLocaleString('pt-BR'), striked: false }]
                });
            }
            document.getElementById('modal-new-todo').value = '';
            saveTodos();
            renderModalTodos(tk);
        }

        function closeTicketDetails() {
            document.getElementById('ticket-modal-content').classList.add('scale-95');
            setTimeout(() => document.getElementById('ticket-modal-backdrop').classList.add('hidden-st'), 200);
        }

        // ==========================================
        // 5. ORDENAÇÃO DE TABELAS (HEADER VISÍVEL)
        // ==========================================
        function sortTable(th) {
            const table = th.closest('table');
            const tbody = table.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            if (rows.length < 2) return;

            const colIdx = Array.from(th.parentNode.children).indexOf(th);
            const isAsc = th.dataset.dir !== 'asc';
            th.dataset.dir = isAsc ? 'asc' : 'desc';

            rows.sort((a, b) => {
                let vA = a.children[colIdx].innerText.trim();
                let vB = b.children[colIdx].innerText.trim();
                
                // Date Parser
                let dateA = vA.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                let dateB = vB.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                if (dateA && dateB) {
                    return (new Date(dateA[3], dateA[2]-1, dateA[1]) - new Date(dateB[3], dateB[2]-1, dateB[1])) * (isAsc ? 1 : -1);
                }

                // Number Parser
                let numA = parseFloat(vA.replace(/[^\d.-]/g, ''));
                let numB = parseFloat(vB.replace(/[^\d.-]/g, ''));
                if (!isNaN(numA) && !isNaN(numB)) return (numA - numB) * (isAsc ? 1 : -1);

                return vA.localeCompare(vB, undefined, {numeric: true}) * (isAsc ? 1 : -1);
            });
            rows.forEach(r => tbody.appendChild(r));
            
            // Icons Update
            th.parentNode.querySelectorAll('i').forEach(i => i.className = "fas fa-sort ml-1 opacity-30");
            th.querySelector('i').className = isAsc ? "fas fa-sort-up ml-1" : "fas fa-sort-down ml-1";
        }

        // ==========================================
        // 6. MOTOR DE PESQUISA GLOBAL
        // ==========================================
        function performGlobalSearch(e) {
            const inputVal = document.getElementById("globalSearch").value.trim();
            if (inputVal.length === 0) {
                document.getElementById('tab-search').classList.add('hidden-st');
                let activeBtn = document.querySelector('.tab-btn.active');
                if (activeBtn) activeBtn.click();
                return;
            }

            document.querySelectorAll('.tab-pane').forEach(c => c.classList.add('hidden-st'));
            document.getElementById('tab-search').classList.remove('hidden-st');

            const term = removeAccents(inputVal.toUpperCase());
            const refDate = new Date(document.getElementById('ref-date').value + 'T12:00:00');
            let results = [];

            [RawData.incs, RawData.reqs, RawData.rca, RawData.ptask].forEach(src => {
                src.forEach(r => {
                    if (removeAccents(Object.values(r).join(" ")).toUpperCase().includes(term)) {
                        let tk = getCol(r, ['Number','Ticket','Problem','Task']);
                        let asg = getCol(r, ['Assigned to','Analista']);
                        results.push({
                            tk,
                            desc: getCol(r, ['Short description','Descrição Curta','Descrição']) || '-',
                            req: getCol(r, ['Requester','Caller','Solicitante']) || 'N/A',
                            asg,
                            gp: getCol(r, ['Assignment group','Grupo']) || '-',
                            st: String(getCol(r, ['State','Status']) || '').toUpperCase(),
                            op: safeDate(getCol(r, ['Opened','opened_at'])),
                            cl: safeDate(getCol(r, ['Resolved','Closed'])),
                            idle: getDaysSilent(r, refDate, asg, safeDate(getCol(r, ['Opened','opened_at'])))
                        });
                    }
                });
            });

            let html = `<div class="report-section-title bg-slate-700">Resultados da Busca Global: "${inputVal}" (${results.length})</div>
                <div class="report-card"><div class="st-dataframe-container"><table class="st-table">
                <thead><tr>
                    <th onclick="sortTable(this)">Ticket <i class="fas fa-sort ml-1"></i></th>
                    <th onclick="sortTable(this)">Solicitante <i class="fas fa-sort ml-1"></i></th>
                    <th onclick="sortTable(this)">Analista <i class="fas fa-sort ml-1"></i></th>
                    <th onclick="sortTable(this)">Status <i class="fas fa-sort ml-1"></i></th>
                    <th onclick="sortTable(this)">Aging / Ocioso <i class="fas fa-sort ml-1"></i></th>
                </tr></thead>
                <tbody>${results.map(t => `
                    <tr class="ticket-row" data-tk="${t.tk}" data-desc="${t.desc}" data-as="${t.asg}" data-st="${t.st}" data-idle="${t.idle}">
                        <td class="font-bold">${t.tk}<br><button onclick="openTicketDetails('${t.tk}')" class="text-[9px] text-blue-600 underline">Saiba mais</button></td>
                        <td>${t.req}</td>
                        <td>${t.asg}<br><span class="text-[9px] text-slate-400">${t.gp}</span></td>
                        <td>${t.st}</td>
                        <td class="text-right font-bold">${t.cl ? 'Fechado' : t.idle+'d ocioso'}</td>
                    </tr>`).join('')}
                </tbody></table></div></div>`;
            document.getElementById('tab-search').innerHTML = html;
        }

        // ==========================================
        // 7. DASHBOARD LOGIC (INC/REQ/UAM/CONS/CLASS)
        // ==========================================
        function calculateClassifications(allData, refDate) {
            let stats = { total: 0, withLink: 0, withoutLink: 0, byReq: {}, byGroup: {}, byAnalyst: {}, byMonth: {} };
            
            allData.forEach(r => {
                let st = String(getCol(r, ['State', 'Status']) || '').toLowerCase();
                let reason = String(getCol(r, ['Reason', 'reason', 'REASON', 'Motivo']) || '').toUpperCase();

                if (st.includes('incomplet') && reason.includes('INCORRECT CLASSIFICATION')) {
                    let op = safeDate(getCol(r, ['Opened','opened_at']));
                    if (!op || op > refDate) return;

                    stats.total++;
                    let closeNotes = String(getCol(r, ['Close notes', 'Close Notes', 'close_notes', 'Closing notes']) || '');
                    let linked = closeNotes.match(/(INC|RITM|REQ|TASK)[\s\-]?(\d{6,8})/i);
                    if (linked) stats.withLink++; else stats.withoutLink++;

                    let req = getCol(r, ['Requester', 'Caller', 'Solicitante']) || 'N/A';
                    let gp = getCol(r, ['Assignment group', 'Grupo']) || 'N/A';
                    let as = getCol(r, ['Assigned to', 'Analista']) || 'N/A';
                    let month = op.toLocaleDateString('pt-BR', {month: 'short', year: 'numeric'}).toUpperCase();

                    stats.byReq[req] = (stats.byReq[req] || 0) + 1;
                    stats.byGroup[gp] = (stats.byGroup[gp] || 0) + 1;
                    stats.byAnalyst[as] = (stats.byAnalyst[as] || 0) + 1;
                    stats.byMonth[month] = (stats.byMonth[month] || 0) + 1;
                }
            });
            return stats;
        }

        function generateClassificationsHTML(d) {
            const tableHelper = (title, data, label) => `
                <div class="report-card">
                    <div class="report-card-title">${title}</div>
                    <div class="st-dataframe-container"><table class="st-table">
                        <thead><tr><th onclick="sortTable(this)">${label} <i class="fas fa-sort ml-1"></i></th><th onclick="sortTable(this)">Qtd <i class="fas fa-sort ml-1"></i></th></tr></thead>
                        <tbody>${Object.entries(data).sort((a,b)=>b[1]-a[1]).map(([k,v])=>`<tr><td>${k}</td><td>${v}</td></tr>`).join('')}</tbody>
                    </table></div>
                </div>`;

            return `
            <div class="report-section-title bg-red-600"><i class="fas fa-exclamation-circle mr-2"></i> Erros de Classificação (Vigentes e Históricos)</div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="report-card h-[400px]"><canvas id="chart-class-trend"></canvas></div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="report-card text-center"><div class="report-card-title">Total Incorretos</div><div class="text-4xl font-black text-red-600">${d.total}</div></div>
                    <div class="report-card text-center"><div class="report-card-title">Sem Vínculo</div><div class="text-4xl font-black text-orange-500">${d.withoutLink}</div></div>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                ${tableHelper("Por Solicitante", d.byReq, "Solicitante")}
                ${tableHelper("Por Grupo", d.byGroup, "Grupo")}
                ${tableHelper("Por Analista", d.byAnalyst, "Analista")}
                ${tableHelper("Por Período", d.byMonth, "Mês")}
            </div>`;
        }

        function processDashboard() {
            if (!RawData.incs.length && !RawData.reqs.length) return;

            document.getElementById('init-alert').classList.add('hidden-st');
            document.getElementById('loader').classList.remove('hidden-st');
            document.getElementById('report-content').classList.add('hidden-st');
            document.getElementById('tabs-container').classList.remove('hidden-st');

            setTimeout(() => {
                const slaI = parseInt(document.getElementById('sla-incs').value);
                const slaR = parseInt(document.getElementById('sla-reqs').value);
                const refDate = new Date(document.getElementById('ref-date').value + 'T12:00:00');

                // Analisar Dados
                let dI = calculateSection(RawData.incs, slaI, "INC", refDate);
                const isUam = r => String(getCol(r, ['Assignment group','Grupo']) || '').toLowerCase().includes('access');
                let rS = RawData.reqs.filter(r => !isUam(r));
                let rU = RawData.reqs.filter(r => isUam(r));
                let dR = calculateSection(rS, slaR, "REQ", refDate);
                let dU = calculateSection(rU, slaR, "REQ", refDate);

                // Popular Abas
                document.getElementById('tab-inc').innerHTML = generateSectionHTML('inc', "INCIDENTES", C.PRI_D, dI, "INC");
                document.getElementById('tab-req').innerHTML = generateSectionHTML('req', "REQs GERAIS", C.PRI_D, dR, "REQ");
                document.getElementById('tab-uam').innerHTML = generateSectionHTML('uam', "REQs ACESSOS (UAM)", C.PRI_D, dU, "REQ");
                
                // Consolidado com Novos Cards
                document.getElementById('tab-cons').innerHTML = `
                    <div class="report-section-title bg-[var(--primary-dark)]">Visão Organizacional Consolidada</div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                        <div class="report-card text-center border-l-4 border-blue-800"><div class="report-card-title">Backlog INCs</div><div class="text-4xl font-black">${dI.backlog}</div></div>
                        <div class="report-card text-center border-l-4 border-blue-600"><div class="report-card-title">Backlog REQs</div><div class="text-4xl font-black">${dR.backlog}</div></div>
                        <div class="report-card text-center border-l-4 border-blue-400"><div class="report-card-title">Backlog UAMs</div><div class="text-4xl font-black">${dU.backlog}</div></div>
                    </div>
                    <div class="report-card h-[400px] mb-6"><canvas id="c-d-cons"></canvas></div>
                `;

                // Erros
                let dClass = calculateClassifications([...RawData.incs, ...RawData.reqs], refDate);
                document.getElementById('tab-class').innerHTML = generateClassificationsHTML(dClass);

                // Finalizar
                document.getElementById('loader').classList.add('hidden-st');
                document.getElementById('report-content').classList.remove('hidden-st');

                // Render Charts
                drawChartsAll('inc', dI, 'Resolvidos');
                drawChartsAll('req', dR, 'Encerrados');
                drawChartsAll('uam', dU, 'Encerrados');
                drawConsolidadoCharts(dI, dR, dU);
                
                // Chart Tendência Erros
                new Chart(document.getElementById('chart-class-trend'), {
                    type: 'line',
                    data: {
                        labels: Object.keys(dClass.byMonth),
                        datasets: [{ label: 'Qtd Erros', data: Object.values(dClass.byMonth), borderColor: C.DAN, fill: false, datalabels: { formatter: v => v > 0 ? v : "" } }]
                    },
                    options: { maintainAspectRatio: false }
                });

                populateTodoAnalystDropdown();
                renderTodos();
            }, 600);
        }

        function drawChartsAll(id, d, lblRes) {
            const common = (canvas, data, isLine = false) => {
                new Chart(document.getElementById(canvas), {
                    type: isLine ? 'line' : 'bar',
                    data: {
                        labels: Object.keys(data).map(k => k.split('-').reverse().join('/')),
                        datasets: [
                            { type: 'line', label: 'Backlog', data: Object.values(data).map(v => v.b), borderColor: C.ORG, fill: false, yAxisID: 'y1', datalabels: { formatter: v => v > 0 ? v : "" } },
                            { label: 'Abertos', data: Object.values(data).map(v => v.a), backgroundColor: C.PRI_D, yAxisID: 'y1', datalabels: { formatter: v => v > 0 ? v : "" } },
                            { label: lblRes, data: Object.values(data).map(v => v.r), backgroundColor: C.SUC, yAxisID: 'y1', datalabels: { formatter: v => v > 0 ? v : "" } }
                        ]
                    },
                    options: { maintainAspectRatio: false, scales: { yAxes: [{ id: 'y1', ticks: { beginAtZero: true } }] } }
                });
            };
            common(`c-d-${id}`, d.trendD);
            common(`c-m-${id}`, d.trendM);
        }

        function drawConsolidadoCharts(i, r, u) {
            // Reutiliza lógica simplificada para fins de demonstração completa
            const ctx = document.getElementById('c-d-cons');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: Object.keys(i.trendD).map(k => k.split('-').reverse().join('/')),
                    datasets: [{ label: 'Volume Total', data: Object.keys(i.trendD).map(k => (i.trendD[k].a || 0) + (r.trendD[k].a || 0) + (u.trendD[k].a || 0)), backgroundColor: C.PRI_D, datalabels: { formatter: v => v > 0 ? v : "" } }]
                },
                options: { maintainAspectRatio: false }
            });
        }

        function populateTodoAnalystDropdown() {
            const select = document.getElementById('todo-analyst');
            let set = new Set();
            [RawData.incs, RawData.reqs].forEach(s => s.forEach(r => { let a = getCol(r, ['Assigned to','Analista']); if(a) set.add(a); }));
            select.innerHTML = '<option value="">Selecione um Analista...</option>' + Array.from(set).sort().map(a => `<option value="${a}">${a}</option>`).join('');
        }

        window.onload = () => { renderTodos(); };
    </script>
