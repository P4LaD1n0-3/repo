        // ==========================================
        // 9. CÁLCULO DE ERROS DE CLASSIFICAÇÃO (PYTHON PORT)
        // ==========================================
        function calculateClassifications(allData, refDateObj) {
            let res = { total:0, link:0, noLink:0, days:0, max:0, req:{}, gp:{}, asg:{}, m:{}, tks:[] };
            allData.forEach(r => {
                let st = String(getCol(r, ['State','Status'])||'').toLowerCase(), rea = String(getCol(r, ['Reason','Motivo'])||'').toUpperCase();
                if(st.includes('incomplet') && reason.includes('INCORRECT CLASSIFICATION')) {
                    let op = safeDate(getCol(r, ['Opened','opened_at'])), cl = safeDate(getCol(r, ['Resolved','Closed']));
                    if(!op || op > refDateObj) return;

                    let cn = String(getCol(r, ['Close notes','Closing notes'])||''), match = cn.match(/(INC|RITM|REQ|TASK)[\s\-]?(\d{6,8})/i);
                    let tk = getCol(r, ['Number','Ticket']), asg = getCol(r, ['Assigned to'])||'N/A', req = getCol(r, ['Requester','Caller'])||'N/A', gp = getCol(r, ['Assignment group'])||'N/A';
                    let d = cl ? Math.floor((cl-op)/86400000) : Math.floor((refDateObj-op)/86400000); if(d<0) d=0;
                    
                    res.total++; if(match) res.link++; else res.noLink++; res.days+=d; if(d>res.max) res.max=d;
                    let mStr = op.toLocaleDateString('pt-BR',{month:'short',year:'numeric'}).toUpperCase().replace('.','');
                    
                    // Condição do Mês Vigente (Apenas popular tabelas se o erro for do mesmo mês/ano selecionado)
                    if(op.getMonth() === refDateObj.getMonth() && op.getFullYear() === refDateObj.getFullYear()) {
                        res.req[req] = (res.req[req]||0)+1; res.gp[gp] = (res.gp[gp]||0)+1; res.asg[asg] = (res.asg[asg]||0)+1;
                    }
                    res.m[mStr] = (res.m[mStr]||0)+1; // Gráfico de tendência recebe todos
                    
                    res.tks.push({tk, req, as:asg, gp, l:match?(match[1].toUpperCase()+match[2]):'⚠️ Erro', rea, st:st.toUpperCase(), d, idle: (!cl||cl>refDateObj)?getDaysSilent(r,refDateObj,asg,op):'-', opS:op.toLocaleDateString('pt-BR'), desc:getCol(r,['Short description'])||'-', info:cn });
                }
            });
            res.avg = res.total ? (res.days/res.total).toFixed(1).replace('.',',') : "0,0";
            res.tks.sort((a,b)=>b.d-a.d); return res;
        }

        function generateClassificationsHTML(d) {
            const tH = (t, data, l, isMonth=false) => {
                let t_vol = Object.values(data).reduce((a,b)=>a+b,0);
                return `<div class="report-card"><div class="report-card-title">${t}</div><div class="st-dataframe-container"><table class="st-table"><thead><tr>${createTh(l,"auto","left")}${createTh("Qtd")}${isMonth?createTh("%"):''}</tr></thead><tbody>${Object.entries(data).sort((a,b)=>b[1]-a[1]).map(([k,v])=>`<tr><td class="text-left font-bold text-slate-700">${k}</td><td>${v}</td>${isMonth?`<td>${Math.round((v/t_vol)*100)}%</td>`:''}</tr>`).join('')}</tbody></table></div></div>`;
            };

            return `<div class="report-section-title bg-red-600"><i class="fas fa-exchange-alt"></i> ERROS DE CLASSIFICAÇÃO (REQ ⇄ INC)</div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6"><div class="report-card h-[300px]"><div class="report-card-title">Tendência Mensal Histórica</div><canvas id="chart-class-trend"></canvas></div><div class="grid grid-cols-2 gap-4"><div class="report-card text-center border-l-4 border-red-500 justify-center"><div class="text-[10px] font-black text-red-600 mb-2 uppercase">Total Incorretos</div><div class="text-4xl font-black">${d.total}</div></div><div class="report-card text-center border-l-4 border-green-500 justify-center"><div class="text-[10px] font-black text-green-600 mb-2 uppercase">Com Vínculo</div><div class="text-4xl font-black">${d.link}</div></div><div class="report-card text-center border-l-4 border-orange-500 justify-center"><div class="text-[10px] font-black text-orange-500 mb-2 uppercase">Sem Vínculo (Erro)</div><div class="text-4xl font-black">${d.noLink}</div></div><div class="report-card text-center border-l-4 border-blue-500 justify-center"><div class="text-[10px] font-black text-blue-600 mb-2 uppercase">Detecção Média</div><div class="text-4xl font-black">${d.avg}d</div></div></div></div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">${tH("Por Solicitante (Mês Vigente)", d.req, "Solicitante")}${tH("Por Grupo (Mês Vigente)", d.gp, "Grupo")}${tH("Por Analista (Mês Vigente)", d.asg, "Analista")}${tH("Consolidado (Todos os Meses)", d.m, "Mês", true)}</div>
            <div class="report-card"><div class="report-card-title"><i class="fas fa-list"></i> LISTA DETALHADA (TODOS OS PERÍODOS)</div><div class="st-dataframe-container"><table class="st-table"><thead><tr>${createTh("Ticket Original")}${createTh("Ticket Vinculado")}${createTh("Descrição / Close Notes","auto","left")}${createTh("Solicitante")}${createTh("Analista/Grupo")}${createTh("Reason / Status")}${createTh("Ocioso/Dias","auto","right")}</tr></thead><tbody>
            ${d.tks.map(t=>`<tr class="ticket-row" data-tk="${t.tk}" data-st="${t.st}" data-idle="${t.idle}"><td class="font-bold text-[var(--primary-dark)]">${t.tk}<button onclick="openTicketDetails('${t.tk}')" class="block w-full mt-1 bg-blue-50 hover:bg-blue-100 border p-1 rounded text-[9px] uppercase"><i class="fas fa-history"></i> Saiba mais</button></td><td class="font-bold ${t.l.includes('⚠️')?'text-red-500':'text-green-500'}">${t.l}</td><td class="text-left"><div class="text-xs font-bold line-clamp-1">${t.desc}</div><div class="text-[10px] text-slate-500 mt-1">Notas: ${t.info}</div></td><td>${t.req}</td><td>${t.as}<br><span class="text-[9px] text-slate-400">${t.gp}</span></td><td><span class="bg-red-100 text-red-700 px-2 py-0.5 rounded text-[9px] font-bold block mb-1">${t.rea}</span><span class="bg-slate-100 border px-2 py-0.5 rounded text-[9px] block">${t.st}</span></td><td class="text-right"><div class="text-red-600 font-black text-sm">${t.d}d totais</div>${t.idle!=='-'?`<div class="text-[10px] font-bold ${t.idle>3?'text-red-500':'text-green-500'}"><i class="fas fa-user-clock"></i> ${t.idle}d ocioso</div>`:''}</td></tr>`).join('')}
            </tbody></table></div></div>`;
        }

        // ==========================================
        // 9. ORQUESTRADOR E PLUGINS CHART
        // ==========================================
        function drawChartsAll(id, d, lblRes) {
            const common = (cId, data, isLine) => {
                let lbls = Object.keys(data).sort();
                window.chartInstances.push(new Chart(document.getElementById(cId), {
                    type: isLine ? 'line' : 'bar',
                    data: { labels: lbls.map(k=>k.split('-').reverse().join('/')), datasets: [
                        { type: 'line', label: 'Backlog', data: lbls.map(k=>data[k].b), borderColor: C.ORG, fill: false, borderWidth:3, yAxisID: 'y1', datalabels: { align: 'top', font: {weight:'bold'}, formatter: v=>v>0?v:"" } },
                        { type: 'bar', label: 'Abertos', data: lbls.map(k=>data[k].a), backgroundColor: C.PRI_D, yAxisID: 'y1', datalabels: { color: '#fff', font: {weight:'bold'}, formatter: v=>v>0?v:"" } },
                        { type: 'bar', label: lblRes, data: lbls.map(k=>data[k].r), backgroundColor: C.SUC, yAxisID: 'y1', stack: 'st', datalabels: { color: '#fff', font: {weight:'bold'}, formatter: v=>v>0?v:"" } },
                        { type: 'bar', label: 'Cancelados', data: lbls.map(k=>data[k].c), backgroundColor: C.DAN, yAxisID: 'y1', stack: 'st', datalabels: { display: false } }
                    ]},
                    options: { maintainAspectRatio: false, legend: { position: 'bottom' }, scales: { xAxes: [{ stacked: true, gridLines: { display: false } }], yAxes: [{ id: 'y1', stacked: true, ticks: { beginAtZero: true } }] } }
                }));
            };
            common(`c-d-${id}`, d.trendD, false); common(`c-m-${id}`, d.trendM, false);

            window.chartInstances.push(new Chart(document.getElementById(`c-a-${id}`), { type: 'horizontalBar', data: { labels: d.topAnalistas.map(a=>a.nome), datasets: [{ label: 'Abertos', data: d.topAnalistas.map(a=>a.ab), backgroundColor: C.PRI_D }, { label: lblRes, data: d.topAnalistas.map(a=>a.res), backgroundColor: C.SUC }] }, options: { maintainAspectRatio: false, legend: { position: 'bottom' }, scales: { xAxes: [{ stacked: true, ticks: { beginAtZero: true } }], yAxes: [{ stacked: true }] }, plugins: { datalabels: { color: '#fff', font: {weight:'bold'}, formatter: v=>v>0?v:"" } } } }));
            let agK = Object.keys(d.agingBuckets);
            window.chartInstances.push(new Chart(document.getElementById(`c-ag-${id}`), { type: 'horizontalBar', data: { labels: agK, datasets: [{ data: agK.map(k=>d.agingBuckets[k].count), backgroundColor: agK.map(k=>d.agingBuckets[k].color) }] }, options: { maintainAspectRatio: false, legend: { display: false }, scales: { xAxes: [{ ticks: { beginAtZero: true } }] }, plugins: { datalabels: { anchor: 'end', align: 'right', formatter: v=>v>0?v:"" } } } }));
            window.chartInstances.push(new Chart(document.getElementById(`c-p-${id}`), { type: 'doughnut', data: { labels: ['No Prazo', 'Estourado'], datasets: [{ data: [d.inSlaTot, d.outSlaTot], backgroundColor: [C.SUC, C.DAN] }] }, options: { cutoutPercentage: 65, maintainAspectRatio: false, legend: { position: 'right' }, plugins: { datalabels: { color: '#fff', font: {weight:'bold', size:14}, formatter: (v, ctx) => v>0 ? Math.round((v/ctx.chart.data.datasets[0].data.reduce((a,b)=>a+b,0))*100)+'%' : "" } } } }));
        }

        function processDashboard() {
            if (!RawData.incs.length && !RawData.reqs.length) return alert("Por favor, importe os arquivos na aba lateral.");

            let now = new Date();
            document.getElementById('extraction-time').innerHTML = `<i class="fas fa-clock mr-1"></i> Extração: ${now.toLocaleDateString('pt-BR')} às ${now.toLocaleTimeString('pt-BR')}`;

            document.getElementById('init-alert').classList.add('hidden-st');
            document.getElementById('loader').classList.remove('hidden-st');
            document.getElementById('report-content').classList.add('hidden-st');
            document.getElementById('tabs-container').classList.remove('hidden-st');
            if (window.innerWidth < 1024) toggleSidebar();
            if (window.chartInstances) { window.chartInstances.forEach(c => c.destroy()); window.chartInstances = []; }
            GlobalOpenTickets = []; activeTableFilters = {};

            setTimeout(() => {
                const slaI = parseInt(document.getElementById('sla-incs').value) || 7, slaR = parseInt(document.getElementById('sla-reqs').value) || 10, slaP = parseInt(document.getElementById('sla-ptask').value) || 10;
                const refDate = new Date(document.getElementById('ref-date').value + 'T12:00:00');

                let dI = null, dRS = null, dRU = null;
                if (RawData.incs.length) { dI = calculateSection(RawData.incs, slaI, "INC", refDate); document.getElementById('tab-inc').innerHTML = generateSectionHTML('inc', "SESSÃO INCs", dI, "INC"); }
                if (RawData.reqs.length) {
                    const isUam = r => String(getCol(r, ['Assignment group','Grupo'])||'').toLowerCase().includes('access');
                    let rS = RawData.reqs.filter(r => !isUam(r)), rU = RawData.reqs.filter(r => isUam(r));
                    if (rS.length) { dRS = calculateSection(rS, slaR, "REQ", refDate); document.getElementById('tab-req').innerHTML = generateSectionHTML('req', "SESSÃO REQs GERAIS", dRS, "REQ"); }
                    if (rU.length) { dRU = calculateSection(rU, slaR, "REQ", refDate); document.getElementById('tab-uam').innerHTML = generateSectionHTML('uam', "SESSÃO UAMs (ACESSOS)", dRU, "REQ"); }
                }

                if(dI && dRS && dRU) {
                    let cTrendD = {}; let dKeys = new Set([...Object.keys(dI.trendD), ...Object.keys(dRS.trendD), ...Object.keys(dRU.trendD)]);
                    dKeys.forEach(k => { cTrendD[k] = { a: (dI.trendD[k]?.a||0)+(dRS.trendD[k]?.a||0)+(dRU.trendD[k]?.a||0), r: (dI.trendD[k]?.r||0)+(dRS.trendD[k]?.r||0)+(dRU.trendD[k]?.r||0), c: (dI.trendD[k]?.c||0)+(dRS.trendD[k]?.c||0)+(dRU.trendD[k]?.c||0), b: (dI.trendD[k]?.b||0)+(dRS.trendD[k]?.b||0)+(dRU.trendD[k]?.b||0) }; });
                    document.getElementById('tab-cons').innerHTML = `<div class="report-section-title bg-[var(--primary-dark)]">Visão Consolidada Organizacional</div><div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6"><div class="report-card text-center border-l-4 border-blue-800"><div class="report-card-title">Backlog INCs</div><div class="text-5xl font-black">${dI.backlog}</div></div><div class="report-card text-center border-l-4 border-blue-600"><div class="report-card-title">Backlog REQs</div><div class="text-5xl font-black">${dRS.backlog}</div></div><div class="report-card text-center border-l-4 border-blue-400"><div class="report-card-title">Backlog UAMs</div><div class="text-5xl font-black">${dRU.backlog}</div></div></div><div class="report-card h-[400px]"><div class="report-card-title">Acompanhamento Global Diário</div><canvas id="c-d-cons"></canvas></div>`;
                    requestAnimationFrame(() => {
                        let lD = Object.keys(cTrendD).sort();
                        window.chartInstances.push(new Chart(document.getElementById('c-d-cons'), { type: 'bar', data: { labels: lD.map(k=>k.split('-').reverse().join('/')), datasets: [{ type: 'line', label: 'Backlog Global', data: lD.map(k=>cTrendD[k].b), borderColor: C.ORG, fill: false, borderWidth: 3, yAxisID: 'y1', datalabels: { align: 'top', formatter: v=>v>0?v:"" } }, { type: 'bar', label: 'Abertos', data: lD.map(k=>cTrendD[k].a), backgroundColor: C.PRI_D, yAxisID: 'y1', datalabels: { color: '#fff', formatter: v=>v>0?v:"" } }, { type: 'bar', label: 'Encerrados/Resolvidos', data: lD.map(k=>cTrendD[k].r), backgroundColor: C.SUC, yAxisID: 'y1', stack: 'st', datalabels: { color: '#fff', formatter: v=>v>0?v:"" } }] }, options: { maintainAspectRatio: false, scales: { xAxes: [{ stacked: true }], yAxes: [{ id: 'y1', stacked: true, ticks: { beginAtZero: true } }] } } }));
                    });
                }

                if(RawData.rca.length || RawData.ptask.length) document.getElementById('tab-prb').innerHTML = generatePRBTab(RawData.rca, RawData.ptask, slaP, refDate);
                else document.getElementById('tab-prb').innerHTML = `<div class="report-card text-center py-10"><h3 class="text-slate-400 font-bold">Nenhum dado PRB.</h3></div>`;

                let allC = [...RawData.incs, ...RawData.reqs];
                if(allC.length > 0) {
                    let dC = calculateClassifications(allC, refDate);
                    document.getElementById('tab-class').innerHTML = generateClassificationsHTML(dC);
                    requestAnimationFrame(() => {
                        let cnv = document.getElementById('chart-class-trend');
                        if(cnv) window.chartInstances.push(new Chart(cnv, { type: 'line', data: { labels: Object.keys(dC.m).sort(), datasets: [{ label: 'Qtd de Erros', data: Object.keys(dC.m).sort().map(k=>dC.m[k]), borderColor: C.DAN, fill: false, borderWidth: 3, datalabels: { align: 'top', font: {weight:'bold'}, formatter: v=>v>0?v:"" } }] }, options: { maintainAspectRatio: false, legend: {display:false}, scales: { yAxes: [{ ticks: {beginAtZero:true} }] } } }));
                    });
                }

                document.getElementById('loader').classList.add('hidden-st'); document.getElementById('report-content').classList.remove('hidden-st'); document.getElementById('search-container').classList.add('visible');

                requestAnimationFrame(() => {
                    if(dI) drawChartsAll('inc', dI, 'Resolvidos');
                    if(dRS) drawChartsAll('req', dRS, 'Encerrados');
                    if(dRU) drawChartsAll('uam', dRU, 'Encerrados');
                    populateTodoAnalystDropdown(); renderTodos();
                    if(document.getElementById("globalSearch").value.trim() !== "") performGlobalSearch();
                });
            }, 600);
        }
    </script>
</body>
