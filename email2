        // ==========================================
        // 8. CÁLCULO GERAL E RENDER DE ABAS
        // ==========================================
        function calculateSection(data, slaDays, type, refDateObj) {
            const refTime = refDateObj.getTime();
            let totalMttr = 0, countRes = 0, inSlaMes = 0, resMes = 0, backlog = 0;
            let trendD = {}, trendM = {}, analistas = {}, criticals = [], agingBuckets = {};
            let bDef = type === "REQ" ? [{l:"1-3 dias",min:0,max:3}, {l:"3-5 dias",min:4,max:5}, {l:"5-7 dias",min:6,max:7}, {l:"7-10 dias",min:8,max:10}, {l:"10 dias +",min:11,max:9999}] : [{l:"1-3 dias",min:0,max:3}, {l:"4-7 dias",min:4,max:7}, {l:"7+ dias",min:8,max:9999}];
            bDef.forEach(b => agingBuckets[b.l] = { count: 0, color: b.min > slaDays ? '#D50000' : '#1E3A8A' });

            for(let i=1; i<=refDateObj.getDate(); i++) trendD[`${refDateObj.getFullYear()}-${String(refDateObj.getMonth()+1).padStart(2,'0')}-${String(i).padStart(2,'0')}`] = {a:0,r:0,c:0,b:0};

            data.forEach(r => {
                let op = safeDate(getCol(r, ['Opened', 'opened_at'])); if (!op || op > refDateObj) return;
                let cl = safeDate(getCol(r, ['Resolved', 'Closed'])); let st = String(getCol(r, ['State', 'Status']) || '').toLowerCase();
                if (cl && cl > refDateObj) { cl = null; st = 'open'; }

                let isRes = cl ? (type==="REQ" ? st.includes('complet') : (st.includes('resolv')||st.includes('clos')&&!st.includes('cancel'))) : false;
                let isCanc = cl ? (type==="REQ" ? st.includes('incomplet') : st.includes('cancel')) : false;
                let age = cl ? Math.floor((cl-op)/86400000) : Math.floor((refDateObj-op)/86400000); if(age<0) age=0;

                let mK = `${op.getFullYear()}-${String(op.getMonth()+1).padStart(2,'0')}`; if(!trendM[mK]) trendM[mK] = {a:0,r:0,c:0,inSla:0}; trendM[mK].a++;
                let dK = `${mK}-${String(op.getDate()).padStart(2,'0')}`; if(trendD[dK]) trendD[dK].a++;

                if (isRes && cl) {
                    let cMk = `${cl.getFullYear()}-${String(cl.getMonth()+1).padStart(2,'0')}`; if(!trendM[cMk]) trendM[cMk] = {a:0,r:0,c:0,inSla:0}; trendM[cMk].r++; if(age <= slaDays) trendM[cMk].inSla++;
                    let cDk = `${cMk}-${String(cl.getDate()).padStart(2,'0')}`; if(trendD[cDk]) { trendD[cDk].r++; resMes++; if(age<=slaDays) inSlaMes++; }
                    totalMttr += age; countRes++;
                } else if(isCanc && cl) {
                    let cMk = `${cl.getFullYear()}-${String(cl.getMonth()+1).padStart(2,'0')}`; if(!trendM[cMk]) trendM[cMk] = {a:0,r:0,c:0,inSla:0}; trendM[cMk].c++;
                    let cDk = `${cMk}-${String(cl.getDate()).padStart(2,'0')}`; if(trendD[cDk]) trendD[cDk].c++;
                }

                if (!cl) {
                    backlog++;
                    let asg = getCol(r, ['Assigned to', 'Analista']) || 'Não Atribuído';
                    let idle = getDaysSilent(r, refDateObj, asg, op);
                    if(!analistas[asg]) analistas[asg] = {ab:0, res:0}; analistas[asg].ab++;
                    GlobalOpenTickets.push({ tk: getCol(r, ['Number','Ticket']), asg });
                    bDef.forEach(b => { if(age >= b.min && age <= b.max) agingBuckets[b.l].count++; });
                    
                    if (age > slaDays) criticals.push({ tk: getCol(r, ['Number', 'Ticket']), req: getCol(r, ['Requester','Caller'])||'N/A', as: asg, gp: getCol(r, ['Assignment group'])||'-', st: st.toUpperCase(), age, prb: getCol(r, ['Problem', 'PRB'])||'N/A', info: (getCol(r, ['Additional comments'])||'Sem notas').replace(/"/g,''), desc: (getCol(r, ['Short description', 'Item'])||'Sem assunto').replace(/"/g,''), opStr: op.toLocaleDateString('pt-BR'), idle });
                }
                if (isRes && cl && cl.getMonth()===refDateObj.getMonth() && cl.getFullYear()===refDateObj.getFullYear()) {
                    let asg = getCol(r, ['Assigned to']) || 'Não Atribuído'; if(!analistas[asg]) analistas[asg]={ab:0,res:0}; analistas[asg].res++;
                }
            });

            let ks = Object.keys(trendM).sort(); let b=0; ks.forEach(k=>{ b+=trendM[k].a-(trendM[k].r+trendM[k].c); trendM[k].b=b; });
            let dKs = Object.keys(trendD).sort(); let db=backlog; for(let i=dKs.length-1; i>=0; i--) { trendD[dKs[i]].b=db; db-=(trendD[dKs[i]].a-(trendD[dKs[i]].r+trendD[dKs[i]].c)); }
            let inS=0, outS=0; bDef.forEach(b => { if(b.min > slaDays) outS+=agingBuckets[b.l].count; else inS+=agingBuckets[b.l].count; });

            return { mttr: countRes ? (totalMttr/countRes).toFixed(1).replace('.',',') : "0,0", pct: resMes ? Math.round((inSlaMes/resMes)*100) : 0, inSla: inSlaMes, outSla: resMes-inSlaMes, backlog, inSlaTot: inS, outSlaTot: outS, trendM, trendD, topAnalistas: Object.keys(analistas).map(k=>({nome:k, ...analistas[k]})).sort((a,b)=>(b.ab+b.res)-(a.ab+a.res)).slice(0,10), agingBuckets, crits: criticals.sort((a,b)=>b.age-a.age) };
        }

